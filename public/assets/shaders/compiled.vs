{@}GardenCommon.glsl{@}const float LOG2 = 1.442695;
const vec2 INV_ATAN = vec2(0.1591, 0.3183);

uniform float uFogMultiplier;
uniform vec3 uFogColor;
uniform vec3 uTint;
uniform vec3 uSunColor;
uniform vec3 uEnv;

uniform float uSaturation;

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * cosTheta - 6.98316) * cosTheta);
}

vec3 applySaturation(vec3 color) {
  return color * uSaturation;
}

float exponentialFog(vec3 modelViewPos) {
    float fogDistance = -modelViewPos.z;
    float fogFactor = 0.0035; // default 0.004
    float fogAmount = 1. - exp2(-fogFactor * fogFactor * fogDistance * fogDistance * LOG2);
    fogAmount *= max(1.0 - clamp(cameraPosition.y * 0.007, 0.0, 1.0), 0.2);
    fogAmount = clamp(fogAmount, 0., 1.);
    return fogAmount;
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec2 sampleSphericalMap(vec3 v, float rotation)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;

    // match default C4D baked HDRI
    uv.x = fract(uv.x + 0.25 + rotation);

    return uv;
}

mat2 rotate2d(float angle){
    return mat2(cos(angle),-sin(angle),
                sin(angle),cos(angle));
}{@}GardenBirdsShader.glsl{@}#!ATTRIBUTES
attribute vec3 lookup;
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tPos;
uniform sampler2D tPrevPos;
uniform sampler2D tAnimation;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uAltColor1;
uniform vec3 uAltColor2;
uniform float uEnabled;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vNormal;
varying vec3 vVel;
// varying vec3 vPrevPos;

#!SHADER: Vertex
#require(range.glsl)
#require(instance.vs)

vec3 getAnimationPos(sampler2D tAnimation, float frameCount, float speed, float offset) {
    float t = fract(time * speed + offset);

    vec2 frameOffset = vec2(1.0 / frameCount, 0.0) * floor(fract(t) * frameCount);
    vec2 nextFrameOffset = mod(frameOffset + vec2(1.0 / frameCount, 0.0), vec2(1.0, 0.0));

    vec3 frame = texture2D(tAnimation, vec2(uv.x / frameCount, uv.y) + frameOffset).rgb;
    vec3 nextFrame = texture2D(tAnimation, vec2(uv.x / frameCount, uv.y) + nextFrameOffset).rgb;

    frame = mix(frame, nextFrame, fract(t * frameCount));

    vec3 res = frame * 2.0 - 1.0;

    return res;
}

vec2 rotate(vec2 v, float a) {
    float s = sin(a);
    float c = cos(a);
    mat2 m = mat2(c, -s, s, c);
    return m * v;
}

vec3 transformTowardsVector(vec3 from, vec3 to) {
    vec3 pos = from;
    vec3 dir = normalize(to);

    // rotate up/down
    float a = dir.y;
    float s = sin(a);
	float c = cos(a);
	mat2 m = mat2(c, -s, s, c);
    pos.yz = m * pos.yz;

    // rotate around y axis
    float a2 = atan(dir.x, dir.z);
    float s2 = sin(a2);
	float c2 = cos(a2);
	mat2 m2 = mat2(c2, -s2, s2, c2);
    pos.xz = m2 * pos.xz;

    return pos;
}

void main() {
    float scale = 0.2 + random.y * 0.05;

    // Scale up to animate in
    scale *= clamp(time * 0.5 - 0.5, 0.0, 1.0);

    vec3 offset = texture2D(tPos, lookup.xy).xyz;
    vec3 prevpos = texture2D(tPrevPos, lookup.xy).xyz;
    vec3 velocity = offset - prevpos;

    // Flap wings
    float upwardDirection = dot(vec3(0.0, 1.0, 0.0), velocity);
    vec3 localpos = position;
    float speed = 2.6;
    float frameCount = 12.0;
    float animationOffset = random.x * 400.0;

    float flapStrength = pow((sin(time + animationOffset) + 1.0) / 2.0, 2.0);
    float glideStrength = 0.3;

    vec3 flapAnimation = getAnimationPos(tAnimation, frameCount, speed, animationOffset);
    vec3 glideAnimation = vec3(0.0, cos(position.x + time * speed + animationOffset) * (1.0 - flapStrength) * glideStrength + cos(offset.x + time * speed), 0.0);

    float flapFactor = clamp(pow(length(velocity), 2.0) * 2000.0, 0.0, 1.0);
    flapFactor = crange(flapFactor, 0.5, 1.0, 0.0, 1.0);

    vec3 flapOffset = mix(glideAnimation, flapAnimation, flapFactor);

    localpos = localpos + flapOffset;

    vec3 n = normal;
    n += flapOffset;

    // Rotate in direction of flight
    localpos.xyz = transformTowardsVector(localpos.xyz, velocity);

    // Rotate normals to match
    n.xyz = transformTowardsVector(n.xyz, velocity);

    vec3 pos = transformPosition(localpos, offset, scale);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vPos = pos;
    vNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vVel = velocity;
}

#!SHADER: Fragment
void main() {
    vec3 lightDir = normalize(vec3(-0.1, 1.0, -1.0));
    float dp = dot(lightDir, normalize(vNormal)) * 0.5 + 0.5;

    vec3 color = vec3(1.0);
    color = mix(uColor1, uColor2, dp);

    gl_FragColor.rgb = color;
    gl_FragColor.a = 1.0;
}
{@}GardenButterfliesShader.glsl{@}#!ATTRIBUTES
attribute vec3 lookup;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;
uniform float uScale;
uniform vec3 uColor0;
uniform vec3 uColor1;

#!VARYINGS
varying vec3 vColor;
varying float vFog;
varying vec2 vUv;
varying vec3 vWorldPos;

#!SHADER: Vertex
#require(range.glsl)
#require(instance.vs)
#require(rotation.glsl)
void main() {
    vec3 offset = texture2D(tPos, lookup.xy).xyz;
    vec3 prevOffset = texture2D(tPrevPos, lookup.xy).xyz;
    vec3 vel = offset - prevOffset;

    float scale = uScale;

    vec3 direction = normalize(vel);
    vec3 axis = vec3(0.0, 1.0, 0.0);
    float angle = atan(direction.x, direction.z);

    mat4 rotMatrix = rotationMatrix(axis, angle);
    vec3 localpos = vec3(rotMatrix * vec4(position, 1.0));
    localpos *= 0.5;
    float stagger = offset.x + offset.y + offset.z;
    localpos.y += pow(sin(-time * 10.7 + uv.x + stagger), 2.0);

    vec3 n = vec3(rotMatrix * vec4(normal, 0.0));

    vec3 pos = transformPosition(localpos, offset, scale);
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = modelViewMatrix * vec4(pos, 1.0);

    gl_Position = projectionMatrix * modelViewPos;

    vColor = mix(uColor0, uColor1, uv.y);
    vUv = uv;
    vWorldPos = worldPos.xyz;
}

#!SHADER: Fragment
#require(range.glsl)

void main() {
    vec4 color = vec4(vColor, 1.0);
    gl_FragColor = color;
}{@}GardenGrassShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tATO;
uniform sampler2D tLightmap;
uniform float uThreshold;
uniform float uLightmapIntensity;
uniform vec4 uParams;
uniform vec3 uBaseColor;
uniform vec3 uTranslucentColor;
uniform vec3 uLight;
uniform float uDistortion;
uniform float uPower;
uniform float uScale;
uniform vec4 uWind;

#!VARYINGS
varying vec2 vUv;
varying vec2 vLightmapUv;
varying vec3 vBaseColor;
varying vec3 vTranslucentColor;
varying vec3 vLightmap;
varying float vTranslucencyFactor;
varying vec3 vWind;
varying float vFog;

#!SHADER: Vertex
#require(GardenCommon.glsl)

void main() {
    vec3 pos = position;

    float t = time * uParams.z;

    // grass animation
    float largeScaleMotion = 0.0;
    float smallScaleMotion = 0.0;
    vec3 windPos = (offset.xyz - position.xyz * 0.5) * 2.0;
    float windRotation = uWind.x;
    windPos.xz = rotate2d(windRotation) * windPos.xz;
    // float offsetFactor = (cos(windPos.z * 0.2) * 4.0 + windPos.x + windPos.y * 2.0 + windPos.z) * uWind.y + t;
    float offsetFactor = (cos(windPos.z * 0.025) * 25.0 + windPos.x + windPos.y * 2.0 + windPos.z) * uWind.y + t;

    // large scale motion
    largeScaleMotion = sin(offsetFactor) * uParams.x;

    // small scale motion
    smallScaleMotion = sin(2.65 * (offsetFactor)) * 0.5 * uParams.x;

    vWind.z += largeScaleMotion;
    vWind.z += smallScaleMotion;
    vWind.x += smallScaleMotion;

    // rotate wind normal distortion direction
    vWind.xz = rotate2d(windRotation) * vWind.xz;
    float noise = length(vWind) - 0.5;

    // move grass in wind
    pos.x += noise * uv.y;
    pos.z += noise * uv.y;

    // scale grass
    pos -= offset;
    pos *= (uParams.w - random.w * 0.1);
    pos += offset;

    vec3 n = normal;

    #ifdef INSTANCED
    n = transformPosition(normal, vec3(0.0), 1.0, orientation);
    #endif

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    vec3 worldNormal = n;

    gl_Position = projectionMatrix * modelViewPos;
    vUv = uv;

    // lighting calculations
    vec3 eye = normalize(worldPos.xyz - cameraPosition);
    vec3 light = normalize(worldPos.xyz - uLight);

    // Sample lightmap at slightly different locations based on wind noise
    vLightmapUv = random.xy;
    // vLightmapUv.x += noise * 0.1 * pow(vUv.y, 2.0);

    vBaseColor = pow(uBaseColor, vec3(2.2));
    vTranslucentColor = pow(uTranslucentColor, vec3(2.2));
    vLightmap = texture2D(tLightmap, vLightmapUv).rgb;
    vLightmap = pow(vLightmap, vec3(2.2)) * uLightmapIntensity;

    // Get noise that changes based on which direction camera is facing
    light = light + n * uDistortion;
    float dp = dot(eye, -light);
    float accum = 0.0;
    accum += clamp(dp, 0.0, 1.0);
    accum += clamp(-dp * 0.8, 0.0, 1.0);
    accum += noise * 0.35;
    accum = pow(accum, uPower) * uScale;
    vTranslucencyFactor = 20.0 * smoothstep(0.2, 0.4, uv.y) * vLightmap.r * max(accum, 0.5);
    vFog = exponentialFog(modelViewPos.xyz);
}

#!SHADER: Fragment
void main() {
    vec4 data = texture2D(tATO, vUv);
    float alpha = data.r;

    if (alpha < uThreshold) discard;

    float ao = data.b;
    float translucent = data.g;
    float blend = vUv.y;
    vec3 baseColor = vBaseColor;

    baseColor *= vLightmap;
    baseColor += translucent * vTranslucentColor * vTranslucencyFactor;
    baseColor *= mix(1.0, ao, vUv.y);
    baseColor = pow(baseColor, vec3(0.4545));
    baseColor.rgb = mix(clamp(baseColor.rgb, 0.0, 1.0), vec3(1.0, 0.9, 0.8), vFog);

    gl_FragColor = vec4(baseColor, 1.0);
}
{@}GardenLeafParticles.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform float uSize;
uniform vec2 uSizeRand;
uniform sampler2D tMap;
uniform float DPR;
uniform float uRes;
uniform vec3 uColor;
uniform vec3 uTranslucencyColor;
uniform float uAlphaCutOff;
uniform vec2 uDistFade;
uniform vec3 uLight;

#!VARYINGS
varying vec2 vUv;
varying float vLife;
varying float vAlpha;
varying vec4 vRandom;
varying float vFog;
varying float vTranslucency;
varying vec3 vEye;
varying vec3 vTranslucencyColor;

#!SHADER: Vertex

#require(range.glsl)

void main() {
    vec4 decodedPos = texture2D(tPos, position.xy);
    vec3 pos = decodedPos.xyz;
    vec4 worldPosition = modelMatrix * vec4(pos, 1.0);
    vec4 mvPosition = viewMatrix * worldPosition;

    float dist = length(worldPosition.xyz - cameraPosition);

    vRandom = random;
    vAlpha = 1.0;
    vLife = crange(pos.y, 10.0, -20.0, 0.0, 1.0);
    


    vFog = crange(dist, uDistFade.x, uDistFade.y, 1.0, 0.0);


    // Translucency lighting effect
    vec3 eye = normalize(worldPosition.xyz - cameraPosition);
    vec3 light = normalize(uLight);
    float dp = max(0.0, dot(eye, light));
    vTranslucency = dp;
    vTranslucencyColor = pow(uTranslucencyColor, vec3(2.2));
    vEye = eye;

    gl_PointSize = 0.02 * DPR * uRes * uSize * crange(random.x, 0.0, 1.0, uSizeRand.x, uSizeRand.y) * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;
}

#!SHADER: Fragment

#require(range.glsl)
#require(transformUV.glsl)

void main() {

    vec2 uv = vec2(gl_PointCoord.x, 1.0 - gl_PointCoord.y);
    uv = rotateUV(uv, radians(360.0 * vRandom.z)-time*vRandom.w*4.0);

    vec3 tex = texture2D(tMap, uv).rgb;
    float alpha = tex.r;
    if (alpha < 0.5) discard;
    
    alpha *= vAlpha;

    // Translucency lighting effect
    float translucency = (tex.g) * vTranslucency;
    vec3 color = pow(uColor, vec3(2.2));
    color += translucency * vTranslucencyColor * 20.0;
    color += mix(vTranslucencyColor, vec3(1.0), tex.b) * vTranslucency * uv.y;
    color = pow(color, vec3(0.45));

    alpha *= smoothstep(1.0, 0.0, vLife);
    alpha *= vFog;



    gl_FragColor = vec4(color, alpha);
}{@}GardenPortalShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNoise;
uniform vec3 uColor0;
uniform vec3 uColor1;

#!VARYINGS
varying vec2 vUv;
varying vec3 vCameraPosition;
varying float vCameraAngle;
varying float vAlpha;

#!SHADER: Vertex
void main() {
    vec3 n = normal;
    n = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    n = normalize(n);

    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    vec3 eye = normalize(worldPos.xyz - cameraPosition.xyz);

    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;
    vCameraPosition = cameraPosition;

    // add horizontal distortion to give portal fake depth
    vCameraAngle = dot(cross(n, vec3(0.0, 1.0, 0.0)), -eye);
    vAlpha = dot(n, -eye);
}

#!SHADER: Fragment
void main() {
    // circular gradients
    float gradient = distance(vUv, vec2(0.5));
    float innerGradient = 1.0 - smoothstep(0.2, 0.4, gradient);
    float outerGradient = 1.0 - (clamp(smoothstep(0.3, 0.5, gradient), 0.0, 1.0) + innerGradient);

    // environment texture seen through portal
    vec2 distortion = vec2(sin(time * 2.0 + vUv.x * 35.0), cos(time * 1.7 + vUv.y * 20.0));
    vec4 env = texture2D(tMap, vUv + distortion * 0.005 + vec2(vCameraAngle * 0.5, 0.0));
    env.rgb = mix(env.rgb, mix(uColor0, uColor1, smoothstep(0.2, 0.8, vUv.y)), 0.5);

    // polar uvs for noise effect around border
    vec2 uv = vUv;
    uv -= 0.5;
    float angle = atan(uv.y, uv.x);
    float dist = length(uv) + time * 0.05;
    vec2 polarUv = vec2(angle * 0.5 + dist * 2.0, dist);

    // noise effect around border
    float noise = clamp(texture2D(tNoise, polarUv).b * 2.0, 0.0, 1.0) * outerGradient;

    // convert to linear to add noise, then back to gamma
    env.rgb = pow(env.rgb, vec3(2.2));
    env.rgb += pow(noise, 2.2) * 5.0;
    env.rgb = pow(env.rgb, vec3(0.4545));

    gl_FragColor = vec4(env.rgb, innerGradient * vAlpha);
}{@}GardenScreenShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tVideo;
uniform float uConnected;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment
#require(range.glsl)
#require(simplenoise.glsl)
#require(transformUV.glsl)

void main() {
    vec3 base = texture2D(tMap, vUv).rgb;
    vec3 video = texture2D(tVideo, scaleUV(vUv, vec2(1.0, 1.4))).rgb;
    vec3 color = mix(base, video, uConnected);

    vec2 uv = vUv;
    //uv += cnoise(vUv*5.0+time*0.2)*0.003;


    float edge = 1.0;
    edge *= smoothstep(0.0, 0.1, uv.x) * smoothstep(1.0, 0.9, uv.x);
    edge *= smoothstep(0.0, 0.2, uv.y) * smoothstep(1.0, 0.8, uv.y);

    float alpha = smoothstep(0.0, 0.4, edge);
    alpha *= 0.9;


    color += smoothstep(1.0, 0.5, alpha);

    float rings = fract(edge*2.0-time*0.2);
    rings = smoothstep(0.1, 0.5, rings) * smoothstep(0.9, 0.5, rings);
    color += rings*0.8*(1.0-edge);

    alpha = mix(mix(alpha, alpha*smoothstep(0.0, 0.4, 1.0-edge)*color.r, 0.6), alpha, uConnected);
    color = mix(color, color, uConnected);


    alpha = mix(alpha, 1.0, base.r);//mix(base.r, base.r, uConnected);
    color += mix(0.0, base.r*step(0.7, uv.y), uConnected);



        


    gl_FragColor = vec4(color, alpha);
}{@}GardenSkyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tFlow;
uniform vec3 uColor0;
uniform vec3 uColor1;
uniform vec3 uColor3;
uniform vec4 uParams;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vWorldPos;
varying float vSunGradient;
varying vec3 vColor;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vPos = position;
    vSunGradient = position.y * 0.5 - position.x - position.z * 1.2;
    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    vWorldPos = worldPos.xyz;
    gl_Position = projectionMatrix * viewMatrix * worldPos;
    vUv = uv;

    vColor = mix(uColor1, uColor0, smoothstep(0.4, 1.0, position.z));
    vColor = mix(vColor, uColor0, smoothstep(0.3, -0.1, position.y));
    vColor = mix(vColor, uColor3, smoothstep(0.0, -2.5, position.z));
}

#!SHADER: Fragment
#require(rotation.glsl)
#require(range.glsl)

vec3 getFlow(sampler2D tMap, sampler2D tFlow, vec2 uv, float speed, float strength, float time, float tile, float multiplier) {
    float t = time * speed;
    float mask = fract(t);
    mask = (mask- 0.5) * 2.0;
    mask = abs(mask);
    
    vec2 flow = texture2D(tFlow, uv * tile).rg;
    flow = flow * 2.0 - 1.0;
    flow *= multiplier;

    vec3 color = texture2D(tMap, uv + flow * strength * fract(t + 0.5)).rgb;
    vec3 color2 = texture2D(tMap, uv + flow * strength * fract(t + 0.0)).rgb; 
    color = mix(color2, color, mask);
    return color;
}

void main() {
    vec2 uv = vec2(0.0, vSunGradient);
    uv.y -= 0.5;
    uv.y *= uParams.x;
    uv.y += 0.5;
    uv = rotationMatrix(sin(time) * 0.75) * uv;

    vec3 color = vColor;

    vec2 cloudsUv = vUv;
    cloudsUv.y *= 2.0;
    float clouds = getFlow(tMap, tFlow, cloudsUv, uParams.y, uParams.z, time, uParams.w, smoothstep(0.5, 0.52, vUv.y)).r;
    clouds *= step(0.5, vUv.y);

    color = pow(color, vec3(2.2)) * 0.85;
    clouds = pow(clouds, 2.2);
    color += clouds * 0.35 * smoothstep(0.0, 0.03, vPos.y);
    color = pow(color, vec3(0.4545));
    
    gl_FragColor = vec4(color, 1.0);
}{@}GardenTerrainShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMRO;
uniform sampler2D tCaustics;
uniform sampler2D tNormal;
uniform sampler2D tLightmap;

uniform vec3 uGrassColor;
uniform vec3 uRockColor;

uniform float uTiling;
uniform vec2 uOffset;
uniform vec2 uBlend;
uniform vec2 uAO;
uniform float uNormalIntensity;
uniform float uLightmapIntensity;
uniform vec3 uLight;
uniform vec3 uSunColor;
uniform vec3 uShadowColor;

uniform vec3 uEnv;

uniform vec4 uWind;

// Character shadow uniforms
// uniform sampler2D tShadowMap;
// uniform vec4 uBox;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec2 vLightmapUv;
varying vec3 vN;
varying vec3 vV;
varying vec3 vColor;
varying float vFog;
varying float vDist;
varying vec3 vWind;
varying vec3 vPos;
varying vec3 vWorldPos;
varying vec3 vNoisePos;
varying vec3 vLight;
varying vec3 vSunColor;
varying vec3 vShadowColor;

#!SHADER: Vertex
#require(rotation.glsl)
#require(GardenCommon.glsl)

void main() {
    vLightmapUv = uv;

    vec3 pos = position;

    // #ifdef INSTANCED
    // pos.y += sin(offset.x + offset.y + offset.z + time * 0.15 * uGlobalWind.y) * 5.0 * uFloat;
    // #endif

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;

    vec3 n = normal;
    vec3 color = vdata;

    float t = time * uWind.z;

    // grass animation
    float largeScaleMotion = 0.0;
    float smallScaleMotion = 0.0;
    vec3 windPos = pos.xyz * 2.0;
    float windRotation = uWind.x;
    windPos.xz = rotate2d(windRotation) * windPos.xz;
    float offsetFactor = (cos(windPos.z * 0.025) * 25.0 + windPos.x + windPos.y * 2.0 + windPos.z) * uWind.y + t;

    // large scale motion
    largeScaleMotion = sin(offsetFactor);

    // small scale motion
    smallScaleMotion = sin(2.65 * (offsetFactor)) * 0.5;

    vWind.z += largeScaleMotion;
    vWind.z += smallScaleMotion;
    vWind.x += smallScaleMotion;

    // rotate wind normal distortion direction
    vWind.xz = rotate2d(windRotation) * vWind.xz;
    vWind = vWind;

    #ifdef INSTANCED
    n = transformPosition(normal, vec3(0.0), 1.0, orientation);
    #endif

    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;

    vN = worldNormal;
    vV = worldPos.xyz - cameraPosition;
    vUv = uv * uTiling + uOffset;
    vUv2 = uv2;
    vColor = color;
    vFog = exponentialFog(modelViewPos.xyz);

    vPos = position;
    vWorldPos = worldPos.xyz;
    vLight = normalize(uLight);
    vSunColor = pow(uSunColor, vec3(2.2));
    vShadowColor = pow(uShadowColor, vec3(2.2));
}

#!SHADER: Fragment

#require(normalmap.glsl)
#require(range.glsl)
#require(simplenoise.glsl)
#require(common.glsl)

void main() {
    // if (isClipping(vUv*0.4, vWorldPos)) discard;

    float blend = vN.y - 0.05;
    vec2 uv = vUv;
    vec3 wind = vWind;
    vec3 windNoise = wind.xyz;
    vec3 N = vN;
    vec3 V = vV;

    float normalIntensity = mix(uNormalIntensity, 0.0, blend);
    vec3 normal = unpackNormal(V, N + windNoise * 0.1, tNormal, normalIntensity, 1.0, uv).xyz;
    float grassMask = smoothstep(uBlend.x, uBlend.x + 0.1, normal.y);
    vec4 MRO = texture2D(tMRO, uv - (wind.zx * 0.5 + 0.5) * 0.03 * smoothstep(0.8, 0.9, blend) * uWind.w);

    // ambient occlusion
    float ao = mix(MRO.z, 1.0, clamp(blend, 0.0, 1.0));

    // diffuse lighting
    float dp = dot(normalize(normal + windNoise * grassMask), vLight);
    vec3 diffuse = mix(uShadowColor, uSunColor, dp * 0.5 + 0.5);

    // baked lighting
    vec3 lightmap = texture2D(tLightmap, vLightmapUv).rgb;
    lightmap = pow(lightmap, vec3(2.2));
    diffuse *= lightmap * uLightmapIntensity;

    // base color
    vec4 baseColor = vec4(1.0);
    baseColor.rgb = mix( uRockColor, mix(uGrassColor, uGrassColor * 0.75, clamp(MRO.x + windNoise.z * 0.5, 0.0, 1.0)), grassMask);
    baseColor.rgb = pow(baseColor.rgb, vec3(2.2));
    diffuse *= baseColor.rgb;

    // caustics
    vec3 caustics = vec3(0.0);
    // vec4 caustics0 = texture2D(tCaustics, vPos.xz * 0.12 + time * 0.05);
    // vec4 caustics1 = texture2D(tCaustics, vPos.xz * 0.12 + time * 0.05 * vec2(-1.81, -1.42));
    // caustics = pow(min(caustics0.rgb, caustics1.rgb), vec3(2.2));
    // caustics *= clamp(1.0 - vPos.y * 0.1, 0.0, 1.0);
    
    vec4 color = vec4(diffuse * ao + caustics, 1.0);

    color.rgb = pow(color.rgb, vec3(0.45454545));
    color.rgb = mix(clamp(color.rgb, 0.0, 1.0), vec3(1.0, 0.9, 0.8), vFog);

    gl_FragColor = color;
}{@}GardenPoolShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tNormal;
uniform sampler2D tEnv;
uniform sampler2D tEnvDiffuse;
uniform vec2 uTiling;
uniform float uSpeed;
uniform vec3 uColor;
uniform vec3 uSpecColor;
uniform float uNormalIntensity;
uniform vec3 uParams;
uniform vec3 uScrollDirection;
uniform vec3 uEnv;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying float vTest;
varying vec3 vN;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec3 vColor;
varying float vAlpha;
varying vec3 vWorldPos;

#!SHADER: Vertex
void main() {
    float t = time * uSpeed * 8.0 * modelMatrix[1].z;
    vec3 pos = position;

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;

    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;

    vN = normal;
    vWorldNormal = worldNormal;
    vV = worldPos.xyz - cameraPosition;
    vUv = uv * uTiling + uScrollDirection.xy * time;
    vUv2 = uv;
    vColor = vdata;
    // vAlpha = vdata.r * 1.5;
    vAlpha = 1.0;

    vWorldPos = worldPos.xyz;
}

#!SHADER: Fragment
const float LOG2 = 1.442695;
const vec2 INV_ATAN = vec2(0.1591, 0.3183);

#require(normalmap.glsl)
#require(range.glsl)

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * cosTheta - 6.98316) * cosTheta);
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec2 sampleSphericalMap(vec3 v, float rotation)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;

    // match default C4D baked HDRI
    uv.x = fract(uv.x + 0.25 + rotation);

    return uv;
}

mat2 rotate2d(float angle){
    return mat2(cos(angle),-sin(angle),
                sin(angle),cos(angle));
}

void main() {
    vec2 uv0 = vUv * uTiling + vec2(0.0, time * uSpeed);
    vec2 uv1 = vUv * uTiling * 0.8 + vec2(0.0, -time * uSpeed * 0.5);
    vec3 N = vWorldNormal;
    vec3 V = normalize(vV);
    vec3 worldNormal = unpackNormal(V, N, tNormal, uNormalIntensity, 1.0, uv0).xyz;
    worldNormal = mix(worldNormal, unpackNormal(V, N, tNormal, uNormalIntensity, 1.0, uv1).xyz, 0.5);
    vec3 R = reflect(V, worldNormal);
    float NdV = abs(dot(worldNormal, V));

    float roughness = 0.01;
    vec3 F0 = vec3(0.04);
    vec3 F = fresnelSphericalGaussianRoughness(NdV, F0, roughness);

    vec2 specUV = sampleSphericalMap(R, uEnv.z);
    vec3 specular = texture2D(tEnv, specUV).rgb;
    specular *= F + 0.5;
    specular *= uParams.y;

    vec3 diffuseContrib = 1.0 - F;
    vec3 diffuse = uColor;
    diffuse = pow(diffuse, vec3(2.2));

    vec3 finalColor = specular * uSpecColor + diffuse * diffuseContrib * uParams.x;
    finalColor = pow(finalColor, vec3(0.454545));

    float alpha = specular.r + 0.25;
    alpha *= vAlpha;

    alpha *= smoothstep(0.5, 0.0, length(vUv2-0.5));


    gl_FragColor = vec4(finalColor, alpha);
}
{@}GardenUnderwaterShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tCaustics;
uniform vec4 uCaustics;
uniform float uBrightness;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vPos = position;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment

void main() {
    vec3 color = texture2D(tMap, vUv).rgb;
    color = pow(color, vec3(2.2));
    color *= uBrightness;

    vec3 caustics = vec3(0.0);
    vec3 caustics0 = texture2D(tCaustics, vUv * uCaustics.x + time * uCaustics.z).rgb;
    vec3 caustics1 = texture2D(tCaustics, vUv * 0.9 * uCaustics.x - time * uCaustics.z).rgb;
    caustics = pow(min(caustics0, caustics1), vec3(2.2));

    color += caustics * 2.5;
    color = pow(color, vec3(0.4545));

    float alpha = smoothstep(0.5, 0.1, length(vUv-0.5));

    gl_FragColor = vec4(color, alpha);
}{@}GardenWhaleShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMRO;
uniform sampler2D tNormal;

uniform vec3 uGrassColor;
uniform vec3 uRockColor;

uniform float uTiling;
uniform vec2 uOffset;
uniform vec2 uBlend;
uniform vec2 uAO;
uniform float uNormalIntensity;
uniform float uLightmapIntensity;
uniform vec3 uLight;
uniform vec3 uSunColor;
uniform vec3 uShadowColor;
uniform float uSize;

uniform vec3 uEnv;

uniform vec4 uWind;

// Character shadow uniforms
// uniform sampler2D tShadowMap;
// uniform vec4 uBox;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec2 vLightmapUv;
varying vec3 vN;
varying vec3 vV;
varying vec3 vColor;
varying float vFog;
varying float vDist;
varying vec3 vWind;
varying vec3 vPos;
varying vec3 vWorldPos;
varying vec3 vNoisePos;
varying vec3 vLight;
varying vec3 vSunColor;
varying vec3 vShadowColor;
varying float vFlipperMask;

#!SHADER: Vertex
#require(rotation.glsl)
#require(GardenCommon.glsl)

void main() {
    float flipperMask = pow(abs(position.x), 3.0);

    vec3 pos = position;
    pos.z *= 0.85;
    pos.y += cos(time * 0.5 + pos.z * 1.0) * 0.05;

    vec3 n = normal;

    // flap flippers
    float s = sign(pos.x);
    mat2 flipperMatrix = rotationMatrix(flipperMask * sin(time * 0.5 * s - pos.x * 2.0) * 0.5);
    pos.x -= s;
    pos.xy = flipperMatrix * pos.xy;
    pos.x += s;

    n.xy = flipperMatrix * n.xy;

    // swimming animation
    mat2 swimMatrix = rotationMatrix(sin(time * 0.5 + pos.z) * 0.15);
    pos.z -= 1.0;
    pos.xy = swimMatrix * pos.xy;
    pos.yz = swimMatrix * pos.yz;
    pos.zx = swimMatrix * pos.zx;
    pos.z += 1.0;

    pos.xyz *= uSize;

    // swim in circle
    mat2 circleMatrix = rotationMatrix(time * 0.03 + pos.z * 0.01);
    pos.x -= 10.0;
    pos.xz = circleMatrix * pos.xz;

    // #ifdef INSTANCED
    // pos.y += sin(offset.x + offset.y + offset.z + time * 0.15 * uGlobalWind.y) * 5.0 * uFloat;
    // #endif

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;

    vec3 color = vdata;

    // #ifdef INSTANCED
    // n = transformPosition(normal, vec3(0.0), 1.0, orientation);
    // #endif

    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    worldNormal.xz = circleMatrix * worldNormal.xz;

    vN = normalize(worldNormal);
    vV = worldPos.xyz - cameraPosition;
    vUv = uv * uTiling + uOffset;
    vUv2 = uv2;
    vColor = color;
    vFog = exponentialFog(modelViewPos.xyz);

    vPos = position;
    vWorldPos = worldPos.xyz;
    vLight = normalize(uLight);
    vSunColor = pow(uSunColor, vec3(2.2));
    vShadowColor = pow(uShadowColor, vec3(2.2));
}

#!SHADER: Fragment

#require(normalmap.glsl)
#require(range.glsl)
#require(simplenoise.glsl)
#require(common.glsl)

void main() {
    // if (isClipping(vUv*0.4, vWorldPos)) discard;

    float blend = vN.y - 0.05;
    vec2 uv = vUv;
    vec3 N = vN;
    vec3 V = vV;

    float normalIntensity = mix(uNormalIntensity, 0.0, blend);
    vec3 normal = unpackNormal(V, N, tNormal, normalIntensity, 1.0, uv).xyz;
    float grassMask = smoothstep(uBlend.x, uBlend.x + 0.1, normal.y);
    vec4 MRO = texture2D(tMRO, uv);

    // ambient occlusion
    float ao = mix(MRO.z, 1.0, clamp(blend, 0.0, 1.0));

    // diffuse lighting
    float dp = dot(normalize(normal), vLight);
    vec3 diffuse = mix(uShadowColor, uSunColor, max(0.0, dp * 0.5 + 0.5)) * uLightmapIntensity;

    // base color
    vec4 baseColor = vec4(1.0);
    baseColor.rgb = mix( uRockColor, mix(uGrassColor, uGrassColor * 0.75, MRO.x), grassMask);
    baseColor.rgb = pow(baseColor.rgb, vec3(2.2));
    diffuse *= baseColor.rgb;
    
    vec4 color = vec4(diffuse * ao, 1.0);

    color.rgb = pow(color.rgb, vec3(0.45454545));
    color.rgb = mix(clamp(color.rgb, 0.0, 1.0), vec3(1.0, 0.9, 0.8), vFog);

    gl_FragColor = color;
}{@}ForesterButterflyShader.glsl{@}#!ATTRIBUTES
attribute vec3 lookup;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;
uniform float uScale;
uniform vec3 uColor0;
uniform vec3 uColor1;

#!VARYINGS
varying vec3 vColor;
varying float vFog;
varying vec2 vUv;
varying vec3 vWorldPos;

#!SHADER: Vertex
#require(range.glsl)
#require(instance.vs)
#require(rotation.glsl)
#require(common.glsl)

void main() {
    vec3 offset = texture2D(tPos, lookup.xy).xyz;
    vec3 prevOffset = texture2D(tPrevPos, lookup.xy).xyz;
    vec3 vel = offset - prevOffset;

    float scale = uScale;

    vec3 direction = normalize(vel);
    vec3 axis = vec3(0.0, 1.0, 0.0);
    float angle = atan(direction.x, direction.z);

    mat4 rotMatrix = rotationMatrix(axis, angle);
    vec3 localpos = vec3(rotMatrix * vec4(position, 1.0));
    // localpos *= 0.5;
    float stagger = offset.x + offset.y + offset.z;
    localpos.y += pow(sin(-time * 12.7 + uv.x + stagger), 2.0);

    vec3 n = vec3(rotMatrix * vec4(normal, 0.0));

    vec3 pos = transformPosition(localpos, offset, scale);
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = modelViewMatrix * vec4(pos, 1.0);

    gl_Position = projectionMatrix * modelViewPos;

    vColor = mix(uColor0, uColor1, uv.y);
    vUv = uv;
    vWorldPos = worldPos.xyz;
}

#!SHADER: Fragment

void main() {
    vec4 color = vec4(vColor, 1.0);
    gl_FragColor = color;
}
{@}ForesterGrassFlowerShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tATO;
uniform sampler2D tBaseColor;
uniform sampler2D tLightmap;
uniform sampler2D tNormal;
uniform float uThreshold;
uniform float uLightmapIntensity;
uniform vec4 uParams;
uniform vec4 uAnimationParams;
uniform vec3 uBaseColor;
uniform vec3 uBaseColor2;
uniform vec3 uScatterColor;
uniform vec3 uBudColor;
uniform vec3 uLight;
uniform float uDiffuse;
uniform float uDistortion;
uniform float uPower;
uniform float uScale;
uniform float uGrow;

#!VARYINGS
varying vec2 vUv;
varying vec2 vLightmapUv;
varying float vNoise;
varying float vDist;
varying vec3 vBaseColor;
varying vec3 vScatterColor;
varying vec3 vLightmap;
varying float vRandom;

varying float vGrowWipe;

varying vec3 vNormal;
varying vec3 vEye;
varying vec3 vLight;
varying float vAttenuation;
varying float vTransmissionDiffuse;
varying float vDiffuse;
varying float vRandom;
varying float vTranslucencyFactor;

#!SHADER: Vertex
void main() {
    vGrowWipe = clamp(smoothstep(uGrow - 1.0, uGrow + 0.5 - 1.0, -offset.z * 0.02) - 0.1, 0.0, 1.1);
    vGrowWipe = pow(vGrowWipe, 2.0);

    vec3 pos = position;

    float t = time * uParams.y - 0.3;
    vec3 noiseUv = pos * uParams.z;
    float largeScaleMotion = sin(noiseUv.x + noiseUv.y + noiseUv.z + t) * uParams.x;
    float smallScaleMotion = sin(2.65 * (noiseUv.x + noiseUv.y + noiseUv.z + t * 1.4)) * uParams.x * 0.5;
    float value = largeScaleMotion + smallScaleMotion;

    pos.x += value * uv.y;
    pos.z += value * uv.y;

    pos.y -= 0.5;

    pos -= offset;
    pos *= uAnimationParams.w - vGrowWipe * 1.0;
    pos *= 0.9;
    pos *= mix(1.0,1.0 -  random.w, 0.2);
    pos += offset;

    vec3 n = normal;

    #ifdef INSTANCED
        n = transformPosition(normal, vec3(0.0), 1.0, orientation);
    #endif

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec3 worldNormal = n;
    vNormal = normalize(worldNormal);
    vEye = normalize(worldPos.xyz - cameraPosition);
    vLight = normalize(worldPos.xyz - uLight);
    vAttenuation = pow(0.6 / distance(uLight, worldPos.xyz), 2.0);

    float wrap = 0.01;
    vTransmissionDiffuse = max(0.0, (dot(normalize(vLight), vNormal) + wrap) / (1.0 + wrap));
    vDiffuse = max(0.0, (dot(normalize(-vLight), vNormal) + wrap) / (1.0 + wrap)) * uDiffuse;

    gl_Position = projectionMatrix * viewMatrix * worldPos;
    vUv = uv;

    vLightmapUv = random.xy;
    vLightmapUv.y += value * 0.07 * vUv.y;
    vLightmapUv.x += value * 0.07 * vUv.y;

    vNoise = value * 0.5 + 0.5;
    vBaseColor = pow(mix(uBaseColor, uBaseColor2, smoothstep(0.4, 0.9, random.w)), vec3(2.2));
    vScatterColor = pow(uScatterColor, vec3(2.2));
    vLightmap = texture2D(tLightmap, vLightmapUv).rgb;
    vLightmap = pow(vLightmap, vec3(2.2)) * uLightmapIntensity;
    vRandom = random.z;

    vec3 light = vLight + vNormal * (uDistortion + vRandom);
    float dp = pow(clamp(dot(vEye, -light), 0.0, 1.0), uPower) * uScale;
    vTranslucencyFactor = max(0.1, dp) * pow(vLightmap.r, 2.5) * uParams.w;
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec3 saturation(vec3 rgb, float adjustment)
{
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}

void main() {
    vec4 data = texture2D(tATO, vUv);
    float alpha = data.r;
    if (alpha < uThreshold + vGrowWipe) discard;

    float ao = mix(1.0, data.b, 0.7);
    float translucent = data.g;

    vec3 N = vNormal;

    if (!gl_FrontFacing) {
        N.z *= -1.0;
    }

    vec3 baseColor = vBaseColor * texture2D(tBaseColor, vUv).b;
    vec3 translucency = vec3(translucent) * vTranslucencyFactor;

    baseColor *= vLightmap;
    baseColor += vNoise * translucency * 0.5;
    baseColor += vScatterColor;
    baseColor = pow(baseColor, vec3(0.4545));
    baseColor *= ao;

    gl_FragColor = vec4(baseColor, 1.0);
}{@}ForesterGrassShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tATO;
uniform sampler2D tBaseColor;
uniform sampler2D tLightmap;
uniform float uThreshold;
uniform float uLightmapIntensity;
uniform vec4 uParams;
uniform vec4 uAnimationParams;
uniform vec3 uBaseColor;
uniform vec3 uTranslucentColor;
uniform float uGrow;

uniform vec3 uLight;
uniform float uDistortion;
uniform float uPower;
uniform float uScale;
uniform float uGrow;

uniform float uDiscardDist;

#!VARYINGS
varying vec2 vUv;
varying vec2 vLightmapUv;
varying float vNoise;
varying float vDist;
varying vec3 vBaseColor;
varying vec3 vTranslucentColor;
varying vec3 vLightmap;
varying float vRandom;
varying float vBounce;

varying float vGrowWipe;

varying vec3 vNormal;
varying vec3 vEye;
varying vec3 vLight;
varying float vAttenuation;
varying float vTransmissionDiffuse;
varying float vDiffuse;
varying float vDp;
varying float vTranslucencyFactor;
varying float vTranslucencyFactorInverse;

#!SHADER: Vertex
void main() {
    vDist = length(offset);
    vGrowWipe = clamp(smoothstep(uGrow - 1.0, uGrow + 0.7 - 1.0, -offset.z * 0.02) - 0.1, 0.0, 1.1);
    vGrowWipe = pow(vGrowWipe, 2.0);

    vec3 pos = position;

    float t = time * uParams.y;
    vec3 noiseUv = pos * uParams.z;
    float largeScaleMotion = sin(noiseUv.x + noiseUv.y + noiseUv.z + t) * uParams.x;
    float smallScaleMotion = sin(2.65 * (noiseUv.x + noiseUv.y + noiseUv.z + t * 1.4)) * uParams.x * 0.5;
    float value = largeScaleMotion + smallScaleMotion;
    value += random.w * 0.01;

    pos.x += value * uv.y;
    pos.z += value * uv.y;

    pos -= offset;
    pos *= (uParams.w - random.w * 0.1) - vGrowWipe * 2.0;
    pos += offset;

    vec3 n = normal;

    #ifdef INSTANCED
    n = transformPosition(normal, vec3(0.0), 1.0, orientation);
    #endif

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec3 worldNormal = n;
    vNormal = normalize(worldNormal);
    vEye = normalize(worldPos.xyz - cameraPosition);
    vLight = normalize(worldPos.xyz - uLight);
    vAttenuation = pow(0.6 / distance(uLight, worldPos.xyz), 2.0);

    gl_Position = projectionMatrix * viewMatrix * worldPos;
    vUv = uv;

    vBounce = random.z;

    vLightmapUv = random.xy;
    vLightmapUv.y += value * 1.0 * pow(vUv.y, 2.0);

    vNoise = value * 0.5 + 0.5;
    vBaseColor = pow(uBaseColor, vec3(2.2));
    vTranslucentColor = pow(uTranslucentColor, vec3(2.2));
    vLightmap = texture2D(tLightmap, vLightmapUv).rgb;
    vLightmap = pow(vLightmap, vec3(2.2)) * uLightmapIntensity;

    vec3 light = vLight + vNormal * uDistortion;
    float dp = dot(vEye, -light);
    float accum = 0.0;
    accum += clamp(dp, 0.0, 1.0);
    // accum += clamp(-dp * 0.8, 0.0, 1.0);
    // accum += value * 0.35;
    accum = pow(accum, uPower) * uScale;
    // float dp = pow(clamp(dot(vEye, -light), 0.0, 1.0), uPower) * uScale;
    vTranslucencyFactor = 20.0 * smoothstep(0.2, 0.4, uv.y) * vLightmap.r * max(accum, 0.2);
    // vTranslucencyFactor = smoothstep(0.2, 0.4, uv.y) * max(accum, 0.2);
    vTranslucencyFactor = max(accum, 0.2);
}

#!SHADER: Fragment
void main() {
    // discard; // hide while testing

    if (vDist > uDiscardDist) discard;
    vec4 data = texture2D(tATO, vUv);
    float alpha = data.r;
    if (alpha < uThreshold) discard;

    float ao = data.b;
    float translucent = data.g;
    float blend = vUv.y;
    vec3 baseColor = vBaseColor;
    vec3 normal = vNormal;

    baseColor *= vLightmap;
    // baseColor += translucent * vTranslucentColor * vTranslucencyFactor;
    // baseColor *= mix(1.0, ao, vUv.y);
    baseColor = pow(baseColor, vec3(0.4545));

    gl_FragColor = vec4(baseColor, 1.0);
}
{@}ForesterLandscapeShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tLightmap;
uniform float uLightmapIntensity;
uniform vec3 uBaseColor;
uniform float uDiscardDist;

uniform sampler2D tTilingGrass;
uniform float uTile;
uniform vec3 uColor0;
uniform vec3 uColor1;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying float vDist;
varying vec3 vBaseColor;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vPos = position;
    vDist = length(position);
    vBaseColor = pow(uBaseColor, vec3(2.2));
}

#!SHADER: Fragment
void main() {
    if (vDist > uDiscardDist) discard;
    // vec3 color = mix(uColor0, uColor1, texture2D(tTilingGrass, vUv * uTile).r);

    vec3 baseColor = vBaseColor;
    vec3 lightmap = pow(texture2D(tLightmap, vUv).rgb, vec3(2.2));
    baseColor = baseColor * lightmap * uLightmapIntensity;
    baseColor = pow(baseColor, vec3(0.4545));
    gl_FragColor = vec4(baseColor, 1.0);
}{@}TerrainShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tBaseColor;
uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform sampler2D tEnvDiffuse;
uniform sampler2D tEnvSpecular;

uniform sampler2D tBlend;

uniform sampler2D tLightmap;
uniform float uLightmapIntensity;

uniform vec3 uTint;
uniform vec3 uSunColor;
uniform vec3 uShadowColor;

uniform vec3 uGrassColor;
uniform vec3 uRockColor;
uniform vec3 uSandColor;
uniform vec3 uFogColor;

uniform float uTiling;
uniform vec2 uOffset;
uniform vec2 uBlend;
uniform vec2 uAO;
uniform float uNormalIntensity;
uniform vec3 uEnv;

uniform vec3 uLightPos;

#!VARYINGS
varying vec2 vUv;
varying vec2 vLightmapUv;
varying vec2 vUv2;
varying vec3 vN;
varying vec3 vV;
varying vec3 vN;
varying vec3 vColor;
varying vec3 vGrassColor;
varying vec3 vRockColor;
varying float vFog;
varying vec3 vBounce;
varying vec3 vPos;
varying float vBlend;
varying vec3 vLight;

varying vec3 vSunColor;
varying vec3 vShadowColor;

#!SHADER: Vertex
#require(rotation.glsl)
const float LOG2 = 1.442695;

vec2 rotate(vec2 v, float a) {
	float s = sin(a);
	float c = cos(a);
	mat2 m = mat2(c, -s, s, c);
	return m * v;
}



void main() {
    float t = time * 1.5;

    vec3 pos = position;

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;

    // vec3 n = mix(normal, vec3(0.0, 1.0, 0.0), 0.1);
    vec3 n = normal;

    #ifdef INSTANCED
    n = transformPosition(normal, vec3(0.0), 1.0, orientation);
    #endif
    
    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;

    vN = worldNormal;
    // vN = normalMatrix * normal;
    vV = -(worldPos.xyz - cameraPosition);
    // vV = -modelViewPos.xyz;
    vUv = uv * uTiling + uOffset;
    vLightmapUv = uv;
    vPos = pos;
    vBlend = worldNormal.y;
    // vLight = -normalize(vec3(-90.0, 10.0, 90.0) - modelViewPos.xyz);
    vLight = normalize(uLightPos);

    vSunColor = pow(uSunColor, vec3(2.2));
    vShadowColor = pow(uShadowColor, vec3(2.2));
    vGrassColor = pow(uGrassColor, vec3(2.2));
    vRockColor = pow(uRockColor, vec3(2.2));
}

#!SHADER: Fragment
#require(normalmap.glsl)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * cosTheta - 6.98316) * cosTheta);
}

vec2 sampleSphericalMap(vec3 v)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;

    // match default C4D baked HDRI
    uv.x = fract(uv.x + 0.25 + uEnv.z);

    return uv;
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

void main() {
    vec2 uv = vUv;
    vec3 N = vN;
    vec3 V = normalize(vV);

    // N.z = abs(N.z);



    // N.y = abs(N.y);

    vec4 MRO = texture2D(tMRO, uv);
    float roughness = MRO.g;
    float blendTexture = texture2D(tBlend, uv).r;

    float blend = smoothstep(uBlend.x - uBlend.y, uBlend.x + uBlend.y, MRO.b * blendTexture * vBlend);

    // vec3 vdata = vColor;

    // // reduce normal intensity for grass/sand
    float normalIntensity = clamp(uNormalIntensity - blend * 10.0, 0.0, 10.0);

    vec3 worldNormal = unpackNormal(V, N, tNormal, normalIntensity, 1.0, uv).xyz;
    worldNormal.z = abs(worldNormal.z);
    float NdV = abs(dot(normalize(worldNormal), normalize(V)));

    // vec3 R = normalize(reflect(V, worldNormal));
    // vec2 specUV = sampleSphericalMap(R);
    // vec3 specular = RGBMToLinear(texture2D(tEnvSpecular, specUV)).rgb;

    // float level = floor(roughness * ENV_LODS);

    // specUV.y /= 2.0;
    // specUV /= pow(2.0, level);
    // specUV.y += 1.0 - exp(-LN2 * level);

    vec3 F0 = vec3(0.01);
    vec3 F = fresnelSphericalGaussianRoughness(NdV, F0, MRO.g);


    vec3 lightmap = texture2D(tLightmap, vLightmapUv).rgb;
    lightmap = pow(lightmap, vec3(2.2));
    // worldNormal.z = abs(worldNormal.z);

    float dp = max(0.0, dot(worldNormal, vLight));
    dp += dp * uEnv.y;
    // dp = dp * 0.5 + 0.5;

    vec3 baseColor = pow(texture2D(tBaseColor, uv).rgb, vec3(2.2));
    baseColor = mix(vRockColor, vGrassColor, blend);
    
    vec3 diffuse = mix(vShadowColor, vSunColor, dp * 0.5 + 0.5);
    diffuse = baseColor * (diffuse * lightmap * uLightmapIntensity);
    

    float ao = mix(1.0, pow(MRO.b, 2.2), clamp(uAO.x - blend, 0.0, 1.0));

    F *= roughness;

    vec4 color = vec4((diffuse) * ao, 1.0);

    color.rgb = pow(color.rgb, vec3(0.45454545));

    // gl_FragColor = color;
    gl_FragColor = color;
}{@}Grass2Shader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tVel;
uniform sampler2D tNoise;
uniform sampler2D tBlueNoise;

#!VARYINGS
varying vec2 vUv;
varying vec3 vWorldNormal;
varying float vFresnel;
varying float vFogFresnel;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;
    vWorldNormal = normalize(vWorldNormal);
    vFresnel = 1.0 - max(dot(normalize(cameraPosition - vWorldNormal), vWorldNormal), 0.0);
    vFogFresnel = pow(vFresnel, 3.0);
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment
const float PHI = 1.61803398874989484820459; // Φ = Golden Ratio 

float gold_noise(in vec2 xy, in float seed)
{
    return fract(tan(distance(xy*PHI, xy)*seed)*xy.x);
}

void main() {
    float strength = 2.5;
    vec2 uv = vUv * 3.0;

    float t = time * 0.06 * strength;

    vec3 vel = texture2D(tVel, uv * 0.5 + t).rgb;
    vel = mix(vel, texture2D(tVel, uv + t * 0.60 - 0.2).rgb, 0.5);
    vel = vel * 2.0 - 1.0;
    vel *= 0.02;
    vel *= clamp(strength, 0.0, 3.0);

    vec3 color = texture2D(tMap, uv * 2.0 + vel.rg * 2.0).rgb;

    float n1 = texture2D(tNoise, uv * 0.5 + vel.rg * 7.0 + t).r;
    float n2 = texture2D(tNoise, uv + vel.rg * 9.0 + t).r;
    float n3 = texture2D(tNoise, uv + vel.rg * 6.0 + t + vec2(0.15, 0.0)).r;
    float n4 = texture2D(tNoise, uv * 0.5 + vel.rg * 12.0 + t + vec2(0.15, 0.0)).r;

    float highlight = n1 * n2;
    // highlight *= color.r * 2.5;
    highlight = smoothstep(0.15, 1.0, highlight);
    highlight *= 1.3;
    highlight *= vFresnel + 0.08;


    float shadow = n3 * n4;
    // shadow *= color.g * 4.5;
    shadow = smoothstep(0.1, 1.0, shadow);
    shadow = 1.0 - shadow;
    shadow *= 0.2;
    shadow += 0.3;
    shadow = mix(0.0, shadow, vFresnel + 0.08);

    float velcolor = vel.r * 45.0 + 0.1;
    velcolor = mix(0.5, velcolor, vFogFresnel + 0.04);

    float comp = shadow + highlight + vFogFresnel * 0.5 + velcolor * 0.5;

    vec3 grass = texture2D(tMap, uv * 2.0 + vel.rg * 0.2).rgb;

    // vec3 blueNoise = texture2D(tBlueNoise, uv * 2.0 + vel.rg * 1.2).rgb;

    float rangedcomp = smoothstep(0.6, 1.0, comp);
    // float final = smoothstep(0.3 - rangedcomp * 0.1, 0.6 - rangedcomp * 0.1, grass.g + grass.r * max(vel.r, 0.0) * 100.0 + grass.r * max(0.0, vel.g) * 100.0 + grass.b * max(0.0, vel.b) * 100.0);
    // final = final * vFresnel * comp + 0.2;
    float final = rangedcomp;
    // final *= rangedcomp;
    // final += comp * 0.5;
    // final = grass;

    gl_FragColor = vec4(vec3(final), 1.0);
}{@}GrassMoveShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tBaseColor;
uniform sampler2D tVel;
uniform float uThreshold;
uniform float uScale;
uniform float uSpring;
uniform vec3 uPlayerPos;
uniform vec3 uVel;
uniform vec3 uLightPos;
uniform float uWindStrength;
uniform float uWindSpeed;
uniform float uWindMapScale;
uniform vec3 uAmbientColor;
uniform float uAltColorShift;

#!VARYINGS
varying vec2 vUv;
varying vec3 vColor;
varying float vRandom;
varying float vFalloff;
varying vec3 vPushDir;
varying vec3 vPos;
varying vec3 vVel;
varying vec3 vN;
varying float vWindSpeed;
varying vec3 vViewDir;
varying vec3 vLightDir;
varying vec3 vHalfDir;
varying float vSpec;
varying float vLighting;

#!SHADER: Vertex
void main() {
    vec3 pos = position;

    #ifdef INSTANCED
    pos = position;

    pos = transformPosition(pos, offset, scale * uScale - random.z * 0.1, orientation);

    float falloff = length(pos - uPlayerPos.xyz) * 0.45;

    falloff = clamp(falloff, 0.0, 1.0);
    falloff = 1.0 - falloff;
    falloff = pow(falloff, 2.0);

    pos = vec3(modelMatrix * vec4(pos, 1.0));
    vec3 n = vec3(0.0, 1.0 + random.w, max(0.0, random.z) * 0.25);

    // push away from user
    vec3 pushDir = normalize(pos - uPlayerPos);
    pos.xz += pushDir.xz * falloff * mix(1.0, position.y, 1.0) * 3.0;
    // pos.y -= (falloff);
    n.xz += pushDir.xz * falloff * 2.0;

    // push away from camera to hide ground
    vec3 cameraUpWorld = vec3(viewMatrix[0][1], viewMatrix[1][1], viewMatrix[2][1]);
    vec3 camPos = cameraPosition + cameraUpWorld;
    vec3 viewDir = normalize(camPos - pos.xyz);
    float bend = abs(dot(viewDir, vec3(0.0, -1.0, 0.0)));
    pos.xz += cameraUpWorld.xz * position.y * bend * uWindStrength * 0.5;

    // wind motion
    float t = time * 0.25 * uWindSpeed;
    vec2 vel = texture2D(tVel, pos.xz * 0.055 * uWindMapScale + vec2(t, t * 0.5)).rg;
    vel = vel * 2.0 - 1.0;
    pos.xz += vel * uWindStrength * position.y * (1.0 - falloff) * (1.0 - bend * 0.5);

    vRandom = max(0.0, random.w);

    #endif

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vColor = vdata;
    vFalloff = falloff;
    vPos = pos.xyz;
    vWindSpeed = pow(length(vel), 2.0);

    n.xz += vel * position.y * uWindStrength;
    n.x += position.x * 0.1;
    n = normalize(n);
    vN = n;

    // phong
    vLightDir = normalize(uLightPos - pos.xyz);
    vHalfDir = normalize(viewDir + vLightDir);
}

#!SHADER: Fragment
float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 applyHue(vec3 col, float hueAdjust)
{
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hueAdjust);
    return col * cosAngle + cross(k, col) * sin(hueAdjust) + k * dot(k, col) * (1.0 - cosAngle);
}

void main() {
    vec2 uv = vUv;

    vec2 screenUv = gl_FragCoord.xy / resolution.xy;
    float r = rand(screenUv + fract(time));
    vec3 data = texture2D(tMap, uv).rgb;
    float a = data.r;

    if (a - r * 0.5 < uThreshold - vRandom * 0.3) discard;
    if (vFalloff > 0.4) discard;

    float spec = max(0.0, dot(normalize(vN), normalize(vHalfDir)));
    spec = pow(spec, 1.5);
    float lighting = spec * 5.5;

    vec3 baseColor = texture2D(tBaseColor, uv).rgb;
    baseColor = mix(baseColor, applyHue(baseColor, uAltColorShift), vRandom);
    baseColor = pow(baseColor, vec3(2.2));

    vec3 color = vec3(0.0);
    float ao = vPos.y * data.g;
    color.rgb = (vec3(lighting * mix(1.0, ao, 0.75)) * baseColor.rgb + pow(uAmbientColor, vec3(2.2))) * ao;
    color.rgb = pow(color.rgb, vec3(0.45));

    gl_FragColor = vec4(color, 1.0);
    // gl_FragColor = vec4(ao);
}{@}StylizedGrassShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMatcap;
uniform sampler2D tBaseColor;
uniform sampler2D tVel;
uniform float uThreshold;
uniform float uScale;
uniform float uSpring;
uniform vec3 uPlayerPos;
uniform vec3 uVel;
uniform vec3 uLightPos;
uniform float uWindStrength;
uniform float uWindSpeed;
uniform float uWindMapScale;
uniform vec3 uAmbientColor;
uniform float uAltColorShift;

#!VARYINGS
varying vec2 vUv;
varying vec3 vColor;
varying float vRandom;
varying float vFalloff;
varying vec3 vPushDir;
varying vec3 vPos;
varying vec3 vVel;
varying vec3 vN;
varying float vWindSpeed;
varying vec3 vViewDir;
varying vec3 vLightDir;
varying vec3 vHalfDir;
varying float vSpec;
varying float vLighting;
varying vec3 vEye;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec3 n = vec3(0.0, 1.0, 0.0);
    float falloff = 0.0;
    vec2 vel = vec2(0.0);
    vec3 viewDir = vec3(0.0);

    #ifdef INSTANCED
    pos = position;

    // normal stored in scale
    n = scale;

    pos = transformPosition(pos, offset, uScale - random.z * 0.1, orientation);

    falloff = length(pos - uPlayerPos.xyz) * 0.45;

    falloff = clamp(falloff, 0.0, 1.0);
    falloff = 1.0 - falloff;
    falloff = pow(falloff, 2.0);

    pos = vec3(modelMatrix * vec4(pos, 1.0));
    // vec3 n = vec3(0.0, 1.0 + random.w, max(0.0, random.z) * 0.25);

    // push away from user
    vec3 pushDir = normalize(pos - uPlayerPos);
    // pos.xz += pushDir.xz * falloff * mix(1.0, position.y, 1.0) * 3.0;
    // pos.y -= (falloff);
    // n.xz += pushDir.xz * falloff * 2.0;

    // push away from camera to hide ground
    vec3 cameraUpWorld = vec3(viewMatrix[0][1], viewMatrix[1][1], viewMatrix[2][1]);
    vec3 camPos = cameraPosition + cameraUpWorld;
    viewDir = normalize(camPos - pos.xyz);
    float bend = abs(dot(viewDir, vec3(0.0, -1.0, 0.0)));
    pos.xz += cameraUpWorld.xz * position.y * bend * uWindStrength * 0.5;

    // wind motion
    float t = time * 0.25 * uWindSpeed;
    vel = texture2D(tVel, pos.xz * 0.055 * uWindMapScale + vec2(t, t * 0.5)).rg;
    vel = vel * 2.0 - 1.0;
    pos.xz += vel * uWindStrength * position.y * (1.0 - falloff) * (1.0 - bend * 0.5);

    vRandom = max(0.0, random.w);

    #endif

    vec4 modelViewPos = modelViewMatrix * vec4(pos, 1.0);
    gl_Position = projectionMatrix * modelViewPos;
    vUv = uv;
    vColor = vdata;
    vFalloff = falloff;
    vPos = position.xyz;
    vWindSpeed = pow(length(vel), 2.0);

    n.xz += vel * position.y * uWindStrength;
    n.x += position.x * 0.1;
 
    vN = normalMatrix * normalize(n);
    vEye = normalize(modelViewPos.xyz);

    // phong
    vLightDir = normalize(uLightPos - pos.xyz);
    vHalfDir = normalize(viewDir + vLightDir);
}

#!SHADER: Fragment
float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 applyHue(vec3 col, float hueAdjust)
{
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hueAdjust);
    return col * cosAngle + cross(k, col) * sin(hueAdjust) + k * dot(k, col) * (1.0 - cosAngle);
}

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    vec2 uv = vUv;

    vec2 screenUv = gl_FragCoord.xy / resolution.xy;
    float r = rand(screenUv + fract(time));
    vec3 data = texture2D(tMap, uv).rgb;
    float a = data.r;

    if (a - r * 0.5 < uThreshold - vRandom * 0.3) discard;
    if (vFalloff > 0.4) discard;

    float spec = max(0.0, dot(normalize(vN), normalize(vHalfDir)));
    spec = pow(spec, 3.5);
    float heightAo = pow(vPos.y * 2.0, 2.0);
    float lighting = spec * 2.0;

    vec3 baseColor = texture2D(tBaseColor, uv).rgb;
    baseColor = mix(baseColor, applyHue(baseColor, uAltColorShift), vRandom);
    baseColor = pow(baseColor, vec3(2.2));

    vec2 muv = matcap(normalize(vEye), vN);
    vec3 matcap = texture2D(tMatcap, muv).rgb;
    // matcap = pow(matcap, vec3(2.2));

    vec3 color = vec3(0.0);
    float ao = mix(heightAo, 1.0, 0.25) * data.g;
    color.rgb += baseColor.rgb;
    // color.rgb *= matcap;
    // color.rgb *= mix(1.0, ao, 0.75);
    color.rgb = (vec3(lighting * mix(1.0, ao, 0.75)) * baseColor.rgb + pow(uAmbientColor, vec3(2.2))) * ao;
    color.rgb = pow(color.rgb, vec3(0.45));

    gl_FragColor = vec4(color, 1.0);
    // gl_FragColor = vec4(matcap, 1.0);
    gl_FragColor.a = 1.0;
}{@}BgShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uColor;

#!VARYINGS

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

    #!SHADER: Fragment
void main() {
    gl_FragColor = vec4(uColor, 1.0);
}
{@}FloorShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMirrorReflection;
uniform mat4 uMirrorMatrix;
uniform float uMirrorRoughness;
uniform float uMirrorColorStrength;
uniform float uTexelSize;

#!VARYINGS
varying vec4 vMirrorCoord;

#!SHADER: Vertex
#require(fbr.vs)

void main() {
    setupFBR(position);

    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    vMirrorCoord = uMirrorMatrix * worldPos;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

    #!SHADER: Fragment
    #require(range.glsl)
    #require(fbr.fs)
    #require(radialblur.fs)

vec2 hash22(vec2 p)
{
    vec3 p3 = fract(vec3(p.xyx) * vec3(.1031, .1030, .0973));
    p3 += dot(p3, p3.yzx+33.33);
    return fract((p3.xx+p3.yz)*p3.zy);

}

void main() {
    vec3 color = getFBR(texture2D(tMap, vUv).rgb);

    vec3 mirrorColor = vec3(0.0);
//    vec3 normal = crange(texture2D(tNormal, vUv).xyz, vec3(0.0), vec3(1.0), vec3(-1.0), vec3(1.0));
    vec3 normal = vec3(0.0, 1.0, 0.0);
    vec3 mro = texture2D(tMRO, vUv).rgb;
    vec2 mirrorCoords = vMirrorCoord.xy / vMirrorCoord.w;
    mirrorCoords += normal.xy * uMirrorRoughness;


//    mirrorColor += texture2D(tMirrorReflection, mirrorCoords).rgb * uMirrorColorStrength * 1.0;
    mirrorColor += textureLod(tMirrorReflection, mirrorCoords, 3.0).rgb * uMirrorColorStrength * 1.0;
//    mirrorColor += radialBlur(tMirrorReflection, mirrorCoords,  5., vec2(1024.0), 5.);

    color += mirrorColor;
    gl_FragColor = vec4(color, smoothstep(0.0, 0.1, dot(color, color)));
}
{@}depthLayer.glsl{@}#!ATTRIBUTES

