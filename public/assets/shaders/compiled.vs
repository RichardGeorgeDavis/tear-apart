    // }

    // // slight hack to scale buildings up to correct size
    // if (temp > 0.0 && temp < radius) {
    //     float scaleMix = (1.0 - smoothstep(0.0, radius, temp));
    //     scaleMix = pow(scaleMix, 2.0);
    //     float maxScale = (1.0 / (2.0 / 3.14));
    //     worldPos.y *= mix(1.0, maxScale, scaleMix);
    // }

    // worldPos.z += distToTangent;

    // gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;
    vUv2 = uv2;

    // corner padding
    if (vUv.x < 0.1) {
        vUv.x -= 0.063 * uCornerPadding;
    } else {
        vUv.x += 0.063 * uCornerPadding;
    }

    vTileIndex = floor(fract(random.g + uRandomizeTiles) * uAtlasTiles);
    vAtlasTiles = floor(uAtlasTiles);
    vDarken = mix(1.0, mix(0.4, 1.0, random.x), uRandomDarken);
    vFog = clamp(-angle * 0.2, 0.0, 1.0);
}

#!SHADER: Fragment

vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}

void main() {
    float offset = vTileIndex;

    vec2 uv = vUv;
    uv = uv / vec2(1.0, vAtlasTiles);

    vec2 dx = dFdx(uv);
    vec2 dy = dFdy(uv);

    uv.y = mod(uv.y, 1.0 / vAtlasTiles) + offset / vAtlasTiles;
    uv.x = fract(uv.x);

    vec3 color = texture2DGrad(tMap, uv, dx, dy).rgb;

    color *= texture2D(tLightmap, vUv2).rgb * uLightmapIntensity;

    color = mix(color, vec3(100.0, 66.0, 61.0) / 255.0, vFog);

    color = czm_saturation(color, 1.5);
    // color = mix(color, vec3(1.0), vTest);
    // color += 0.2;

    gl_FragColor = vec4(color, 1.0);
}{@}LightProjectionShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform mat4 uTextureMatrix;
uniform sampler2D tMap;
uniform sampler2D tMap2;
uniform sampler2D tBounce;
uniform sampler2D tProjectionTexture;
uniform vec3 uCharacterOffset;
uniform vec3 uLightCameraPos;
uniform float uLightmapIntensity;

#!VARYINGS
varying vec2 vUv;
varying vec4 vProjectedUv;
varying vec2 vRtUv;
varying vec3 vWorldPos;
varying vec3 vNormal;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vWorldPos = (modelMatrix * vec4(position, 1.0)).xyz;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;

    vec4 color = texture2D(tMap, uv);
    mat4 textureMatrix = uTextureMatrix;

    vProjectedUv = uTextureMatrix * modelMatrix * vec4(position - uCharacterOffset, 1.0);
    vProjectedUv += 0.5;

    vRtUv = texture2D(tMap, vProjectedUv.xy).rg;

    vNormal = normal;
    vPos = vWorldPos.xyz;
}

#!SHADER: Fragment

const float fixed_scale = 4.0;

vec4 encode_fixed(vec2 v) {
  vec2 scaled = 0.5 + v/fixed_scale;
  vec2 big = scaled * 65535.0/256.0;
  vec2 high = floor(big) / 255.0;
  vec2 low = fract(big);

  return vec4(low.x,high.x,low.y,high.y);
}

vec2 decode_fixed(vec4 v) {
  v = floor(v * 255.0 + 0.5);
  vec2 scaled = vec2(v.yw * 256.0 + v.xz) / 65535.0;
  return (scaled - 0.5) * fixed_scale;
}

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 15.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

void main() {
    vec3 normal = normalize(vNormal);
    vec3 lightDir = normalize(uLightCameraPos - vWorldPos);
    float directional = dot(normal, normalize(uLightCameraPos - vWorldPos));
    float ambient = 0.2;

    vec3 halfVec = normalize(-lightDir + vec3(0.0, -1.0, 0.0) * 0.5);
    float bounceMask = dot(normal, halfVec) * 0.5 + 0.5;
    bounceMask *= pow(max(smoothstep(14.0, 0.0, vPos.y), 0.0), 4.0); // height attenuation
    bounceMask *= 0.5;

    float lightMask = clamp(directional, 0.0, 1.0);


    // light += ambient;


    bool inRange = 
    vProjectedUv.x >= 0.0 &&
    vProjectedUv.x <= 1.0 &&
    vProjectedUv.y >= 0.0 &&
    vProjectedUv.y <= 1.0;

    bool border = 
    vProjectedUv.x >= -0.01 &&
    vProjectedUv.x <= 1.01 &&
    vProjectedUv.y >= -0.01 &&
    vProjectedUv.y <= 1.01;

    float projectedAmount = inRange ? 1.0 : 0.0;
    float borderAmount = border ? 1.0 : 0.0;

    vec4 encodedUv = texture2D(tMap, vProjectedUv.xy);

    vec3 baseColor = vec3(0.3);
    
    vec3 lightmap = texture2D(tMap, vProjectedUv.xy).xyz;
    vec3 bounce = texture2D(tBounce, vProjectedUv.xy).xyz;

    lightmap = pow(lightmap, vec3(2.2)) * uLightmapIntensity;
    bounce = pow(bounce, vec3(2.2));

    vec3 color = lightmap * lightMask + bounce * bounceMask;
    color += vec3(133.0, 119.0, 122.0) / 255.0 * 0.01 * max(dot(normal, vec3(0.0, 1.0, 0.0)) * 0.5 + 0.8, 0.0);
    color = uncharted2(color);
    color = pow(color, vec3(0.4545));

    // vec3 color = texture2D(tMap, vUv).rgb;
    // color = vec3(vUv, 0.0);
    // vec3 projectedColor = lightmap;
    // color = mix(vec3(0.0), projectedColor, projectedAmount) * (1.0 - (borderAmount - projectedAmount));
    // gl_FragColor = vec4(color, 1.0);
    gl_FragColor = vec4(color, 1.0);
}{@}UvRenderShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec3 uCharacterOffset;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position - uCharacterOffset, 1.0);
    vUv = uv;
}

#!SHADER: Fragment

const float fixed_scale = 4.0;

vec4 encode_fixed(vec2 v) {
  vec2 scaled = 0.5 + v/fixed_scale;
  vec2 big = scaled * 65535.0/256.0;
  vec2 high = floor(big) / 255.0;
  vec2 low = fract(big);

  return vec4(low.x,high.x,low.y,high.y);
}

vec2 decode_fixed(vec4 v) {
  v = floor(v * 255.0 + 0.5);
  vec2 scaled = vec2(v.yw * 256.0 + v.xz) / 65535.0;
  return (scaled - 0.5) * fixed_scale;
}

void main() {
    vec3 color = texture2D(tMap, vUv).xyz;
    gl_FragColor = vec4(color, 1.0);
}{@}ManorShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tSky;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vEye;
varying float vWindowMask;

#!SHADER: Vertex
void main() {
    vec3 worldPos = (modelMatrix * vec4(position, 1.0)).xyz;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vEye = worldPos - cameraPosition;
    vNormal = normal;
    vWindowMask = vdata.r;
}

#!SHADER: Fragment
void main() {
    vec2 screenUv = gl_FragCoord.xy / resolution;

    vec3 R = reflect(normalize(vEye), normalize(vNormal));
    vec3 color = texture2D(tMap, vUv).rgb;

    vec2 specUv = R.xy * vec2(2.0, 2.0) + vec2(0.5, 0.2);
    specUv -= 0.5;
    specUv *= 0.5;
    specUv += 0.5;
    vec3 spec = texture2D(tSky, specUv).rgb;
    color *= mix(1.0, 0.0, vWindowMask * 0.2);
    color += pow(spec, vec3(4.0)) * vWindowMask * 0.35;
    gl_FragColor = vec4(color, 1.0);
}{@}ManorSkyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tFlow;
uniform vec3 uCloudsColor;
uniform vec2 uShift;
uniform vec2 uScale;

uniform vec4 uParams;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vWorldPos;
varying float vSunGradient;
varying vec3 vColor;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vPos = position;
    vSunGradient = position.y * 0.5 - position.x - position.z * 1.2;
    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    vWorldPos = worldPos.xyz;
    gl_Position = projectionMatrix * viewMatrix * worldPos;
    vUv = uv;

}

#!SHADER: Fragment
#require(rotation.glsl)
#require(range.glsl)
#require(simplenoise.glsl)

vec3 getFlow(sampler2D tMap, sampler2D tFlow, vec2 uv, float speed, float strength, float time, float tile, float multiplier) {
    float t = time * speed;
    float mask = fract(t);
    mask = (mask- 0.5) * 2.0;
    mask = abs(mask);
    
    vec2 flow = texture2D(tFlow, uv * tile).rg;
    flow = flow * 2.0 - 1.0;
    flow *= multiplier;

    vec3 color = texture2D(tMap, uv + flow * strength * fract(t + 0.5)).rgb;
    vec3 color2 = texture2D(tMap, uv + flow * strength * fract(t + 0.0)).rgb; 
    color = mix(color2, color, mask);
    return color;
}

void main() {
    vec2 uv = vec2(0.0, vSunGradient);
    uv.y -= 0.5;
    uv.y *= uParams.x;
    uv.y += 0.5;
    uv = rotationMatrix(sin(time) * 0.75) * uv;

    float noise = cnoise(vWorldPos * 0.003 - time * 0.1);

    vec2 cloudsUv = uScale * vUv + vec2(uShift.x, uShift.y);
    cloudsUv.y *= 2.0;
    vec3 clouds = getFlow(tMap, tFlow, cloudsUv, uParams.y, uParams.z, time, uParams.w, smoothstep(0.5, 0.52, vUv.y)).rgb;
    clouds *= step(0.5, vUv.y);
    clouds *= 1.01;
    
    gl_FragColor = vec4(clouds, 1.0);
}{@}ShrubShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uThreshold;
uniform float uDistortion;

#!VARYINGS
varying vec2 vUv;
varying vec3 vWorldPos;

#!SHADER: Vertex
void main() {
    vec3 worldPos = (modelMatrix * vec4(position, 1.0)).xyz;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vWorldPos = worldPos;
}

#!SHADER: Fragment
void main() {
    vec4 distortion = texture2D(tMap, vUv);
    vec2 distort = vec2(sin(distortion.g * 6.0 + vUv.y * 2.0 + vUv.x + time * 1.5 + vWorldPos.x * 0.25));
    vec4 color = texture2D(tMap, vUv + distort * 0.005 * uDistortion);
    float alpha = color.a;
    color.rgb += color.rgb * (1.0 - alpha) * 2.0;

    gl_FragColor = vec4(color.rgb, alpha);
}{@}MegaParticlesShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform float dataY;
uniform sampler2D uPositions;
uniform sampler2D uColors;
uniform float totalParticlesPerVoxel;

#!VARYINGS
varying vec4 vColor;

#!SHADER: Vertex

void main() {

    float dataX = mod(float(gl_VertexID), totalParticlesPerVoxel) / totalParticlesPerVoxel;
    vec2 texIndex = vec2(dataX, dataY);
    vec3 pos = position;

    vec3 texturePosition = texture(uPositions, texIndex).rgb;
    vec4 textureColor = texture(uColors, texIndex);
    float dist = length(cameraPosition - texturePosition) / 3.;
    gl_PointSize = min(max(dist * 0.2, 2.), 5.);

    vColor = textureColor;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(texturePosition, 1.);

    //vColor = vec4(1., 1., 1., 1.);
    //gl_Position = vec4( , dataY, 0., 1.);
}

#!SHADER: Fragment

void main() {

    gl_FragColor = vColor;

}
{@}SarlacBodyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;
    pos.z += 1.0;
    pos = vec3(rotationMatrix(vec3(1.0, 0.0, 0.0), sin(time + pos.y * 1.25) * 0.05) * vec4(pos, 1.0));
    pos = vec3(rotationMatrix(vec3(0.0, 1.0, 0.0), cos(time * 0.5+ pos.y * 1.25) * 0.05) * vec4(pos, 1.0));
    pos.z -= 1.0;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec4 color = texture2D(tMap, vUv);
    color.rgb /= color.a;
    gl_FragColor = vec4(color);
}{@}SarlacLeftHandShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;
    pos.z += 1.0;
    pos = vec3(rotationMatrix(vec3(1.0, 0.0, 0.0), sin(time + pos.y * 0.5 - 0.5 + 1.0) * 0.03) * vec4(pos, 1.0));
    pos.z -= 1.0;

    pos.x += 0.5;
    pos.z += 0.25;
    pos = vec3(rotationMatrix(vec3(0.0, 1.0, 0.0), cos(time + pos.z * 3.5 + 0.05) * 0.1) * vec4(pos, 1.0));
    pos.x -= 0.5;
    pos.z -= 0.25;


    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vPos = pos;
}

#!SHADER: Fragment
void main() {
    vec4 color = texture2D(tMap, vUv);

    color.rgb /= color.a;
    color.a *= clamp(1.0 - -vPos.z * 3.0 + 1.5, 0.0, 1.0);
    gl_FragColor = vec4(color);
}{@}SarlacParticleShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;

#!VARYINGS
varying vec3 vColor;
varying vec3 vVel;
varying vec3 vNormal;
varying vec3 vMvPos;
varying vec3 vPos;
varying float vRandom;
varying float vSpeed;
varying float vShadow;

#!SHADER: Vertex

void main() {
    vec4 decodedPos = texture2D(tPos, position.xy);
    vec4 decodedPrevPos = texture2D(tPrevPos, position.xy);
    vec3 vel = decodedPos.xyz - decodedPrevPos.xyz;
    vSpeed = length(vel) * 250.0;
    vSpeed = clamp(vSpeed, 0.0, 1.0);
    vSpeed = vSpeed * vSpeed;
    vVel = vel * 150.0;
    
    vec3 pos = decodedPos.xyz;
    float scale = mix(0.3, 0.5, random.x) * 0.5;

    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = scale * 0.1 * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;

    vPos = pos;
}

#!SHADER: Fragment

void main() {
    vec2 uv = gl_PointCoord.xy;

    float a = 1.0 - length(uv - 0.5);
    if (a < 0.75) discard;
    a = 1.0 - length(uv - vec2(0.5, 0.35));
    a = a * a * a;

    float falloff = clamp(1.0 - length(vPos) * 2.0, 0.0, 1.0);
    a *= falloff;
    a *= 0.5;
    a += pow(falloff, 5.0) * a * 15.0;

    // vec3 lightDir   = normalize(vec3(0.2, 1.0, 0.2));
    // vec3 viewDir    = normalize(-vMvPos.xyz);
    // vec3 halfwayDir = normalize(lightDir + viewDir);
    // float spec = pow(max(dot(vNormal, halfwayDir), 0.0), (42.0 - vRandom * 15.0) * a);

    // float diffuseContribution = vColor.r;
    // float specContribution = 1.0 - diffuseContribution;

    // vec3 color = mix(vec3(1.0), vec3(0.8, 0.05, 0.18) * 2.5, clamp(vSpeed, 0.0, 1.0)) * vec3(diffuseContribution + specContribution * spec) * a * vShadow;
    gl_FragColor = vec4(vec3(1.0, 1.0, 0.5), a);
}{@}SarlacRightHandShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;
    pos.z += 1.0;
    pos = vec3(rotationMatrix(vec3(1.0, 0.0, 0.0), sin(time + pos.y * 0.5 - 0.5) * 0.02) * vec4(pos, 1.0));
    // pos = vec3(rotationMatrix(vec3(0.0, 1.0, 0.0), cos(time * 0.5+ pos.y * 0.5) * 0.05) * vec4(pos, 1.0));
    pos.z -= 1.0;

    pos.x += 0.5;
    pos.z += 0.25;
    pos = vec3(rotationMatrix(vec3(0.0, 1.0, 0.0), cos(time + pos.y * 0.5) * 0.1) * vec4(pos, 1.0));
    pos.x -= 0.5;
    pos.z -= 0.25;


    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec4 color = texture2D(tMap, vUv);
    color.rgb /= color.a;
    gl_FragColor = vec4(color);
    gl_FragColor.a = color.a;
}{@}MilkPathShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tNoise;
uniform sampler2D tCaustics;
uniform vec2 uTiling;
uniform float uSpeed;
uniform float uDisplacement;
uniform vec3 uShadowColor;

#!VARYINGS
varying float vDisplacement;
varying vec2 vUv;
varying vec2 vUv2;
varying vec2 vUv2Original;
varying vec3 vEye;
varying vec3 vNormal;

#!SHADER: Vertex
void main() {
    float t = time * uSpeed;
    vec3 pos = position;
    vUv2Original = uv2;
    vUv2 = uv * uTiling + vec2(t, t * 0.1);

    vec3 displacement = texture2D(tNoise, vUv2).rgb;
    // vDisplacement = displacement * 2.0 - 1.0;
    vDisplacement = displacement.r;
    vDisplacement = mix(vDisplacement, 0.0, 1.0 - smoothstep(0.0, 0.1, uv2.x));
    vDisplacement = mix(vDisplacement, 0.0, smoothstep(0.9, 1.0, uv2.x));

    pos += vDisplacement * normal * uDisplacement;
    vec3 n = normal;
    // n.xy += displacement.gb * 0.4;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vNormal = normalMatrix * n;
    vEye = vec3(modelViewMatrix * vec4(pos, 1.0));
}

#!SHADER: Fragment
vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    vec2 muv = matcap(normalize(vEye), normalize(vNormal));
    vec3 color = texture2D(tMatcap, muv).rgb;
    float displacement = 1.0 - pow(1.0 - texture2D(tNoise, vUv2).r, 3.0);
    displacement = mix(displacement, 1.0, 1.0 - smoothstep(0.0, 0.2, vUv2Original.x));
    displacement = mix(displacement, 1.0, smoothstep(0.8, 1.0, vUv2Original.x));

    gl_FragColor = vec4(color * mix(uShadowColor, vec3(1.0), displacement), 1.0);
}{@}InflateObjectShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec3 pivot;
attribute vec3 rand;
attribute vec2 uv2;
attribute float ramp;

#!UNIFORMS
uniform sampler2D tAo;
uniform sampler2D tNormal;
uniform sampler2D tTilingNormal;
uniform sampler2D tDisplacement;
uniform sampler2D tHeight;
uniform float uCutoff;
uniform float uOff;
uniform float uFlip;
uniform float uProgress;
uniform float uIsHovered;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vPivot;
varying vec3 vDisplacement;
varying vec3 vPos;
varying vec3 vEye;
varying vec3 vColor;
varying vec3 vMvPos;
varying vec3 vNormal;
varying vec2 vSt;
varying float vEdge;
varying float vTransition;
varying float vIndex;
varying float vRamp;

#!SHADER: Vertex
#require(range.glsl)

vec3 getInterpolatedSprite(sampler2D tSpritesheet, vec2 uv, float width, float height, float index) {
    
    // padding
    vec2 tc = uv;
    tc -= 0.5;
    tc *= 0.997;
    tc += 0.5;

    float t = index * width;
    float tnextx = mod(t + (1.0 / width), 1.0);
    float tnexty = mod(t + (1.0 / width), 8.0);

    vec2 frameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(t) * width);
    vec2 nextFrameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(tnextx) * width);

    vec2 frameOffsetY = vec2(0.0, 1.0 / height) * floor(fract(t / height) * height);
    vec2 nextFrameOffsetY = vec2(0.0, 1.0 / height) * floor(fract((tnexty) / height) * height);

    vec2 frameuv = (vec2(tc.x / width, tc.y / height) + frameOffsetX - frameOffsetY);
    vec2 nextframeuv = (vec2(tc.x / width, tc.y / height) + nextFrameOffsetX - nextFrameOffsetY);

    vec3 frame = texture2D(tSpritesheet, frameuv).rgb;
    vec3 nextFrame = texture2D(tSpritesheet, nextframeuv).rgb;

    frame = mix(frame, nextFrame, fract(t * width));

    return frame;
}

float random(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

mat2 rotate(float angle) {
    float s = sin(angle);
    float c = cos(angle);
    return mat2(c, -s, s, c);
}

void main() {
    vPivot = pivot;

    float t = fract(time * 0.2 - length(vdata) * 0.1);
    t += 0.01;
    vIndex = t;
    
    float width = 8.0;
    float height = 8.0;

    vec3 n = normal;

    vec3 displacement = getInterpolatedSprite(tDisplacement, uv, width, height, fract(t + 0.5));
    displacement = displacement * 2.0 - 1.0;

    // displacement = vec3(0.0, ramp * 2.0, 0.0);

    float edge = 1.0;

    edge *= smoothstep(0.0, 0.05, uv.x);
    edge *= smoothstep(1.0, 0.95, uv.x);
    edge *= smoothstep(0.0, 0.05, uv.y);
    edge *= smoothstep(1.0, 0.95, uv.y);

    displacement *= edge;

    vEdge = edge;


    // idle animation
    // displacement += displacement * uBounce * 0.1;

    // flip z for houdini
    displacement *= vec3(1.0, 1.0, -1.0);

    // invert displacement for back side
    // displacement = mix(displacement * vec3(1.0, -1.0, 1.0), displacement, mix(vdata.x, 1.0, uFlip));

    // invert normal for back side
    // n = mix(n * vec3(1.0, -1.0, 1.0), n, mix(vdata.x, 1.0, uFlip));

    // reduce displacement on hover
    // displacement *= mix(0.0, 1.0, uIsHovered);
    vec3 pos = position;

    pos += displacement.y * normal * 1.5;

    float angle = sin(time - pos.y * 0.05 + pos.z * 0.023 + pos.x * 0.03) * 0.017;
    angle += cos(time * 0.613 - pos.y * 0.0414 + pos.x * 0.017) * 0.017;
    pos.xz -= pivot.xz;
    pos.xy = rotate(angle) * pos.xy;
    pos.xz += pivot.xz;



    // n -= displacement * 0.5;
    // n = normalize(n);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vDisplacement = displacement;
    vPos = pos;
    vColor = vdata;
    vMvPos = normalize(vec3(modelMatrix * vec4(pos, 1.0)) - cameraPosition);
    vNormal = normalize(vec3(pos.x - pivot.x, 0.0, pos.z - pivot.z));
    vEye = -vMvPos.xyz;
    vRamp = ramp;
    vUv2 = uv2;
}

#!SHADER: Fragment

vec3 unpackNormalCustom( vec3 eye_pos, vec3 surf_norm, vec3 sampled_norm, float intensity, float scale, vec2 uv ) {
    vec3 q0 = dFdx( eye_pos.xyz );
    vec3 q1 = dFdy( eye_pos.xyz );
    vec2 st0 = dFdx( uv.st );
    vec2 st1 = dFdy( uv.st );
    
    vec3 S = normalize( q0 * st1.t - q1 * st0.t );
    vec3 T = normalize( -q0 * st1.s + q1 * st0.s );
    vec3 N = normalize( surf_norm );
    
    vec3 mapN = sampled_norm;
    mapN.xy *= intensity;
    mat3 tsn = mat3( S, T, N );
    return normalize( tsn * mapN );
}

vec3 getInterpolatedSprite(sampler2D tSpritesheet, vec2 uv, float width, float height, float index) {
    
    // padding
    vec2 tc = uv;
    tc -= 0.5;
    tc *= 0.997;
    tc += 0.5;

    float t = index * width;
    float tnextx = mod(t + (1.0 / width), 1.0);
    float tnexty = mod(t + (1.0 / width), 8.0);

    vec2 frameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(t) * width);
    vec2 nextFrameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(tnextx) * width);

    vec2 frameOffsetY = vec2(0.0, 1.0 / height) * floor(fract(t / height) * height);
    vec2 nextFrameOffsetY = vec2(0.0, 1.0 / height) * floor(fract((tnexty) / height) * height);

    vec2 frameuv = (vec2(tc.x / width, tc.y / height) + frameOffsetX - frameOffsetY);
    vec2 nextframeuv = (vec2(tc.x / width, tc.y / height) + nextFrameOffsetX - nextFrameOffsetY);

    vec3 frame = texture2D(tSpritesheet, frameuv).rgb;
    vec3 nextFrame = texture2D(tSpritesheet, nextframeuv).rgb;

    frame = mix(frame, nextFrame, fract(t * width));

    return frame;
}

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {

    float width = 8.0;
    float height = 8.0;

    vec3 normal = getInterpolatedSprite(tNormal, vUv, width, height, vIndex);

    // normal = normalize(normal);
    normal = normalize(normal + vNormal * mix(0.2, 0.8, 1.0 - vDisplacement.y));

    vec2 st = vSt;

    float lighting = dot(normal, normalize(vec3(8.0, 4.0, 1.0)));
    vec3 color = vec3(pow(lighting * 0.5 + 0.5, 1.0) + pow(clamp(-lighting, 0.0, 1.0), 2.0) * 0.2);
    color *= 0.7;
    color += pow(max(0.0, lighting), 8.0) * 0.5;
    color *= mix(1.0, 1.0 - pow(1.0 - vDisplacement.y, 2.0), 0.4);
    color *= 1.0 - clamp(pow(length(vPos), 2.0) * 0.00008, 0.0, 1.0);

    float ao = texture2D(tAo, vUv2).r;
    color *= ao;

    gl_FragColor = vec4(color, 1.0);
}{@}InflateShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;
attribute vec3 rand;
attribute float ramp;

#!UNIFORMS
uniform sampler2D tAo;
uniform sampler2D tNormal;
uniform sampler2D tTilingNormal;
uniform sampler2D tDisplacement;
uniform sampler2D tHeight;
uniform float uCutoff;
uniform float uOff;
uniform float uFlip;
uniform float uProgress;
uniform float uIsHovered;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vDisplacement;
varying vec3 vPos;
varying vec3 vEye;
varying vec3 vColor;
varying vec3 vMvPos;
varying vec3 vNormal;
varying vec2 vSt;
varying float vEdge;
varying float vTransition;
varying float vIndex;
varying float vRamp;

#!SHADER: Vertex
#require(range.glsl)

vec3 getInterpolatedSprite(sampler2D tSpritesheet, vec2 uv, float width, float height, float index) {
    
    // padding
    vec2 tc = uv;
    tc -= 0.5;
    tc *= 0.85;
    tc += 0.5;

    float t = index * width;
    float tnextx = mod(t + (1.0 / width), 1.0);
    float tnexty = mod(t + (1.0 / width), 8.0);

    vec2 frameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(t) * width);
    vec2 nextFrameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(tnextx) * width);

    vec2 frameOffsetY = vec2(0.0, 1.0 / height) * floor(fract(t / height) * height);
    vec2 nextFrameOffsetY = vec2(0.0, 1.0 / height) * floor(fract((tnexty) / height) * height);

    vec2 frameuv = (vec2(tc.x / width, tc.y / height) + frameOffsetX - frameOffsetY);
    vec2 nextframeuv = (vec2(tc.x / width, tc.y / height) + nextFrameOffsetX - nextFrameOffsetY);

    vec3 frame = texture2D(tSpritesheet, frameuv).rgb;
    vec3 nextFrame = texture2D(tSpritesheet, nextframeuv).rgb;

    frame = mix(frame, nextFrame, fract(t * width));

    return frame;
}

float random(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    float t = fract(time * 0.2 - length(vdata) * 0.01);
    t += 0.01;
    vIndex = t;
    
    float width = 8.0;
    float height = 8.0;

    vec3 n = normal;

    vec3 displacement = getInterpolatedSprite(tDisplacement, uv, width, height, fract(t + 0.5));
    displacement = displacement * 2.0 - 1.0;

    // displacement = vec3(0.0, ramp * 2.0, 0.0);

    float edge = 1.0;

    edge *= smoothstep(0.0, 0.05, uv.x);
    edge *= smoothstep(1.0, 0.95, uv.x);
    edge *= smoothstep(0.0, 0.05, uv.y);
    edge *= smoothstep(1.0, 0.95, uv.y);

    displacement *= edge;

    vEdge = edge;


    // idle animation
    // displacement += displacement * uBounce * 0.1;

    // flip z for houdini
    displacement *= vec3(1.0, 1.0, -1.0);

    // invert displacement for back side
    // displacement = mix(displacement * vec3(1.0, -1.0, 1.0), displacement, mix(vdata.x, 1.0, uFlip));

    // invert normal for back side
    // n = mix(n * vec3(1.0, -1.0, 1.0), n, mix(vdata.x, 1.0, uFlip));

    // reduce displacement on hover
    // displacement *= mix(0.0, 1.0, uIsHovered);
    vec3 pos = position;

    vec2 st = pos.xz;
    st += time * 9.0;
    st *= 0.002;
    vSt = st;
    float eps = 0.002;
    float x = texture2D(tHeight, st - vec2(eps, 0.0)).r - texture2D(tHeight, st + vec2(eps, 0.0)).r;
    float y = texture2D(tHeight, st - vec2(0.0, eps)).r - texture2D(tHeight, st + vec2(0.0, eps)).r;
    vec3 data = texture2D(tHeight, st).rgb;
    float z = data.r;
    vec3 calculatedNormal = vec3(x, z * 0.1, y);
    calculatedNormal = normalize(calculatedNormal);
    float heightMap = (data.r * 2.0 - 1.0) * 17.0;

    pos.y += heightMap * 0.1;

    pos += displacement.y * calculatedNormal * 1.5;



    // n -= displacement * 0.5;
    // n = normalize(n);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vUv2 = uv2;
    vDisplacement = displacement;
    vPos = pos;
    vColor = vdata;
    vMvPos = normalize(vec3(modelMatrix * vec4(pos, 1.0)) - cameraPosition);
    vNormal = calculatedNormal;
    vEye = -vMvPos.xyz;
    vRamp = ramp;
}

#!SHADER: Fragment

vec3 unpackNormalCustom( vec3 eye_pos, vec3 surf_norm, vec3 sampled_norm, float intensity, float scale, vec2 uv ) {
    vec3 q0 = dFdx( eye_pos.xyz );
    vec3 q1 = dFdy( eye_pos.xyz );
    vec2 st0 = dFdx( uv.st );
    vec2 st1 = dFdy( uv.st );
    
    vec3 S = normalize( q0 * st1.t - q1 * st0.t );
    vec3 T = normalize( -q0 * st1.s + q1 * st0.s );
    vec3 N = normalize( surf_norm );
    
    vec3 mapN = sampled_norm;
    mapN.xy *= intensity;
    mat3 tsn = mat3( S, T, N );
    return normalize( tsn * mapN );
}

vec3 getInterpolatedSprite(sampler2D tSpritesheet, vec2 uv, float width, float height, float index) {
    
    float t = index * width;
    float tnextx = mod(t + (1.0 / width), 1.0);
    float tnexty = mod(t + (1.0 / width), 8.0);

    vec2 frameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(t) * width);
    vec2 nextFrameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(tnextx) * width);

    vec2 frameOffsetY = vec2(0.0, 1.0 / height) * floor(fract(t / height) * height);
    vec2 nextFrameOffsetY = vec2(0.0, 1.0 / height) * floor(fract((tnexty) / height) * height);

    vec3 frame = texture2D(tSpritesheet, vec2(uv.x / width, uv.y / height) + frameOffsetX - frameOffsetY).rgb;
    vec3 nextFrame = texture2D(tSpritesheet, vec2(uv.x / width, uv.y / height) + nextFrameOffsetX - nextFrameOffsetY).rgb;

    frame = mix(frame, nextFrame, fract(t * width));

    return frame;
}

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {

    float width = 8.0;
    float height = 8.0;

    vec3 normal = getInterpolatedSprite(tNormal, vUv, width, height, vIndex);

    // normal = normalize(normal + vNormal * 0.6);
    normal = normalize(normal + vNormal * mix(0.2, 0.8, 1.0 - vDisplacement.y));

    vec2 st = vSt;
    float heightmap = texture2D(tHeight, st).r;

    float lighting = dot(normal, normalize(vec3(8.0, 4.0, 1.0)));
    vec3 color = vec3(pow(lighting * 0.5 + 0.5, 1.0) + pow(clamp(-lighting, 0.0, 1.0), 2.0) * 0.2);
    color *= 0.6;
    color += pow(max(0.0, lighting), 8.0);
    color *= mix(1.0, 1.0 - pow(1.0 - vDisplacement.y, 2.0), 0.4);
    color *= clamp(heightmap * 2.0 + 0.1, 0.0, 1.0);
    color *= 1.0 - clamp(pow(length(vPos), 2.0) * 0.00008, 0.0, 1.0);

    float ao = texture2D(tAo, vUv2).r;
    color *= ao;


    // color = vec3(vRamp);

    // color = normalize(vNormal + normal);

    gl_FragColor = vec4(color, 1.0);
