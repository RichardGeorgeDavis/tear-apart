#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tDither;
uniform vec3 uCenterPos;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec2 vSt;

#!SHADER: Vertex
#require(rotation.glsl)
void main() {
    float maxDist = 1.5;
    vec3 center = position - uCenterPos;
    float sphereFalloff = clamp(1.0 - length(center) / maxDist, 0.0, 1.0);
    float stFalloff = clamp(1.0 - length(center) / 5.0, 0.0, 1.0);

    vec3 pos = position;
    vec3 cylindricalPos = pos;

    vec3 displacement = texture2D(tMap, pos.xz * 0.2 + time * 0.1).rgb;
    displacement += texture2D(tMap, pos.xz * 0.1 - time * 0.1).rgb;
    displacement = normalize(displacement);
    displacement = displacement * 2.0 - 1.0;
    pos += sphereFalloff * (normal * 0.2 + displacement * 3.0);

    vec3 target = vec3(0.0, 1.0, 0.0);
    vec3 dir = normalize(uCenterPos);
    float angleUpDown = dot(dir, vec3(0.0, 1.0, 0.0)) * (3.14 / 2.0);
    float angleLeftRight = atan(dir.x, dir.z);

    cylindricalPos = vec3(rotationMatrix(vec3(1.0, 0.0, 0.0), 3.14 / 2.0) * vec4(cylindricalPos, 1.0));

    cylindricalPos.yz = rotationMatrix(angleUpDown) * cylindricalPos.yz;
    cylindricalPos.xz = rotationMatrix(-angleLeftRight) * cylindricalPos.xz;

    // dir.x = -dir.x;
    // dir.z = -dir.z;
    // float angleUpDown = acos(dot(dir, vec3(0.0, 1.0, 0.0)) * (3.14 / 2.0));
    // float angleLeftRight = atan(dir.x, dir.z);

    // pos = vec3(rotationMatrix(vec3(0.0, 1.0, 0.0), 3.14 / 2.0) * vec4(pos, 1.0));
    // pos.yz = rotationMatrix(-angleUpDown) * pos.yz;
    // pos.xz = rotationMatrix(-angleLeftRight) * pos.xz;

    // float angle = acos(dot(normalize(center), vec3(0.0, 1.0, 0.0)));
    // vec3 axis = cross(vec3(0.0, 1.0, 0.0), normalize(center));
    // vec3 transformedCenter = (rotationMatrix(axis, -angle) * vec4(normalize(center), 1.0)).xyz;
    // pos = (rotationMatrix(axis, angle) * vec4(pos, 1.0)).xyz;
    // vec2 st = vec2(atan(transformedCenter.x, transformedCenter.z) / (3.14159 * 2.0), stFalloff * 10.0);
    // vec2 st = vec2(sphereFalloff);
    vec2 st = vec2(atan(cylindricalPos.x, cylindricalPos.z) / (3.14 * 2.0), stFalloff);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vPos = position;
    vSt = st;
}

#!SHADER: Fragment

float noise(vec2 st) {
    return fract(sin(dot(st, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    float maxDist = 1.3;
    float sphereFalloff = clamp(1.0 - length(vPos - uCenterPos) / maxDist, 0.0, 1.0);
    float sphereFalloffEdge = clamp(1.0 - length(vPos - uCenterPos) / (maxDist + 0.3), 0.0, 1.0);

    float dither = texture2D(tDither, vSt + vec2(0.0, -time * 0.1)).r;
    float d = dither * (1.0 - pow(1.0 - sphereFalloff, 2.0));
    if (d > 0.05) discard;


    float ambient = 0.4;
    // vec3 color = vec3(smoothstep(0.3, 0.4, sphereFalloff + dither * 0.3));
    vec3 color = vec3(max(0.1, sphereFalloff));
    color = vec3(max(0.1, vSt.y));

    gl_FragColor = vec4(color, 1.0);
}{@}DJAuraShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tPost;
uniform sampler2D tScreen;

// uniform sampler2D tex;
// uniform float texWidth;
// uniform float texHeight;

uniform vec3 uKeyColor;
uniform float uSimilarity;
uniform float uSmoothness;
uniform float uSpill;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment

// From https://github.com/libretro/glsl-shaders/blob/master/nnedi3/shaders/rgb-to-yuv.glsl
vec2 RGBtoUV(vec3 rgb) {
  return vec2(
    rgb.r * -0.169 + rgb.g * -0.331 + rgb.b *  0.5    + 0.5,
    rgb.r *  0.5   + rgb.g * -0.419 + rgb.b * -0.081  + 0.5
  );
}

// From https://jameshfisher.com/2020/08/11/production-ready-green-screen-in-the-browser/
vec4 getChromaKey(vec2 texCoord) {
  vec4 rgba = texture2D(tMap, texCoord);
  float chromaDist = distance(RGBtoUV(texture2D(tMap, texCoord).rgb), RGBtoUV(uKeyColor));

  float baseMask = chromaDist - uSimilarity;
  float fullMask = pow(clamp(baseMask / uSmoothness, 0., 1.), 1.5);
  rgba.a = fullMask;

  float spillVal = pow(clamp(baseMask / uSpill, 0., 1.), 1.5);
  float desat = clamp(rgba.r * 0.2126 + rgba.g * 0.7152 + rgba.b * 0.0722, 0., 1.);
  rgba.rgb = mix(vec3(desat, desat, desat), rgba.rgb, uSpill);

  return rgba;
}

#require(gaussianblur.fs)
#require(rgb2hsv.fs)

void main() {
    float x = sin(time*4.0) * 2.5;
    float y = cos(time*4.0) * 2.5;

    // vec4 color = getChromaKey(vUv);
    // color = blur5(tMap, vUv, vec2(256.0), vec2(x,y));
    vec4 post = texture2D(tPost, vUv);

    vec4 screenColor = texture2D(tScreen, (vUv - 0.5) * 0.3);

    vec3 minBright = rgb2hsv(screenColor.rgb);
    minBright.z = max(0.3, minBright.z);
    screenColor.rgb = hsv2rgb(minBright);

    // vec4 color = post;

    // float light = sin(time * 18.0) * 0.5 + 0.5;
    // float lightHalf = sin(time * 36.0) * 0.5 + 0.5;
    // vec3 lightColor = pow(vec3(1.0, 0.1, 0.1), vec3(2.2));

    // float underLight = dot(vec3(0.5, -0.5, -0.5), color.rgb * 2.0 - 1.0);


    // color.rgb = pow(color.rgb, vec3(2.2));
    //strobes
    // vec3 lighting = vec3(0.0);
    // color.rgb = mix(color.rgb, vec3(0.05), 1.7 - (1.0 - pow(abs(vUv.x - 0.5), 1.5)));

    // lighting += post.r * 0.5 * light * vec3(1.0, 1.0, 0.0) * vUv.y * (sin(vUv.y * 4.0 + color.b * 2.0 + 2.0) * 0.5 + 0.5);
    // lighting += post.g * 0.2 * light * vec3(1.0, 0.0, 0.0) * vUv.y;
    // lighting += pow(vUv.y, 4.0) * lightColor * 0.03;
    // lighting = pow(color.rgb, vec3(0.45));

    //height fog
    // color.rgb = mix(color.rgb, lightColor, smoothstep(0.7, -2.0, vUv.y));
    // color.rgb += post.r * 0.2 * light * lightColor * pow(1.0 - vUv.y, 2.0);
    // color.rgb *= vUv.y * 0.1;
    // color.rgb += lighting;
    // color.rgb = post.r * vec3(1.0, 0.0, 0.0);
    // color.rgb = pow(color.rgb, vec3(0.45));
    // color.rgb -= 0.5;
    // color.rgb *= 1.2;
    // color.rgb += 0.5;
    float alpha = pow(clamp(1.0 - length(vUv - 0.5) * 2.0, 0.0, 1.0), 5.0);
    alpha = 1.0 - clamp(length((vUv - 0.5) * 2.0), 0.0, 1.0);
    alpha = pow(alpha, 2.0);

    // draws the light source to the default frame buffer 
    #drawbuffer Color gl_FragColor = vec4(screenColor.rgb, alpha);
    // #drawbuffer Color gl_FragColor = vec4(0.0);

    // draws the light source to the VolumetricLight frame buffer 
    #drawbuffer VolumetricLight gl_FragColor = vec4(screenColor.rgb, alpha);
    // #drawbuffer VolumetricLight gl_FragColor = vec4(0.0);
}{@}DJFloorShader.glsl{@}#!ATTRIBUTES

