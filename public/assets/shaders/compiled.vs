}{@}TableBuildingsShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying float vRamp;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec3 offset = vdata;
    pos.xz -= offset.xz;
    offset.x += sin(time * 1.25) * 42.0;
    offset.z += cos(time * 1.25) * 52.0;

    // float ramp = length(offset);
    // ramp = clamp(1.0 - ramp * 0.015, 0.0, 1.0);
    // ramp = 1.0 - pow(1.0 - ramp, 24.0);

    float ramp = length(offset.x);
    ramp = max(ramp, length(offset.z));
    ramp = clamp(1.0 - ramp * 0.015, 0.0, 1.0);
    ramp = 1.0 - pow(1.0 - ramp, 26.0);

    pos.y *= ramp;
    pos.xz += offset.xz;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vRamp = ramp;
    vNormal = normal;
}



#!SHADER: Fragment

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    vec2 screenUv = gl_FragCoord.xy / resolution;
    float r = rand(screenUv);

    // if (vRamp - r * 0.6 < 0.0001) discard;
    // vec3 color = texture2D(tMap, vUv).rgb;
    // vec3 color = vec3(vUv, 1.0);
    vec3 color = vec3(texture2D(tMap, vUv).b);
    color *= max(0.5, dot(vNormal, vec3(0.0, 1.0, -1.0)) * 0.5 + 0.5);
    color *= vRamp;
    gl_FragColor = vec4(color, 1.0);
}{@}TearApartShaderPBR.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
// attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;

uniform vec3 uEpicenter;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vColor;
varying float vInside;
varying float vDist;

#!SHADER: Vertex
#require(rotation.glsl)
// #require(curl.glsl)
#require(pbr.vs)

void main() {
    vec3 pos = position;
    vec3 pivot = vdata;
    vec3 n = normal;

    // pos += pivot * 0.1;

    float dist = distance(pivot, uEpicenter);
    float falloff = 4.0;
    float attenuation = 22.0;
    float strength = 3.0;
    dist = 1.0 - clamp(dist, 0.0, falloff) / falloff;
    dist = pow(dist, attenuation);
    dist *= strength;

    vec3 axis = normalize(pivot - uEpicenter);
    axis = normalize(cross(axis, vec3(0,1,0)));
    mat4 transformationMatrix = rotationMatrix(axis, dist);

    pos -= pivot;
    pos = (transformationMatrix * vec4(pos, 1.0)).xyz;
    n = (transformationMatrix * vec4(n, 0.0)).xyz;
    // pos *= (1.0 - dist / strength);

    pos += pivot;

    // pos += curl * 0.3;
    pos += clamp(dist, 0.0, 0.1) * normalize(uEpicenter - pos) * 2.0;

    mat4 twistMatrix = rotationMatrix(normalize(pivot - uEpicenter), -pos.x * 5.0 * dist + pos.z * 5.0 * dist);
    pos -= pivot;
    pos = (twistMatrix * vec4(pos, 1.0)).xyz;
    n = (twistMatrix * vec4(n, 0.0)).xyz;
    pos += pivot;

    pos += pivot * dist * strength;

    setupPBR(pos);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vInside = uv2.x;
    vPos = pos;
    vColor = pos;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vDist = dist;
}

#!SHADER: Fragment
#require(pbr.fs)
void main() {
    float dist = distance(vPos, uEpicenter);
    float falloff = 4.0;
    float attenuation = 20.0;
    float strength = 3.0;
    dist = clamp(dist, 0.0, falloff) / falloff;
    // dist = pow(dist, attenuation);

    vec3 baseColor = texture2D(tBaseColor, vUv).rgb;
    vec3 pbr = getPBR(baseColor).xyz;
    pbr += pbr * vInside * 0.5;
    pbr += vInside * vec3(0.0, 0.2, 1.0);

    gl_FragColor = vec4(pbr, 1.0);
}{@}AMDModBugTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform float uDenominatorMin;
uniform float uDenominatorMax;
uniform float uWorkaround;
uniform float uAlpha;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment
#require(range.glsl)

float getBorder(vec2 uv, float thickness) {
    vec2 p = uv * 2.0 - 1.0;
    vec2 d = abs(p) - vec2(1.0 - thickness * 2.0);
    float dist = length(max(d, 0.0)) + min(max(d.x, d.y), 0.0);
    float delta = fwidth(dist);
    return smoothstep(-delta, delta, dist);
}

void main() {
    float thickness = 0.01;
    float border = getBorder(vUv, thickness);

    float denominator = crange(vUv.x, thickness, 1.0 - thickness, uDenominatorMin, uDenominatorMax);
    float numerator = denominator;
//    float numerator = crange(vUv.x, thickness, 1.0 - thickness, -4.0 * uDenominatorMin, 4.0 * uDenominatorMin);
//    float denominator = uDenominatorMin;
    float value;
    if (uWorkaround < 0.5) {
        // Demonstrate the bug.
        // value should be 0.0, but on AMD it can be equal to denominator
        // Observed on Macbook Pro with AMD Radeon Pro 5500M.
        value = mod(numerator, denominator);
    } else {
        // Test some workarounds
        if (vUv.y < 0.5) {
            // The minimum viable epsilon for denominator 2^n seems to be 2^(n-24)
            float eps = exp2(log2(denominator) - 24.0);
            value = mod(denominator + eps, denominator);
        } else {
            value = mod(numerator, denominator);
            if (value >= denominator) value = 0.0;
        }
    }
    value = value / denominator;

    gl_FragColor = vec4(vec3(max(border, value)), uAlpha);
}
{@}InstanceTestShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying vec3 vColor;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vColor = random.xyz;
}

#!SHADER: Fragment
void main() {
