  gl_FragColor = color;
}{@}DistQuad.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    gl_Position = vec4(position, 1.0);
}

#!SHADER: Fragment



float msdf(sampler2D tMap, vec2 uv) {
    vec3 tex = texture2D(tMap, uv).rgb;
	  // If you have small artifacts, try to tweak the 0.5 value.
    float signedDist = max(min(tex.r, tex.g), min(max(tex.r, tex.g), tex.b)) - 0.5;
    float d = fwidth(signedDist);
    float alpha = smoothstep(-d, d, signedDist);
    return alpha;
}

void main() {

    vec2 st = vUv;
    st = 2. * st - 1.;
    st *= 5.;
    st = 0.5 * st + 0.5;

    st -= vec2(2.3);
    float d = msdf(tMap, st);

    for(float i = 1.; i < 9.; i ++) {
        d = max(d, msdf(tMap, st + i * vec2(0.56)));
    }
    
    for(float i = 1.; i < 9.; i ++) {
        d = max(d, msdf(tMap, vec2(1., -0.56) + st + i * vec2(0.56)));
    }

    bool paint = d > 0.0;
    vec3 yellow = vec3(255., 214., 0.) / 255.;
    gl_FragColor = vec4(yellow, 1.);
    if(paint) gl_FragColor = vec4(0.);
}{@}BlueSurfaceShader.glsl{@}#!ATTRIBUTES
attribute vec3 barycentric;

#!UNIFORMS
uniform sampler2D tAO;
uniform sampler2D tLightmap;
uniform sampler2D tColorRamp;

#!VARYINGS
varying vec2 vUv;
varying vec3 vBc;
varying vec3 vNormal;
varying vec3 vEye;



#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vBc = barycentric;
    vNormal = normalMatrix * normal;
}

#!SHADER: Fragment

float edgeFactor(float lineWidth) {
  vec3 d = fwidth(vBc);
  vec3 f = smoothstep(-d, d, vBc);
  return min(min(f.x, f.y), f.z);
}

void main() {
    // ao
    float s = 0.0005;
    float ao = 0.0;
    ao += texture2D(tAO, vUv + vec2(s, 0.0)).r;
    ao += texture2D(tAO, vUv + vec2(-s, 0.0)).r;
    ao += texture2D(tAO, vUv + vec2(0.0, s)).r;
    ao += texture2D(tAO, vUv + vec2(0.0, -s)).r;
    ao /= 4.0;

    // lightmap
    float lightmap = 0.0;
    lightmap += texture2D(tLightmap, vUv + vec2(s, 0.0)).r;
    lightmap += texture2D(tLightmap, vUv + vec2(-s, 0.0)).r;
    lightmap += texture2D(tLightmap, vUv + vec2(0.0, s)).r;
    lightmap += texture2D(tLightmap, vUv + vec2(0.0, -s)).r;
    lightmap /= 4.0;

    // wireframe
    float lineWidth = 2.0;
    vec3 d = fwidth(vBc) * lineWidth;
    vec3 f = smoothstep(-d, d, vBc);
    float wireframe = 1.0 - min(min(f.x, f.y), f.z);
    wireframe *= 0.5;

    // fresnel
    float fresnel = pow(1.0 - max(0.0, dot(vec3(0.0, 0.0, 1.0), normalize(vNormal))), 1.0);

    // emissive
    vec3 color1 = vec3(0.0, 0.4, 0.6);
    vec3 color2 = vec3(0.002, 0.0, 0.03);
    vec3 emissive = mix(color1, color2, fresnel);
    emissive += wireframe * 0.5;
    // emissive *= 0.5;

    vec3 color = vec3(max(0.0, lightmap * 3.0));
    color = mix(color, emissive, ao);

    color *= mix(max(vec3(0.3), color), mix(vec3(0.3, 1.0, 1.0), vec3(0.3, 0.3, 1.0), 1.0 - color.r), 0.4);
    // color = vec3(lightmap);

    gl_FragColor = vec4(color, 1.0);
}{@}BouncyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNormal;
uniform vec2 uMouse;
uniform vec2 uMouse2;
uniform vec2 uMouse3;
uniform float uIsHovered;
uniform float uProgress;
uniform float uBounce;
uniform float uSpring;
uniform float uSpeed;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
float merge(float shape1, float shape2){
    return min(shape1, shape2);
}

float roundMerge(float shape1, float shape2, float radius){
    vec2 intersectionSpace = vec2(shape1 - radius, shape2 - radius);
    intersectionSpace = min(intersectionSpace, 0.);
    float insideDistance = -length(intersectionSpace);
    float simpleUnion = merge(shape1, shape2);
    float outsideDistance = max(simpleUnion, radius);
    return  insideDistance + outsideDistance;
}

float circle(vec2 samplePosition, float radius){
    //get distance from center and grow it according to radius
    return length(samplePosition) - radius;
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

// vec2 calcNormal() // for function f(p){
//     float eps = 0.0001; // or some other value
//     vec2 h = vec2(eps,0.);
//     return normalize( vec2(fwidth(sampler2D(tMap, vUv+h.xy).r) - fwidth(sampler2D(tMap, vUv+h.xy).r),
//                            fwidth(sampler2D(tMap, vUv+h.yx).r) - fwidth(sampler2D(tMap, vUv+h.yx).r);
// }

void main() {
    vec2 screenUv = gl_FragCoord.xy / resolution;
    // float circ = (1.0 - distance(uMouse, vUv));
    // circ = smoothstep(0.5, 1.0, circ);
    float circ = circle(uMouse - vUv, 0.01);
    // float circ2 = circle(uMouse2 - vUv, 0.001);
    // float circ3 = circle(uMouse3 - vUv, 0.001);
    // circ = min(circ, circ2);
    // circ = min(circ, circ3);

    float rad = 0.6;

    float dist = texture2D(tMap, vUv).r;
    dist = 1.0 - dist;
    dist -= 0.05;
    float alpha = roundMerge(1.0 - pow(1.0 - circ, 5.0), dist, rad);
    float grad = alpha;
    grad = 1.0 - (grad + 0.7);

    float eps = 0.001; // or some other value
    eps += rand(screenUv + time) * 0.005;
    
    vec2 h = vec2(eps,0.);

    float dist1 = texture2D(tMap, vUv+h.xy).r;
    dist1 = 1.0 - dist1;
    dist1 -= 0.05;
    float alpha1 = roundMerge(1.0 - pow(1.0 - circ, 5.0), dist1, rad);
    float grad1 = alpha1;
    grad1 = 1.0 - (grad1 + 0.7);

    float dist2 = texture2D(tMap, vUv-h.xy).r;
    dist2 = 1.0 - dist2;
    dist2 -= 0.05;
    float alpha2 = roundMerge(1.0 - pow(1.0 - circ, 5.0), dist2, rad);
    float grad2 = alpha2;
    grad2 = 1.0 - (grad2 + 0.7);

    float dist3 = texture2D(tMap, vUv+h.yx).r;
    dist3 = 1.0 - dist3;
    dist3 -= 0.05;
    float alpha3 = roundMerge(1.0 - pow(1.0 - circ, 5.0), dist3, rad);
    float grad3 = alpha3;
    grad3 = 1.0 - (grad3 + 0.7);

    float dist4 = texture2D(tMap, vUv-h.yx).r;
    dist4 = 1.0 - dist4;
    dist4 -= 0.05;
    float alpha4 = roundMerge(1.0 - pow(1.0 - circ, 5.0), dist4, rad);
    float grad4 = alpha4;
    grad4 = 1.0 - (grad4 + 0.7);

    // dist = max(dist, circ);
    float f = fwidth(vUv.x);

    float inner = smoothstep(0.36, 0.25, grad1);
    inner = 1.0 - inner;

    alpha = smoothstep(0.05, 0.05 + f, alpha);
    alpha = 1.0 - alpha;

    vec3 normal = texture2D(tNormal, vUv).rgb;
    normal.y = 1.0 - normal.y;
    vec3 color = normal;
    color = vec3(grad);

    vec3 n = normalize( vec3(
        grad1 - grad2,
        grad3 - grad4, 
        grad * 0.5)
    );

    n = mix(n, vec3(0.0, 0.0, 1.0), inner);
    n = normalize(n);

    float v = dot(n, normalize(vec3(0.0, -1.0, 0.5)));
    v += pow(max(0.0, dot(n, normalize(vec3(0.0, 1.0, 0.0)))), 1.5);
    // v += grad * max(0.0, pow(circ, 2.0));
    vec3 final = vec3(0.1);
    final += vec3(pow(v, 2.2));
    // v*= grad;
    // v*= 2.5;

    gl_FragColor = vec4(final, alpha);
}{@}BoxCityInteriorMappingShader.glsl{@}#!ATTRIBUTES
attribute vec3 random;
attribute vec2 uv2;

// interior mapping attributes
attribute vec3 primpos;
attribute vec3 tangent;
attribute vec3 walldata;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tInterior;
uniform sampler2D tInteriorEmissive;
uniform float uInteriorBrightness;
uniform sampler2D tWindowMask;
uniform sampler2D tLightmap;
uniform float uLightmapIntensity;
uniform float uAtlasTiles;
uniform float uRandomizeTiles;
uniform float uCornerPadding;
uniform float uHeightOffset;

uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying float vTileIndex;
varying float vAtlasTiles;

// interior mapping varyings
varying vec3 vTangentPos;
varying vec3 vTangentEye;
varying vec3 vEye;
varying mat3 vTbn;
varying float vFloorHeight;
varying float vFloorWidth;
varying float vFloorDepth;
varying float vSeed;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);

    vUv = uv;
    vUv2 = uv2;

    // interior mapping
    vec3 B = vec3(0.0, 1.0, 0.0);
    vec3 N = normal;
    vec3 T = tangent;

    mat3 tbn;
    tbn[0] = vec3(T.x, T.y, T.z); 
    tbn[1] = vec3(B.x, B.y, B.z); 
    tbn[2] = vec3(N.x, N.y, N.z); 

    mat3 invtbn = transpose(tbn);
    vec3 eye = inverse(modelViewMatrix)[3].xyz;

    vTbn = tbn;
    vEye = (modelMatrix * vec4(position, 1.0)).xyz - cameraPosition;

    vTangentPos = invtbn * position;
    vTangentEye = invtbn * inverse(modelViewMatrix)[3].xyz;

    vTangentPos.x -= primpos.x;
    vTangentEye.x -= primpos.x;
    vTangentPos.z -= primpos.z;
    vTangentEye.z -= primpos.z;
    vTangentPos.y -= primpos.y;
    vTangentEye.y -= primpos.y;
    vTangentPos.z = -abs(vTangentPos.z);

    vTangentPos.y += uHeightOffset;
    vTangentEye.y += uHeightOffset;

    vFloorHeight = walldata.z;
    vFloorWidth = walldata.y;
    vFloorDepth = 5.0;
    vSeed = walldata.x;

    // corner padding
    if (vUv.x < 0.1) {
        vUv.x -= 0.063 * uCornerPadding;
    } else {
        vUv.x += 0.063 * uCornerPadding;
    }

    vTileIndex = floor(fract(random.g + uRandomizeTiles) * uAtlasTiles);
    vAtlasTiles = floor(uAtlasTiles);
}

#!SHADER: Fragment
float rand(vec2 co, float seed){
    return fract(seed + sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    vec2 mosaic = vec2(floor(vUv.x), floor(vUv.y));
    float rand1 = rand(mosaic, vSeed + 20.5);
    float rand2 = sin(rand1 * 600.1) * 0.5 + 0.5;
    float rand3 = sin(rand1 * 758.5) * 0.5 + 0.5;

    // interior mapping
    vec3 camToPixel = vTangentPos - vTangentEye;
    
    float isFloor = step(camToPixel.y, 0.0);
    float ceilingHeight = ceil(vTangentPos.y / vFloorHeight - isFloor) * vFloorHeight;
    float ceilingDist = (ceilingHeight - vTangentEye.y) / camToPixel.y;

    float isRear = step(camToPixel.z, 0.0);
    float rearWallDepth = ceil(vTangentPos.z / vFloorDepth - isRear) * vFloorDepth;
    float rearWallDist = (rearWallDepth - vTangentEye.z) / camToPixel.z;

    float innerDepth = ceil(vTangentPos.z / vFloorDepth - isRear) * 0.2;
    float innerDist = (rearWallDepth - vTangentEye.z) / camToPixel.z;

    float isSide = step(camToPixel.x, 0.0);
    float sideWallWidth = ceil((vTangentPos.x) / vFloorWidth - isSide) * vFloorWidth;
    float sideWallDist = (sideWallWidth - vTangentEye.x) / (camToPixel.x);

    vec2 interiorUv = vec2(0.0);
    float interiorUvOffset;
    float minDist = min(min(ceilingDist, rearWallDist), sideWallDist);
    if (sideWallDist == minDist) {
        interiorUv = vTangentEye.zy + sideWallDist * camToPixel.zy;
        interiorUv.x /= vFloorDepth;
        interiorUv.y /= vFloorHeight;
        interiorUvOffset = isSide == 0.0 ? 1.0 : 0.0;
    } else if (rearWallDist == minDist) {
        interiorUv = vTangentEye.xy + rearWallDist * camToPixel.xy;
        interiorUv.x /= vFloorWidth;
        interiorUv.y /= vFloorHeight;
        interiorUvOffset = 4.0;
    } else if (ceilingDist == minDist) {
        interiorUv = vTangentEye.xz + ceilingDist * camToPixel.xz;
        interiorUv.x /= vFloorWidth;
        interiorUv.y /= vFloorDepth;
        interiorUvOffset = isFloor == 0.0 ? 2.0 : 3.0;
    }

    float column = 1.0 / 5.0;
    interiorUv = fract(interiorUv);
    interiorUv.x *= column;
    interiorUv.x += column * interiorUvOffset;

    // exterior color
    vec2 uv = vUv;
    float offset = vTileIndex;

    uv = uv / vec2(1.0, vAtlasTiles);

    vec2 dx = dFdx(uv);
    vec2 dy = dFdy(uv);

    uv.y = mod(uv.y, 1.0 / vAtlasTiles) + offset / vAtlasTiles;
    uv.x = fract(uv.x);

    vec3 color = texture2DGrad(tMap, uv, dx, dy).rgb;
    color *= texture2D(tLightmap, vUv2).rgb * uLightmapIntensity;

    // interior color
    vec3 interior = texture2DGrad(tInterior, interiorUv, dx, dy).rgb;
    vec3 interiorEmissive = texture2DGrad(tInteriorEmissive, interiorUv, dx, dy).rgb;
    float randomBrightness = max(0.1, rand3 * rand3);
    // randomBrightness -= sin(rand1 * 10.0 + time * 2.0 + mosaic.y * 2.0);
    interior = mix(uColor1, uColor2, rand2) * interior;
    interior = pow(interior, vec3(2.2));
    interior += pow(interiorEmissive.r, 2.2) * 2.0;
    interior = pow(interior, vec3(0.45));
    interior *= uInteriorBrightness * randomBrightness;

    // compositing
    float interiorMask = texture2DGrad(tWindowMask, uv, dx, dy).r;
    color = mix(color, interior, interiorMask);

    // lightmap

    gl_FragColor = vec4(color, 1.0);
}{@}BoxCityShader.glsl{@}#!ATTRIBUTES
attribute vec3 random;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tLightmap;
uniform float uLightmapIntensity;
uniform float uAtlasTiles;
uniform float uRandomizeTiles;
uniform float uCornerPadding;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying float vTileIndex;
varying float vAtlasTiles;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vUv2 = uv2;

    // corner padding
    if (vUv.x < 0.1) {
        vUv.x -= 0.063 * uCornerPadding;
    } else {
        vUv.x += 0.063 * uCornerPadding;
    }

    vTileIndex = floor(fract(random.g + uRandomizeTiles) * uAtlasTiles);
    vAtlasTiles = floor(uAtlasTiles);
}

#!SHADER: Fragment

void main() {
    float offset = vTileIndex;

    vec2 uv = vUv;
    uv = uv / vec2(1.0, vAtlasTiles);

    vec2 dx = dFdx(uv);
    vec2 dy = dFdy(uv);

    uv.y = mod(uv.y, 1.0 / vAtlasTiles) + offset / vAtlasTiles;
    uv.x = fract(uv.x);

    vec3 color = texture2DGrad(tMap, uv, dx, dy).rgb;

    color *= texture2D(tLightmap, vUv2).rgb * uLightmapIntensity;

    gl_FragColor = vec4(color, 1.0);
}{@}BuildinShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vPos;
varying float vAngle;
varying float vDriver;

#!SHADER: Vertex
#require(rotation.glsl)
void main() {
    vec3 n = normal;

    float t = time * 0.4;
    vec3 pos = position;
    float driver = sin(t + vdata.z * 0.0065 + abs(vdata.x * 0.02) - abs(vdata.y * 0.01)) * 0.5 + 0.5;
    driver = clamp(driver, 0.0, 1.0);
    driver = smoothstep(0.0, 1.0, driver);
    driver = pow(driver, 55.0);

    // pos -= vdata;
    float angle = 1.0 - driver;

    vec3 axis = vec3(-abs(vdata.x) * 0.25, -abs(vdata.x) * 0.5, 5.5);
    if (vdata.x < 0.0) {
        axis.z *= -1.0;
        axis.y *= -1.0;
        // axis.x *= -1.0;
        // angle *= -1.0;

    }
    axis = normalize(axis);
    angle = pow(angle, 5.0);

    pos -= vdata;
    // pos.y += 3.0;
    pos = (rotationMatrix(axis, (1.0 - angle) * 3.14 * 2.5) * vec4(pos, 1.0)).xyz;
    pos.xy *= clamp(angle * 1.25 - 0.25, 0.0, 1.0);
    n = (rotationMatrix(axis, (1.0 - angle) * 3.14 * 2.5) * vec4(n, 0.0)).xyz;
    pos.x += (vdata.x + 10.0) * (1.0 - angle) * 0.25;
    pos.y += (1.0 - angle) * 26.0;
    // pos.y -= 3.0;
    // pos -= vdata;
    pos *= mix(0.0, 1.0, angle) * 0.5 + 0.5;
    pos += vdata;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vNormal = n;
    vPos = pos;
    vAngle = angle;
    vDriver = driver; 
}

#!SHADER: Fragment
void main() {
    // if (vPos.y < -1.5) discard;
    // if (vAngle < 0.5 + vPos.y * 0.02) discard;
    vec3 color = vNormal * 0.5 + 0.5;
    float value = dot(vNormal, vec3(0.25, 0.0, -1.0)) * 0.5 + 0.5;
    value = max(0.15, value);
    color = vec3(value);
    color += (1.0 - vAngle) * 3.5;
    // color = vec3(vDriver);
    // vec3 color = vec3(vAngle);
    gl_FragColor = vec4(color, 1.0);
}{@}FloatingBokehShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNoise;
uniform float uTimeOffset;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vColor;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    float t = time * 0.01 + uTimeOffset;
    vec3 color = texture2D(tNoise, vdata.xz * 0.5 + t).rgb;
    color *= 2.0;
    color -= 1.0;
    color *= 0.3;
    pos += color;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vUv2 = uv2;
    vColor = vdata;
}

#!SHADER: Fragment
void main() {
    float t = time + uTimeOffset;
    vec3 color = texture2D(tMap, vUv).rgb;
    float fade = sin(t + vUv2.y * 10.0) * 0.5 + 0.5;
    color.rgb *= fade;
    // color *= noise;
    gl_FragColor = vec4(color, 1.0);
}{@}FloatingCharacterShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tTranslucency;
uniform sampler2D tNoise;
uniform float uTimeOffset;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vColor;

#!SHADER: Vertex
void main() {
    vec3 pos = position;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    float t = time + uTimeOffset;
    vec4 color = texture2D(tMap, vUv + vec2(sin(time + vUv.y * 8.0 - vUv.x * 3.0) * 0.025 * pow((1.0 - vUv.y), 3.0), 0.0));
    vec3 translucent = texture2D(tTranslucency, vUv).rgb;
    float noise = texture2D(tNoise, vUv * 0.1 + vec2(0.0, -t * 0.025)).r;
    // color.rgb += translucent * noise * 2.0;
    color.rgb = clamp(color.rgb, vec3(0.0), vec3(1.0));
    gl_FragColor = vec4(color.rgb / color.a, color.a);
}{@}FloatingFXShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tNoise1;
uniform sampler2D tNoise2;
uniform float uTimeOffset;
uniform vec3 uColor;
uniform float uSpeed1;
uniform float uSpeed2;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vColor;

#!SHADER: Vertex
void main() {
    vec3 pos = position;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    float t = time * 0.25 + uTimeOffset;
    // vec3 color = texture2D(tMap, vUv).rgb;
    float noise = texture2D(tNoise1, vUv + vec2(0.0, -t * 0.25 * uSpeed1)).r;
    noise *= texture2D(tNoise2, vUv * 2.0 + vec2(0.0, -t * 0.2 * uSpeed2)).r;
    noise *= clamp(1.0 - length(vUv - 0.5) * 1.5, 0.0, 1.0);
    noise *= 3.0;
    noise = smoothstep(0.1, 0.7, noise);
    gl_FragColor = vec4(uColor, noise);
}{@}FloatingFlareShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNoise;
uniform float uTimeOffset;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vColor;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    float t = time * 0.01 + uTimeOffset;
    vec3 color = texture2D(tNoise, vdata.xz * 0.5 + t).rgb;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vUv2 = uv2;
    vColor = vdata;
}

#!SHADER: Fragment
void main() {
    float t = time + uTimeOffset;
    vec3 color = texture2D(tMap, vUv).rgb;
    float fade = mix(0.9, 1.1, sin(t * 30.0 + vUv2.y * 10.0) * 0.5 + 0.5);
    fade *= mix(0.5, 1.0, sin(t * 2.0 + vUv2.y * 6.0) * 0.5 + 0.5);
    fade += (sin(vUv2.x + time * 1.0) * 0.5 + 0.5) * 0.5;
    fade += (sin(vUv2.x + time * 45.0) * 0.5 + 0.5) * 0.1;
    color.rgb *= fade;
    // color *= noise;
    gl_FragColor = vec4(color, 1.0);
    gl_FragColor.a = 1.0;
}{@}FloatingGlowShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNoise;
uniform float uTimeOffset;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vColor;

#!SHADER: Vertex
void main() {
    vec3 pos = position;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    float t = time + uTimeOffset;
    vec3 color = texture2D(tMap, vUv).rgb;
    float noise = texture2D(tNoise, vUv * 0.4 + vec2(0.0, -time * 0.25)).r;
    color += noise * color * 0.5;
    gl_FragColor = vec4(color, 1.0);
}{@}BuildingVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

const float PHI = 1.61803398874989484820459; // Φ = Golden Ratio 

float gold_noise(in vec2 xy, in float seed)
{
    return fract(tan(distance(xy*PHI, xy)*seed)*xy.x);
}

void main() {
    vec4 color = texture2D(tDiffuse, vUv);

    vec3 bloom = pow(getUnrealBloom(vUv).rgb, vec3(2.2));

    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb += bloom * 1.42;
    color.rgb = pow(color.rgb, vec3(0.45));
    color.rgb += (getNoise(vUv, time) - 0.5) * 0.1;

    // color.b *= 0.7;

    // color.rgb -= 0.5;
    // color.rgb *= 1.1;
    // color.rgb += 0.5;

  gl_FragColor = color;
}{@}BuildingsEmissiveShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tLightmap;
uniform sampler2D tDetail;
uniform sampler2D tNoise;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform vec3 uFogColor;
uniform float uLightmapIntensity;
uniform float uEmissiveIntensity;
uniform vec2 uRangeFar;
uniform vec2 uRangeVertical;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec4 vMvPosition;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vUv2 = uv2;
    vMvPosition = mvPosition;
    vPos = position;
}

#!SHADER: Fragment
const float PHI = 1.61803398874989484820459; // Φ = Golden Ratio 

float gold_noise(in vec2 xy, in float seed)
{
    return fract(tan(distance(xy*PHI, xy)*seed)*xy.x);
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

void main() {
    vec4 color = texture2D(tMap, vUv);
    float window = color.g;
    vec2 uv = vUv;
    uv.y = floor(vPos.y);
    uv.y += floor(vPos.y * 6.0);
    // uv.y += floor(vPos.y * 3.0);
    uv.x = floor(vPos.x * 2.0);
    float r = rand(uv);
    float r2 = rand(uv + 20.0);
    vec3 emissive = mix(uColor1, uColor2, color.r) * smoothstep(0.0, 0.2 + max(0.0, step(0.5, sin(time * 0.05 + r * 200.0 + vPos.y * 0.01))), color.r) * uEmissiveIntensity;
    emissive = clamp(hueShift(emissive, fract(r * 114.0) * 0.8), vec3(0.0), vec3(1.0));
    uv.x = 0.0;
    
    color.b *= max(0.85, (1.0 - color.g) * r2);

    vec4 lightmap = texture2D(tLightmap, vUv2) * uLightmapIntensity;
    lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
    emissive.rgb = pow(emissive.rgb, vec3(2.2)) * uEmissiveIntensity * smoothstep(0.93, 0.96, r);
    color.rgb = (lightmap.rgb) * pow(color.b, 1.5);

    vec3 detail = texture2D(tDetail, vUv * 9.0).rgb;
    detail = detail - 0.5;
    color.rgb += detail * window * 0.2;
    color.rgb -= 0.02;
    color.rgb += emissive.rgb;
    // color.rgb -= 0.01 * noise.r;
    // color.rgb += 0.01 * noise.g;
    float fog = smoothstep(uRangeFar.x, uRangeFar.y, -vMvPosition.z);
    fog = pow(fog, 2.2);
    float verticalFog = smoothstep(uRangeVertical.x, uRangeVertical.y, vPos.y);
    verticalFog = pow(verticalFog, 2.2);
    fog += verticalFog;
    fog = pow(fog, 0.45);
    color.rgb = mix(color.rgb, pow(uFogColor, vec3(2.2)), fog);
    // color.rgb += emissive * clamp(-vMvPosition.z * 0.01, 0.0, 1.0);
    color.rgb = pow(color.rgb, vec3(0.45));


    gl_FragColor = vec4(vec3(color.rgb), 1.0);
    // gl_FragColor = vec4(uv, 1.0, 1.0);
    // gl_FragColor = vec4(r);
    // gl_FragColor = vec4(vec3(noise.rgb), 1.0);
}{@}ChimneySmokeShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tFlipbook;
uniform vec2 uFlipbookDimensions;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec4 uParams;

#!VARYINGS
varying vec2 vUv;
varying float vIndex;
varying vec4 vRandom;
varying float vWorldLength;
varying float vFade;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;
    vIndex = random.x;
    vWorldLength = length(worldPos.xyz);

    vec3 cameraDir = normalize(worldPos.xyz - cameraPosition);
    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;
    float dp = dot(cameraDir, normalize(worldNormal));
    vFade = pow(dp, 2.0);
}

#!SHADER: Fragment
vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

void main() {
    float t = time * uParams.w + vWorldLength * 0.01;
    vec4 color = getInterpolatedSubUV(tFlipbook, uFlipbookDimensions, vUv, t);
    float alpha = color.r;
    color.rgb = mix(uColor1, uColor2, color.r);
    // color.a = smoothstep(0.0, 1.0, color.a);
    // color.rgb = mix(uColor1, uColor2, clamp(color.r * 2.0, 0.0, 1.0));
    
    // color *= 1.0 - pow(abs(fract(t / uParams.w) * 2.0 - 1.0), 8.0);

    // turn off every second one
    // color *= step(0.5, clamp(fract(t / uParams.w * 0.5), 0.0, 1.0));
    gl_FragColor = color;
    gl_FragColor.a = alpha * uParams.x * vFade;
    // gl_FragColor.rgb = vec3(1.0, 0.0, 0.0);
    // gl_FragColor.a = 1.0;
}{@}FlyingCarShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tMap;
uniform vec3 uColor;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform float uIntensity;
uniform vec3 uOffset;
uniform float uWaveStrength;
uniform float uSpeed;
uniform float uWobbleStrength;

uniform vec2 uRangeVertical;
uniform vec2 uRangeFar;
uniform vec3 uFogColor;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec2 vTc;
varying vec3 vWorldNormal;
varying vec3 vEye;
varying vec3 vWorldUpVector;
varying vec3 vWorldPos;
varying vec3 vMvPos;
varying vec3 vPos;
varying float vIsBraking;
varying float vRandom;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;
    pos = position;

    // compression wave
    float wave = sin(-offset.z * 0.2 + time + random.g * 1.2) * 1.1 * uWaveStrength;
    wave *= mix(0.5, 1.5, random.g);
    float isBraking = step(0.0, wave);

    pos.y -= 1.0;
    mat4 rotMatrix = rotationMatrix(vec3(0.0, 0.0, 1.0), sin(time * uWobbleStrength + offset.z) * 0.2 * uWobbleStrength);
    pos = vec3(rotMatrix * vec4(pos, 1.0));


    pos.z += wave;
    pos.y += random.g + random.b * 2.0;
    pos.z += random.b;
    pos.x += random.r;
    pos.z *= mix(0.7, 2.0, random.b);
    
    float t = time * 2.5 * uSpeed - 25.0;

    vPos = pos;



    vec3 n = normal;

    #ifdef INSTANCED
    vec3 off = offset;
    off.z -= t;
    off.z = mod(off.z, 350.0) - 175.0;
    pos += uOffset;
    vec4 orient = orientation;
    pos = transformPosition(pos, off, mix(0.8, 1.2, random.b), orient);
    n = transformPosition(normal, vec3(0.0), 1.0, orient);
    #endif

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;

    vUv = uv * vec2(1.0, 0.5) - vec2(0.0, time * 0.05);
    vTc = uv;
    vEye = cameraPosition - worldPos.xyz;

    mat3 transform = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz);

    vWorldNormal = transform * n;
    vWorldUpVector = transform * vec3(0.0, 1.0, 0.0);
    vWorldPos = worldPos.xyz;
    vUv2 = uv2;
    vUv = uv;
    vMvPos = modelViewPos.xyz;
    vIsBraking = 1.0 - isBraking;
    vRandom = random.r;
}

#!SHADER: Fragment

#require(range.glsl)
#require(transformUV.glsl)

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

void main() {
    if (vUv2.y > 0.0) discard;
    // alpha when viewing from side
    vec3 eye = normalize(vEye);
    vec3 worldNormal = normalize(vWorldNormal);
    vec3 worldUpVector = vWorldUpVector;
    float dp = dot(eye, worldNormal) * 0.5 + 0.5;
    float sideAlpha = pow(dp, 1.0) * 0.3;
    sideAlpha *= 1.0 - vUv2.y;

    // alpha when viewing from front
    float mixValue = pow(abs(dot(worldUpVector, eye)), 8.0);
    float frontAlpha = pow(pow(dp, 2.0) * vTc.y * 4.0, 2.0);

    // float alpha = mix(sideAlpha, frontAlpha, mixValue) * 3.0;
    float alpha = sideAlpha * 2.0;
    alpha *= clamp(1.0 - vUv2.y, 0.0, 1.0);
    alpha *= alpha;
    alpha *= 2.0;

    float carMask = (1.0 - step(0.0, vUv2.y));
    alpha = clamp(alpha + carMask, 0.0, 1.0);

    vec3 car = texture2D(tMap, vUv).rgb;
    vec3 color = car;
    color = mix(uColor1, uColor2, color.g);
    color = mix(color, uColor3, 1.0 - carMask);

    color *= clamp(dot(vWorldNormal, vec3(0.0, 0.0, -1.0)) * 0.5 + 0.5 + (1.0 - carMask), 0.0, 1.0);
    color += hueShift(mix(uColor, vec3(1.0, 0.3, 0.0), vIsBraking) * car.r, vRandom * 0.5);

    float fog = smoothstep(uRangeFar.x, uRangeFar.y, -vMvPos.z);
    // fog = pow(fog, 2.2);
    // float verticalFog = smoothstep(uRangeVertical.x, uRangeVertical.y, vWorldPos.y);
    // verticalFog = pow(verticalFog, 2.2);
    // fog += verticalFog;
    // fog = pow(fog, 0.45);
    color.rgb = mix(color.rgb, uFogColor, fog);

    gl_FragColor = vec4(color, alpha * uIntensity);
}
{@}FuguShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tLightmap;
uniform sampler2D tDetail;
uniform sampler2D tNoise;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform vec3 uFogColor;
uniform float uLightmapIntensity;
uniform float uEmissiveIntensity;
uniform vec2 uRangeFar;
uniform vec2 uRangeVertical;
uniform float uTimeOffset;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec4 vMvPosition;
varying vec3 vPos;

#!SHADER: Vertex
#require(rotation.glsl)
void main() {
    float t = time * 0.7 + uTimeOffset;
    vec3 pos = position;

    vec3 axis = vec3(1.0, 0.0, 0.0);
    float angle = sin(t * 0.7) * 0.1;
    mat4 rotMatrix = rotationMatrix(axis, angle);
    pos = vec3(rotMatrix * vec4(pos, 1.0));
    axis = vec3(0.0, 0.0, 1.0);
    angle = sin(t * 1.2 + 0.2) * 0.1;
    rotMatrix = rotationMatrix(axis, angle);
    pos = vec3(rotMatrix * vec4(pos, 1.0));
    pos.y += cos(t) * 0.05;
    
    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vUv2 = uv2;
    vMvPosition = mvPosition;
    vPos = position;
}

#!SHADER: Fragment
const float PHI = 1.61803398874989484820459; // Φ = Golden Ratio 

float gold_noise(in vec2 xy, in float seed)
{
    return fract(tan(distance(xy*PHI, xy)*seed)*xy.x);
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

void main() {
    vec4 color = texture2D(tMap, vUv);
    vec4 lightmap = texture2D(tLightmap, vUv2) * uLightmapIntensity;
    lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
    lightmap.rgb -= 0.05;
    lightmap.rgb *= pow(color.rgb, vec3(2.2));

    float fog = smoothstep(uRangeFar.x, uRangeFar.y, -vMvPosition.z);
    fog = pow(fog, 2.2);
    float verticalFog = smoothstep(uRangeVertical.x, uRangeVertical.y, vPos.y);
    verticalFog = pow(verticalFog, 2.2);
    fog += verticalFog;
    fog = pow(fog, 0.45);
    lightmap.rgb = mix(lightmap.rgb, pow(uFogColor, vec3(2.2)), fog);
    lightmap.rgb = pow(lightmap.rgb, vec3(0.45));

    // float glow = color.b * clamp(vPos.y + 0.4, 0.0, 1.0);
    // lightmap.rgb += glow;

    gl_FragColor = vec4(vec3(lightmap.rgb), 1.0);
}{@}MegaBuildingShader.glsl{@}#!ATTRIBUTES
