{@}densityVelocity.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPosition;
uniform sampler2D tVelocity;
uniform sampler2D tGrid;

uniform vec3 uBoundsMin;
uniform vec3 uBoundsMax;

uniform float uTextureSize; //size of texture containing all the voxel slices in px
uniform float uSliceSize; //size of slice in px

uniform float uDrawDensity;

#!VARYINGS
varying vec3 vVelocity;
varying float vDensity;

vec2 computeSliceOffset(float slice, float slicesPerRow, vec2 sliceSize) {
    return sliceSize * vec2(mod(slice, slicesPerRow),
    floor(slice / slicesPerRow));
}

vec2 calc3DTexCoord(vec3 texCoord, float size, float numRows, float slicesPerRow) {
    float slice   = texCoord.z * size;
    float sliceZ  = floor(slice);                         // slice we need
    float zOffset = fract(slice);                         // dist between slices

    vec2 sliceSize = vec2(1.0 / slicesPerRow,             // u space of 1 slice
    1.0 / numRows);                 // v space of 1 slice

    vec2 slice0Offset = computeSliceOffset(sliceZ, slicesPerRow, sliceSize);
    vec2 slicePixelSize = sliceSize / size;               // space of 1 pixel
    vec2 sliceInnerSize = slicePixelSize * (size - 1.0);  // space of size pixels

    vec2 uv = slicePixelSize * 0.5 + texCoord.xy * sliceInnerSize;
    uv += slice0Offset;
    return uv;

}

void calcDensity(in vec3 pos, float neighbourIndex, inout float density, inout vec3 gridVelocity, in vec3 velocity) {

    float gridCoordX = (mod(neighbourIndex, uTextureSize) + 0.5);
    float gridCoordY = (floor(neighbourIndex / uTextureSize) + 0.5);
    vec3 otherPos = texture2D(tPosition, vec2(gridCoordX, gridCoordY)).xyz;

    otherPos -= uBoundsMin;
    otherPos /= abs(uBoundsMax - uBoundsMin);
    otherPos = otherPos * 2.0 - 1.0;
    pos = pos * 2.0 - 1.0;

    float dX = clamp(1.0 - abs(otherPos.x - pos.x), 0.0, 1.0);
    float dY = clamp(1.0 - abs(otherPos.y - pos.y), 0.0, 1.0);
    float dZ = clamp(1.0 - abs(otherPos.z - pos.z), 0.0, 1.0);

    float totalWeight = dX * dY * dZ;
    density += totalWeight;
    gridVelocity += totalWeight * velocity;
}

vec3 calcVelocity(in vec3 pos, float neighbourIndex, in vec3 velocity) {

    float gridCoordX = (mod(neighbourIndex, uTextureSize) + 0.5);
    float gridCoordY = (floor(neighbourIndex / uTextureSize) + 0.5);
    vec3 otherPos = texture2D(tPosition, vec2(gridCoordX, gridCoordY)).xyz;
    otherPos -= uBoundsMin;
    otherPos /= abs(uBoundsMax - uBoundsMin);
    otherPos = otherPos * 2.0 - 1.0;
    pos = pos * 2.0 - 1.0;

    float dX = 1.0 - abs(otherPos.x - pos.x);
    float dY = 1.0 - abs(otherPos.y - pos.y);
    float dZ = 1.0 - abs(otherPos.z - pos.z);

    return dX * dY * dZ * velocity;
}

#!SHADER: Vertex
void main() {

    vec3 velocity = texture2D(tVelocity, position.xy).xyz;
    vec3 pos = texture2D(tPosition, position.xy).xyz;

    vec3 gridPos = pos;
    gridPos -= uBoundsMin;
    gridPos.xyz /= abs(uBoundsMax - uBoundsMin);

    vec3 voxelPosition = floor(gridPos * uSliceSize);

    vec3 offsets[27];
    offsets[0] = vec3(-1., -1., -1.);
    offsets[1] = vec3(-1., -1., 0.);
    offsets[2] = vec3(-1., -1., 1.);
    offsets[3] = vec3(-1., 0., -1.);
    offsets[4] = vec3(-1., 0., 0.);
    offsets[5] = vec3(-1., 0., 1.);
    offsets[6] = vec3(-1., 1., -1.);
    offsets[7] = vec3(-1., 1., 0.);
    offsets[8] = vec3(-1., 1., 1.);
    offsets[9] = vec3(0., -1., -1.);
    offsets[10] = vec3(0., -1., 0.);
    offsets[11] = vec3(0., -1., 1.);
    offsets[12] = vec3(0., 0., -1.);
    offsets[13] = vec3(0., 0., 0.);
    offsets[14] = vec3(0., 0., 1.);
    offsets[15] = vec3(0., 1., -1.);
    offsets[16] = vec3(0., 1., 0.);
    offsets[17] = vec3(0., 1., 1.);
    offsets[18] = vec3(1., -1., -1.);
    offsets[19] = vec3(1., -1., 0.);
    offsets[20] = vec3(1., -1., 1.);
    offsets[21] = vec3(1., 0., -1.);
    offsets[22] = vec3(1., 0., 0.);
    offsets[23] = vec3(1., 0., 1.);
    offsets[24] = vec3(1., 1., -1.);
    offsets[25] = vec3(1., 1., 0.);
    offsets[26] = vec3(1., 1., 1.);

    float density = 0.0;
    vec3 voxelVelocity = vec3(0.0);

    for(int i = 0; i < 27; i++) {
        vec3 neighbour = voxelPosition + offsets[i];
        float voxelIndex = dot(neighbour, vec3(1.0, uSliceSize, uSliceSize * uSliceSize));
        float otherCoordX = (mod(voxelIndex, uTextureSize) + 0.5);
        float otherCoordY = (floor(voxelIndex / uTextureSize) + 0.5);
        vec4 neighbourIndex = texture2D(tGrid, vec2(otherCoordX, otherCoordY) / uTextureSize);


        if(neighbourIndex.x > -1.0) calcDensity(gridPos, neighbourIndex.x, density, voxelVelocity, velocity);
        if(neighbourIndex.y > -1.0) calcDensity(gridPos, neighbourIndex.y, density, voxelVelocity, velocity);
        if(neighbourIndex.z > -1.0) calcDensity(gridPos, neighbourIndex.z, density, voxelVelocity, velocity);
        if(neighbourIndex.w > -1.0) calcDensity(gridPos, neighbourIndex.w, density, voxelVelocity, velocity);

//        if(neighbourIndex.x > -1.0) voxelVelocity += calcVelocity(gridPos, neighbourIndex.x, velocity);
//        if(neighbourIndex.y > -1.0) voxelVelocity += calcVelocity(gridPos, neighbourIndex.y, velocity);
//        if(neighbourIndex.z > -1.0) voxelVelocity += calcVelocity(gridPos, neighbourIndex.z, velocity);
//        if(neighbourIndex.w > -1.0) voxelVelocity += calcVelocity(gridPos, neighbourIndex.w, velocity);


    }

    vDensity = density;
    vVelocity = voxelVelocity;
//    vVelocity = velocity;

    float voxelIndex = dot(voxelPosition, vec3(1.0, uSliceSize, uSliceSize * uSliceSize));
    float gridCoordX = ((mod(voxelIndex, uTextureSize) + 0.5) / uTextureSize);
    float gridCoordY = ((floor(voxelIndex / uTextureSize) + 0.5) / uTextureSize);

    vec2 gridCoord = 2.0 * vec2(gridCoordX, gridCoordY) - 1.0;
    gl_Position = vec4(gridCoord, 0.0, 1.0);

//    vec2 gridCoord = calc3DTexCoord(gridPos, uSliceSize, 8.0, 8.0);
//    gl_Position = vec4(2.0 * gridCoord - 1.0, 0.0, 1.0);
    gl_PointSize = 1.0;
}

    #!SHADER: Fragment
void main() {
    gl_FragColor = vec4(vVelocity, vDensity);
}
