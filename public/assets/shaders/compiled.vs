}{@}ShowroomVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)
#require(rgbshift.fs)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}



void main() {
    // vec4 color = texture2D(tDiffuse, vUv);
    vec4 color = getRGB(tDiffuse, vUv, 0.1, 0.00075);

    float n = rand( vUv + fract(time) );
    float n2 = rand( vUv + fract(time + 0.5) );

    vec3 bloom = getUnrealBloom(vUv + n * 0.005).rgb;
    // bloom.b += n2 * 0.05;
    // bloom.r += n * 0.05;
    // bloom.r += n2 * 0.05;

    // color.rgb += n2 * 0.02;

    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb += pow(bloom, vec3(2.2));
    color.rgb = mix(color.rgb, bloom, clamp((bloom.r + bloom.g + bloom.b) * 0.8, 0.0, 1.0));
    color.rgb = pow(color.rgb, vec3(1.0/2.2));


    color.rgb += (n2 * 2.0 - 1.0) * 0.02;
    color.rgb -= 0.5;
    color.rgb *= 1.4;
    color.rgb += 0.5;


  gl_FragColor = color;
  gl_FragColor.a = 1.0;
}{@}SpotlightShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tVideo;

#!VARYINGS
varying vec2 vUv;
varying vec2 vTc;
varying vec3 vWorldNormal;
varying vec3 vEye;
varying vec3 vWorldUpVector;
varying vec3 vWorldPos;
varying vec3 vVideo;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;

    vUv = uv * vec2(1.0, 0.5) - vec2(0.0, time * 0.05);
    vTc = uv;
    vEye = cameraPosition - worldPos.xyz;

    vec3 n = normal;

    #ifdef INSTANCED
    vec4 orien = orientation * (1.0 + sin(time*0.4+abs(worldPos.x)*0.02+abs(worldPos.z)*0.05+worldPos.y*0.03) * 0.8);
    n = transformPosition(normal, vec3(0.0), 1.0, orien);
    #endif

    mat3 transform = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz);


    vWorldNormal = transform * n;
    vWorldUpVector = transform * vec3(0.0, 1.0, 0.0);
    vWorldPos = worldPos.xyz;
}

#!SHADER: Fragment

#require(range.glsl)
#require(transformUV.glsl)

void main() {
    
    // alpha when viewing from side
    vec3 eye = normalize(vEye);
    vec3 worldNormal = normalize(vWorldNormal);
    vec3 worldUpVector = vWorldUpVector;
    float dp = dot(eye, worldNormal) * 0.5 + 0.5;
    float sideAlpha = pow(dp, 12.0) * 0.3;
    sideAlpha *= vTc.y;
    sideAlpha *= 1.0 - pow(vTc.y, 12.0);

    float alpha = sideAlpha;
    alpha *= 4.0;

    vec3 color = vec3(1.0);

    gl_FragColor = vec4(color, alpha);
}{@}StyleTestShader1.glsl{@}#!ATTRIBUTES
attribute vec3 pivot;
attribute float area;

#!UNIFORMS
uniform sampler2D tMap;
uniform vec3 uEpicenter;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vNormal;
varying float vAo;
varying float vFalloff;

#!SHADER: Vertex
#require(rotation.glsl)

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    vec3 pos = position;
    vec3 axis = cross(normalize(pivot), normalize(vec3(0.0, 1.0, 0.0)));
    float angle = sin(length(uEpicenter - pos) * 0.2 - time * 1.0 + area * 2.0) * 0.5 + 0.5;
    vAo = angle;
    angle = pow(angle, 5.0);
    mat4 rotMatrix = rotationMatrix(axis, angle * 3.0);

    pos -= pivot;
    pos.y -= 0.5;
    pos *= mix(1.0, 1.0 - angle, 1.0);
    pos = vec3(rotMatrix * vec4(pos, 1.0));
    pos.y += 0.5;
    pos += pivot;

    vec3 n = normal;
    n = vec3(rotMatrix * vec4(n, 1.0));

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vNormal = n;
    vFalloff = 1.0 - clamp(length(uEpicenter - pos), 0.0, 35.0) / 35.0;
    vPos = pos;
}

#!SHADER: Fragment
void main() {
    float dp = dot(vNormal, normalize(uEpicenter - vPos)) * 0.5 + 0.5;
    dp = sin(dp + time * 1.0 + 0.5) * 0.5 + 0.5;
    vec3 color = vec3(dp * vFalloff + vAo * vFalloff) * mix(vec3(0.0, 0.0, 1.0), vec3(0.1, 0.3, 0.9), dp) + vAo * vFalloff;
    gl_FragColor = vec4(color, 1.0);
}{@}StyleTestShader2.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNoise;
uniform float uTiling;
uniform vec3 uEpicenter;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vWorldNormal;
varying vec3 vMvPos;
varying vec3 vEyeNormal;
varying vec3 vEye;
varying float vGradient;

#!SHADER: Vertex


void main() {

    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;
    vPos = position;

    vec3 pos = position;

    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    vec4 mvPos = modelViewMatrix * vec4(pos, 1.0);
    gl_Position = projectionMatrix * mvPos;
    vUv = uv;
    vMvPos = mvPos.xyz;
    vEyeNormal = normalMatrix * normal;
    vEye = normalize(cameraPosition.xyz - worldPos.xyz);
}

#!SHADER: Fragment
// https://gist.github.com/patriciogonzalezvivo/20263fe85d52705e4530
vec3 getTriPlanarBlend(vec3 _wNorm){
	// in wNorm is the world-space normal of the fragment
	vec3 blending = abs( _wNorm );
	blending = normalize(max(blending, 0.00001)); // Force weights to sum to 1.0
	float b = (blending.x + blending.y + blending.z);
	blending /= vec3(b, b, b);
	return blending;
}

void main() {
    float t = time * 0.005;
    vec3 uv1 = vPos * uTiling;
    vec3 uv2 = vPos * uTiling * 3.0;
    vec3 blending = getTriPlanarBlend(vWorldNormal);
	vec3 xaxis1 = texture2D( tMap, uv1.yz).rgb;
	vec3 yaxis1 = texture2D( tMap, uv1.xz).rgb;
	vec3 zaxis1 = texture2D( tMap, uv1.xy).rgb;
	vec3 triplanarTex1 = xaxis1 * blending.x + yaxis1 * blending.y + zaxis1 * blending.z;
    vec3 xaxis2 = texture2D( tMap, uv2.yz).rgb;
	vec3 yaxis2 = texture2D( tMap, uv2.xz).rgb;
	vec3 zaxis2 = texture2D( tMap, uv2.xy).rgb;
	vec3 triplanarTex2 = xaxis2 * blending.x + yaxis2 * blending.y + zaxis2 * blending.z;
    vec3 triplanarTex = triplanarTex1 + triplanarTex2;

    // float fresnel = pow(1.0 - dot(normalize(vEyeNormal), -normalize(vMvPos.xyz)), 1.0);
    // float lighting = max(0.0, dot(vWorldNormal, normalize(vec3(-8.0, 1.0, -6.0))));
    
    float contribution = 0.0;
    contribution += triplanarTex.r * 2.0 + smoothstep(0.03, 0.9, triplanarTex.r);

    float maxDist = 6.0;
    float falloff = 1.0 - clamp(pow(length(vPos - uEpicenter), 2.0), 0.0, maxDist) / maxDist;
    contribution *= 2.5;

    vec3 color = contribution * vec3(0.0, 0.5, 1.0) * 1.3;

    gl_FragColor = vec4(color, falloff);
}{@}StyleTestShader3.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tDepth;
uniform sampler2D tNoise;
uniform float uTiling;
uniform vec3 uEpicenter;
uniform float uFrameGlow;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vWorldNormal;
varying vec3 vNormal;
varying vec3 vMvPos;
varying vec3 vWorldPos;
varying vec3 vEyeNormal;
varying vec3 vEye;
varying float vGradient;
varying vec3 vLightDir;

#!SHADER: Vertex

void main() {

    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;
    vPos = position;

    vec3 pos = position;

    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    vec4 mvPos = modelViewMatrix * vec4(pos, 1.0);
    gl_Position = projectionMatrix * mvPos;
    vUv = uv;
    vMvPos = mvPos.xyz;
    vEyeNormal = normalMatrix * normal;
    vEye = normalize(-mvPos.xyz);
    vWorldPos = worldPos.xyz;
    vLightDir = normalize(uEpicenter - worldPos.xyz);
    vNormal = normal;
}

#!SHADER: Fragment

void main() {
    vec3 color = vEyeNormal;
    vec3 normal = normalize(vEyeNormal);

    float d = 1.0 - clamp(distance(vWorldPos, uEpicenter), 0.0, 2.0) / 3.0;
    d = pow(d, 3.0);

    vec3 dir = normalize(uEpicenter - vWorldPos);
    float c = dot(dir, vWorldNormal.xyz) * 0.5 + 0.5;

    float fresnel = max(0.0, dot(vEye, normal));
    fresnel = pow(1.0 - fresnel, 2.0);

    color = vec3(mix(vec3(0.0, 0.015, 0.03), vec3(0.0, 0.6, 0.9), mix(d * c, d, 0.8)));

    color += vec3(0.8 * fresnel * smoothstep(0.0, 0.02, vWorldPos.y) * (clamp(-vMvPos.z, 0.5, 1.0) / 1.0)) * vec3(0.0, 0.6, 0.9);

    vec3 pointLight = vec3(0.5, 0.9, 0.0);
    vec3 lightDir = normalize(vWorldPos - pointLight);
    float r = dot(lightDir, normalize(vWorldNormal)) * 0.5 + 0.5;

    color += (1.0 - clamp(length(vWorldPos - pointLight), 0.0, 1.5) / 1.5) * vec3(0.0, 0.5, 1.0) * 0.5;

    vec3 frameGlow = vec3(0.0, 1.0, 0.5) * uFrameGlow;
    frameGlow *= pow(max(0.0, dot(normalize(vNormal), vec3(0.0, 1.0, 0.0))), 3.0);
    frameGlow *= (1.0 - fresnel) * clamp(vPos.y * 1.0, 0.0, 1.0);
    frameGlow *= 1.0 - clamp(vPos.y * 0.4 - 0.6, 0.0, 1.0);
    color += frameGlow;
    gl_FragColor = vec4(color, 1.0);
}{@}FlipbookShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec2 uDimensions;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment

vec4 getSubUV(sampler2D _tMap, float _width, vec2 _uv, float _index) {
    float index = _index * (1.0 / _width);
    vec2 uv = _uv;
    uv.x /= _width;
    uv.x += floor(fract(index) * _width) / _width;
    return texture2D(_tMap, uv);
}

vec4 getSubUV(sampler2D _tMap, float _width, vec2 _uv, float _index, float _padding) {
    float index = _index * (1.0 / _width);
    vec2 uv = _uv;
    uv -= 0.5;
    uv /= 1.0 + _padding;
    uv += 0.5;
    uv.x /= _width;
    uv.x += floor(fract(index) * _width) / _width;
    return texture2D(_tMap, uv);
}

vec4 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {

    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return texture2D(_tMap, uv);
}

vec4 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding) {

    float index = _index * (1.0 / _dimensions.x);

    vec2 uv = _uv;
    uv -= 0.5;
    uv /= 1.0 + _padding;
    uv += 0.5;
    uv /= _dimensions;

    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex = texture2D(_tMap, uv);

    return tex;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding) {

    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 -= 0.5;
    subUV1 /= 1.0 + _padding;
    subUV1 += 0.5;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding, vec2 _uvScale, vec2 _uvOffset) {

    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 -= 0.5;
    subUV1 /= 1.0 + _padding;
    subUV1 += 0.5;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    subUV1 *= _uvScale;
    subUV1 += _uvOffset;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    subUV2 *= _uvScale;
    subUV2 += _uvOffset;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

void main() {
    float frames = 9.0;
    float fps = 8.0;
    float t = time * fps;

    vec4 color = getSubUV(tMap, uDimensions, vUv, t).rgba;
    // float alpha = fract(time * fps / frames + 1.0/frames);

    gl_FragColor = vec4(color.rgb, 1.0);
}{@}SubUvShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec2 uDimensions;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment

vec4 getSubUV(sampler2D _tMap, float _width, vec2 _uv, float _index) {
    float index = _index * (1.0 / _width);
    vec2 uv = _uv;
    uv.x /= _width;
    uv.x += floor(fract(index) * _width) / _width;
    return texture2D(_tMap, uv);
}

vec4 getSubUV(sampler2D _tMap, float _width, vec2 _uv, float _index, float _padding) {
    float index = _index * (1.0 / _width);
    vec2 uv = _uv;
    uv -= 0.5;
    uv /= 1.0 + _padding;
    uv += 0.5;
    uv.x /= _width;
    uv.x += floor(fract(index) * _width) / _width;
    return texture2D(_tMap, uv);
}

vec4 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {

    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return texture2D(_tMap, uv);
}

vec4 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding) {

    float index = _index * (1.0 / _dimensions.x);

    vec2 uv = _uv;
    uv -= 0.5;
    uv /= 1.0 + _padding;
    uv += 0.5;
    uv /= _dimensions;

    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex = texture2D(_tMap, uv);

    return tex;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding) {

    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 -= 0.5;
    subUV1 /= 1.0 + _padding;
    subUV1 += 0.5;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding, vec2 _uvScale, vec2 _uvOffset) {

    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 -= 0.5;
    subUV1 /= 1.0 + _padding;
    subUV1 += 0.5;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    subUV1 *= _uvScale;
    subUV1 += _uvOffset;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    subUV2 *= _uvScale;
    subUV2 += _uvOffset;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

void main() {
    float frames = 25.0;
    float fps = 24.0;
    float t = time * fps;
    // float t = clamp(sin(time), 0.0, 1.0) * fps;
    // vec3 distortion = texture2D(tMap, vUv * vec2(1.0/8.0, 1.0/4.0)).rgb;
    vec2 distortion = vec2(sin(time * 1.21 + vUv.y * 3.0), 0.0);
    vec4 color = getInterpolatedSubUV(tMap, uDimensions, vUv, t).rgba;
    float alpha = fract(time * fps / frames + 1.0/frames);
    alpha = 1.0 - abs(alpha - 0.5) * 2.0;
    alpha = 1.0 - pow(1.0 - alpha, 3.0);

    alpha *= step(0.0, sin((t / frames + 1.0/frames) * 3.14159));
    // alpha = 1.0;
    // alpha = pow(alpha, 2.0) * 1.0 - pow(alpha, 2.0);
    gl_FragColor = vec4(color.rgb, clamp(color.a * alpha, 0.0, 1.0) * 1.0);
}{@}IbizaVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)
#require(rgbshift.fs)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}


void main() {
    // vec4 color = texture2D(tDiffuse, vUv);
    vec4 color = getRGB(tDiffuse, vUv, 0.1, 0.0005);

    vec3 bloom = getUnrealBloom(vUv).rgb;

    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb += pow(bloom, vec3(2.2));
    color.rgb = pow(color.rgb, vec3(0.45));

    // color.rgb += bloom * bloom.r * 3.0;
    // color.rgb *= mix(vec3(1.0), vec3(1.0, 0.0, 0.0) + 0.5, bloom.r);

    // color.rgb -= 0.5;
    // color.rgb *= 1.1;
    // color.rgb += 0.5;


    color.rgb += rand(vUv + fract(time)) * 0.05;


  gl_FragColor = color;
  gl_FragColor.a = 1.0;
}{@}MobileShaderVFX.fs{@}
