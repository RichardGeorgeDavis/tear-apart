    color += gradient * 0.3 * vec3(0.5, 0.6, 1.0);
    gl_FragColor = vec4(color, 1.0);
}{@}Spine.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D map;
uniform sampler2D tNormal;

uniform vec3 uDynamicLightPos;

#!VARYINGS
varying vec2 vUv;
varying vec2 vFlippedUv;

varying vec3 vNormal;
varying vec3 vWorldPos;

varying vec3 vLightPos;

#!SHADER: Vertex
void main() {
    vUv = uv;

    vFlippedUv = uv;
    vFlippedUv.y = 1.0 - vFlippedUv.y;

    vNormal = normalMatrix * normal;

    vWorldPos = (modelMatrix * vec4(position, 1.0)).xyz;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);

    vLightPos = normalize(uDynamicLightPos - vWorldPos);
}

#!SHADER: Fragment
void main() {
    
    vec3 normal = texture2D( tNormal, vFlippedUv ).rgb * 2.0 - 1.0;
    normal = normalize(normal);

    vec4 tex = texture2D( map, vUv );
    vec3 color = tex.rgb;
    float alpha = tex.a;

    float fresnel = 1.0 - max(0.0, dot(normal, vec3(0,0,1)));

    color *= vec3(0.1, 0.1, 0.15) * 0.25;

    vec3 light1dir = normalize(vec3(1.5, -0.5, -0.3));
    vec3 light1 = pow(max(0.0, dot(normal, light1dir)), 2.0) * vec3(0.5, 0.5, 1.0);
    color += tex.rgb * light1 * 2.0;

    vec3 light2dir = normalize(vec3(-0.9, 0.1, 0.01));
    vec3 light2 = pow(max(0.0, dot(normal, light2dir)), 2.0) * vec3(0.5, 0.8, 1.0);
    color += tex.rgb * light2 * 0.5;

    float falloff = clamp(1.0 - 0.05 * distance(uDynamicLightPos * vec3(1.0, 1.0, 0.0), vWorldPos * vec3(1.0, 1.0, 0.0)), 0.0, 1.0);
    falloff = pow(falloff, 3.0);
    falloff = falloff * 0.5 + pow(falloff, 4.0) * 0.7;

    float dynamicLight = max(0.0, dot(normalize(vLightPos + vec3(0.0, 0.0, 1.5)), normal));
    color += vec3(dynamicLight * falloff) * tex.rgb * 1.5 * vec3(0.9, 0.9, 1.0);

    // color = normalize(tex.rgb);
    // color = tex.rgb;
    // color -= 0.5;
    // color *= 1.025;
    // color += 0.5;

    // color = vec3(dynamicLight);
    // color += tex.rgb * pow(fresnel, 2.0) * 1.0;
    gl_FragColor = vec4(color, alpha);
