    float t = time * 85.0;
    float t2 = time * 157.0;
    t = floor(t / 2.0);
    pos.y += sin(t) * 0.01 + sin(t2) * 0.01;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec3 color = vec3(1.0);
    gl_FragColor = vec4(color, 1.0);
}{@}HandDrawnSmokeShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMap;
uniform vec2 uDimensions;
uniform float uTimeOffset;

#!VARYINGS
varying vec2 vUv;
varying vec3 vColor;
varying float vTime;

#!SHADER: Vertex
void main() {
    float frames = 32.0;
    float fps = 24.0;
    float t = time * fps + vdata.g * 26.0 + vdata.r * 16.14 * uTimeOffset + uTimeOffset;
    vTime = t;
    vec3 pos = position;
    float driver = 1.0 - pow(1.0 - fract(t / frames), 3.0);
    pos.x *= mix(2.0, 1.0, driver);
    pos.x -= driver * 0.5;
    pos.y += pow(driver, 3.0) * 0.35;
    pos *= mix(0.2, 1.25, driver);

    vUv = uv;
    vColor = vdata;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment

// vec4 getSubUV(sampler2D _tMap, float _width, vec2 _uv, float _index) {
//     float index = _index * (1.0 / _width);
//     vec2 uv = _uv;
//     uv.x /= _width;
//     uv.x += floor(fract(index) * _width) / _width;
//     return texture2D(_tMap, uv);
// }

vec2 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {

    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

vec4 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding) {

    float index = _index * (1.0 / _dimensions.x);

    vec2 uv = _uv;
    // uv -= 0.5;
    // uv /= 1.0 + _padding;
    // uv += 0.5;
    uv /= _dimensions;

    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex = texture2D(_tMap, uv);

    return tex;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding) {

    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 -= 0.5;
    subUV1 /= 1.0 + _padding;
    subUV1 += 0.5;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index, float _padding, vec2 _uvScale, vec2 _uvOffset) {

    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 -= 0.5;
    subUV1 /= 1.0 + _padding;
    subUV1 += 0.5;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    subUV1 *= _uvScale;
    subUV1 += _uvOffset;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    subUV2 *= _uvScale;
    subUV2 += _uvOffset;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

void main() {
    float frames = 32.0;
    float fps = 24.0;
    float t = vTime;

    // vec4 color = getSubUV(tMap, uDimensions, vUv, t).rgba;
    vec2 uv = getSubUV(tMap, uDimensions, vUv, t);
    vec4 color = texture2D(tMap, uv);

    float value = smoothstep(0.8, 0.9, color.r);
    color.rgb = vec3(max(0.3, value));

    if (color.a < 0.5) discard;
    // if (vColor.r < 0.9) discard;


    gl_FragColor = vec4(color.rgb, color.a);
}{@}AuroraShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec2 uTiling;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUvTiled;
varying vec3 vMvPos;
varying vec3 vNormal;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vUvTiled = (uv + vec2(0.0, uv.x)) * uTiling;
    vMvPos = vec3(modelViewMatrix * vec4(position, 1.0));
    vNormal = normalMatrix * normal;

    // make fresnel work double sided
    vNormal.z = abs(vNormal.z);
}

#!SHADER: Fragment
void main() {
    float fresnel = dot(normalize(-vMvPos.xyz), vNormal);
    fresnel = pow(fresnel, 2.0);

    float t = time * 0.2;
    float alpha = texture2D(tMap, vUvTiled + vec2(t * 0.3, t * 0.01)).r;
    alpha *= texture2D(tMap, vUvTiled * 1.7 + vec2(t * 0.1, -t * 0.1)).r;
    alpha *= 8.0;

    // fade top and bottom
    float topBottomFade = smoothstep(0.0, 0.1, vUv.y) * smoothstep(1.0, 0.0, vUv.y);
    alpha *= topBottomFade;

    // fade at glancing angles
    alpha *= fresnel;
    alpha = mix(alpha, fresnel, 0.2) * topBottomFade;
    alpha += smoothstep(0.3, 0.0, vUv.y) * topBottomFade * 0.3 * fresnel;

    // fade ends
    float endFade = 1.0 - pow(abs(vUv.x - 0.5) * 2.0, 5.0);
    alpha *= endFade;

    vec3 color = vec3(1.0);

    gl_FragColor = vec4(color, alpha);
    // gl_FragColor = vec4(vUv, 1.0, 1.0);
}{@}BalloonShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tNormal;
uniform sampler2D tTilingNormal;
uniform sampler2D tDisplacement;
uniform float uCutoff;
uniform float uFlip;
uniform float uProgress;
uniform float uIsHovered;
uniform float uBounce;

#!VARYINGS
varying vec2 vUv;
varying vec3 vDisplacement;
varying vec3 vPos;
varying vec3 vColor;
varying vec3 vMvPos;
varying vec3 vNormal;

#!SHADER: Vertex

vec3 getInterpolatedSprite(sampler2D tSpritesheet, vec2 uv, float width, float height, float index) {
    
    // padding
    vec2 tc = uv;
    tc -= 0.5;
    tc *= 0.85;
    tc += 0.5;

    float t = index * width;
    float tnextx = mod(t + (1.0 / width), 1.0);
    float tnexty = mod(t + (1.0 / width), 8.0);

    vec2 frameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(t) * width);
    vec2 nextFrameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(tnextx) * width);

    vec2 frameOffsetY = vec2(0.0, 1.0 / height) * floor(fract(t / height) * height);
    vec2 nextFrameOffsetY = vec2(0.0, 1.0 / height) * floor(fract((tnexty) / height) * height);

    vec2 frameuv = (vec2(tc.x / width, tc.y / height) + frameOffsetX - frameOffsetY);
    vec2 nextframeuv = (vec2(tc.x / width, tc.y / height) + nextFrameOffsetX - nextFrameOffsetY);

    vec3 frame = texture2D(tSpritesheet, frameuv).rgb;
    vec3 nextFrame = texture2D(tSpritesheet, nextframeuv).rgb;

    

    frame = mix(frame, nextFrame, fract(t * width));

    return frame;
}

void main() {
    float width = 8.0;
    float height = 8.0;
    float index = clamp(uProgress, 0.125, 1.0);

    vec3 n = normal;

    vec3 displacement = getInterpolatedSprite(tDisplacement, uv, width, height, index);
    displacement = displacement * 2.0 - 1.0;
    displacement *= 1.8;

    // idle animation
    // displacement += displacement * uBounce * 0.1;

    // flip z for houdini
    displacement *= vec3(1.0, 1.0, -1.0);

    // invert displacement for back side
    displacement = mix(displacement * vec3(1.0, -1.0, 1.0), displacement, mix(vdata.x, 1.0, uFlip));

    // invert normal for back side
    n = mix(n * vec3(1.0, -1.0, 1.0), n, mix(vdata.x, 1.0, uFlip));

    // reduce displacement on hover
    displacement *= mix(0.0, 1.0, uIsHovered);

    vec3 pos = position;

    pos += displacement;
    // n -= displacement * 0.5;
    n = normalize(n);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vDisplacement = displacement;
    vPos = pos;
    vColor = vdata;
    vMvPos = normalize(vec3(modelMatrix * vec4(pos, 1.0)) - cameraPosition);
    vNormal = normalMatrix * n;
}

#!SHADER: Fragment

vec3 getInterpolatedSprite(sampler2D tSpritesheet, vec2 uv, float width, float height, float index) {
    
    float t = index * width;
    float tnextx = mod(t + (1.0 / width), 1.0);
    float tnexty = mod(t + (1.0 / width), 8.0);

    vec2 frameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(t) * width);
    vec2 nextFrameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(tnextx) * width);

    vec2 frameOffsetY = vec2(0.0, 1.0 / height) * floor(fract(t / height) * height);
    vec2 nextFrameOffsetY = vec2(0.0, 1.0 / height) * floor(fract((tnexty) / height) * height);

    vec3 frame = texture2D(tSpritesheet, vec2(uv.x / width, uv.y / height) + frameOffsetX - frameOffsetY).rgb;
    vec3 nextFrame = texture2D(tSpritesheet, vec2(uv.x / width, uv.y / height) + nextFrameOffsetX - nextFrameOffsetY).rgb;

    frame = mix(frame, nextFrame, fract(t * width));

    return frame;
}

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {

    float width = 8.0;
    float height = 8.0;
    float index = clamp(uProgress, 0.125, 1.0);

    vec3 tilingNormal = texture2D(tTilingNormal, vUv * 8.0).rgb;
    tilingNormal = tilingNormal * 2.0 - 1.0;

    vec3 normal = getInterpolatedSprite(tNormal, vUv, width, height, index);

    // sample the default normal slightly in from the edges to hide the seam
    float padding = 0.01;
    vec2 tc = vUv;
    tc -= 0.5;
    tc *= 1.0 - padding;
    tc += 0.5;
    vec3 defaultNormal = texture2D(tNormal, tc * (1.0 / vec2(width, height)) - vec2(0.0, 1.0 / height * 1.0)).rgb;

    normal = mix(defaultNormal, normal, pow(uIsHovered, 2.0));

    // hide seam
    normal = mix(defaultNormal, normal, 1.0 - pow(1.0 - vColor.x, 3.0));

    // shift normal back to -1 to 1 space
    normal = normal * 2.0 - 1.0;

    // invert normal for back side
    if (uFlip > 0.5) {
        normal.z *= -1.0;
    }

    // add detail
    normal = mix(normal * 1.5, tilingNormal, 0.5);

    normal = normalize(normal);

    // swizzle to correct direction
    normal.xyz = normal.xzy;
    normal.z = -normal.z;

    float lighting = dot(normal, normalize(vec3(1.0, 4.0, 8.0)));
    vec3 color = vec3((lighting * 0.5 + 0.5) + pow(clamp(-lighting, 0.0, 1.0), 5.0) * 0.2);
    color += pow(max(0.0, lighting), 3.0);

    gl_FragColor = vec4(color, 1.0);
}{@}TShirtShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tNormal;
uniform sampler2D tTilingNormal;
uniform sampler2D tDisplacement;
uniform float uCutoff;
uniform float uFlip;
uniform float uProgress;
uniform float uIsHovered;
uniform float uBounce;

#!VARYINGS
varying vec2 vUv;
varying vec3 vDisplacement;
varying vec3 vPos;
varying vec3 vColor;
varying vec3 vMvPos;
varying vec3 vNormal;

#!SHADER: Vertex

vec3 getInterpolatedSprite(sampler2D tSpritesheet, vec2 uv, float width, float height, float index) {
    
    // padding
    vec2 tc = uv;
    // tc -= 0.5;
    // tc *= 0.85;
    // tc += 0.5;

    float t = index * width;
    float tnextx = mod(t + (1.0 / width), 1.0);
    float tnexty = mod(t + (1.0 / width), 8.0);

    vec2 frameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(t) * width);
    vec2 nextFrameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(tnextx) * width);

    vec2 frameOffsetY = vec2(0.0, 1.0 / height) * floor(fract(t / height) * height);
    vec2 nextFrameOffsetY = vec2(0.0, 1.0 / height) * floor(fract((tnexty) / height) * height);

    vec2 frameuv = (vec2(tc.x / width, tc.y / height) + frameOffsetX - frameOffsetY);
    vec2 nextframeuv = (vec2(tc.x / width, tc.y / height) + nextFrameOffsetX - nextFrameOffsetY);

    vec3 frame = texture2D(tSpritesheet, frameuv).rgb;
    vec3 nextFrame = texture2D(tSpritesheet, nextframeuv).rgb;

    frame = mix(frame, nextFrame, fract(t * width));

    return frame;
}

void main() {
    float width = 8.0;
    float height = 8.0;
    // float index = clamp(uProgress, 0.125, 1.0);
    float index = fract(time * 0.2);

    vec3 n = normal;

    vec3 displacement = getInterpolatedSprite(tDisplacement, uv, width, height, index);
    displacement = displacement * 2.0 - 1.0;
    displacement *= 1.8;

    // idle animation
    // displacement += displacement * uBounce * 0.1;

    // flip z for houdini
    displacement *= vec3(1.0, 1.0, -1.0) * 0.5;

    // invert displacement for back side
    // displacement = mix(displacement * vec3(1.0, -1.0, 1.0), displacement, mix(vdata.x, 1.0, uFlip));

    // invert normal for back side
    // n = mix(n * vec3(1.0, -1.0, 1.0), n, mix(vdata.x, 1.0, uFlip));

    // reduce displacement on hover
    // displacement *= mix(0.0, 1.0, uIsHovered);

    vec3 pos = position;

    pos += displacement;
    pos.y += sin((displacement.x + displacement.y * 3.0 + displacement.z) * 2.0 + time) * 0.1;
    pos.y += sin(time * 2.2 + uv.x * 6.0 + uv.y * 3.0 + displacement.z * 5.0) * 0.1;
    // pos.z += cos(time * 2.3 + uv.y * 4.31 + uv.x * 3.41 + displacement.x * 5.0) * 0.12;
    n = normalize(n);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vDisplacement = displacement;
    vPos = pos;
    vColor = vdata;
    vMvPos = normalize(vec3(modelMatrix * vec4(pos, 1.0)) - cameraPosition);
    vNormal = normalMatrix * n;
}

#!SHADER: Fragment

vec3 getInterpolatedSprite(sampler2D tSpritesheet, vec2 uv, float width, float height, float index) {
    
    float t = index * width;
    float tnextx = mod(t + (1.0 / width), 1.0);
    float tnexty = mod(t + (1.0 / width), 8.0);

    vec2 frameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(t) * width);
    vec2 nextFrameOffsetX = vec2(1.0 / width, 0.0) * floor(fract(tnextx) * width);

    vec2 frameOffsetY = vec2(0.0, 1.0 / height) * floor(fract(t / height) * height);
    vec2 nextFrameOffsetY = vec2(0.0, 1.0 / height) * floor(fract((tnexty) / height) * height);

    vec3 frame = texture2D(tSpritesheet, vec2(uv.x / width, uv.y / height) + frameOffsetX - frameOffsetY).rgb;
    vec3 nextFrame = texture2D(tSpritesheet, vec2(uv.x / width, uv.y / height) + nextFrameOffsetX - nextFrameOffsetY).rgb;

    frame = mix(frame, nextFrame, fract(t * width));

    return frame;
}

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {

    float width = 8.0;
    float height = 8.0;
    // float index = clamp(uProgress, 0.125, 1.0);
    float index = fract(time * 0.2);

    vec3 tilingNormal = texture2D(tTilingNormal, vUv * 8.0).rgb;
    tilingNormal = tilingNormal * 2.0 - 1.0;

        // sample the default normal slightly in from the edges to hide the seam
    float padding = 0.0;
    vec2 tc = vUv;
    tc -= 0.5;
    tc *= 1.0 - padding;
    tc += 0.5;

    vec3 normal = getInterpolatedSprite(tNormal, tc, width, height, index);


    // vec3 defaultNormal = texture2D(tNormal, tc * (1.0 / vec2(width, height)) - vec2(0.0, 1.0 / height * 1.0)).rgb;

    // normal = mix(defaultNormal, normal, pow(uIsHovered, 2.0));

    // hide seam
    // normal = mix(defaultNormal, normal, 1.0 - pow(1.0 - vColor.x, 3.0));

    // shift normal back to -1 to 1 space
    // normal = normal * 2.0 - 1.0;

    // invert normal for back side
    // if (uFlip > 0.5) {
    //     normal.z *= -1.0;
    // }

    // add detail
    // normal = mix(normal * 1.5, tilingNormal * 2.0, 0.5);

    normal = normalize(normal * vec3(3.0, 1.0, 1.0));

    // swizzle to correct direction
    // normal.xyz = normal.xzy;
    // normal.z = -normal.z;

    float lighting = dot(normal, normalize(vec3(0.1, 8.0, 7.0)));
    // vec3 color = vec3((lighting * 0.5 + 0.5) + pow(clamp(-lighting, 0.0, 1.0), 5.0) * 0.2);
    // color += pow(max(0.0, lighting), 3.0);

    vec3 color = vec3(lighting);

    gl_FragColor = vec4(color, 1.0);
}{@}MatcapShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tNormal;
uniform float uTiling;
uniform float uNormalIntensity;

#!VARYINGS
varying vec2 vUv;
varying vec3 vEye;
varying vec3 vNormal;
varying vec3 vViewDir;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec3 n = normal;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vNormal = normalMatrix * n;
    vEye = vec3(modelViewMatrix * vec4(pos, 1.0));
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    vec3 normal = unpackNormal(vEye, vNormal, tNormal, uNormalIntensity, uTiling, vUv).xyz;
    // normal = normalize(vNormal);

    vec2 muv = matcap(normalize(vEye), normal);
    vec3 color = texture2D(tMatcap, muv).rgb;



    gl_FragColor = vec4(color, 1.0);
}{@}RadialGlowShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uColor;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    float alpha = length(vUv - 0.5);
    alpha = smoothstep(0.5, 0.0, alpha);
    gl_FragColor = vec4(uColor, alpha);
}{@}BaselineTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uBaseline;

#!VARYINGS
