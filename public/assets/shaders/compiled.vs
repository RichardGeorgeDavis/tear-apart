}{@}WaterfallShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;

#!SHADER: Vertex
void main() {
    vec3 pos = position;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;

    // gravity
    vUv.y *= mix(1.0, vUv.y, 0.55);
    vNormal = normalMatrix * normal;
}

#!SHADER: Fragment
void main() {
    float speed = 0.1;
    float distortion = 0.05;

    vec2 uv = vUv;
    uv.y += time * speed;

    float alpha = 1.0;

    vec3 color = texture2D(tMap, uv + vec2(0.0, time * (speed * 0.15))).rgb;
    vec3 water = texture2D(tMap, uv + color.rg * distortion).rgb;
    water = mix(vec3(0.4), water, smoothstep(0.7, 0.6, vUv.y - water.b * 0.15));

    vec3 normal = normalize(color);

    water = vec3(mix(water.r, water.g, pow(1.0 - vUv.y, 0.8)));


    float edgeGradient = 1.0 - abs((vUv.x - 0.5) * 2.0);
    edgeGradient = smoothstep(0.12, 0.35, edgeGradient + water.r * 0.1 + color.b * 0.1);

    water += pow(water, vec3(2.2)) * 0.8;

    alpha *= edgeGradient;

    // top fade
    alpha *= clamp(1.0 - pow(vUv.y, 2.0), 0.0, 1.0);

    // bottom fade
    alpha *= 1.0 - pow(1.0 - vUv.y, 3.0);
    // alpha += smoothstep(0.3, 0.8, water.r) * alpha * 5.0;

    alpha = clamp(alpha, 0.0, 1.0);
    alpha += smoothstep(0.55, 0.75, 1.2 - vUv.y + (color.r - 0.5) * 0.1) * 4.0 * edgeGradient;

    gl_FragColor = vec4(water, alpha);
}{@}BustShader.glsl{@}#!ATTRIBUTES

