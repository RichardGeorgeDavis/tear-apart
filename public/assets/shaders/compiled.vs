    float t = floor(time * 6.0) / 6.0;
    noiseUv += vec2(t, -t);
    vec2 displacement = texture2D(tNoise, noiseUv).xy;
    displacement *= texture2D(tNoise, noiseUv).xy;

    vec4 color = texture2D(tDiffuse, vUv + displacement * 0.0015);

    color.rgb += rand(vUv + fract(floor(time * 12.0) / 12.0)) * 0.15;



