    // gl_FragColor = vec4(vTransformedNormal, 1.0);
}{@}ScrollFXShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uShear;
uniform float uSpeed;
uniform float uAlpha;
uniform vec2 uRange1;
uniform vec2 uRange2;
uniform vec2 uRange3;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec2 uv = vUv;
    float t = time * uSpeed;
    uv.x += vUv.y * uShear;

    float alpha = texture2D(tMap, uv + vec2(t * 0.1, -t * 0.7)).r;
    alpha *= texture2D(tMap, uv * 2.0 + vec2(t * 0.1, -t)).r;

    alpha *= smoothstep(uRange1.x, uRange1.y, vUv.y);
    alpha *= smoothstep(uRange2.x, uRange2.y, vUv.y);
    alpha = smoothstep(uRange3.x, uRange3.y, alpha);
    alpha = pow(alpha, 0.45);
    alpha *= uAlpha;

    gl_FragColor = vec4(vec3(1.0), alpha);
}{@}SharkShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec3 vColor;
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vNormal;
varying vec3 vTransformedNormal;
