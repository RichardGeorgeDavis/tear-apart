{@}SkinData.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec3 vWorldPosition;
varying vec3 vNormal;

#!SHADER: Vertex
#require(skinning.glsl)
void main() {

    vNormal = normalize(normal);
    mat4 boneMatX = getBoneMatrix(skinIndex.x);
    mat4 boneMatY = getBoneMatrix(skinIndex.y);
    mat4 boneMatZ = getBoneMatrix(skinIndex.z);
    mat4 boneMatW = getBoneMatrix(skinIndex.w);

    // update normal
    mat4 skinMatrix = mat4(0.0);
    skinMatrix += skinWeight.x * boneMatX;
    skinMatrix += skinWeight.y * boneMatY;
    skinMatrix += skinWeight.z * boneMatZ;
    skinMatrix += skinWeight.w * boneMatW;
    vNormal = vec4(skinMatrix * vec4(vNormal, 0.0)).xyz;

    // Update position
    vec4 bindPos = vec4(position, 1.0);
    vec4 transformed = vec4(0.0);
    transformed += boneMatX * bindPos * skinWeight.x;
    transformed += boneMatY * bindPos * skinWeight.y;
    transformed += boneMatZ * bindPos * skinWeight.z;
    transformed += boneMatW * bindPos * skinWeight.w;
    vec3 localPos = transformed.xyz;

    vec4 worldPosition = modelMatrix * vec4(localPos, 1.0);
    vWorldPosition = worldPosition.xyz;
    gl_Position = vec4(2.0 * uv - 1.0, 0.0, 1.0);
}

    #!SHADER: Fragment

layout(location = 0) out vec4 data1;
layout(location = 1) out vec4 data2;

void main() {
    data1 = vec4(vWorldPosition, 1.0);
    data2 = vec4(vNormal, 1.0);
}
{@}SkinVelocity.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tVel;
uniform sampler2D tCurrentPos;
uniform sampler2D tPrevPos;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment
void main() {

    vec3 vel = texture2D(tVel, vUv).xyz;
    vec3 currentPos = texture2D(tCurrentPos, vUv).xyz;
    vec3 prevPos = texture2D(tPrevPos, vUv).xyz;
    vel += currentPos - prevPos;

    vel *= 0.9998;

    gl_FragColor = vec4(vel, 1.0);
}
{@}SplineParticleInstance.glsl{@}#!ATTRIBUTES
attribute vec2 lookup;

#!UNIFORMS
uniform sampler2D tPos;

#!VARYINGS

#!SHADER: Vertex

#require(instance.vs)
#require(rotation.glsl)

void main() {
    vec3 offset = texture2D(tPos, lookup).xyz;
    vec3 p = vec3(rotationMatrix(vec3(0.0, 0.0, 1.0), radians(time*10000000.0)) * vec4(position, 1.0));
    vec3 pos = transformPosition(p, offset);
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    gl_FragColor = vec4(1.0);
}{@}SplineParticleLife.fs{@}uniform sampler2D tAttribs;
uniform sampler2D tPos;
uniform sampler2D tOrigin;
uniform float uMaxCount;
uniform float uSplineCount;
uniform float uSetup;
uniform float uDecayRate;
uniform float uTimeMultiplier;
uniform float uIHold;
uniform vec2 uDecayRange;
uniform vec2 uRelease;
uniform float uStartOffset;
uniform vec2 uFlowRange;
uniform vec2 uSplineSpeed;
uniform float uInfinite;
uniform float uDelayStart;
uniform float uMaxDelay;
uniform float uMaxSDelay;
uniform float uHoldBack;
uniform float uHoldBack2;
uniform float uStartSpacing;
uniform vec4 uLifeSlow;
uniform float HZ;

#require(range.glsl)
#require(conditionals.glsl)
#require(simplenoise.glsl)

float sround(float i) {
    return floor(i + 0.5);
}

float randomSeed(float seed) {
    float n = sin(seed) * 10.0;
    return n - floor(n);
}

float srand(float seed, float min, float max) {
    return (min + randomSeed(seed) * (max - min));
}

void main() {
    vec2 uv = vUv;

    if (vUv.x + vUv.y * fSize > uMaxCount) {
        gl_FragColor = vec4(9999.0);
        return;
    }

    vec4 inputData = getData4(tInput, uv);
    vec4 random = getData4(tAttribs, uv);
    vec4 random2 = (getData4(tOrigin, uv) / 2.0) + 0.5;
    vec4 pos = getData4(tPos, uv);

    vec4 outputData;
    outputData.x = sround(crange(random.x, 0.0, 1.0, 0.0, uSplineCount-1.0));

//    float decay = crange(random.w, 0.0, 1.0, uDecayRange.x, uDecayRange.y);
//
//    outputData.y = inputData.y + mix(0.02 * uDecaySpeed.x * decay, 0.002 * uDecaySpeed.y * decay, when_gt(inputData.y, 0.999));
//    outputData.y = clamp(outputData.y, 0.0, 2.0);

    outputData.y = inputData.y - (0.01 * uDecayRate * mix(uDecayRange.x, uDecayRange.y, random2.y) * timeScale * HZ);
    outputData.y = clamp(outputData.y, 0.0, 1.0);

    if (uSetup > 0.5) {
        outputData.z = crange(random.w, 0.0, 1.0, 0.0, uStartOffset);
        outputData.z += srand(outputData.x, 0.0, uStartSpacing);
    } else {
        float delayed = 1.0;
        float delayedSpline = 1.0;

        float sRandom = crange(cnoise(vec2(random.x)), -1.0, 1.0, 0.0, 1.0);

        bool isStarting = inputData.z == 0.0;

        if (uDelayStart > 0.0) {
            delayed = time - uDelayStart > uMaxDelay * random2.y ? 1.0 : 0.0;
            delayedSpline = time - uDelayStart > uMaxSDelay * random.x ? 1.0 : 0.0;
        }

        float lifeSlow = crange(inputData.z, uLifeSlow.x, uLifeSlow.y, uLifeSlow.z, uLifeSlow.w);
        outputData.z = inputData.z + (0.001 * timeScale * uTimeMultiplier * lifeSlow * HZ * crange(random2.z, 0.0, 1.0, uFlowRange.x, uFlowRange.y) * crange(sRandom, 0.0, 1.0, uSplineSpeed.x, uSplineSpeed.y));

        if (uRelease.y > 1.0) {
            if (inputData.z < 0.001 || inputData.z > 1.0) {
                float minR = uRelease.x / uRelease.y;
                float maxR = (uRelease.x+1.0) / uRelease.y;
                if (random.w < minR || random.w > maxR) {
                    outputData.z = 0.0;
                }
            }
        }
//
        if (isStarting) outputData.z *= delayed * delayedSpline * step(1.0 - ((1.0 - uHoldBack) * (1.0 - uHoldBack2)), random2.x);

        if (outputData.z > 1.0) {
            outputData.w = 0.0;
            if (uInfinite > 0.5) outputData.z = 0.0;
        } else if (outputData.z < 0.01) {
            outputData.y = 1.0;
        }

        if (uIHold > 0.5) outputData.z = 0.0;
    }

    gl_FragColor = outputData;
}{@}SplineParticlePreset.fs{@}void main() {
sRandom = random;
sOrigin = origin;

float travel = texture2D(tLife, vUv).z;
vec3 target = getSplinePos(travel);

if (uSetup > 0.5 || travel < 0.001) {
    pos = target;
}

pos += (target - pos) * 0.07 * HZ;
}{@}splineparticles.fs{@}uniform sampler2D tSpline;
uniform sampler2D tLife;
uniform float uSplineTexSize;
uniform float uPerSpline;
uniform float uSplineCount;
uniform float uInfinite;
uniform float uSetup;

vec4 sRandom;
vec3 sOrigin;

float splinenoise(vec3 v) {
    float t = v.z * 0.3;
    v.y *= 0.8;
    float noise = 0.0;
    float s = 0.5;
    noise += range(sin(v.x * 0.9 / s + t * 10.0) + sin(v.x * 2.4 / s + t * 15.0) + sin(v.x * -3.5 / s + t * 4.0) + sin(v.x * -2.5 / s + t * 7.1), -1.0, 1.0, -0.3, 0.3);
    noise += range(sin(v.y * -0.3 / s + t * 18.0) + sin(v.y * 1.6 / s + t * 18.0) + sin(v.y * 2.6 / s + t * 8.0) + sin(v.y * -2.6 / s + t * 4.5), -1.0, 1.0, -0.3, 0.3);
    return noise;
}

float sround(float i) {
    return floor(i + 0.5);
}

float randomSeed(float seed) {
    float n = sin(seed) * 10000000.0;
    return n - floor(n);
}

float srand(float seed, float min, float max) {
    return sround((min + randomSeed(seed) * (max - min)));
}

float getSplineIndex() {
    return sround(crange(sRandom.x, 0.0, 1.0, 0.0, uSplineCount-1.0));
}

vec2 getSplineLookupUV(float index, float time) {
    float pixel = uPerSpline * (index + time);
    return vec2(mod(pixel, uSplineTexSize), floor(pixel / uSplineTexSize)) / uSplineTexSize;
}

float ssineOut(float t) {
    return sin(t * 1.5707963267948966);
}

float scnoise(vec3 v) {
    float t = v.z * 0.3;
    v.y *= 0.8;
    float noise = 0.0;
    float s = 0.5;
    noise += range(sin(v.x * 0.9 / s + t * 10.0) + sin(v.x * 2.4 / s + t * 15.0) + sin(v.x * -3.5 / s + t * 4.0) + sin(v.x * -2.5 / s + t * 7.1), -1.0, 1.0, -0.3, 0.3);
    noise += range(sin(v.y * -0.3 / s + t * 18.0) + sin(v.y * 1.6 / s + t * 18.0) + sin(v.y * 2.6 / s + t * 8.0) + sin(v.y * -2.6 / s + t * 4.5), -1.0, 1.0, -0.3, 0.3);
    return noise;
}

vec3 getSplineThickness(vec3 pos, float time) {
    float angle = radians(360.0 * sRandom.z);

    float gamma = ssineOut(crange(scnoise(sOrigin.xyz * uDistribution), -1.0, 1.0, 0.0, 1.0));
    float fizzy = pow(mix(uDistributionRange.x, uDistributionRange.y, gamma), 3.0);

    float splineRandom = 0.0;//srand(getSplineIndex() * 10000.0, 0.0, 1000.0) / 1000.0;
    float splineRandomStep = step(uThicknessStep.x, splineRandom);
    float distribution = mix(uThicknessStep.y, 1.0, 1.0 - splineRandomStep);

    float radius = 0.5 * uSplineThickness * distribution * fizzy;

    radius *= crange(splinenoise((pos * uRangeScale) + time*uThicknessSpeed), -1.0, 1.0, 1.0 - uRangeThickness, 1.0 + uRangeThickness);
    radius *= mix(1.0, uExtrudeRandom, sRandom.y);

    return normalize(sOrigin) * radius;
}

vec3 getSplinePosRaw(float time) {
    float step = 1.0 / uPerSpline;
    float index = getSplineIndex();

    float next = time + step;
    vec2 uv0 = vec2(0.);
    vec2 uv1 = vec2(1.);

    if(next <= 1.) {
        uv0 = getSplineLookupUV(index, time);
        uv1 = getSplineLookupUV(index, next);
    } else {
        uv0 = getSplineLookupUV(index, 1.);
        uv1 = getSplineLookupUV(index, time - step);
    }
    
    float interpolate = mod(time, step) * uPerSpline;

    vec3 cpos = texture2D(tSpline, uv0).xyz;
    vec3 npos = texture2D(tSpline, uv1).xyz;
    vec3 pos = mix(cpos, npos, interpolate);

    if (uSCurlNoiseSpeed > 0.0) {
        pos += curlNoise((pos * uSCurlNoiseScale*0.1) + (time * uSCurlTimeScale*0.1)) * uSCurlNoiseSpeed * 0.01 * HZ;
    }

    return pos;
}

vec3 getSplinePos(float time) {
    vec3 pos = getSplinePosRaw(time);
    pos += getSplineThickness(pos, time);
    return pos;
}{@}splineshader.glsl{@}uniform sampler2D tSpline;
uniform float uSplineTexSize;
uniform float uPerSpline;

#require(conditionals.glsl)

float sround(float i) {
    return floor(i + 0.5);
}

vec2 getSplineLookupUV(float index, float time) {
    float pixel = (index * uPerSpline) + (time * uPerSpline);

    float size = uSplineTexSize;
    float p0 = pixel / size;
    float y = floor(p0);
    float x = p0 - y;

    vec2 uv = vec2(0.0);
    uv.x = x;
    uv.y = y / size;
    return uv;
}

vec3 getSplinePos(float index, float time) {
    vec2 uv = getSplineLookupUV(index, time);
    vec3 pos = texture2D(tSpline, uv).xyz;
    return pos;
}

float isMoving(float index, float time) {
    vec3 cpos = getSplinePos(index, time);
    vec3 npos = getSplinePos(index, time + (1.0 / uPerSpline));

    float moving = when_gt(length(cpos - npos), 0.001);
    moving = mix(moving, 1.0, when_gt(time, 0.5));

    return moving;
}{@}BaseTetaviModelShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tDiffuse;
uniform sampler2D tGeometry1;
uniform sampler2D tGeometry2;
uniform sampler2D tGeometryUV1;
uniform sampler2D tGeometryUV2;

uniform int uStartGeom1, uEndGeom1, uStartGeom2, uEndGeom2;
uniform int uStartUV1, uEndUV1, uStartUV2, uEndUV2;

#!VARYINGS

#!SHADER: Vertex

//// Util Functions ////
int modInt(in int i,in int m)
{
    return i-((i/m)*m);
}

void roundVecToFloat(inout vec3 v){
    v=v*255.0;
    const vec3 h=vec3(0.5);
    v=v+h;
    v=vec3(ivec3(v));
}
ivec3 roundVecToInt(in vec3 v){
    v=v*255.0;
    const vec3 h=vec3(0.5);
    v=v+h;
    return ivec3(v);
}
int getFrameNumberFromAtlas(sampler2D tex)
{
    int value = 0;
    for (int i=7; i>=0; i--) {
        value*=4;
        float dv=texture2D( tex, vec2((8.5+float(i)*16.0)/2048.0, (8.5/2048.0))).r;
        int idv=int(0.5+(dv*255.0/85.0));
        value+=idv;
    }
    return value;
}


vec4 ProjectPosition(vec3 pos)
{
    vec4 p = projectionMatrix * modelViewMatrix * vec4( pos, 1.0 );
    return p;
}

void getMetaDataFromPosTexture(in bool isFirstTexture,in int frameIdx,out int posLinePrime,out int posLineDelta,out int gopLine){
    const float textuleLines=256.0;
    float fIndex=float(frameIdx);
    float metaDeltaX = ((fIndex+0.5) /4096.0);
    float metaDeltaY =0.5/textuleLines;//addition is half a pixel height

    if (metaDeltaX > 1.0) { //each metadata set is exactly 1 pixel
        metaDeltaY += 1.0/textuleLines;
        metaDeltaX -= 1.0;
    }
    vec3 pixf;
    if (isFirstTexture){
        pixf=(texture2D( tGeometry1, vec2(metaDeltaX, metaDeltaY))).bgr;
    }
    else{
        pixf=(texture2D( tGeometry2, vec2(metaDeltaX, metaDeltaY))).bgr;
    }
    ivec3 pix=roundVecToInt(pixf);
    posLinePrime=(pix[0]*16)+modInt(pix[1],16);
    gopLine=(pix[2]*16)+(pix[1]/16);
    posLineDelta=1+modInt(posLinePrime,2)+modInt(gopLine,2)*2;
    posLinePrime=posLinePrime/2;
    gopLine=gopLine/2;
}

bool getUVData(in bool isFirstTexture,in int gopLine,in int vertexIdx,out vec3 minBbox,out vec3 spanBbox,out int posIndex,out vec2 uv){

    const float textuleLines=256.0;
    float metaDeltaX = (0.5/4096.0);//addition is half a pixel width
    float metaDeltaY = (float(gopLine)/textuleLines)+0.5/textuleLines;//addition is half a pixel height
    vec3 pix1f;

    if (isFirstTexture){
        minBbox=texture2D( tGeometryUV1, vec2(metaDeltaX, metaDeltaY)).bgr;
        metaDeltaX+=1.0/4096.0;
        spanBbox=texture2D( tGeometryUV1, vec2(metaDeltaX, metaDeltaY)).bgr;
        metaDeltaX+=1.0/4096.0;
        pix1f=texture2D( tGeometryUV1, vec2(metaDeltaX, metaDeltaY)).bgr;
    }
    else {
        minBbox=texture2D( tGeometryUV2, vec2(metaDeltaX, metaDeltaY)).bgr;
        metaDeltaX+=1.0/4096.0;
        spanBbox=texture2D( tGeometryUV2, vec2(metaDeltaX, metaDeltaY)).bgr;
        metaDeltaX+=1.0/4096.0;
        pix1f=texture2D( tGeometryUV2, vec2(metaDeltaX, metaDeltaY)).bgr;
    }

    roundVecToFloat(minBbox);
    roundVecToFloat(spanBbox);
    ivec3 pix1=roundVecToInt(pix1f);

    int vertexN=pix1[0]+pix1[1]*256+pix1[2]*65536;
    if (vertexN<=vertexIdx){
        return false;
    }
    const vec3 q=vec3(-4.0);
    minBbox=q+minBbox*0.03137254901; //8.0/255.0
    spanBbox=spanBbox*0.03137254901;


    bool isOdd=modInt(vertexIdx,2)>0;
    int sampleN=1+(vertexIdx/2);//header is the size of 1 sample,each sample is 2 vertices
    int ds=sampleN*3;//3 pixels per 2 vertices(1 sample)
    int activePixelsPerLine=3*(4096/3);
    int dl=ds/activePixelsPerLine;
    ds-=dl*activePixelsPerLine;
    metaDeltaY+=(float(dl)/textuleLines);
    metaDeltaX=0.5/4096.0+float(ds)/4096.0;
    if (isOdd){
        metaDeltaX+=1.0/4096.0;
    }
    vec3 pix2f;
    if (isFirstTexture){
        pix1f=texture2D( tGeometryUV1, vec2(metaDeltaX, metaDeltaY)).bgr;
        metaDeltaX+=1.0/4096.0;
        pix2f=texture2D( tGeometryUV1, vec2(metaDeltaX, metaDeltaY)).bgr;
    }
    else{
        pix1f=texture2D( tGeometryUV2, vec2(metaDeltaX, metaDeltaY)).bgr;
        metaDeltaX+=1.0/4096.0;
        pix2f=texture2D( tGeometryUV2, vec2(metaDeltaX, metaDeltaY)).bgr;
    }
    pix1=roundVecToInt(pix1f);
    ivec3 pix2=roundVecToInt(pix2f);

    if (isOdd){
        posIndex=(pix1[2]*256)+pix2[0];
        uv.x=float((pix2[1]*4)+modInt((pix1[1]/16),4))/1023.0;
        uv.y=float((pix2[2]*4)+pix1[1]/64)/1023.0;
    }
    else{
        posIndex=(pix1[0]*256)+pix1[1];
        uv.x=float((pix1[2]*4)+modInt(pix2[1],4))/1023.0;
        uv.y=float((pix2[0]*4)+modInt((pix2[1]/4),4))/1023.0;
    }


    return true;
}
vec3 getPosData(in bool isFirstTexture,in int posLinePrime,in int posLineDelta,in int posIndexEncoded,in vec3 minBbox,in vec3 spanBbox){
    int delteModIdx=modInt(posIndexEncoded,4);
    int posIndex=posIndexEncoded/4;

    const float textuleLines=256.0;
    int sampleN=(posIndex/2);
    int ds=sampleN*3;//3 pixels per 2 vertices(1 sample)
    int activePixelsPerLine=3*(4096/3);
    int dl=ds/activePixelsPerLine;
    ds-=dl*activePixelsPerLine;
    float metaDeltaX = (float(ds) /4096.0)+(0.5/4096.0);//addition is half a pixel width
    float metaDeltaY = (float(posLinePrime+dl)/textuleLines)+0.5/textuleLines;//addition is half apixel height
    vec3 pix1;
    vec3 pix2;
    bool isOdd=modInt(posIndex,2) >0;
    if (isOdd){
        metaDeltaX+=1.0/4096.0;
    }
    if (isFirstTexture){
        pix1=texture2D( tGeometry1, vec2(metaDeltaX, metaDeltaY)).bgr;
        metaDeltaX+=1.0/4096.0;
        pix2=texture2D( tGeometry1, vec2(metaDeltaX, metaDeltaY)).bgr;
    }
    else{
        pix1=texture2D( tGeometry2, vec2(metaDeltaX, metaDeltaY)).bgr;
        metaDeltaX+=1.0/4096.0;
        pix2=texture2D( tGeometry2, vec2(metaDeltaX, metaDeltaY)).bgr;
    }
    ivec3 iPix1=roundVecToInt(pix1);
    ivec3 iPix2=roundVecToInt(pix2);


    ivec3 ixyz;
    if (isOdd){
        ixyz.x=(iPix2[0]*16)+(iPix1[2]/16);
        ixyz.y=(iPix2[1]*16)+(modInt(iPix1[2],16));
        ixyz.z=(iPix2[2]*16)+(modInt(iPix1[1],16));
    }
    else{
        ixyz.x=(iPix1[0]*16)+(iPix2[0]/16);
        ixyz.y=(iPix1[1]*16)+(modInt(iPix2[0],16));
        ixyz.z=(iPix1[2]*16)+(iPix2[1]/16);
    }

    if (delteModIdx!=0){
        ds=(posIndex*3+delteModIdx-1);
        activePixelsPerLine=4096;
        dl=ds/activePixelsPerLine;
        ds-=dl*activePixelsPerLine;
        metaDeltaX = (float(ds) /4096.0)+(0.5/4096.0);//addition is half a pixel width
        metaDeltaY = (float(posLinePrime+posLineDelta+dl)/textuleLines)+0.5/textuleLines;//addition is half apixel height
        if (isFirstTexture){
            pix1=texture2D( tGeometry1, vec2(metaDeltaX, metaDeltaY)).bgr;
        }
        else{
            pix1=texture2D( tGeometry2, vec2(metaDeltaX, metaDeltaY)).bgr;
        }
        ivec3 delta=roundVecToInt(pix1);
        ixyz=ixyz+delta+ivec3(-127);
    }


    vec3 xyz=vec3(ixyz);
    xyz[0]/=4095.0;
    xyz[1]/=4095.0;
    xyz[2]/=4095.0;
    xyz=(xyz*spanBbox)+minBbox;
    return xyz;
}

vec3 decodeTetaviData(out vec2 uv) {
    precision highp float;
    int frameIdx=getFrameNumberFromAtlas(tDiffuse);
    bool useFirstGopTexture=true;
    bool useFirstPosTexture=true;
    if ((frameIdx>=uStartUV2) && (frameIdx<uEndUV2)){
        useFirstGopTexture=false;
    }else{
        if ((frameIdx>=uStartUV1) && (frameIdx<uEndUV1)){

        }else{
            return vec3(0.0);
        }
    }
    if ((frameIdx>=uStartGeom2) && (frameIdx<uEndGeom2)){
        useFirstPosTexture=false;
        frameIdx-=uStartGeom2;
    }
    else{
        frameIdx-=uStartGeom1;
    }

    int posLinePrime;
    int posLineDelta;
    int gopLine;
    getMetaDataFromPosTexture(useFirstPosTexture,frameIdx,posLinePrime,posLineDelta,gopLine);


    int vertexIdx=int(position.x);
    vec3 minBbox;
    vec3 spanBbox;
    int posIndex;
    vec3 xyz;
    if (getUVData(useFirstGopTexture,gopLine,vertexIdx,minBbox,spanBbox,posIndex,uv)){
        xyz = getPosData(useFirstPosTexture,posLinePrime,posLineDelta,posIndex,minBbox,spanBbox);

    }
    return xyz;
}

#!SHADER: Fragment
{@}TetaviModelShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform int uNormalMode;
uniform int uNormalVisMode;

#!VARYINGS
varying vec2 vUv;
varying vec3 vSunPos;
varying vec3 vViewDir;
varying vec3 vMPos;
varying vec3 vWorldPos;
varying vec3 vNormal;

#!SHADER: Vertex
#require(BaseTetaviModelShader.vs)
#require(getNormalFromWorldPosTexture.vs)
#require(lights.vs)

void main() {
    vec3 pos = decodeTetaviData(vUv);

    vec4 mPos = modelMatrix * vec4(pos, 1.0);
    vec4 mvPos = viewMatrix * mPos;
    vMPos = mPos.xyz / mPos.w;
    vViewDir = -mvPos.xyz;
    vWorldPos = mPos.xyz;

    vSunPos = worldLight(normalize(vec3(sin(time*2.0)*20.0, cos(time*2.0)*20.0, sin(time*1.0)*20.0)));
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    if (uNormalMode == 2) {
        vNormal = getNormalFromWorldPosTexture(gl_Position);
    }
}

#!SHADER: Fragment
#require(BaseTetaviModelShader.fs)
#require(dnormal.fs)
#require(fresnel.glsl)
#require(range.glsl)
#require(contrast.glsl)

void main() {
    vec3 color = texture2D(tDiffuse, vUv).rgb;
    vec3 normal = vNormal;
    if (uNormalMode == 1) {
        normal = getDNormal(vViewDir);
    }
    if (uNormalVisMode == 1) {
        color = normal;
    } else if (uNormalMode != 0) {
        float fresnel = getFresnel(normal, vViewDir, 1.0);
        float lighting = clamp(dot(normal, vSunPos), 0.0, 1.0);

        vec3 lit = pow(color, vec3(1.2)) * 1.5;
        //lit = vec3(length(vUv-0.5));
        //lit *= smoothstep(0.5, 1.0, fresnel);

        float ambient = 0.3;
        lighting += ambient;
        lit = pow(lit, vec3(2.2));
        lit += smoothstep(0.0, 1.0, fresnel)*0.15;
        lit *= mix(0.5, 1.0, smoothstep(0.0, 1.0, fresnel));
        lit *= crange(pow(lighting, 0.9), 0.0, 1.0, 0.6, 1.2);
        lit = pow(lit, vec3(0.4545));
        color = mix(color, lit, 0.4);
    }

    color = adjustContrast(color, 1.1, 1.1);

    gl_FragColor = vec4(color, 1.0);
}
{@}TetaviWorldPos.fs{@}varying vec3 vWorldPos;

void main() {
    gl_FragColor = vec4(vWorldPos, 1.0);
}
{@}getNormalFromWorldPosTexture.vs{@}uniform sampler2D tWorldPos;

vec3 getWorldPosFromTexture(vec2 uv, vec2 eps, inout float mult) {
    vec3 val = texture2D(tWorldPos, uv + eps).xyz;
    if (abs(val.x) + abs(val.y) + abs(val.z) < 0.0001) {
        eps = -eps;
        mult = -mult;
        val = texture2D(tWorldPos, uv + eps).xyz;
    }
    return val;
}

vec3 getNormalFromWorldPosTexture(vec4 pos) {
    //Modify the epsilon to tweak visual results.
    vec2 eps = vec2(0.0005, 0.0);

    vec2 uv = (pos.xy / pos.w) * 0.5 + 0.5;
    float mult = -1.0;

    vec3 pos0 = texture2D(tWorldPos, uv).xyz;
    vec3 pos1 = getWorldPosFromTexture(uv, eps.xy, mult);
    vec3 pos2 = getWorldPosFromTexture(uv, eps.yx, mult);
    vec3 nx = normalize(pos0 - pos1);
    vec3 ny = normalize(pos0 - pos2);
    return mult * normalize(cross(nx, ny));
}

{@}textureanimation.vs{@}attribute vec2 uv2;

uniform highp sampler2D uAnimationTexture;
uniform float uTextureHeight;
uniform float uAnimationLength[10];
uniform float uOffsets[10];
uniform float uSpeed[10];
uniform float uHzMultiplier;
uniform float speedMultiplier;

vec3 rotate(vec3 v, float angle) {
    float s = sin(angle);
    float c = cos(angle);
    return mat3(c, 0., -s,
                0., 1., 0.,
                s, 0, c) * v;
}

vec3 rotate(vec3 vec, vec4 quat) {
    float angle = atan(quat.w, quat.y) + 3.14159265359;
    vec4 yQuat = vec4(0., sin(angle), 0., cos(angle));
    return vec + 2.0 * cross( cross( vec, yQuat.xyz ) + yQuat.w * vec, yQuat.xyz );
}

vec3 getAnimatedPosition(int animationIndex, float blend) {
    float frames = uAnimationLength[animationIndex];
    float offset = uOffsets[animationIndex];
    float speed = uSpeed[animationIndex];
    float phaseY = fract(speed * time * speedMultiplier * uHzMultiplier) * max(frames - 1., 0.);
    
    vec2 frameOffsetY = vec2(0.0, (offset + floor(phaseY) + 0.5) / uTextureHeight);
    vec3 animationA = texture2D(uAnimationTexture, vec2(uv2.x, 0.) + frameOffsetY).rgb;

    frameOffsetY = vec2(0.0, (offset + ceil(phaseY) + 0.5) / uTextureHeight);
    vec3 animationB = texture2D(uAnimationTexture, vec2(uv2.x, 0.) + frameOffsetY).rgb;

    vec3 animation = mix(animationA, animationB, vec3(fract(phaseY)));

    return mix(position, animation, blend);
}

vec3 getAnimatedPositionRaw(int animationIndex) {
    float frames = uAnimationLength[animationIndex];
    float offset = uOffsets[animationIndex];
    float speed = uSpeed[animationIndex];
    float phaseY = fract(speed * time * speedMultiplier * uHzMultiplier) * max(frames - 1., 0.);
    
    vec2 frameOffsetY = vec2(0.0, (offset + floor(phaseY) + 0.5) / uTextureHeight);
    vec3 animationA = texture2D(uAnimationTexture, vec2(uv2.x, 0.) + frameOffsetY).rgb;

    frameOffsetY = vec2(0.0, (offset + ceil(phaseY) + 0.5) / uTextureHeight);
    vec3 animationB = texture2D(uAnimationTexture, vec2(uv2.x, 0.) + frameOffsetY).rgb;
    vec3 animation = mix(animationA, animationB, vec3(fract(phaseY)));

    return animation;
}
{@}TexturedLight.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec4 tlbBoundingPlane;
uniform vec4 tlbConfig;
uniform vec4 tlbTransform;
uniform sampler2D tlbLight;

#!VARYINGS
varying vec2 tlbUv;

#!SHADER: texturedlight.vs

#require(transformUV.glsl)

float tlrange(float oldValue, float oldMin, float oldMax, float newMin, float newMax) {
    float oldRange = oldMax - oldMin;
    float newRange = newMax - newMin;
    return (((oldValue - oldMin) * newRange) / oldRange) + newMin;
}

void setupTexturedLight(vec3 pos) {
    vec3 worldPos = vec3(modelMatrix * vec4(pos, 1.0));

    vec2 xAxis;
    vec2 yAxis;

    float worldX;
    float worldY;

    xAxis = tlbBoundingPlane.xy;
    yAxis = tlbBoundingPlane.zw;

    if (tlbConfig.x < 0.5) {
        worldX = worldPos.x;
        worldY = worldPos.y;

        if (tlbConfig.w > 0.5) {
            worldX = worldPos.y;
            worldY = worldPos.x;
        }
    } else if (tlbConfig.x < 1.5) {
        worldX = worldPos.x;
        worldY = worldPos.z;

        if (tlbConfig.w > 0.5) {
            worldX = worldPos.z;
            worldY = worldPos.x;
        }
    } else if (tlbConfig.x < 2.5) {
        worldX = worldPos.z;
        worldY = worldPos.y;

        if (tlbConfig.w > 0.5) {
            worldX = worldPos.y;
            worldY = worldPos.z;
        }
    }

    tlbUv.x = tlrange(worldX, xAxis.x, xAxis.y, 0.0, 1.0);
    tlbUv.y = tlrange(worldY, yAxis.x, yAxis.y, 0.0, 1.0);

    if (tlbConfig.y > 0.5) tlbUv.x = 1.0 - tlbUv.x;
    if (tlbConfig.z > 0.5) tlbUv.y = 1.0 - tlbUv.y;

    tlbUv = translateUV(tlbUv, tlbTransform.xy);
    tlbUv = scaleUV(tlbUv, tlbTransform.zw);
}

#!SHADER: texturedlight.fs
vec3 getTexturedLightColor() {
    return texture2D(tlbLight, tlbUv).rgb;
}

vec3 getTexturedLightDebug() {
    return vec3(tlbUv, 1.0);
}{@}TweenUILPathFallbackShader.glsl{@}#!ATTRIBUTES
