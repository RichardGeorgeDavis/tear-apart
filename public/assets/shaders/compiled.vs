#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
// Raymarch a sphere at the origin with radius 1
float marchSphere(vec3 pos) {
  return length(pos) - 1.0;
}

// Define constants for the maximum number of steps and the
// threshold for determining when we have hit the sphere
const int MAX_STEPS = 100;
const float EPSILON = 0.01;

void main() {
  // Create ray starting at the camera and going through the fragment
  vec3 rayOrigin = cameraPosition;
  vec3 rayDirection = normalize(vec3(gl_FragCoord.xy, 1.0) - cameraPosition);
  vec3 finalColor = vec3(0.0);
  
  // Raymarch the sphere, using a maximum number of steps and a small step size
  float t = 0.0;
  for (int i = 0; i < MAX_STEPS; i++) {
    float dist = marchSphere(rayOrigin + t * rayDirection);
    if (dist < EPSILON) {
      // We hit the sphere, so calculate the normal at the hit point
      vec3 hitPos = rayOrigin + t * rayDirection;
      vec3 hitNormal = normalize(hitPos);
      
      // Output the normal as the final color
      finalColor = hitNormal;
    }
    t += dist;
  }
  
  // If we didn't hit the sphere, output black
  gl_FragColor = vec4(finalColor, 1.0);
}{@}PortalRampShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tRamp;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec2 uv = vUv.yx;
    uv.x *= 0.25;
    float t = time * 0.25;
    uv.x -= t;

    float value = texture2D(tMap, uv).r;
    value += clamp(1.0 - vUv.y, 0.0, 1.0) * 0.5;
    value *= 1.0 - vUv.y;

    float a = clamp(value * 2.5, 0.0, 1.0);
    float lookup = 1.0 - clamp(value * 1.5, 0.0, 1.0);
    vec3 color = texture2D(tRamp, vec2(lookup, 0.0)).rgb;

    gl_FragColor = vec4(color, a);
}{@}ScrollingTextureVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}

void main() {
    vec4 color = texture2D(tDiffuse, vUv);

    vec3 bloom = getUnrealBloom(vUv).rgb;
    // color.rgb += bloom;
    color.r *= 0.9;
    // color.rgb = pow(color.rgb, vec3(2.2));
    // color.rgb += pow(bloom, vec3(2.2));
    // color.rgb = czm_saturation(color.rgb, 1.0);

    // color.rgb = pow(color.rgb, vec3(0.45));

    // color.rgb -= 0.5;
    // color.rgb *= 1.1;
    // color.rgb += 0.5;


    color.rgb += rand(vUv + fract(time)) * 0.075;


  gl_FragColor = color;
}{@}StylizedSmokeShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec2 uv = vUv;
    uv.x -= time * 0.7;
    float smoke = texture2D(tMap, uv * vec2(2.0, 0.15)).r;
    smoke *= 1.0 - vUv.y;
    smoke *= pow(smoothstep(0.0, 1.0, vUv.x), 5.0);
    smoke += pow(1.0 - vUv.y, 2.0) * 0.015;
    smoke *= smoothstep(1.0, 0.5, vUv.x);
    smoke *= smoothstep(0.0, 0.5, vUv.x);
    smoke += (1.0 - vUv.y) * 0.03;
    smoke = smoothstep(0.035, 0.0351, smoke);
    vec3 color = vec3(smoke);
    gl_FragColor = vec4(color, 1.0);
}{@}TrailShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tRamp;
uniform float uTimeOffset;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec2 uv = vUv;
    float t = time * 1.1 + uTimeOffset;
    uv.x -= t;
    uv.y += sin(t * 10.0 - vUv.x * 10.0) * vUv.x * 0.1;

    float value = texture2D(tMap, uv).r;
    value *= 1.0 - pow(1.0 - vUv.x, 6.0);
    value *= 1.0 - pow(vUv.x, 2.0);
    value = smoothstep(0.05, 0.95, value);

    float a = smoothstep(0.0, 0.01, value);
    a *= 1.0 - pow(vUv.x, 2.0) * 2.0;
    value += texture2D(tMap, vUv).g * clamp(a, 0.0, 1.0) * 0.15;

    float lookup = 1.0 - clamp(value + pow(1.0 - vUv.x, 2.0) * 1.0, 0.0, 1.0);
    vec3 color = texture2D(tRamp, vec2(lookup, 0.0)).rgb;

    gl_FragColor = vec4(color, a);
}{@}UltraSparksShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec2 uv = vUv;
    uv.y *= 3.0;
    uv.y -= time * 6.5;
    float alpha = 1.0;
    alpha *= smoothstep(0.0, 0.2, vUv.x);
    alpha *= smoothstep(1.0, 0.8, vUv.x);
    alpha *= 1.0 - vUv.y;
    alpha *= smoothstep(0.0, 0.05, vUv.y);
    vec3 color = texture2D(tMap, uv).rgb;
    uv.y *= 0.75;
    // color += texture2D(tMap, uv * 0.5 + vec2(0.75, 0.0)).rgb;
    alpha *= color.r;
    alpha = smoothstep(0.2, 0.5, alpha);
    gl_FragColor = vec4(color, alpha);
}{@}VertexColorTestShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tMap;
uniform float uDelay;
uniform float uStrength;
uniform float uMix;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vColor;
varying vec3 vNormal;
varying float vVertexId;

#!SHADER: Vertex
void main() {
    vec3 pos = position;

    #ifdef INSTANCED
        pos.y += sin(random.x * uDelay + time) * uStrength;
    #endif

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vUv2 = uv2;
    vColor = vdata;
    vNormal = normal;
}

#!SHADER: Fragment
void main() {
    vec3 color = mix(vColor, vNormal * 0.5 + 0.5, clamp(uMix, 0.0, 1.0));
    // color = max(vec3(0.1), color);
    // color = vec3(vUv, 0.0);
    // color = texture2D(tMap, vUv).rgb;
    // color.rg = vUv2;
    gl_FragColor = vec4(color, 1.0);
}{@}FlowerInstances.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec3 lookup;
attribute vec4 random;

#!UNIFORMS
uniform vec4 uOptions;

uniform sampler2D tPos;

uniform vec4 uParams;
uniform float uCurl;
uniform float uDelayOffset;
uniform float uRadial;
uniform float uVerticalOffset;

uniform vec3 uShadowColor;

uniform vec3 uColorStart;
uniform vec3 uColorEnd;

uniform vec3 uColorBase;
uniform vec3 uColorTip;

uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform sampler2D tLUT;

uniform sampler2D tEnvDiffuse;
uniform sampler2D tEnvSpecular;

uniform vec4 uParams;

uniform vec2 uTiling;
uniform vec4 uMRON;
uniform vec2 uEnv;

uniform float uHDR;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vWorldNormal;
varying vec3 vPos;
varying float vIndex;

varying vec3 vN;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec3 vColor;
varying vec3 vBaseColor;
varying float vDriver;
varying float vProgress;
varying vec3 vOffset;

#!SHADER: Vertex
#require(rotation.glsl)
#require(range.glsl)
#require(instance.vs)
#require(simplenoise.glsl)
#require(lookat.glsl)


vec3 hash3( uint n ) {
	n = (n << 13U) ^ n;
    n = n * (n * n * 15731U + 789221U) + 1376312589U;
    uvec3 k = n * uvec3(n,n*16807U,n*48271U);
    return vec3( k & uvec3(0x7fffffffU))/float(0x7fffffff);
}

void main() {

    vec3 offset = texture2D(tPos, lookup.xy).xyz;
    vec4 worldOffset = modelMatrix * vec4(offset, 1.);
    vOffset = worldOffset.xyz;

    uint instanceIndex = uint(lookup.z);

    vec3 hash = hash3(instanceIndex);

    vec3 guideVector = vec3(0., 0., 1.);
    guideVector = lookAt(guideVector, cameraQuaternion);
    vec3 lookVector = normalize(worldOffset.xyz - cameraPosition);
    float lookCone = abs(dot(guideVector, lookVector));
    lookCone = pow(lookCone, 100.);
    lookCone = clamp(lookCone, 0., 1.);

    hash.x += lookCone * 0.03;

    vec4 hashOptions = vec4(hash.x * 100., hash.y * 0.1, hash.z, uOptions.w);

    vNormal = normal;
    vUv = uv;

    vec3 pos = position;

    vec4 pos4 = vec4(position, 1.0);

    // Petal index. First petal is 0, second is 1, etc.
    float index = vdata.r;

    // Delay value to offset petal opening animations
    float delayOffset = uDelayOffset * index;

    // Create a value that loops infinitely between 0.0 and 3.14. We'll use this to drive everything
    // float progress = time + hashOptions.x;
    float progress = hashOptions.x;
    float driverNormalized = fract(uCurl / 3.14 - delayOffset + progress * 0.2);
    float driver = driverNormalized * 3.14;

    // Noise
    float noise = vdata.b;
    float animatedNoise = sin(noise + progress + index * 0.1);

    // How much to rotate petals around in a circle
    float rotationOffset = index * uRadial;

    // Clamp values
    float MIN_ANGLE = -3.14/2.0;
    float MAX_ANGLE = -MIN_ANGLE;

    // Petal width
    float widthOffset = hashOptions.y;
    widthOffset += sin(progress * 0.5) * 0.7;

    // Petals that are smaller and closer together need to curl to the sides so that they don't intersect
    float bendGradient = (abs(uv.x) - 0.5); // curl up on both sides of petal
    float bendAngle =  bendGradient * (1.0 - driverNormalized);
    bendAngle += widthOffset * bendGradient * 0.5;
    mat4 bendMatrix = rotationMatrix(vec3(1.0, 0.0, 0.0), bendAngle);

    // Blooming animation
    float curl = clamp(driver + MIN_ANGLE, MIN_ANGLE, MAX_ANGLE);
    float curlAngle = uv.y * curl;
    curlAngle -= clamp(uv.y - 0.5, 0.0, 1.0) * 2.0 * driverNormalized;

    // Organic noise
    float centerGradient = pow((1.0 - driverNormalized), 7.0);
    curlAngle += sin(index * 0.5 + uv.y + noise * 5.0 + centerGradient * 10.0) * 0.25 * centerGradient; //top
    curlAngle += sin(index * 0.5 + uv.y + noise * 1.0 + length(pos4.xyz) * 5.0 - progress * 5.0) * pow(driverNormalized, 3.0) * 0.75;

    // Bloom matrix
    mat4 curlMatrix = rotationMatrix(vec3(0.0, 0.0, 1.0), curlAngle);

    // Create a gradient that runs from 0 -> 1 -> 0, so we can scale the petals up
    // and back down as the uCurl uniform moves from 0 to 3.14
    float scaleStart = 0.0;
    float scaleMiddle = 1.0;
    float scaleEnd = -1.0;
    float h = 0.5; // middle value
    float gradient = clamp(driver, 0.0, 3.14) / 3.14;
    
    float scale = mix(
        mix(scaleStart, scaleMiddle, gradient/h), 
        mix(scaleMiddle, scaleEnd, (gradient - h)/(1.0 - h)), 
        step(h, gradient));

    scale = 1.0 - pow(1.0 - scale, 5.0); // smooth the gradient
    scale = max(scale, 0.0); // clamp negative values

    // Place petals in circle formation
    mat4 rotMatrix = rotationMatrix(vec3(0.0, 1.0, 0.0), rotationOffset);

    // Deform in circle to stretch petals
    float deformation = (uv.x - 0.5) * 2.0 * widthOffset;
    mat4 deformationMatrix = rotationMatrix(vec3(0.0, 1.0, 0.0), deformation);

    // Where the magic happens
    pos4 *= scale;
    pos4 = bendMatrix * pos4;
    pos4 = curlMatrix * pos4;
    pos4 = deformationMatrix * pos4;
    pos4 = rotMatrix * pos4;

    vec4 n = vec4(normal, 0.0);
    n.xyz = mix(n.xyz, vec3(0.0, 1.0, 0.0), 0.5);

    // Deform normals to match petal pos4itions
    n = bendMatrix * n;
    n = curlMatrix * n;
    n = deformationMatrix * n;
    n = rotMatrix * n;

    // Move petals downwards so they don't intersect as much
    pos4.y -= pow(driverNormalized * uVerticalOffset, 1.5);
    // More noise
    float n2 = sin(length(pos4.xz) * 8.0 + progress * 1.0) * 0.1;
    pos4.y += n2;
    n.y += n2;

    pos4.xyz = transformPosition(pos4.xyz, offset, scale * 0.4);

    vec4 worldPos = modelMatrix * vec4(pos4.xyz, 1.0);

    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n.xyz;
    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vIndex = vdata.r;
    vWorldNormal = worldNormal;
    vPos = pos4.xyz;
    vV = worldPos.xyz - cameraPosition.xyz;
    vUv = uv;
    vN = normal;
    vColor = mix(uColorStart, uColorEnd, driverNormalized);
    vBaseColor = mix(uColorBase, uColorTip, uv.y);
    vDriver = driverNormalized;
    vProgress = progress;
}

#!SHADER: Fragment
#require(normalmap.glsl)
#require(lookat.glsl)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
    float res = cosTheta;
    // res = max(0.2, res); // hack to remove black lines
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * res - 6.98316) * res);
}

vec2 sampleSphericalMap(vec3 v)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;

    // match default C4D baked HDRI
    uv.x = fract(uv.x + 0.25 + uParams.y);

    return uv;
}

vec4 SRGBtoLinear(vec4 srgb) {
    vec3 linOut = pow(srgb.xyz, vec3(2.2));
    return vec4(linOut, srgb.w);
}

vec3 linearToSRGB(vec3 color) {
    return pow(color, vec3(0.4545454545454545));
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec4 autoToLinear(vec4 texel, float uHDR) {
    vec4 color = RGBMToLinear(texel);
    if (uHDR == 0.0) { color = SRGBtoLinear(texel); }
    return color;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N, sampler2D tLUT, sampler2D tEnvDiffuse, sampler2D tEnvSpecular) {
    float metallic = clamp(MRO.x + uMRON.x - 1.0, 0.0, 1.0);
    float roughness = clamp(MRO.y + uMRON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uMRON.z);

    vec2 lutUV = vec2(NdV, roughness);
    vec2 diffuseUV = sampleSphericalMap(N);

    vec3 brdf = SRGBtoLinear(texture2D(tLUT, lutUV)).rgb;
    vec3 diffuse = autoToLinear( texture2D(tEnvDiffuse, diffuseUV ), uHDR).rgb;

    diffuse *= baseColor.rgb;

    float level = floor(roughness * ENV_LODS);
    vec2 specUV = sampleSphericalMap(R);

    specUV.y /= 2.0;
    specUV /= pow(2.0, level);
    specUV.y += 1.0 - exp(-LN2 * level);

    vec3 specular = autoToLinear(texture2D(tEnvSpecular, specUV), uHDR).rgb;

    // fake stronger specular highlight
    specular += pow(specular, vec3(1.2)) * uEnv.y;

    vec3 F0 = vec3(0.01);
    F0 = mix(F0, baseColor.rgb, metallic);

    vec3 F = fresnelSphericalGaussianRoughness(NdV, F0, roughness);
    // vec3 F = fresnelSchlick(NdV, F0);

    vec3 diffuseContrib = 1.0 - F;
    specular = specular.rgb * (F);

    diffuseContrib *= 1.0 - metallic;

    float alpha = baseColor.a;

    return vec4((diffuseContrib * diffuse + specular) * ao * uEnv.x, alpha);
    // return vec4((diffuseContrib * diffuse) * ao * uEnv.x, alpha);
}

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 15.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

void main() {

    vec2 uv = vUv;
    vec3 N = normalize(vWorldNormal);
    vec3 V = normalize(vV);

    if (!gl_FrontFacing) {
        N *= -1.0;
    }

    vec3 worldNormal = unpackNormal(V, N, tNormal, uMRON.w, 1.0, uv).xyz;
    vec3 R = reflect(V, worldNormal);
    float NdV = abs(dot(worldNormal, V));

    vec4 baseColor = vec4(vBaseColor, 1.0);
    baseColor = vec4(R * 0.5 + 0.5, 1.0).xzyw;
    baseColor.rgb = mix(baseColor.rgb, baseColor.rbg, sin(vProgress * 0.3) * 0.5 + 0.5);
    baseColor.rgb = mix(vBaseColor.rgb, baseColor.rgb, sin(vProgress * 1.5 - vDriver * 5.0) * 0.5 + 0.5);
    // baseColor.rgb = vec3(0.2);

    if (!gl_FrontFacing) {
        baseColor.b = 1.0;
    }

    baseColor.rgb *= vColor;
    baseColor = SRGBtoLinear(baseColor);
    
    vec4 MRO = texture2D(tMRO, uv * uOptions.w + vec2(vIndex * 0.1));

    // Shadow from middle of flower, and also at base of flower
    vec3 ao = vec3(uv.y * clamp(length(vPos) * 4.0, 0.0, 1.0) * (1.0 - vDriver - 0.25));
    ao = mix(uShadowColor, vec3(1.0), clamp(ao.r, 0.0, 1.0));

    if (!gl_FrontFacing) {
        ao = mix(ao, vec3(1.0), 0.5);
    }

    vec4 color = getIBLContribution(NdV, baseColor, MRO, R, V, worldNormal, tLUT, tEnvDiffuse, tEnvSpecular);
    color.rgb *= ao;

    color.rgb = uncharted2(color.rgb);
    color.rgb = pow(color.rgb, vec3(0.45454545));

   
    vec3 guideVector = vec3(0., 0., 1.);
    guideVector = lookAt(guideVector, cameraQuaternion);
    vec3 lookVector = normalize(vOffset.xyz - cameraPosition);
    float lookCone = abs(dot(guideVector, lookVector));
    lookCone = clamp(pow(lookCone, 100.), 0., 1.);

    //gl_FragColor = color;
    gl_FragColor.rgb =  vec3(vUv.r, vUv.g, 1.0);

    gl_FragColor.a = 1.0;
}{@}InstancedMeshParticles.glsl{@}#!ATTRIBUTES
