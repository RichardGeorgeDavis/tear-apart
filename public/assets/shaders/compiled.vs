{@}grid.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPositions;

uniform vec3 uBoundsMin;
uniform vec3 uBoundsMax;

uniform float uTextureSize; //size of texture containing all the voxel slices in px
uniform float uSliceSize; //size of slice in px

uniform float uParticleCount;

#!VARYINGS
varying float vParticleIndex;

#!SHADER: Vertex
void main() {

    //fetch positions
    vec3 pos = texture2D(tPositions, position.xy).xyz;

    //remap positions to a range between 0 and 1 within the volume
    pos -= uBoundsMin;

    //assuming the min size is negative, the subtraction with min and max bounds
    //will return the total width of the bounding volume
    pos.x /= abs(uBoundsMax.x - uBoundsMin.x);
    pos.y /= abs(uBoundsMax.y - uBoundsMin.y);
    pos.z /= abs(uBoundsMax.z - uBoundsMin.z);

    vec3 gridPosition = floor(pos * uSliceSize);

    float voxelIndex = dot(gridPosition, vec3(1.0, uSliceSize, uSliceSize * uSliceSize));
    float gridCoordX = ((mod(voxelIndex, uTextureSize) + 0.5) / uTextureSize);
    float gridCoordY = ((floor(voxelIndex / uTextureSize) + 0.5) / uTextureSize);

    vec2 gridCoord = 2.0 * vec2(gridCoordX, gridCoordY) - 1.0;

    float particleIndex = float(gl_VertexID); //double check this if this break depth sorting
    vParticleIndex = particleIndex;

    //replace
    gl_Position = vec4(gridCoord, particleIndex / uParticleCount, 1.0);
    gl_PointSize = 1.0;
}

    #!SHADER: Fragment
void main() {
    gl_FragColor = vec4(vParticleIndex);
}
{@}NeighborhoodSearch.glsl{@}#!ATTRIBUTES
attribute vec2 index;

#!UNIFORMS
uniform sampler2D uPositions;
uniform vec4 uBucketData;

#!VARYINGS
varying vec4 colorData;

#!SHADER: Vertex
void main() {

    vec3 particlePosition = texture2D(uPositions, index).rgb;
    vec3 gridPosition = floor(particlePosition);
    
    float gridIndex = dot(gridPosition, vec3(1., uBucketData.y, uBucketData.y * uBucketData.y));
    vec2 voxelPosition = 2. * (vec2(mod(gridIndex, uBucketData.x), floor(gridIndex / uBucketData.x)) + vec2(0.5)) / uBucketData.x - vec2(1.);
       
    float index1D = dot(floor(uBucketData.w * index), vec2(1., uBucketData.w));
    gl_Position = vec4(voxelPosition, index1D / (uBucketData.w * uBucketData.w), 1.0);

    colorData = vec4(index1D);
    gl_PointSize = 1.;

}

#!SHADER: Fragment
void main() {
    gl_FragColor = colorData;
}
{@}CollisionConstrains.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPosition;

uniform sampler2D tGrid;
uniform vec3 uBoundsMin;
uniform vec3 uBoundsMax;
uniform float uGridTextureSize;
uniform float uVoxelSliceSize;

uniform vec2 uHairData;

uniform float uTexelSize;
uniform float uRestLength;

uniform float uApplyInput;
uniform vec3 uInputPos;

uniform float uDeltaTime;
uniform vec2 uHairData;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment
layout(location = 0) out vec4 data1;
layout(location = 1) out vec4 data2;

vec2 indexToCoord(in float index) {
    float x = (mod(index, uHairData.x) + 0.5) / uHairData.x;
    float y = (floor(index / uHairData.y) + 0.5) / uHairData.y;
    return vec2(x, y);
}

void applyCollision(in vec4 pos, in float neighborIndex, inout vec3 deltaPosition, in float strandIndex) {

    vec2 otherCoord = indexToCoord(neighborIndex);

    vec4 otherPos = texture2D(tPosition, otherCoord);
    if(otherPos.w == pos.w) return;

    otherPos.xyz -= uBoundsMin;
    otherPos.x /= abs(uBoundsMax.x - uBoundsMin.x);
    otherPos.y /= abs(uBoundsMax.y - uBoundsMin.y);
    otherPos.z /= abs(uBoundsMax.z - uBoundsMin.z);

    vec3 dir = pos.xyz - otherPos.xyz;
    float dist = length(dir);
    float minDist = (1.0 / uVoxelSliceSize)*1.0;
    if(dist > 0.0 && dist < minDist) deltaPosition -= normalize(dir) * 0.5 * (dist - minDist);


}

void main() {
    vec2 index = (floor(vUv * uHairData) + 0.5) / uHairData;
    vec4 gridPos = texture2D(tPosition, vUv);

    vec3 deltaPosition = vec3(0.0);

    //vec4 gridPos = pos;
    //remap positions to a range between 0 and bounds total width within the volume
    gridPos.xyz -= uBoundsMin;

    //assuming the min size is negative, the subtraction with min and max bounds
    //will return the total width of the bounding volume
    gridPos.x /= abs(uBoundsMax.x - uBoundsMin.x);
    gridPos.y /= abs(uBoundsMax.y - uBoundsMin.y);
    gridPos.z /= abs(uBoundsMax.z - uBoundsMin.z);

    vec3 gridPosition = floor(gridPos.xyz * uVoxelSliceSize);
    vec3 offsets[27];
    offsets[0] = vec3(-1., -1., -1.);
    offsets[1] = vec3(-1., -1., 0.);
    offsets[2] = vec3(-1., -1., 1.);
    offsets[3] = vec3(-1., 0., -1.);
    offsets[4] = vec3(-1., 0., 0.);
    offsets[5] = vec3(-1., 0., 1.);
    offsets[6] = vec3(-1., 1., -1.);
    offsets[7] = vec3(-1., 1., 0.);
    offsets[8] = vec3(-1., 1., 1.);
    offsets[9] = vec3(0., -1., -1.);
    offsets[10] = vec3(0., -1., 0.);
    offsets[11] = vec3(0., -1., 1.);
    offsets[12] = vec3(0., 0., -1.);
    offsets[13] = vec3(0., 0., 0.);
    offsets[14] = vec3(0., 0., 1.);
    offsets[15] = vec3(0., 1., -1.);
    offsets[16] = vec3(0., 1., 0.);
    offsets[17] = vec3(0., 1., 1.);
    offsets[18] = vec3(1., -1., -1.);
    offsets[19] = vec3(1., -1., 0.);
    offsets[20] = vec3(1., -1., 1.);
    offsets[21] = vec3(1., 0., -1.);
    offsets[22] = vec3(1., 0., 0.);
    offsets[23] = vec3(1., 0., 1.);
    offsets[24] = vec3(1., 1., -1.);
    offsets[25] = vec3(1., 1., 0.);
    offsets[26] = vec3(1., 1., 1.);

    for(int i = 0; i < 27; i++) {

        vec3 neighbour = gridPosition + offsets[i];
        float voxelIndex = dot(neighbour, vec3(1.0, uVoxelSliceSize, uVoxelSliceSize * uVoxelSliceSize));
        float gridCoordX = (mod(voxelIndex, uGridTextureSize) + 0.5);
        float gridCoordY = (floor(voxelIndex / uGridTextureSize) + 0.5);

        vec4 neighbourIndex = texture2D(tGrid, vec2(gridCoordX, gridCoordY) / uGridTextureSize);

        if(neighbourIndex.x > -1.0) applyCollision(gridPos, neighbourIndex.x, deltaPosition, gl_FragCoord.y);
        if(neighbourIndex.y > -1.0) applyCollision(gridPos, neighbourIndex.y, deltaPosition, gl_FragCoord.y);
        if(neighbourIndex.z > -1.0) applyCollision(gridPos, neighbourIndex.z, deltaPosition, gl_FragCoord.y);
        if(neighbourIndex.w > -1.0) applyCollision(gridPos, neighbourIndex.w, deltaPosition, gl_FragCoord.y);

    }

    gridPos.xyz += deltaPosition;

    gridPos.x *= abs(uBoundsMax.x - uBoundsMin.x);
    gridPos.y *= abs(uBoundsMax.y - uBoundsMin.y);
    gridPos.z *= abs(uBoundsMax.z - uBoundsMin.z);

    gridPos.xyz += uBoundsMin;

    //Follow the leader!
    vec3 correction = vec3(0.0);

    if(vUv.x > uTexelSize) {

        vec3 target = texture2D(tPosition, vec2(index.x - uTexelSize, vUv.y)).xyz;
        vec3 correctionDir = target - gridPos.xyz;
        float dist = length(correctionDir);
        if(dist > 0.0) correction = (correctionDir/dist) * (dist - uRestLength) * 0.5;
        gridPos.xyz += correction;

    }

    //constrain particles to floor
    if(gridPos.y < -1.0) {
        gridPos.y = -1.0;
    }

    data1 = gridPos;
    data2 = vec4(correction, 1.0);
}
{@}Constrain.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPosition;

uniform vec2 uHairData;

uniform float uTexelSize;
uniform float uRestLength;
uniform float uStiffness;

uniform float uDeltaTime;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment
    #define RADIUS 0.5
layout(location = 0) out vec4 data1;
layout(location = 1) out vec4 data2;

void main() {
    vec2 index = (floor(vUv * uHairData) + 0.5) / uHairData;
    vec4 pos = texture2D(tPosition, vUv);

    float compliance = uStiffness / uDeltaTime / uDeltaTime;
    compliance = 1.0 / compliance;

    vec3 correction = vec3(0.0);
    //Follow the leader!
    if(vUv.x > uTexelSize) {

        vec3 target = texture2D(tPosition, vec2(index.x - uTexelSize, vUv.y)).xyz;
        vec3 correctionDir = target - pos.xyz;
        float dist = length(correctionDir);
        correction = normalize(correctionDir) * (dist - uRestLength) * 0.5 * compliance;
        pos.xyz += correction;

    }

    data1 = pos;
    data2 = vec4(correction, 1.0);
}
{@}CopyData.glsl{@}#!ATTRIBUTES

