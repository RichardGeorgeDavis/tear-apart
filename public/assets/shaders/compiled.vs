#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tScreen;
uniform sampler2D tPost;

// uniform sampler2D tex;
// uniform float texWidth;
// uniform float texHeight;

uniform vec3 uKeyColor;
uniform float uSimilarity;
uniform float uSmoothness;
uniform float uSpill;
uniform float uAlpha;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment

#require(blendmodes.glsl)
#require(transformUV.glsl)

// From https://github.com/libretro/glsl-shaders/blob/master/nnedi3/shaders/rgb-to-yuv.glsl
vec2 RGBtoUV(vec3 rgb) {
  return vec2(
    rgb.r * -0.169 + rgb.g * -0.331 + rgb.b *  0.5    + 0.5,
    rgb.r *  0.5   + rgb.g * -0.419 + rgb.b * -0.081  + 0.5
  );
}

// From https://jameshfisher.com/2020/08/11/production-ready-green-screen-in-the-browser/
vec4 getChromaKey(vec2 texCoord) {
  vec4 rgba = texture2D(tMap, texCoord);
  float chromaDist = distance(RGBtoUV(texture2D(tMap, texCoord).rgb), RGBtoUV(uKeyColor));

  float baseMask = chromaDist - uSimilarity;
  float fullMask = pow(clamp(baseMask / uSmoothness, 0., 1.), 1.5);
  rgba.a = fullMask;

  float spillVal = pow(clamp(baseMask / uSpill, 0., 1.), 1.5);
  float desat = clamp(rgba.r * 0.2126 + rgba.g * 0.7152 + rgba.b * 0.0722, 0., 1.);
  rgba.rgb = mix(vec3(desat, desat, desat), rgba.rgb, uSpill);

  return rgba;
}

void main() {
    vec4 color = getChromaKey(vUv);
    vec4 post = texture2D(tPost, vUv);
    vec4 screenColor = texture2D(tScreen, scaleUV(vUv, vec2(10.0)));

    float light = sin(time * 18.0) * 0.5 + 0.5;
    float lightHalf = sin(time * 36.0) * 0.5 + 0.5;
    vec3 lightColor = pow(vec3(1.0, 0.1, 0.1), vec3(2.2));

    float underLight = dot(vec3(0.5, -0.5, -0.5), color.rgb * 2.0 - 1.0);


    color.rgb = pow(color.rgb, vec3(2.2));
    //strobes
    vec3 lighting = vec3(0.0);
    // color.rgb = mix(color.rgb, vec3(0.05), 1.7 - (1.0 - pow(abs(vUv.x - 0.5), 1.5)));
    lighting += post.r * screenColor.rgb * 1.5;


    // lighting += post.r * 0.5 * light * vec3(1.0, 1.0, 0.0) * vUv.y * (sin(vUv.y * 4.0 + color.b * 2.0 + 2.0) * 0.5 + 0.5);
    // lighting += post.g * 0.2 * light * vec3(1.0, 0.0, 0.0) * vUv.y * 1.0;
    // lighting += pow(vUv.y, 4.0) * lightColor * 0.03;
    // lighting = pow(color.rgb, vec3(0.45));



    //height fog
    color.rgb *= pow(vUv.y, 2.0) * 0.2;
    color.rgb += lighting * vUv.y * pow(uAlpha, 2.0) * 1.0;
    color.rgb = pow(color.rgb*2.0, vec3(1.3));
    // color.rgb += pow(post.r * 0.3 * vec3(1.0, 0.0, 0.0), vec3(2.2));
    color.rgb = pow(color.rgb, vec3(0.45));
    // color.rgb -= 0.5;
    // color.rgb *= 1.2;
    // color.rgb += 0.5;

    color.rgb = blendSoftLight(color.rgb, screenColor.rgb+0.5, 0.5);


    // gl_FragColor = color;
    color.a *= uAlpha;

    // draws the light source to the default frame buffer 
    #drawbuffer Color gl_FragColor = color;

    // draws the light source to the VolumetricLight frame buffer 
    #drawbuffer VolumetricLight gl_FragColor = vec4(0.0);
}{@}DJVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

uniform sampler2D tGlow;
uniform float uGlowAdd;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

void main() {
    vec4 color = texture2D(tDiffuse, vUv);

    vec3 bloom = pow(getUnrealBloom(vUv).rgb, vec3(2.2));
    vec3 volumetric = pow(texture2D(tGlow, vUv).rgb, vec3(2.2)) * 50.0;
    // bloom = mix(bloom, uncharted2(bloom), 0.5);

    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb += bloom;
    color.rgb += volumetric;
    color.rgb += vec3(0.002, 0.001, 0.0015);
    color.rgb = uncharted2(color.rgb);
    color.rgb = pow(color.rgb, vec3(0.45454545));
    
    // color.rgb = unreal(color.rgb);




    color.rgb += (getNoise(vUv, time) - 0.5) * 0.1;

    // color.rgb = mix(texture2D(tDiffuse, vUv).rgb + getUnrealBloom(vUv).rgb, color.rgb, 0.0);

    // color.rgb = uncharted2(bloom);
    // color.rgb = bloom;

  gl_FragColor = color;
}{@}OccluderShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tPost;

// uniform sampler2D tex;
// uniform float texWidth;
// uniform float texHeight;

uniform vec3 uKeyColor;
uniform float uSimilarity;
uniform float uSmoothness;
uniform float uSpill;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment

// From https://github.com/libretro/glsl-shaders/blob/master/nnedi3/shaders/rgb-to-yuv.glsl
vec2 RGBtoUV(vec3 rgb) {
  return vec2(
    rgb.r * -0.169 + rgb.g * -0.331 + rgb.b *  0.5    + 0.5,
    rgb.r *  0.5   + rgb.g * -0.419 + rgb.b * -0.081  + 0.5
  );
}

// From https://jameshfisher.com/2020/08/11/production-ready-green-screen-in-the-browser/
vec4 getChromaKey(vec2 texCoord) {
  vec4 rgba = texture2D(tMap, texCoord);
  float chromaDist = distance(RGBtoUV(texture2D(tMap, texCoord).rgb), RGBtoUV(uKeyColor));

  float baseMask = chromaDist - uSimilarity;
  float fullMask = pow(clamp(baseMask / uSmoothness, 0., 1.), 1.5);
  rgba.a = fullMask;

  float spillVal = pow(clamp(baseMask / uSpill, 0., 1.), 1.5);
  float desat = clamp(rgba.r * 0.2126 + rgba.g * 0.7152 + rgba.b * 0.0722, 0., 1.);
  rgba.rgb = mix(vec3(desat, desat, desat), rgba.rgb, uSpill);

  return rgba;
}

void main() {
    vec4 color = getChromaKey(vUv);

    // draws the occluder to the default frame buffer 
    #drawbuffer Color gl_FragColor = vec4(vec3(0.0), color.a);

    // draws the occluder to the VolumetricLight frame buffer
    // as a solid black color to occlude the light source
    #drawbuffer VolumetricLight gl_FragColor = vec4(vec3(0.0), color.a);
}{@}PBRDJ.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tScreen;
uniform vec3 uLightColor;

#!VARYINGS
varying vec3 vPos;
varying vec2 vUv2;

#!SHADER: Vertex

#require(pbr.vs)

void main() {
    vec3 pos = position;
    setupPBR(position);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vPos = pos;
    // vUv2 = uv2;
}

#!SHADER: Fragment

#require(pbr.fs)

void main() {
    vec2 screenUv = gl_FragCoord.xy / resolution;

    vec3 pbr = getPBR().rgb;

    vec3 lightmap = texture2D(tLightmap, vUv).rgb;
    // lightmap.r += vPos.y * 3.0;
    vec3 video = texture2D(tScreen, vec2((vPos.x - 1.0) * 0.1, 0.1)).rgb;

    pbr.rgb *= video * (lightmap.r * 5.0) * 2.0;
    // pbr += (dot(vWorldNormal, normalize(vec3(0.0, 0.2, -1.0))) * 0.5 + 0.5 + 1.5 * smoothstep(-1.0, 0.5, vPos.y)) * light * vec3(1.0, 0.0, 0.0) * (smoothstep(-4.0, 8.0, vPos.x)) * 0.2;

    gl_FragColor = vec4(pbr, 1.0);
}{@}SphereFogShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uColor;
uniform float uAlpha;
uniform float uIntensity;
uniform float uDebug;
uniform sampler2D tScreen;

#!VARYINGS
varying vec2 vUv;
varying vec3 vEyePos;
varying vec3 vNormal;
varying vec3 vPos;

#!SHADER: Vertex
#require(lookat.glsl)
void main() {
    vec3 pos = position;
    vec4 mvPos = modelViewMatrix * vec4(pos, 1.0);
    vEyePos = mvPos.xyz;
    vUv = uv;
    vNormal = normalMatrix * normal;
    vPos = pos;
    gl_Position = projectionMatrix * mvPos;
}

    #!SHADER: Fragment
void main() {

    vec3 dir = normalize(-vEyePos);
    float nDotL = clamp(dot(dir, normalize(vNormal)), 0.0, 1.0);
    float inverseFresnel = pow(nDotL, 12.0);
    inverseFresnel *= smoothstep(-0.4, 0.2, vPos.y);
    vec3 col = uColor * uIntensity;
    vec3 finalCol = clamp(col * inverseFresnel, 0.0, 0.9);

    // float light = sin(time * 18.0) * 0.5 + 0.5;
    // float light 

    // col *= light * 0.5;

    // vec3 light = texture2D(tScreen, vec2(0.3)).rgb;
    // col *= light;

    gl_FragColor = vec4(col, inverseFresnel);
}{@}StaticCrowdShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uOffset;
uniform sampler2D tScreen;

#!VARYINGS
varying float vStageDist;
varying float vLight;
varying vec3 vNormal;
varying vec3 vPos;
varying vec3 vOffset;
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    pos += uOffset;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vStageDist = 1.0 - min(length(offset - vec3(0.0, 0.0, -15.0)) * 0.05, 1.0);
    vStageDist = pow(vStageDist, 2.0);

    vLight = sin(time * 18.0) * 0.5 + 0.5;

    vNormal = normalMatrix * normal;
    vPos = pos;
    vOffset = offset.xyz;
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec3 screenColor = texture2D(tScreen, vec2(vOffset.x * 0.1 + vOffset.z * 0.1 + vUv.x * 0.1, 0.0)).rgb;
    // gl_FragColor = vec4(0.0);
    float stageLight = dot(vNormal, normalize(vec3(0.0, 0.5, -1.0))) * 0.5 + 0.5;
    gl_FragColor = vec4(screenColor, 1.0) * vStageDist * stageLight * smoothstep(-1.0, 1.2, vPos.y) * 2.0;
    gl_FragColor.rgb += vStageDist * screenColor * smoothstep(-1.0, 1.2, vPos.y) * 0.1;
}{@}DreamScreenShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tVideo;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment
void main() {
    vec4 color = texture2D(tVideo, vUv);
    gl_FragColor = color;
}{@}DreamSkyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tVideo;
uniform vec2 uTile;
uniform vec2 uOffset;

uniform float uGradientCenter;
uniform float uGradientWidth;
uniform float uGradientIntensity;
uniform vec3 uColorStart;
uniform vec3 uColorEnd;

uniform float uNoiseStrength;
uniform vec3 uNoiseColor;
uniform vec3 uNoiseSize;
uniform vec3 uNoiseSpeed;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUvTile;
varying vec3 vPos;
varying vec3 vWorldPos;
varying vec3 vColorStart;
varying vec3 vColorEnd;
varying vec3 vVideoColor;
varying float vNoise;

#!SHADER: Vertex

void main() {
    vec2 uvVideo = uv * 0.005;
    vec4 worldPos = modelMatrix * vec4(position, 1.0);

    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;
    vUvTile = uv * uTile + uOffset;
    vPos = position;
    vWorldPos = worldPos.xyz;
    vColorStart = pow(uColorStart, vec3(2.2));
    vColorEnd = pow(uColorEnd, vec3(2.2));
    vVideoColor = texture2D(tVideo, uvVideo).rgb;
}

#!SHADER: Fragment
#require(simplenoise.glsl)

void main() {
    vec3 texture = texture2D(tMap, vUvTile).rgb;

    float t = time * 0.1;
    float noise = cnoise(vPos.xyz * uNoiseSize + t * uNoiseSpeed) * 0.5;

    float scatter = pow(noise, 2.0);
    scatter = clamp(scatter, 0.0, 1.0);

    float atmosphere = sqrt(1.0-(clamp(vUv.y * 8.0 - 4.0, 0.0, 1.0)));
    atmosphere = pow(atmosphere, 5.0);

    vec3 skyColor = mix(uColorStart, uColorEnd, atmosphere);
    vec3 color = skyColor += scatter * vVideoColor * uNoiseStrength;

    color += texture;

    gl_FragColor = vec4(color, 1.0);
}{@}DreamSurfaceShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tVideo;

uniform sampler2D tDiffuse;
uniform sampler2D tLightmap;

uniform float uLightmapIntensity;
uniform float uTile;

uniform vec3 uStageLightPos;
uniform float uStageLightIntensity;
uniform float uStageLightDist;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUvTiled;
varying vec2 vUvVideo;
varying vec3 vWorldNormal;
varying vec3 vLightDir;
varying float vFog;
varying vec3 vFogColor;
varying vec3 vVideoColor;

#!SHADER: Vertex
#require(fbr.vs)
#require(common.glsl)

void main() {
    vUv = uv;
    vUvTiled = uv * uTile;

    vec3 pos = position;
    setupFBR(pos);
    
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUvVideo = (vMPos.xz - vMPos.xy) * 0.0005;
    vLightDir = normalize(uStageLightPos - vMPos.xyz);
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;
    vFog = clamp(exponentialFog(vEyePos.xyz, vMPos.xyz), 0.0, 1.0);
    vFogColor = uFogColor;
    vVideoColor = texture2D(tVideo, vUvVideo).rgb;
}

#!SHADER: Fragment
#require(fbr.fs)

void main() {
    vec3 baseColor = texture2D(tDiffuse, vUvTiled).rgb;
    vec3 fbr = getFBR(baseColor, vUvTiled);

    vec3 lightmap = texture2D(tLightmap, vUv).rgb;
    fbr *= lightmap * uLightmapIntensity;

    float intensity = max(dot(vWorldNormal, vLightDir), 0.0) * uStageLightIntensity;
    intensity *= 1.0 - clamp(distance(uStageLightPos, vMPos.xyz) * (1.0/uStageLightDist), 0.0, 1.0);

    fbr += intensity * vVideoColor;
    fbr = clamp(fbr, vec3(0.0), vec3(1.0));
    fbr = mix(fbr, vFogColor, vFog);

    gl_FragColor.rgb = fbr;
    gl_FragColor.a = 1.0;
}{@}DreamTerrainShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMRO;
uniform sampler2D tCaustics;
uniform sampler2D tNormal;
uniform sampler2D tLightmap;

uniform vec3 uGrassColor;
uniform vec3 uRockColor;

uniform float uTiling;
uniform vec2 uOffset;
uniform vec2 uBlend;
uniform vec2 uAO;
uniform float uNormalIntensity;
uniform float uLightmapIntensity;
uniform vec3 uLight;
uniform vec3 uSunColor;
uniform vec3 uShadowColor;

uniform vec3 uEnv;

uniform vec4 uWind;

// Character shadow uniforms
// uniform sampler2D tShadowMap;
// uniform vec4 uBox;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec2 vLightmapUv;
varying vec3 vN;
varying vec3 vV;
varying vec3 vColor;
varying float vFog;
varying float vDist;
varying vec3 vWind;
varying vec3 vPos;
varying vec3 vWorldPos;
varying vec3 vNoisePos;
varying vec3 vLight;
varying vec3 vSunColor;
varying vec3 vShadowColor;

#!SHADER: Vertex
#require(rotation.glsl)
#require(common.glsl)

void main() {
    vLightmapUv = uv;

    vec3 pos = position;

    // #ifdef INSTANCED
    // pos.y += sin(offset.x + offset.y + offset.z + time * 0.15 * uGlobalWind.y) * 5.0 * uFloat;
    // #endif

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;

    vec3 n = normal;
    vec3 color = vdata;

    float t = time * uWind.z;

    // grass animation
    float largeScaleMotion = 0.0;
    float smallScaleMotion = 0.0;
    vec3 windPos = pos.xyz * 2.0;
    float windRotation = uWind.x;
    windPos.xz = rotate2d(windRotation) * windPos.xz;
    float offsetFactor = (cos(windPos.z * 0.2) * 4.0 + windPos.x + windPos.y * 2.0 + windPos.z) * uWind.y + t;

    // large scale motion
    largeScaleMotion = sin(offsetFactor);

    // small scale motion
    smallScaleMotion = sin(2.65 * (offsetFactor)) * 0.5;

    vWind.z += largeScaleMotion;
    vWind.z += smallScaleMotion;
    vWind.x += smallScaleMotion;

    // rotate wind normal distortion direction
    vWind.xz = rotate2d(windRotation) * vWind.xz;
    vWind = vWind;

    #ifdef INSTANCED
    n = transformPosition(normal, vec3(0.0), 1.0, orientation);
    #endif

    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;

    vN = worldNormal;
    vV = worldPos.xyz - cameraPosition;
    vUv = uv * uTiling + uOffset;
    vUv2 = uv2;
    vColor = color;
    vFog = exponentialFog(modelViewPos.xyz);

    vPos = position;
    vWorldPos = worldPos.xyz;
    vLight = normalize(uLight);
    vSunColor = pow(uSunColor, vec3(2.2));
    vShadowColor = pow(uShadowColor, vec3(2.2));
}

#!SHADER: Fragment

#require(normalmap.glsl)
#require(range.glsl)
#require(simplenoise.glsl)
#require(common.glsl)

void main() {
    // if (isClipping(vUv*0.4, vWorldPos)) discard;

    float blend = vN.y - 0.05;
    vec2 uv = vUv;
    vec3 wind = vWind;
    vec3 windNoise = wind.xyz;
    vec3 N = vN;
    vec3 V = vV;

    float normalIntensity = mix(uNormalIntensity, 0.0, blend);
    vec3 normal = unpackNormal(V, N + windNoise * 0.1, tNormal, normalIntensity, 1.0, uv).xyz;
    float grassMask = smoothstep(uBlend.x, uBlend.x + 0.1, normal.y);
    vec4 MRO = texture2D(tMRO, uv - (wind.zx * 0.5 + 0.5) * 0.03 * smoothstep(0.8, 0.9, blend));

    // ambient occlusion
    float ao = mix(MRO.z, 1.0, blend);

    // diffuse lighting
    float dp = dot(normalize(normal + windNoise * 2.0 * grassMask), vLight);
    vec3 diffuse = mix(uShadowColor, uSunColor, dp * 0.5 + 0.5);

    // baked lighting
    vec3 lightmap = texture2D(tLightmap, vLightmapUv).rgb;
    lightmap = pow(lightmap, vec3(2.2));
    diffuse *= lightmap * uLightmapIntensity;

    // base color
    vec4 baseColor = vec4(1.0);
    baseColor.rgb = mix( uRockColor, mix(uGrassColor, uGrassColor * 0.75, MRO.x), grassMask);
    baseColor.rgb = pow(baseColor.rgb, vec3(2.2));
    diffuse *= baseColor.rgb;

    // caustics
    vec3 caustics = vec3(0.0);
    // vec4 caustics0 = texture2D(tCaustics, vPos.xz * 0.2 + time * 0.05);
    // vec4 caustics1 = texture2D(tCaustics, vPos.xz * 0.2 + time * 0.05 * vec2(-1.81, -1.42));
    // caustics = pow(min(caustics0.rgb, caustics1.rgb), vec3(2.2));
    // caustics *= (1.0 - normal.y) * clamp(1.0 - vPos.y, 0.0, 1.0);
    
    vec4 color = vec4(diffuse * ao + caustics, 1.0);

    color.rgb = pow(color.rgb, vec3(0.45454545));
    // color.rgb = mix(color.rgb, uFogColor, vFog);

    gl_FragColor = color;
}{@}common.glsl{@}const float LOG2 = 1.442695;
const vec2 INV_ATAN = vec2(0.1591, 0.3183);

uniform float uFogMultiplier;
uniform vec3 uFogColor;
uniform vec3 uTint;
uniform vec3 uSunColor;
uniform vec3 uEnv;

uniform float uSaturation;

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * cosTheta - 6.98316) * cosTheta);
}

vec3 applySaturation(vec3 color) {
  return color * uSaturation;
}

float exponentialFog(vec3 modelViewPos) {
    float fogDistance = -modelViewPos.z;
    float fogFactor = 0.004 * uFogMultiplier; // default 0.004
    float fogAmount = 1. - exp2(-fogFactor * fogFactor * fogDistance * fogDistance * LOG2);
    fogAmount = clamp(fogAmount, 0., 1.);
    return fogAmount;
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec2 sampleSphericalMap(vec3 v, float rotation)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;

    // match default C4D baked HDRI
    uv.x = fract(uv.x + 0.25 + rotation);

    return uv;
}

mat2 rotate2d(float angle){
    return mat2(cos(angle),-sin(angle),
                sin(angle),cos(angle));
}{@}TempleCloudBillboardShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMap2;
uniform sampler2D tLightmap;
uniform vec3 uLightPos;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vPos;
varying float vCameraFade;

#!SHADER: Vertex
vec2 rotate(vec2 v, float a) {
	float s = sin(a);
	float c = cos(a);
	mat2 m = mat2(c, -s, s, c);
	return m * v;
}


void main() {
        vec3 pos = position;

    vec3 cameraRightWorld = vec3(viewMatrix[0][0], viewMatrix[1][0], viewMatrix[2][0]);
    vec3 cameraUpWorld = vec3(viewMatrix[0][1], viewMatrix[1][1], viewMatrix[2][1]);
    vec3 cameraForwardWorld = vec3(-viewMatrix[0][2], -viewMatrix[1][2], -viewMatrix[2][2]);

    float billboardSize = 22.0;
    vec3 center = vdata;
    vec2 st = uv2 * 2.0 - 1.0;

    vec3 vertexPosition =
    center
    + cameraRightWorld * st.x * billboardSize
    + cameraUpWorld * st.y * billboardSize;

    pos = vertexPosition;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;

    vUv = uv;
    vUv2 = uv2;
    vPos = vertexPosition;
}

#!SHADER: Fragment
vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}

void main() {
    vec3 lightPos = uLightPos;
    float dist = length(lightPos - vPos);
    dist = vPos.y * 0.025 + 0.45;

    vec4 clouds2 = texture2D(tMap2, vUv);
    vec4 clouds = texture2D(tMap, vUv);
    float s = (sin(time * 1.5 + vUv.x * 18.0 + vUv.y * 2.0) * 0.5 + 0.5) * 0.35;
    s += (sin(time * 3.1 + vUv.x * 14.0 + vUv.y * 7.0) * 0.5 + 0.5) * 0.35;
    float a = smoothstep(-0.1 + s, 0.75 , clouds2.b);

    float light = vUv2.r * 0.3 + vPos.y * 0.003 + vPos.x * 0.0006 + 0.4;
    light = clamp(light, 0.0, 1.0);
    light *= mix(1.0, clouds.r, 0.35);
    light += clouds2.r * dist * vUv2.y;

    vec3 color1 = uColor1;
    vec3 color2 = uColor2;
    vec3 color3 = uColor3;

    color1 = pow(color1, vec3(2.2));
    color2 = pow(color2, vec3(2.2));
    color3 = pow(color3, vec3(2.2));
    color2 = mix(color2, color3, clamp(vPos.x * 0.01 + 0.7, 0.0, 1.0));

    vec3 color = mix(color2, color1, light);
    color *= 0.9;
    color += color1 * light * 0.2;
    color = pow(color, vec3(0.45));

    color = czm_saturation(color, 2.0);

    gl_FragColor = vec4(color, a);
}{@}TempleCloudShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMap2;
uniform sampler2D tLightmap;
uniform vec3 uLightPos;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vPos;
varying float vCameraFade;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec4 worldPosition = modelMatrix * vec4(position, 1.0);
    // pos -= vdata;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vUv2 = uv2;
    vPos = position;

    vec3 vertexToCam = normalize(cameraPosition - worldPosition.xyz);
    vec3 forward = normalize(vec3(-1488.7, 0.0, -2748.9));
    vCameraFade = max(0.0, dot(vertexToCam, forward));
    vCameraFade = pow(vCameraFade, 3.0);
}

#!SHADER: Fragment
vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}

void main() {
    // vec3 color1 = vec3(233.0, 206.0, 201.0) / 255.0;
    // vec3 color2 = vec3(169.0, 109.0, 125.0) / 255.0;


    vec3 lightPos = uLightPos;
    float dist = length(lightPos - vPos);
    dist = 1.0 - clamp(dist, 0.0, 500.0) / 500.0;

    vec4 clouds2 = texture2D(tMap2, vUv);
    vec4 clouds = texture2D(tMap, vUv);
    float s = (sin(time * 1.5 + vUv.x * 18.0 + vUv.y * 2.0) * 0.5 + 0.5) * 0.35;
    s += (sin(time * 3.1 + vUv.x * 14.0 + vUv.y * 7.0) * 0.5 + 0.5) * 0.35;
    float a = smoothstep(-0.1 + s, 0.75 , clouds2.b);


    float light = vUv2.r * 0.3 + vPos.y * 0.003 + vPos.x * 0.0006 + 0.2;
    light = clamp(light, 0.0, 1.0);
    light *= mix(1.0, clouds.r, 0.35);
    light += light * clouds.b * dist;



    vec3 color1 = uColor1;
    vec3 color2 = uColor2;
    vec3 color3 = uColor3;

    color1 = pow(color1, vec3(2.2));
    color2 = pow(color2, vec3(2.2));
    color3 = pow(color3, vec3(2.2));
    color2 = mix(color2, color3, clamp(vPos.x * 0.01, 0.0, 1.0));
    vec3 color = mix(color2, color1, light);
    color *= 0.9;
    color += color1 * light * 0.2;
    color = pow(color, vec3(0.45));



    color = czm_saturation(color, 2.0);

    color -= 0.65;
    color *= 1.5;
    color += 0.5;
    a *= vCameraFade;

    


    // vec3 lightmap = texture2D(tLightmap, vUv).rgb;
    gl_FragColor = vec4(color, a);
}{@}TempleSkyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}

void main() {
    vec2 uv = vUv;
    uv.x *= 3.0;

    vec3 color = texture2D(tMap, uv).rgb;
    gl_FragColor = vec4(color, 1.0);
    gl_FragDepth = 0.99999;
