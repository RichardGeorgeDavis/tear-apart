    vec4 lightmap = texture2D(tLightmap, vUv);
    color.rgb = pow(color.rgb, vec3(2.2)) * pow(lightmap.rgb, vec3(2.2)) * uLightmapIntensity;
    color.rgb = pow(color.rgb, vec3(0.45));
    gl_FragColor = vec4(color.rgb, color.a);
}{@}InstanceTestShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tBaseColor;
uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform samplerCube tCube;
uniform samplerCube tCubeDiffuse;
uniform sampler2D tLightmap;
uniform float uUseLightmap;
uniform float uLightmapIntensity;
uniform vec3 uTint;
uniform vec4 uERON;
uniform vec2 uEnv;
uniform vec2 uTiling;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vN;
varying vec3 vV;
varying vec3 vWorldNormal;
varying float vFog;
varying float vFlicker;

#!SHADER: Vertex
#require(rotation.glsl)
void main() {
    vec3 pos = position;
    pos -= offset;
    pos.y -= 0.5;
    float t = time * 2.0;
    vec3 axis = normalize(vec3(1.0, 0.0, sin(t) * 0.1));
    float angle = cos(t + offset.x * 50.0) * 0.05 + sin(t * 2.0 + offset.x * 3.14159) * 0.1;
    angle *= sin(t * 0.5 + offset.x * 2.14783) * 0.5 + 0.5;
    pos = vec3(rotationMatrix(axis, angle) * vec4(pos, 1.0));
    pos.y += 0.5;
    pos += offset;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;

    vN = normal;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;
    vV = worldPos.xyz - cameraPosition;
    vUv = uv;
    vUv2 = uv2;
    vFog = smoothstep(25.0, 150.0, -modelViewPos.z);
    // vFlicker = 1.0;
    // vFlicker = mix(1.0, sin(time * max(3.0, worldPos.y) * 2.0 + worldPos.y * 15.5) * 0.5 + 0.5, vdata.r);
    // vFlicker = step(0.1, vFlicker);
    // vFlicker = mix(1.0, vFlicker, 0.8);
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N) {
    float roughness = clamp(MRO.y + uERON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uERON.z);
    vec3 diffuse = pow(textureCube(tCubeDiffuse, N, 12.0).rgb, vec3(2.2));
    float brdf = envBRDFApproxNonmetal(roughness, NdV);
    vec3 lightmap = vec3(1.0);

    if (uUseLightmap > 0.0) {
        lightmap = texture2D(tLightmap, vUv2).rgb;
        lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
        lightmap.rgb *= uLightmapIntensity;
    }

    diffuse *= baseColor.rgb;
    // diffuse *= 0.5;
    diffuse *= pow(uTint, vec3(2.2));

    float lod = roughness * 8.0;
    vec3 specular = pow(textureCube(tCube, R, lod).rgb, vec3(2.2));
    vec4 result = vec4(mix(diffuse * uEnv.x, specular, brdf) * ao, 1.0);
    result.rgb *= lightmap.rgb;
    return result;
}

void main() {
    vec2 uv = vUv;
    vec3 N = normalize(vWorldNormal);
    vec3 V = normalize(vV);
    vec3 unpackedNormal = unpackNormal(V, N, tNormal, uERON.w, 1.0, uv).xyz;
    vec3 R = reflect(V, unpackedNormal);
    float NdV = abs(dot(unpackedNormal, V));
    vec4 MRO = texture2D(tMRO, uv);
    vec4 baseColor = texture2D(tBaseColor, uv);
    baseColor.rgb = pow(baseColor.rgb, vec3(2.2));
    vec4 color = getIBLContribution(NdV, baseColor, MRO, R, V, unpackedNormal);
    vec3 emissive = baseColor.rgb * MRO.r * uERON.r;
    // emissive *= vFlicker;
    color.rgb += emissive;
    color.rgb = unreal(color.rgb);

    // fog
    // vec3 fogColor = textureCube(tCubeDiffuse, V, 12.0).rgb * 0.2;
    // color.rgb = mix(color.rgb, fogColor, vFog);
    // color.rgb += emissive * 0.5;
    gl_FragColor = color;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
}{@}MobileCablesShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tBaseColor;
uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform samplerCube tCube;
uniform samplerCube tCubeDiffuse;
uniform sampler2D tLightmap;
uniform float uUseLightmap;
uniform float uLightmapIntensity;
uniform vec3 uTint;
uniform vec4 uERON;
uniform vec2 uEnv;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vN;
varying vec3 vV;
varying vec3 vWorldNormal;
varying float vFog;
varying float vAo;

#!SHADER: Vertex
#require(rotation.glsl)
void main() {
    vec3 pos = position;
    // pos = vec3( rotationMatrix(vec3(1.0, 0.0, 0.0), sin(pos.x * 0.04 + time - pos.y * 0.03) * 0.2) * vec4(pos, 1.0));

    // pos = vec3( rotationMatrix(vec3(1.0, 0.0, 0.0), sin(time + pos.x * 0.03) * 0.4) * vec4(pos, 1.0));
    // pos.y += sin(time + pos.x * 0.1) * 0.25;
    float offset = 0.1 * (position.z + position.x + position.y);
    float t = time * 4.0;
    float noiseY = 0.0;
    float noiseX = 0.0;
    noiseY += sin(t + offset) * vdata.r * 0.1;
    noiseY += sin(t * 1.5 + offset * 0.3) * vdata.r * 0.1;
    noiseX += cos(time + offset) * vdata.r * 0.1;
    noiseX += cos(t * 0.63 + offset * 0.5) * vdata.r * 0.1;
    noiseY *= clamp(sin(offset * 0.5 + time), -0.2, 1.0);
    noiseX *= clamp(sin(offset * 0.5 + time), -0.2, 1.0);
    pos.y += noiseY;
    pos.x += noiseX * 5.0; 
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;
    vN = normal;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;;
    vV = worldPos.xyz - cameraPosition;
    vUv = uv;
    vUv2 = uv2;
    vFog = smoothstep(25.0, 150.0, -modelViewPos.z);
    vAo = vdata.r;
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N) {
    float roughness = clamp(MRO.y + uERON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uERON.z);
    vec3 diffuse = pow(textureCube(tCubeDiffuse, N, 12.0).rgb, vec3(2.2));
    float brdf = envBRDFApproxNonmetal(roughness, NdV);
    vec3 lightmap = vec3(1.0);

    if (uUseLightmap > 0.0) {
        lightmap = texture2D(tLightmap, vUv2).rgb;
        lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
        lightmap.rgb *= uLightmapIntensity;
    }

    diffuse *= baseColor.rgb;
    // diffuse *= 0.5;
    diffuse *= pow(uTint, vec3(2.2));

    float lod = roughness * 8.0;
    vec3 specular = pow(textureCube(tCube, R, lod).rgb, vec3(2.2));
    vec4 result = vec4(mix(diffuse * uEnv.x, specular, brdf) * ao, 1.0);
    result.rgb *= lightmap.rgb;
    return result;
}

void main() {
    vec2 uv = vUv;
    vec3 N = normalize(vWorldNormal);
    vec3 V = normalize(vV);
    vec3 unpackedNormal = unpackNormal(V, N, tNormal, uERON.w, 1.0, uv).xyz;
    vec3 R = reflect(V, unpackedNormal);
    float NdV = abs(dot(unpackedNormal, V));
    vec4 MRO = texture2D(tMRO, uv);
