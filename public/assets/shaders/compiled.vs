    gl_PointSize = 2.0;
}

    #!SHADER: Fragment
void main() {
    gl_FragColor = vec4(1.0);
}
{@}replaceVelocity.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPosition;
uniform sampler2D tVelocity;
uniform sampler2D tGrid;
uniform sampler2D tVelocityDensityGrid;

uniform vec3 uBoundsMin;
uniform vec3 uBoundsMax;

uniform float uGridTextureSize;
uniform float uVoxelSliceSize;

uniform vec2 uHairData;
uniform float uFriction;
uniform float uRepulsion;

uniform float uDt;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment

//vec2 computeSliceOffset(float slice, float slicesPerRow, vec2 sliceSize) {
//    return sliceSize * vec2(mod(slice, slicesPerRow),
//    floor(slice / slicesPerRow));
//}
//
//vec4 sampleAs3DTexture(
//sampler2D tex, vec3 texCoord, float size, float numRows, float slicesPerRow) {
//    float slice   = texCoord.z * size;
//    float sliceZ  = floor(slice);                         // slice we need
//    float sliceZNext  = ceil(slice);                         // slice we need
//    float zOffset = fract(slice);                         // dist between slices
//
//    vec2 sliceSize = vec2(1.0 / slicesPerRow,             // u space of 1 slice
//    1.0 / numRows);                 // v space of 1 slice
//
//    vec2 slice0Offset = computeSliceOffset(sliceZ, slicesPerRow, sliceSize);
//    vec2 slice1Offset = computeSliceOffset(sliceZ + 1.0, slicesPerRow, sliceSize);
//
//    vec2 slicePixelSize = sliceSize / size;               // space of 1 pixel
//    vec2 sliceInnerSize = slicePixelSize * (size - 1.0);  // space of size pixels
//
//    vec2 uv = slicePixelSize * 0.5 + texCoord.xy * sliceInnerSize;
//    vec4 slice0Color = texture2D(tex, slice0Offset + uv);
//    vec4 slice1Color = texture2D(tex, slice1Offset + uv);
//    return mix(slice0Color, slice1Color, zOffset);
//    return slice0Color;
//}

vec3 calcVelocityFromGrid(in vec3 pos, float neighbourIndex, in vec3 voxelVelocity) {

    float gridCoordX = (mod(neighbourIndex, uGridTextureSize) + 0.5);
    float gridCoordY = (floor(neighbourIndex / uGridTextureSize) + 0.5);
    vec3 otherPos = texture2D(tPosition, vec2(gridCoordX, gridCoordY)).xyz;
    otherPos -= uBoundsMin;
    otherPos /= abs(uBoundsMax - uBoundsMin);
    otherPos = otherPos * 2.0 - 1.0;
    pos = pos * 2.0 - 1.0;

    float dX = clamp(1.0 - abs(otherPos.x - pos.x), 0.0, 1.0);
    float dY = clamp(1.0 - abs(otherPos.y - pos.y), 0.0, 1.0);
    float dZ = clamp(1.0 - abs(otherPos.z - pos.z), 0.0, 1.0);

    float totalWeight = dX * dY * dZ;
    return totalWeight * voxelVelocity;
}

void main() {

    vec3 velocity = texture2D(tVelocity, vUv).xyz;
    vec3 pos = texture2D(tPosition, vUv).xyz;

    vec3 gridPos = pos;
    gridPos -= uBoundsMin;
    gridPos.xyz /= abs(uBoundsMax - uBoundsMin);

    vec3 voxelPosition = floor(gridPos * uVoxelSliceSize);

    float voxelIndex = dot(voxelPosition, vec3(1.0, uVoxelSliceSize, uVoxelSliceSize * uVoxelSliceSize));
    float gridCoordX = ((mod(voxelIndex, uGridTextureSize) + 0.5) / uGridTextureSize);
    float gridCoordY = ((floor(voxelIndex / uGridTextureSize) + 0.5) / uGridTextureSize);

    vec4 voxelVelocityAndDensity = texture2D(tVelocityDensityGrid, vec2(gridCoordX, gridCoordY));
    vec3 voxelVelocity = voxelVelocityAndDensity.xyz/voxelVelocityAndDensity.w;

    vec3 offsets[27];
    offsets[0] = vec3(-1., -1., -1.);
    offsets[1] = vec3(-1., -1., 0.);
    offsets[2] = vec3(-1., -1., 1.);
    offsets[3] = vec3(-1., 0., -1.);
    offsets[4] = vec3(-1., 0., 0.);
    offsets[5] = vec3(-1., 0., 1.);
    offsets[6] = vec3(-1., 1., -1.);
    offsets[7] = vec3(-1., 1., 0.);
    offsets[8] = vec3(-1., 1., 1.);
    offsets[9] = vec3(0., -1., -1.);
    offsets[10] = vec3(0., -1., 0.);
    offsets[11] = vec3(0., -1., 1.);
    offsets[12] = vec3(0., 0., -1.);
    offsets[13] = vec3(0., 0., 0.);
    offsets[14] = vec3(0., 0., 1.);
    offsets[15] = vec3(0., 1., -1.);
    offsets[16] = vec3(0., 1., 0.);
    offsets[17] = vec3(0., 1., 1.);
    offsets[18] = vec3(1., -1., -1.);
    offsets[19] = vec3(1., -1., 0.);
    offsets[20] = vec3(1., -1., 1.);
    offsets[21] = vec3(1., 0., -1.);
    offsets[22] = vec3(1., 0., 0.);
    offsets[23] = vec3(1., 0., 1.);
    offsets[24] = vec3(1., 1., -1.);
    offsets[25] = vec3(1., 1., 0.);
    offsets[26] = vec3(1., 1., 1.);

    float density = 0.0;
    vec3 gridVelocity = vec3(0.0);

    for(int i = 0; i < 27; i++) {
        vec3 neighbour = voxelPosition + offsets[i];
        float voxelIndex = dot(neighbour, vec3(1.0, uVoxelSliceSize, uVoxelSliceSize * uVoxelSliceSize));
        float otherCoordX = (mod(voxelIndex, uGridTextureSize) + 0.5);
        float otherCoordY = (floor(voxelIndex / uGridTextureSize) + 0.5);
        vec4 neighbourIndex = texture2D(tGrid, vec2(otherCoordX, otherCoordY) / uGridTextureSize);

        if(neighbourIndex.x > -1.0) gridVelocity += calcVelocityFromGrid(gridPos, neighbourIndex.x, voxelVelocity);
        if(neighbourIndex.y > -1.0) gridVelocity += calcVelocityFromGrid(gridPos, neighbourIndex.y, voxelVelocity);
        if(neighbourIndex.z > -1.0) gridVelocity += calcVelocityFromGrid(gridPos, neighbourIndex.z, voxelVelocity);
        if(neighbourIndex.w > -1.0) gridVelocity += calcVelocityFromGrid(gridPos, neighbourIndex.w, voxelVelocity);

    }

//    vec4 left = sampleAs3DTexture(tVelocityDensityGrid, gridPos + off3, uVoxelSliceSize, 8.0, 8.0);
//    vec4 right = sampleAs3DTexture(tVelocityDensityGrid, gridPos + off4, uVoxelSliceSize, 8.0, 8.0);
//    vec4 top = sampleAs3DTexture(tVelocityDensityGrid, gridPos + off1, uVoxelSliceSize, 8.0, 8.0);
//    vec4 bottom = sampleAs3DTexture(tVelocityDensityGrid, gridPos + off2, uVoxelSliceSize, 8.0, 8.0);
//    vec4 front = sampleAs3DTexture(tVelocityDensityGrid, gridPos + off5, uVoxelSliceSize, 8.0, 8.0);
//    vec4 back = sampleAs3DTexture(tVelocityDensityGrid, gridPos + off6, uVoxelSliceSize, 8.0, 8.0);

//    float gradX = (left.w - right.w) * 0.5;
//    float gradY = (top.w - bottom.w) * 0.5;
//    float gradZ = (front.w - back.w) * 0.5;

//    if(velocityGrid.w > 0.0) {
        //todo: divide velocity by density to get averege velocity

        //todo: replace velocity per paper
        velocity = (1.0 - uFriction) * velocity + (uFriction * gridVelocity.xyz);
//        velocity += normalize(vec3(gradX, gradY, gradZ)) / (uDt * uDt);
//        velocity = velocityGrid/velocityGrid.w;
//            velocity += velocityGrid.xyz;
//    }


    gl_FragColor = vec4(velocity, 1.0);
}
{@}updateVelocity.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tCurrentPos;
uniform sampler2D tPrevPos;
uniform sampler2D tCorrection;

uniform float uDamping;

uniform float uDT;
uniform float uTexelSize;
uniform vec2 uHairData;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment
void main() {

    vec3 currentPos = texture2D(tCurrentPos, vUv).xyz;
    vec3 prevPos = texture2D(tPrevPos, vUv).xyz;

    vec3 vel = (currentPos - prevPos) / uDT;

    if(vUv.x < 1.0) {
        vec3 D = texture(tCorrection, vec2(vUv.x + uTexelSize, vUv.y)).xyz;
        vel += min(1.0, uDamping) * (-D / uDT);
    }

    gl_FragColor = vec4(vel, 1.0);
}
