{@}BoundingBox.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMin;
uniform sampler2D tMax;
uniform vec4 lightOrientation;

#!VARYINGS
varying vec4 vColor;

#!SHADER: Vertex

vec3 rotateVector( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}

void main() {
    vec3 pos = position;

    vec3 minPosition = texture2D(tMin, vec2(0.5)).rgb;
    vec3 maxPosition = texture2D(tMax, vec2(0.5)).rgb;

    vec4 or = lightOrientation;
    or.xyz *= -1.;
    minPosition = rotateVector(or, minPosition);
    maxPosition = rotateVector(or, maxPosition);

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);
    pos *= s;

    pos += minPosition + vec3(scale * 0.5);

    vColor = mix(vec4(1., 0., 0., 1.), vec4(1., 1., 1., 1.), vec4(position.y + 0.5));

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment

void main() {
    gl_FragColor = vColor;
}{@}ParticlesVolume.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform float uScattering;
uniform float shadowSize;
uniform vec4 lightOrientation;
uniform vec3 voxelData;
uniform sampler2D positionTexture;
uniform sampler2D tMin;
uniform sampler2D tMax;

uniform float autoBB;
uniform vec3 bbMin;
uniform vec3 bbMax;

#!VARYINGS

#!SHADER: Vertex

vec3 rotateVector( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}

void main() {
        
    vec3 pos = texture(positionTexture, position.xy).rgb;

    pos = rotateVector(lightOrientation, pos);

    vec3 minPosition = bbMin;
    vec3 maxPosition = bbMax;

    if(autoBB > 0.5) {
        minPosition = texture2D(tMin, vec2(0.5)).rgb;
        maxPosition = texture2D(tMax, vec2(0.5)).rgb;
    }

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);

    pos -= minPosition;
    pos /= s;


    vec3 gridPosition = floor(voxelData.y * pos);

    vec2 voxelPosition =  2. * (gridPosition.xz + voxelData.y * vec2(mod(gridPosition.y, voxelData.x), floor(gridPosition.y / voxelData.x)) + vec2(0.5)) / voxelData.z - vec2(1.);

    gl_PointSize = shadowSize;
    
    gl_Position = vec4(voxelPosition, 0., 1.0);
}

#!SHADER: Fragment

void main() {

    gl_FragColor = vec4(vec3(1./ max(1., uScattering * voxelData.y)), 1.);

}
{@}Quad.glsl{@}#!ATTRIBUTES

#!UNIFORMS
