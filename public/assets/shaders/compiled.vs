void main() {
    vec3 pos = position;
    setupPBR(position);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
#require(pbr.fs)

void main() {
    float opacity = texture2D(tAlpha, vUv).r;
    if (opacity < 0.5) discard;

    vec4 baseColor = texture2D(tBaseColor, vUv);
    vec3 pbr = getPBR(baseColor.rgb).rgb;

    float a = uAlpha;
    gl_FragColor = vec4(pbr, uAlpha + pbr.r);
}{@}FaceProjectionShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tDiffuse;
uniform sampler2D tWorldNormal;
uniform sampler2D tEyeNormal;
uniform sampler2D tEyeMatcap;
uniform sampler2D tDepth;
uniform sampler2D tAlpha;
uniform sampler2D tHairFlow;

uniform vec3 uMousePos;
uniform vec3 uPrevMousePos;
uniform float uMouseBright;
uniform vec3 uFlickerLightPos;
uniform float uMouseHold;
uniform vec3 uTemplateLight;

uniform float uSplit;
uniform float uDirectionalStretchRight;
uniform float uDirectionalStretchLeft;
uniform float uGlow;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vData;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vEyeNormal;
varying vec2 vEyeSaccades;
varying float vDist;
varying float vMouseSpeed;

#!SHADER: Vertex
#require(rotation.glsl)
#require(skinning.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;

    // top teeth
    if (vdata.r > 0.9 && vdata.r < 1.1) {
        // pos.y += 0.001;
    }

    // bottom teeth
    if (vdata.r > 1.9 && vdata.r < 2.1) {
        // pos.y += 0.003;
        pos.z -= 0.005;
    }

    // applySkin(pos, n);

    // subtle breathing animation
    float angle = sin(time * 1.5 + 0.1) * 0.009;
    pos.z += 0.05;
    pos = (rotationMatrix(vec3(1.0, 0.0, 0.0), angle) * vec4(pos, 1.0)).xyz;
    pos.z -= 0.05;

    // clone split
    pos.x *= mix(1.0, 2.5, uSplit);
    pos.y *= mix(1.0, mix(pow(abs(position.x * 15.0), 2.0), 1.0, 0.5), uSplit);

    // directional stretch right
    pos.x += clamp(position.x + 0.1, 0.0, 1.0) * uDirectionalStretchRight;
    pos.y *= mix(1.0, pow(clamp(1.0 - pos.x * 3.0, 0.0, 1.0), 2.0), uDirectionalStretchRight);

    // directional stretch left
    float px = pos.x;
    pos.x -= clamp(-position.x + 0.1, 0.0, 1.0) * uDirectionalStretchLeft;
    pos.y *= mix(1.0, pow(clamp(1.0 + px * 3.0 - 0.2, 0.0, 1.0), 2.0), uDirectionalStretchLeft);


    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vUv2 = uv2;
    vData = vdata;
    vDist = length(pos - position);
    vec3 worldPos = (modelMatrix * vec4(pos, 1.0)).xyz;
    vPos = worldPos;
    vV = worldPos - cameraPosition;

    // reduce strength of transformation matrix so that eye catch light doesn't move around too much
    vEyeNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz * vec3(0.4, 0.5, 1.0)) * (texture2D(tEyeNormal, uv).xyz * 2.0 - 1.0);
    vMouseSpeed = clamp(length(uMousePos - uPrevMousePos) * 10.0, 0.0, 1.0);
    
    // eye saccades in vertex shader for better performance
    vEyeSaccades.x += floor(sin(time) * 0.5 + 0.6) * 0.0002;
    vEyeSaccades.x += floor(sin(time * 1.7) * 0.5 + 0.6) * 0.0002;
    vEyeSaccades.y += floor(sin(time * 0.43) * 0.5 + 0.6) * 0.00015;
}

#!SHADER: Fragment

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    vec3 hairMask = texture2D(tAlpha, vUv).rgb;
    float alpha = hairMask.r;

    if (alpha < 0.5) discard;

    // subtle wind blowing through hair
    vec2 hairFlow = texture2D(tHairFlow, vUv).rg;
    vec2 hairDistortion = hairMask.g * vec2(sin(-vPos.y * 6.0 + vPos.z * 0.1 - time * 6.5 - hairFlow.r * 4.0)) * 2.0 - 1.0;
    vec2 uv = vUv;
    uv -= 0.5;
    uv += hairDistortion * 0.00055;
    uv += 0.5;

    // eye saccades
    uv.x += hairMask.b * vEyeSaccades.x;
    uv.x += hairMask.b * vEyeSaccades.x;
    uv.y += hairMask.b * vEyeSaccades.y;

    vec3 color = texture2D(tMap, uv).rgb;

    // eye catch light
    // vec2 muv = matcap(vV, (texture2D(tEyeNormal, uv).xyz * 2.0 - 1.0));
    vec2 muv = matcap(vV, normalize(vEyeNormal));
    vec3 matcap = texture2D(tEyeMatcap, muv).rgb;

    // mouse point light
    vec3 normal = texture2D(tWorldNormal, vUv).rgb;
    normal = normal * 2.0 - 1.0;

    float dist = length(uMousePos.xy - vPos.xy);
    float clampedDist = 1.0 - clamp(dist * 1.0, 0.0, 1.0);
    clampedDist = pow(clampedDist, 2.0);
    clampedDist = clamp(clampedDist * 1.0, 0.0, 1.0);
    
    vec3 lightDir = -normalize(vPos * vec3(1.0, 1.0, 1.0) - (uMousePos * vec3(1.0, 1.0, 1.0) + vec3(0.0, 0.0, 4.0 + sin(time) * 2.0)));
    float lighting = max(0.0, dot(lightDir, normal));
    lighting *= clampedDist;

    vec3 diff = texture2D(tDiffuse, vUv).rgb;
    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb = mix(color.rgb, color.rgb * 0.5, uMouseHold * smoothstep(0.8, 1.0, 1.0-lighting));
    float strength = 1.0 + uMouseHold * 10.0;
    color.rgb += lighting * pow(diff, vec3(2.2)) * 1.0 * uMouseBright;
    color.rgb = pow(color.rgb, vec3(0.45));


    // Flicker Light
    // vec3 lightDir2 = -normalize(vPos * uFlickerLightPos + vec3(sin(time * 0.5)) * 1.0);
    // float lighting2 = max(0.0, dot(lightDir2, normal));
    // color.rgb = pow(color.rgb, vec3(2.2));
    // float flickerSine= sin(time*60.5) * 0.1 + sin(time*15.5) * 0.2 + sin(time*0.5) * 1.5;
    // float flicker = (0.5 + flickerSine * 0.2);
    // color.rgb += lighting2 * pow(diff, vec3(2.2)) * flicker * (0.4 + uMouseHold * 0.1);
    // color.rgb = pow(color.rgb, vec3(0.45));

    // Catch light
    color.rgb += matcap * hairMask.b;

    // Template Light
    // vec3 lightDir3 = -normalize(vPos * vec3(1.0, 1.0, 1.0) - vec3(uTemplateLight.xy, 3.0));
    // float lighting3 = max(0.0, dot(lightDir3, normal));
    // lighting3 = pow(lighting3, 2.0);
    // lighting3 *= alpha;//smoothstep(0.35, 0.3, length(vPos));

    // color.rgb = pow(color.rgb, vec3(2.2));
    // color.rgb += lighting3 * pow(diff, vec3(2.2)) * uTemplateLight.z * 0.8;
    // color.rgb = pow(color.rgb, vec3(0.45));

        // inner mouth
    if (vData.r > 2.9 && vData.r < 3.1) {
        color = vec3(0.0);
    }

    // depth map test
    // float fadeFactor = sin(time * 2.0) * 0.5 + 0.5;
    // color.rgb *= smoothstep(0.8 - fadeFactor * 0.8, 0.9, texture2D(tDepth, vUv).r);


    // color.rgb = vec3(clampedDist);
    // color.rgb = vec3(uMouseBright);


    gl_FragColor = vec4(color, alpha);
}{@}TorsoShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tDiffuse;
uniform sampler2D tWorldNormal;
uniform sampler2D tAlpha;
uniform sampler2D tDepth;

uniform vec3 uMousePos;
uniform vec3 uPrevMousePos;
uniform float uMouseBright;
uniform float uMouseHold;

uniform float uSplit;
uniform float uDirectionalStretchRight;
uniform float uDirectionalStretchLeft;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying float vDist;
varying float vMouseSpeed;

#!SHADER: Vertex
#require(rotation.glsl)
#require(skinning.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;

    // subtle breathing animation
    pos = (rotationMatrix(vec3(1.0, 0.0, 0.0), sin(time * 1.5 + pos.y * 2.0) * 0.04 * (1.0 - uv.y)) * vec4(pos, 1.0)).xyz;
    pos.y += 0.001;

    // clone split
    pos.x *= mix(1.0, 2.5, uSplit);
    // pos.y *= mix(1.0, mix(pow(abs(position.x * 15.0), 2.0), 1.0, 0.5), uSplit);

    // directional stretch right
    pos.x += clamp(position.x + 0.1, 0.0, 1.0) * uDirectionalStretchRight;
    // pos.y *= mix(1.0, pow(clamp(1.0 - pos.x * 3.0, 0.0, 1.0), 2.0), uDirectionalStretchRight);

    // directional stretch left
    float px = pos.x;
    pos.x -= clamp(-position.x + 0.1, 0.0, 1.0) * uDirectionalStretchLeft;
    // pos.y *= mix(1.0, pow(clamp(1.0 + px * 3.0 - 0.2, 0.0, 1.0), 2.0), uDirectionalStretchLeft);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vDist = length(pos - position);
    vPos = (modelMatrix * vec4(pos, 1.0)).xyz;
    vMouseSpeed = clamp(length(uMousePos - uPrevMousePos) * 10.0, 0.0, 1.0);
}

#!SHADER: Fragment
void main() {
    float mask = vUv.y - abs(vUv.x - 0.5) * 0.95;
    if (mask > 0.8) discard;

    vec3 color = texture2D(tMap, vUv).rgb;

    // mouse point light
    vec3 normal = texture2D(tWorldNormal, vUv).rgb;

    normal = normal * 2.0 - 1.0;

    float dist = length(uMousePos.xy - vPos.xy);
    float clampedDist = 1.0 - clamp(dist * 1.3, 0.0, 1.0);
    clampedDist = pow(clampedDist, 2.0);
    clampedDist = clamp(clampedDist * 1.0, 0.0, 1.0);

    vec3 lightDir = -normalize(vPos * vec3(1.0, 1.0, 1.0) - (uMousePos * vec3(1.0, 1.0, 1.0) + vec3(0.0, 0.0, 0.5)));
    float lighting = max(0.0, dot(lightDir, normal));
    lighting *= clampedDist;

    // color.rgb = pow(color.rgb, vec3(2.2));
    // color.rgb += lighting * pow(texture2D(tDiffuse, vUv).rgb, vec3(2.2)) * 0.2 * uMouseBright;
    // color.rgb = pow(color.rgb, vec3(0.45));

    vec3 diff = texture2D(tDiffuse, vUv).rgb;

    color.rgb = pow(color.rgb, vec3(2.2));

    color.rgb = mix(color.rgb, color.rgb * 0.4, uMouseHold * smoothstep(0.8, 1.0, 1.0-lighting));
    float strength = 1.0 + uMouseHold * 8.0;
    color.rgb += lighting * pow(diff, vec3(2.2)) * 1.0 * uMouseBright;
    color.rgb = pow(color.rgb, vec3(0.45));

    // depth map test
    // float fadeFactor = sin(time * 2.0) * 0.5 + 0.5;
    // color.rgb *= smoothstep(0.8 - fadeFactor * 0.8, 0.9, texture2D(tDepth, vUv).r);



    gl_FragColor = vec4(color, 1.0);
}{@}CloudLayersBackgroundShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tSkyGradient;
uniform sampler2D tMap;
uniform float uThreshold;
uniform float uSoftness;
uniform float uHighlightOffset;
uniform vec2 uTiling;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform vec3 uColor4;
uniform vec3 uColor5;
uniform float uContrast;

#!VARYINGS
varying vec3 vColor;
varying vec2 vUv;
varying vec3 vBaseColor;
varying vec3 vLightColor;
varying vec3 vScatterColor;
varying vec3 vShadowColor;
varying vec3 vSkyBaseColor;
varying vec3 vSkyColor;
varying float vAlpha;
varying vec3 vPos;
varying float vSunDistGradient;

#!SHADER: Vertex
float getClouds(sampler2D tMap, vec2 uv, float t, vec2 off) {
    float n1 = texture2D(tMap, uv + off).r;
    float n2 = texture2D(tMap, uv * 0.4 + off * 0.8).r;
    return n1 * n2;
}

void main() {
    vec3 pos = position;
    vUv = uv;

    float t = time * 0.05;
    float displacement = getClouds(tMap, uv, t, vec2(0.0));
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vBaseColor = pow(uColor1, vec3(2.2));
    vScatterColor = pow(uColor2, vec3(2.2));
    vLightColor = pow(uColor3, vec3(2.2));
    vShadowColor = pow(uColor4, vec3(2.2));
    vSkyBaseColor = pow(uColor5, vec3(2.2));
    vAlpha = smoothstep(1.0, 0.5, abs(uv.x - 0.5) * 2.0);
    vPos = position;
    vSunDistGradient = pow(uv.y, 2.0);
}

#!SHADER: Fragment
float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

float getClouds(sampler2D tMap, vec2 uv, float t, vec2 off) {
    float n1 = texture2D(tMap, uv + off).r;
    float n2 = texture2D(tMap, uv * 0.4 + off * 0.8).r;
    return n1 * n2;
}

void main() {
    vec2 uv = vUv * uTiling;
    float t = time * 0.05;

    // clouds
    vec2 off = vec2(0.0, t);
    float eps = uHighlightOffset * 0.01;
    vec2 h = vec2(eps, 0.0);
    float grad1 = getClouds(tMap, uv, t, off + h.yx);
    float grad2 = getClouds(tMap, uv, t, off - h.yx);
    float a = grad1;
    vec3 n = normalize(vec3(
        0.0,
        grad2 - grad1,
        a * 0.4
    ));

    a = smoothstep(uThreshold, uThreshold + uSoftness, a);

    float dist = 1.0 - length(vPos - vec3(6.0, 0.0, 0.0)) * 0.05;
    dist = pow(dist + 0.1, 6.0);
    vec3 lightColor = max(0.0, n.y + vUv.y) * vLightColor * dist;
    vec3 scatterColor = (n.y * 0.5 + 0.5) * vScatterColor * dist;
    vec3 color = vShadowColor + vBaseColor * vUv.y + scatterColor + lightColor;

    a = a * vBaseColor.r + lightColor.r * a;
    a *= vAlpha;
    a *= 1.0 - pow(vUv.y, 5.0);

    color *= a;
    color += pow(vSunDistGradient, 5.0) * vLightColor * 1.5;
    a *= mix(1.0, vSunDistGradient, 0.5);

    // sky
    vec3 skyColor = texture2D(tSkyGradient, vec2(0.0, abs(vPos.y) * 0.3)).rgb;
    skyColor = mix(vSkyBaseColor, skyColor, mix(dist * 0.6, 1.0, 0.0));
    skyColor *= clamp(1.0 - a * 0.75, 0.0, 1.0);
    skyColor = pow(skyColor, vec3(2.2));

    color += skyColor;
    color = pow(color, vec3(0.45));

    color -= 0.5;
    color *= uContrast;
    color += 0.5;


    gl_FragColor = vec4(color, 1.0);
}{@}CloudLayersOpaqueShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform vec3 uColor4;
uniform vec3 uColor5;

#!VARYINGS
varying vec2 vUv;
varying vec3 vBaseColor;
varying vec3 vLightColor;
varying vec3 vScatterColor;
varying vec3 vShadowColor;
varying float vAlpha;

#!SHADER: Vertex
float getClouds(sampler2D tMap, vec2 uv, float t, vec2 off) {
    float n1 = texture2D(tMap, uv + off).r;
    float n2 = texture2D(tMap, uv * 0.4 + off * 0.8).r;
    return n1 * n2;
}

void main() {
    vec3 pos = position;
    vUv = uv;

    float t = time * 0.05;
    float displacement = getClouds(tMap, uv, t, vec2(0.0));
    // vUv.x -= 0.5;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    // vUv.x *= vUv.y;
    // vUv.x += 0.5;

    vBaseColor = pow(uColor1, vec3(2.2));
    vScatterColor = pow(uColor2, vec3(2.2));
    vLightColor = pow(uColor3, vec3(2.2));
    vShadowColor = pow(uColor4, vec3(2.2));
    vAlpha = smoothstep(1.0, 0.5, abs(uv.x - 0.5) * 2.0);
}

#!SHADER: Fragment
float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

float getClouds(sampler2D tMap, vec2 uv, float t, vec2 off) {
    float n1 = texture2D(tMap, uv + off).r;
    float n2 = texture2D(tMap, uv * 0.4 + off * 0.8).r;
    return n1 * n2;
}

void main() {
    vec2 uv = vUv * vec2(2.0, 1.5);
    float t = time * 0.02;
    vec2 off = vec2(0.0, t);
    float eps = 0.02;
    vec2 h = vec2(eps, 0.0);
    float grad1 = getClouds(tMap, uv, t, off + h.xy);

    float grad2 = getClouds(tMap, uv, t, off - h.xy);
    float grad3 = getClouds(tMap, uv, t, off + h.yx);
    float grad4 = getClouds(tMap, uv, t, off - h.yx);
    float a = mix(grad1, grad2, 0.5);
    vec3 n = normalize(vec3(
        grad2 - grad1,
        grad4 - grad3,
        a * 0.3
    ));

    float low = 0.25;
    a = smoothstep(low, low + 0.3, a);

    // color/lighting
    float dist = 1.0 - length(vUv - vec2(0.5, 1.0));
    dist = pow(dist + 0.35, 3.0);
    // vec3 lightColor = max(0.0, n.y + vUv.y) * vLightColor * dist;
    vec3 scatterColor = (n.y * 0.5 + 0.5) * vScatterColor * dist;
    // vec3 color = vShadowColor + vBaseColor * vUv.y + scatterColor + lightColor;
    vec3 color = vShadowColor;
    color += scatterColor;
    color = pow(color, vec3(0.45));

    // a = a * dist * vBaseColor.r + lightColor.r * a;
    // a *= vAlpha;
    // a *= 1.0 - pow(vUv.y, 5.0);

    gl_FragColor = vec4(color, 1.0);
}{@}CloudLayersShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uThreshold;
uniform vec2 uTiling;
uniform vec2 uSoftness;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform vec3 uColor4;
uniform vec3 uColor5;

#!VARYINGS
varying vec2 vUv;
varying vec3 vBaseColor;
varying vec3 vLightColor;
varying vec3 vScatterColor;
varying vec3 vShadowColor;
varying float vAlpha;

#!SHADER: Vertex
float getClouds(sampler2D tMap, vec2 uv, float t, vec2 off) {
    float n1 = texture2D(tMap, uv + off).r;
    float n2 = texture2D(tMap, uv * 0.4 + off * 0.8).r;
    return n1 * n2;
}

void main() {
    vec3 pos = position;
    vUv = uv;

    float t = time * 0.05;
    float displacement = getClouds(tMap, uv, t, vec2(0.0));
    // vUv.x -= 0.5;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    // vUv.x *= vUv.y;
    // vUv.x += 0.5;

    vBaseColor = pow(uColor1, vec3(2.2));
    vScatterColor = pow(uColor2, vec3(2.2));
    vLightColor = pow(uColor3, vec3(2.2));
    vShadowColor = pow(uColor4, vec3(2.2));
    vAlpha = smoothstep(1.0, 0.5, abs(uv.x - 0.5) * 2.0);
}

#!SHADER: Fragment
float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

float getClouds(sampler2D tMap, vec2 uv, float t, vec2 off) {
    float n1 = texture2D(tMap, uv + off).r;
    float n2 = texture2D(tMap, uv * 0.4 + off * 0.8).r;
    return n1 * n2;
}

void main() {
    vec2 uv = vUv * uTiling;
    float t = time * 0.05;
    vec2 off = vec2(0.0, t);
    float eps = 0.008;
    vec2 h = vec2(eps, 0.0);
    float grad1 = getClouds(tMap, uv, t, off + h.yx);
    float grad2 = getClouds(tMap, uv, t, off - h.yx);
    float a = mix(grad1, grad2, 0.5);
    vec3 n = normalize(vec3(
        0.0,
        grad2 - grad1,
        a * 0.3
    ));

    float low = 0.25;
    // a = smoothstep(low, low + 0.3, a);
    a = smoothstep(uThreshold, uThreshold + 0.3, a);
    // if (a < 0.1) discard;

    // color/lighting
    float dist = 1.0 - length(vUv - vec2(0.5, 1.0)) * 1.5;
    dist = pow(dist + 0.35, 3.0);
    vec3 lightColor = max(0.0, n.y + vUv.y) * vLightColor * dist;
    vec3 scatterColor = (n.y * 0.5 + 0.5) * vScatterColor * dist;
    vec3 color = vShadowColor + vBaseColor * vUv.y + scatterColor + lightColor;
    // vec3 color = vShadowColor + vBaseColor * vUv.y + lightColor;
    color = pow(color, vec3(0.45));

    a = a * dist * vBaseColor.r + lightColor.r * a;
    a *= vAlpha;
    a *= 1.0 - pow(vUv.y, 5.0);

    gl_FragColor = vec4(color, a);
}{@}CloudLayersVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}

void main() {
    vec4 color = texture2D(tDiffuse, vUv);

    vec3 bloom = getUnrealBloom(vUv).rgb;

    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb += pow(bloom, vec3(2.2));
    // color.rgb = czm_saturation(color.rgb, 1.1);
    color.rgb = pow(color.rgb, vec3(0.45));

    color.rgb += rand(vUv + fract(time)) * 0.075;

  gl_FragColor = color;
}{@}LayeredSkyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tClouds;

uniform float uSpeed;
uniform float uGrayscale;
uniform vec3 uHSL;

uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform vec3 uColor4;
uniform vec3 uColor5;
uniform vec3 uColor6;

#!VARYINGS
varying vec2 vUv;
varying vec3 vColor1;
varying vec3 vColor2;
varying vec3 vColor3;
varying vec3 vColor4;
varying vec3 vColor5;
varying vec3 vColor6;
varying float vDist;
varying vec3 vRayDir;
varying vec3 vSamplePos;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);

    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;

    vec3 rayDir = normalize(worldPos.xyz - cameraPosition);
    
    vRayDir = rayDir;
    vec3 rayOrigin = worldPos.xyz - rayDir;
    vec3 samplePos = rayOrigin;
    vSamplePos = rayOrigin - rayDir * 300.0;
    vPos = pos;

    vColor1 = pow(uColor1, vec3(2.2));
    vColor2 = pow(uColor2, vec3(2.2));
    vColor3 = pow(uColor3, vec3(2.2));
    vColor4 = pow(uColor4, vec3(2.2));
    vColor5 = pow(uColor5, vec3(2.2));
    vColor6 = pow(uColor6, vec3(2.2));
}

#!SHADER: Fragment

#require(rgb2hsv.fs)

float getClouds(vec3 samplePos, vec3 rayDir) {
    float dist = distance(samplePos, vec3(samplePos.x, 280.0, samplePos.z));
    dist = dist / dot(rayDir, vec3(0.0, 1.0, 0.0));
    return dist;
}

float getVolumeSample(vec3 samplePos) {
    float cloud = texture2D(tClouds, samplePos.xz * 0.0004 + vec2(0.0, -time * 0.02 * uSpeed)).r;
    cloud *= texture2D(tClouds, samplePos.xz * 0.0002 + vec2(0.0, -time * 0.02 * uSpeed)).r;
    return cloud;
}

void main() {
    vec3 rayDir = vRayDir;
    float ground = clamp(1.0 - (rayDir.y * 15.0 + 0.5), 0.0, 1.0);
    // if (rayDir.y < 0.0) {
    //     ground = 1.0;   
    // }

    float dist = 0.0;
    float totalDist = 0.0;
    vec3 samplePos = vSamplePos;

    float l = length(vPos);

    // move sample pos exactly to surface
    dist = getClouds(samplePos, rayDir);
    samplePos += dist * rayDir;
    samplePos.xz *= vec2(1.0, 0.5);
    vec3 firstSamplePos = samplePos;

    // accumulate volume samples
    float volume = 0.0;
    float stepLength = 1250.0;
    float val1 = 0.0;
    float val2 = 0.0;

    // first sample
    val1 = getVolumeSample(samplePos);
    volume += val1;
    samplePos += stepLength * rayDir;
    float volume1 = volume;

    // second sample
    val2 = getVolumeSample(samplePos);
    volume += val2;
    samplePos += stepLength * rayDir;

    vec2 uv = vUv;

    float alpha = smoothstep(0.0, 0.09, volume);
    alpha = clamp(alpha, 0.0, 1.0);

    // calculate normal
    float eps = 0.01;
    vec3 n = normalize(vec3((vUv.x - 0.5) * 0.1, 0.2, 3.0 * (getVolumeSample(firstSamplePos + vec3(0.0, 0.0, 4.0 * dist * 0.004)) - val1)));

    // sky color
    float skyGrad = length(vPos - vec3(0.0, -0.5, 4.5)) * 0.1;
    skyGrad = clamp(1.0 - skyGrad, 0.0, 1.0);
    float skyGradTight = pow(skyGrad + 0.07, 3.0); 
    float skyGradTighter = pow(skyGrad + 0.01, 12.0); 
    vec3 skyColor = vColor6 + vColor6 * skyGradTight * 0.5;

    // cloud color
    vec3 color = mix(vColor1, vColor2, alpha * skyGrad);
    color += skyGradTight * vColor3 * clamp(n.z * 0.5 + 0.5, 0.0, 1.0) * volume * 10.0;
    color += (skyGradTight + skyGrad * 0.25) * vColor4 * clamp(n.z, 0.0, 1.0) * volume * 10.0;

    color *= alpha;
    color += skyColor * (1.0 - alpha);


    color += skyGradTighter * (vColor5) * 6.0;
    color += skyGradTighter * (vColor4) * 5.0;

    color += smoothstep(1.5, -1.5, vPos.y) * 1.0 * vColor3 *  smoothstep(-15.0, 5.0, vPos.z);

    color = pow(color, vec3(0.45));
    //color = mix(color, uColor1, ground);


    color = rgb2hsv(color);
    color.x += uHSL.x;
    color.y *= uHSL.y;
    color.z *= uHSL.z;
    color = hsv2rgb(color);

    // grayscale
    // vec3 grayscale = vec3(color.b * 0.75 + color.r * 0.55 + color.g * 0.1);
    // color = mix(color, grayscale, 1.0);

    gl_FragColor = vec4(color, 1.0);
}{@}LightmapCloudsShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tSkyGradient;
uniform sampler2D tLightmap;
uniform sampler2D tMap;
uniform float uThreshold;
uniform float uSoftness;
uniform float uHighlightOffset;
uniform vec2 uTiling;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform vec3 uColor4;
uniform vec3 uColor5;
uniform float uContrast;

#!VARYINGS
varying vec2 vUv;
varying float vAlpha;
varying vec3 vPos;
varying vec3 vColor1;
varying vec2 vCloudUv;

#!SHADER: Vertex
float getClouds(sampler2D tMap, vec2 uv, float t, vec2 off) {
    float n1 = texture2D(tMap, uv + off).r;
    float n2 = texture2D(tMap, uv * 0.4 + off * 0.8).r;
    return n1 * n2;
}

void main() {
    vec3 pos = position;
    vec3 worldPos = (modelMatrix * vec4(position, 1.0)).xyz;
    vUv = uv;

    float t = time * 0.05;
    float displacement = getClouds(tMap, uv, t, vec2(0.0));
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vPos = position;
    vCloudUv = mix(worldPos.xz, worldPos.xy * vec2(1.0, -1.0), 0.85) * 0.01;
    vCloudUv.y *= -1.0;
    vCloudUv *= uTiling;
    vColor1 = pow(uColor1, vec3(2.2));
}

#!SHADER: Fragment
float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

float getClouds(sampler2D tMap, vec2 uv, float t, vec2 off) {
    float n1 = texture2D(tMap, uv + off).r;
    float n2 = texture2D(tMap, uv * 0.4 + off * 0.8).r;
    return n1 * n2;
}

void main() {
    vec2 uv = vUv * uTiling;
    float t = time * 0.05;

    // clouds
    vec2 off = vec2(0.0, t);
    float eps = uHighlightOffset * 0.01;
    vec2 h = vec2(eps, 0.0);
    float grad1 = getClouds(tMap, vCloudUv, t, off + h.yx);
    float a = grad1;

    a = smoothstep(uThreshold, uThreshold + uSoftness, a);
    a = clamp(a, 0.0, 1.0);

    // sky
    vec3 lightmap = texture2D(tLightmap, vUv).rgb;
    lightmap = pow(lightmap, vec3(2.2));
    // float blend = clamp(a - pow(lightmap.r, 2.0), 0.0, 1.0);
    // float blend = clamp(a - pow(lightmap.r, 2.0), 0.0, 1.0);
    float blend = a;
    vec3 cloudColor = min(vColor1, lightmap) * blend;
    lightmap *= 1.0 - blend;
    vec3 color = lightmap + cloudColor;

    color = pow(color, vec3(0.45));

    color -= 0.5;
    color *= uContrast;
    color += 0.5;

    gl_FragColor = vec4(color, 1.0);
}{@}SimpleSkyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec3 uColor3;
uniform vec3 uColor4;
uniform float uDist;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUvOriginal;
varying vec3 vPos;
varying vec3 vColor1;
varying vec3 vColor2;
varying vec3 vColor3;
varying vec3 vColor4;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vUv *= uTiling;
    vUv += uOffset;
    vUvOriginal = uv;
    vPos = position;
    vColor1 = pow(uColor1, vec3(2.2));
    vColor2 = pow(uColor2, vec3(2.2));
    vColor3 = pow(uColor3, vec3(2.2));
    vColor4 = pow(uColor4, vec3(2.2));
}

#!SHADER: Fragment
void main() {
    float dist = max(0.0, 1.0 - length(vPos - vec3(0.0, 0.0, 1.0)) * uDist);
    dist = pow(dist, 3.0);
    vec3 color = pow(texture2D(tMap, vUv).rgb, vec3(2.2));
    color = mix(vColor1, color, dist);
    color += vColor2 * pow(dist, 5.0);
    color *= 1.3;
    color = pow(color, vec3(0.45));
    gl_FragColor = vec4(color, 1.0);
}{@}CoinShaderPBR.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uCoinRadius;
uniform float uCoinThickness;
uniform float uSteepness;
uniform float uTime;
uniform float uAngle;
uniform vec3 uLocalOffset;
uniform vec3 uLocalScale;
uniform vec3 uCenterOffset;

uniform float uTransition;
uniform float uLocalTime;
uniform float uLocalSteepness;
uniform float uLocalRadius;

uniform float uSmallCoinTime;
uniform float uSmallCoinAngle;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
#require(pbr.vs)
#require(rotation.glsl)

const float PI = 3.14159;
const float HALF_PI = PI * 0.5;
const float COIN_RADIUS = 1.0;
const float COIN_THICKNESS = 0.09 * 0.5;

const float SMALL_COIN_RADIUS = 0.4147;


void main() {

    float t = uTime;
    float angle = uAngle;

    vec3 pos = position;
    pos *= uLocalScale;
    vec3 up = vec3(0.0, 1.0, 0.0);

    // put small coin in center of big coin
    pos += uLocalOffset;

    mat4 rmatrix1 = rotationMatrix(up, t);
    mat4 rmatrix2 = rotationMatrix(vec3(1.0, 0.0, 0.0), angle);
    mat4 rmatrix3 = rotationMatrix(vec3(0.0, 0.0, 1.0), -t);

    pos = (rmatrix3 * vec4(pos, 1.0)).xyz;

    pos.y += COIN_RADIUS;
    pos = (rmatrix2 * vec4(pos, 1.0)).xyz;
    pos.y -= COIN_RADIUS;

    pos.z += COIN_RADIUS;
    pos = (rmatrix1 * vec4(pos, 1.0)).xyz;
    pos.z -= COIN_RADIUS;

    float smallt = 0.4 * uSmallCoinTime;
    float smallangle = uSmallCoinAngle;

    vec3 n = normal;

    // if small coin has been transitioned to the ground, play spinning animation
    if (uTransition > 0.5) {
        pos += uCenterOffset;
        mat4 rmatrix4 = rotationMatrix(up, smallt);
        mat4 rmatrix5 = rotationMatrix(vec3(0.0, 0.0, 1.0), smallangle);
        mat4 rmatrix6 = rotationMatrix(vec3(0.0, 1.0, 0.0), -smallt);

        pos = (rmatrix6 * vec4(pos, 1.0)).xyz;

        pos.x += SMALL_COIN_RADIUS;
        pos = (rmatrix5 * vec4(pos, 1.0)).xyz;
        pos.x -= SMALL_COIN_RADIUS;

        pos = (rmatrix4 * vec4(pos, 1.0)).xyz;

        pos -= uCenterOffset;

        n = (rmatrix6 * vec4(n, 0.0)).xyz;
        n = (rmatrix5 * vec4(n, 0.0)).xyz;
        n = (rmatrix4 * vec4(n, 0.0)).xyz;
    }

    vUv = uv * uTiling + uOffset;
    vUv2 = uv2;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;

    n = (rmatrix3 * vec4(n, 0.0)).xyz;
    n = (rmatrix2 * vec4(n, 0.0)).xyz;
    n = (rmatrix1 * vec4(n, 0.0)).xyz;

    vNormal = normalMatrix * normal;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
#require(pbr.fs)

void main() {
    vec3 color = texture2D(tBaseColor, vUv).rgb;

    vec3 pbr = getPBR(color).rgb;
    pbr = mix(pbr, length(pbr) * color, 0.75);

    gl_FragColor = vec4(pbr, 1.0);
}{@}CubemapTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform samplerCube tCube;
uniform float uMipLevel;
uniform float uUseBias;
varying vec3 vNormal;

#!VARYINGS

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vNormal = normal;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    vec3 color;
    if (uUseBias > 0.0) {
        color = texture(tCube, vNormal, uMipLevel).rgb;
    } else {
        color = textureLod(tCube, vNormal, uMipLevel).rgb;
    }
    gl_FragColor = vec4(color, 1.0);
}
{@}DebugUvShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
