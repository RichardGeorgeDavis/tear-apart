}

#!SHADER: Fragment
#require(rotation.glsl)
void main() {
    vec2 uv = vec2(0.0, vPos.y);
    uv.y -= 0.5;
    uv.y *= uParams.x;
    uv.y += 0.5;
    uv = rotationMatrix(sin(time) * 0.5) * uv;

    float clouds = texture2D(tMap, vUv).r;

    vec3 color = mix(uColor0, uColor1, uv.y);
    color += clouds;
    // color *= mix(vec3(1.0), uColor3, clamp(vWorldPos.y * 0.005, 0.0, 1.0));
    gl_FragColor = vec4(color, 1.0);
}{@}SkyShader.glsl{@}#!ATTRIBUTES

