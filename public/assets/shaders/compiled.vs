}{@}RaymarchBillboardShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler3D tCloud3D;
uniform sampler3D tVoronoi3D;
uniform sampler3D tPerlin3D;
uniform sampler2D tIndirection1;
uniform sampler2D tIndirection2;

uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec2 vUv;
varying vec3 vColor;
varying float vDist;
varying float vTotalDist;
varying float vMaxDist;
varying vec3 vRayDir;
varying vec3 vSamplePos;
varying vec3 vScrollOffset;
// varying float vSnoise;
varying float vCount;
varying vec3 vCameraRightWorld;
varying vec3 vCameraUpWorld;
varying vec3 vCameraForwardWorld;
varying vec4 vRandom;

#!SHADER: Vertex
const float PHI = 1.61803398874989484820459; // Φ = Golden Ratio 

float gold_noise(in vec2 xy, in float seed)
{
    return fract(tan(distance(xy*PHI, xy)*seed)*xy.x);
}

float sdBox( vec3 p, vec3 b )
{
  vec3 q = abs(p) - b;
  return length(max(q,0.0)) + min(max(q.x,max(q.y,q.z)),0.0);
}

float opSmoothUnion( float d1, float d2, float k ) {
    float h = clamp( 0.5 + 0.5*(d2-d1)/k, 0.0, 1.0 );
    return mix( d2, d1, h ) - k*h*(1.0-h); }

mat2 rotate2d(float angle){
    return mat2(cos(angle),-sin(angle),
                sin(angle),cos(angle));
}

void main() {
    vec3 pos = position;


    vScrollOffset = time * 0.2 * vec3(0.5, 0.55, 0.05);
    // this shader billboards every quad
    vec3 cameraRightWorld = vec3(viewMatrix[0][0], viewMatrix[1][0], viewMatrix[2][0]);
    vec3 cameraUpWorld = vec3(viewMatrix[0][1], viewMatrix[1][1], viewMatrix[2][1]);
    vec3 cameraForwardWorld = vec3(-viewMatrix[0][2], -viewMatrix[1][2], -viewMatrix[2][2]);

    #ifdef INSTANCED
    // float billboardSize = 0.5 * scale.x;
    float billboardSize = 0.5;
    vec3 center = offset;
    center.y += billboardSize * 0.5;

    // padding
    // center.y += 0.3 * billboardSize;
    
    vec2 st = uv * 2.0 - 1.0;

    // reduce all vertices of the quad to the quad's position (stored in vdata)
    // and then stretch them back out to a square using the stored, unitized UVs
    vec3 vertexPosition =
    center
    + cameraRightWorld * st.x * billboardSize
    + cameraUpWorld * st.y * billboardSize;
    vertexPosition += vec3(0.0, 0.4, 0.0);

    pos = vertexPosition;

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);

    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;

    // raymarch
    vec3 screenPos = gl_Position.xyz / gl_Position.w;
    vec3 rayDir = normalize(worldPos.xyz - cameraPosition);
    // rayDir = cameraForwardWorld;
    
    vRayDir = rayDir;
    vec3 rayOrigin = worldPos.xyz - rayDir;
    vec3 samplePos = rayOrigin;
    float dist = 0.0;
    float totalDist = 0.0;
    float epsilon = 0.0003;
    float max_dist = 3.0;
    float count = 0.0;
    float voronoi;
    float bounds;
    float max_scale = 1.148;

    vRandom = vec4(offset, 1.0);

    #endif
    vColor = rayDir;

    // int max_steps = 12;

    // first march samples instances to get close
    for (int i = 0; i < 7; i++) {

        vec3 samplePosProxy = samplePos;
        samplePosProxy += vec3(0.5, 0.0, 0.5);
        samplePosProxy -= offset;
        samplePosProxy.y -= billboardSize * 0.5;

        samplePosProxy -= 0.5;
        samplePosProxy *= 1.0 / scale.r;
        samplePosProxy.xz = rotate2d(-3.14159 / 2.0) * samplePosProxy.xz;
        samplePosProxy += 0.5;
        
        samplePosProxy = clamp(samplePosProxy, vec3(0.0), vec3(1.0));
        dist = texture(tCloud3D, samplePosProxy).r;
        bounds = sdBox(samplePosProxy - vec3(0.5, 0.5, 0.5), vec3(0.5));
        dist = max(dist, bounds);

        // if (dist < epsilon || totalDist > max_dist)
        //     break;

        totalDist += dist;
        samplePos += dist * rayDir; 
    }

    for (int i = 0; i < 0; i++)
    {

        vec3 samplePosProxy = samplePos;
        samplePosProxy.y -= billboardSize * 0.5;
        samplePosProxy.xz *= 0.5;

        // sample indirection texture to get uvs to sample sdf with
        vec4 uv1 = texture2D(tIndirection1, samplePosProxy.xz);
        uv1.xyz = vec3(uv1.y, samplePosProxy.y / (uv1.z * max_scale), uv1.x);
        // uv1.xyz = clamp(uv1.xyz, vec3(0.0), vec3(1.0));

        vec4 uv2 = texture2D(tIndirection2, samplePosProxy.xz);
        uv2.xyz = vec3(uv2.y, samplePosProxy.y / (uv2.z * max_scale), uv2.x);
        // uv2.xyz = clamp(uv2.xyz, vec3(0.0), vec3(1.0));

        // clean up interpolation artifacts caused by linear filtering
        uv1 *= step(0.99, uv1.a);
        uv2 *= step(0.99, uv2.a);

        float SDF1 = texture(tCloud3D, uv1.xyz).r;
        float SDF2 = texture(tCloud3D, uv2.xyz).r;
        bounds = sdBox(samplePosProxy - vec3(0.5, 0.5, 0.5), vec3(0.5));
        SDF1 = max(SDF1, bounds);
        SDF2 = max(SDF2, bounds);

        float SDF = opSmoothUnion(SDF1, SDF2, 0.15);
        // float SDF = min(SDF1, SDF2);


        // float voronoi = texture(tVoronoi3D, samplePosProxy.xyz * 1.5 + vScrollOffset).r;
        // voronoi *= texture(tVoronoi3D, samplePosProxy.xyz * 2.0 + vScrollOffset * 1.5).r;
        // voronoi = min(voronoi, texture(tVoronoi3D, samplePosProxy.xyz * 2.0 + vScrollOffset * 1.5).r);
        voronoi = texture(tVoronoi3D, samplePosProxy.xyz * 1.0 + vScrollOffset).r;
        voronoi = min(voronoi, texture(tVoronoi3D, samplePosProxy.xyz * 2.0 + vScrollOffset * 1.5).r);
        // voronoi = max(voronoi, bounds);
        // SDF += voronoi * 0.3;

        dist = SDF;

        // // Either we've hit the object or hit nothing at all, either way we should break out of the loop
        if (dist < epsilon || totalDist > max_dist)
            break;

        totalDist += dist;
        samplePos += dist * rayDir; // Advance the point forwards in the ray direction by the distance

        count += 1.0;
    }

    // vSnoise = sin((samplePos.x + samplePos.y + samplePos.z) * 2.0 + time);
    // float gn = gold_noise(position.xy, time);
    vSamplePos = samplePos;
    vDist = dist;
    vTotalDist = totalDist;
    vMaxDist = max_dist;
    vCount = count;

    vCameraRightWorld = vec3(viewMatrix[0][0], viewMatrix[1][0], viewMatrix[2][0]);
    vCameraUpWorld = vec3(viewMatrix[0][1], viewMatrix[1][1], viewMatrix[2][1]);
    vCameraForwardWorld = vec3(-viewMatrix[0][2], -viewMatrix[1][2], -viewMatrix[2][2]);

}

#!SHADER: Fragment
const float PHI = 1.61803398874989484820459; // Φ = Golden Ratio 

float opSmoothUnion( float d1, float d2, float k ) {
    float h = clamp( 0.5 + 0.5*(d2-d1)/k, 0.0, 1.0 );
    return mix( d2, d1, h ) - k*h*(1.0-h); }

float gold_noise(in vec2 xy, in float seed)
{
return fract(tan(distance(xy*PHI, xy)*seed)*xy.x);
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

float sdBox( vec3 p, vec3 b )
{
  vec3 q = abs(p) - b;
  return length(max(q,0.0)) + min(max(q.x,max(q.y,q.z)),0.0);
}

void main() {
    // float fovFactor = 3.758;
    // vec2 screenPos = -1.0 + 2.0 * gl_FragCoord.xy / resolution.xy; // screenPos can range from -1 to 1
    // screenPos.x *= resolution.x / resolution.y; // Correct aspect ratio
    // vec3 rayDir = normalize(vCameraRightWorld * screenPos.x + vCameraUpWorld * screenPos.y + vCameraForwardWorld * fovFactor);

    vec3 rayDir = vRayDir;

    float dist = vDist;
    float totalDist = vTotalDist;
    vec3 samplePos = vSamplePos;
    vec3 samplePosProxy;
    float max_scale = 1.148;

    float voronoi;
    float perlin;
    float SDF;
    float bounds;

    float gnoise = gold_noise(gl_FragCoord.xy, time);

    for (int i = 0; i < 0; i++) {
        vec3 samplePosProxy = samplePos;
        samplePosProxy.xz *= 0.5;

        // sample indirection texture to get uvs to sample sdf with
        vec4 uv1 = texture2D(tIndirection1, samplePosProxy.xz);
        uv1.xyz = vec3(uv1.y, samplePosProxy.y / (uv1.z * max_scale), uv1.x);
        uv1.xyz = clamp(uv1.xyz, vec3(0.0), vec3(1.0));

        vec4 uv2 = texture2D(tIndirection2, samplePosProxy.xz);
        uv2.xyz = vec3(uv2.y, samplePosProxy.y / (uv2.z * max_scale), uv2.x);
        uv2.xyz = clamp(uv2.xyz, vec3(0.0), vec3(1.0));

        // clean up interpolation artifacts caused by linear filtering
        uv1 *= step(0.99, uv1.a);
        uv2 *= step(0.99, uv2.a);

        float SDF1 = texture(tCloud3D, uv1.xyz).r;
        float SDF2 = texture(tCloud3D, uv2.xyz).r;

        bounds = sdBox(samplePosProxy - vec3(0.5, 0.5, 0.5), vec3(0.4));
        SDF1 = max(SDF1, bounds);
        SDF2 = max(SDF2, bounds);

        float SDF = opSmoothUnion(SDF1, SDF2, 0.15);
        // float SDF = min(SDF1, SDF2);

        // bounds = sdBox(samplePosProxy - vec3(0.5, 0.5, 0.5), vec3(0.4));
        // SDF = max(SDF, bounds);

        voronoi = texture(tVoronoi3D, samplePos.xyz * 1.0 + vScrollOffset).r;
        voronoi = min(voronoi, texture(tVoronoi3D, samplePos.xyz * 2.0 + vScrollOffset * 1.5).r);

        perlin = texture(tPerlin3D, samplePos.xyz * 6.0 + vec3(time * 0.1, 0.0, time * 0.2)).r;
        perlin = min(perlin, texture(tPerlin3D, samplePos.xyz * 12.0 + vec3(time * 0.3, 0.0, time * 0.25)).r);

        // voronoi = voronoi * perlin * 0.75;
        // SDF += voronoi * 0.3;

        dist = SDF;

        if (totalDist > vMaxDist || dist < 0.0003)
            break;

        totalDist += dist;
        samplePos += dist * rayDir; 
    }

    vec2 uv = vUv;

    float v = dist * 3.0 + 0.1;

    // vec3 col = vec3(clamp(voronoi * 3.0, 0.0, 1.0));
    vec3 col = vec3(clamp(dist * 5.0 + 0.5, 0.0, 1.0));

    // if (totalDist >= vMaxDist) {
    //     discard;
    // }

    // if (dist >= 0.1) {
    //     discard;
    // }




    // float lighting = max(length(samplePos - vec3(0.45, 0.25, 0.45)), 0.0);
    float lighting = length(samplePos - vec3(0.45, 0.25, 0.45));
    lighting = pow(lighting * 2.5, 1.9);
    lighting -= voronoi * 0.8;

    vec3 color = mix(uColor1, uColor2, lighting);

    // gl_FragColor = vec4(color, 1.0);
    // gl_FragColor = vec4(dist * 3.0 + 0.1);
    // gl_FragColor = vec4(col, 1.0);
    gl_FragColor = vec4(uv, 1.0, 1.0);
}{@}RaymarchCageShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler3D tSDF3D;
uniform sampler3D tVoronoi3D;
uniform sampler2D tLightmap;
uniform vec4 uParams;
uniform vec3 uColor1;
uniform vec3 uColor2;

uniform sampler2D tIndirectionA;
uniform sampler2D tIndirectionB;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec4 vDistInfo;
varying vec3 vRayDir;
varying vec3 vScrollOffset;
varying vec3 vScrollOffset2;

#!SHADER: Vertex
float opSmoothUnion( float d1, float d2, float k ) {
    float h = clamp( 0.5 + 0.5*(d2-d1)/k, 0.0, 1.0 );
    return mix( d2, d1, h ) - k*h*(1.0-h); }

void main() {
    vec3 pos = position;

    vScrollOffset = (time - pos.z) * 0.2 * vec3(0.4, 0.7, 0.25);
    vScrollOffset2 = time * 0.3 * vec3(0.25, 0.5, 0.4);

    vec3 worldPos = vec3(modelMatrix * vec4(position, 1.0));
    vUv = uv;

    float fovFactor = 3.758;
    vec3 rayDir = normalize(worldPos.xyz - cameraPosition);
    vec3 currentPos = worldPos.xyz;
    vec3 samplePoint = currentPos;

    float epsilon = uParams.z;
    float dist = 0.0;
    float max_dist = 0.6;

    float totalDist = 0.0;
    float count = 0.0;

    int max_steps = 2;

    float cubeSize = 16.0;
    float MAX_SCALE = 1.148;
    float t = time * 0.2;
    float voronoi;

    for (int i = 0; i < max_steps; i++)
    {
        samplePoint = currentPos;

        // normalize samplePoint to line up with incoming indirection
        // texture. this one covers a space that is 2x2 units large
        // so we need to halve pos to cover it
        samplePoint.xz *= 0.5;

        // sample indirection texture to get uvs to sample sdf with
        vec4 uv1 = texture2D(tIndirectionA, samplePoint.xz);

        uv1.xyz = vec3(uv1.y, samplePoint.y / (uv1.z * MAX_SCALE), uv1.x);
        uv1.xyz = clamp(uv1.xyz, vec3(0.0), vec3(1.0));

        vec4 uv2 = texture2D(tIndirectionB, samplePoint.xz);
        uv2.xyz = vec3(uv2.y, samplePoint.y / (uv2.z * MAX_SCALE), uv2.x);
        uv2.xyz = clamp(uv2.xyz, vec3(0.0), vec3(1.0));

        // clean up interpolation artifacts caused by linear filtering
        uv1 *= step(0.99, uv1.a);
        uv2 *= step(0.99, uv2.a);

        samplePoint.xyz *= vec3(1.0, 0.75, 1.0);

        float SDF1 = texture(tSDF3D, uv1.xyz).r;
        float SDF2 = texture(tSDF3D, uv2.xyz).r;
        samplePoint.y *= 0.8;
        float voronoi1 = texture(tVoronoi3D, samplePoint.xyz * 2.0 + vScrollOffset).r;
        float voronoi2 = texture(tVoronoi3D, samplePoint.xyz * 3.5 + vScrollOffset2).r;

        voronoi = voronoi1 * voronoi2;
        // voronoi = voronoi * 6.0;

        // float SDF = opSmoothUnion(SDF1, SDF2, 0.15);
        float SDF = min(SDF1, SDF2);
        SDF += voronoi * 2.0;

        // padding
        SDF += 0.015;

        dist = SDF;

        // Either we've hit the object or hit nothing at all, either way we should break out of the loop
        if (dist < epsilon || totalDist >= max_dist)
            break;

        totalDist += dist;
        currentPos += dist * rayDir; // Advance the point forwards in the ray direction by the distance

        count += 1.0;
    }

    vDistInfo = vec4(currentPos, totalDist);
    vRayDir = rayDir;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment

float unpack(vec4 pos) {
    return pos[0] * 255.0 / 256.0 + pos[1] * 255.0 / 65536.0 + pos[2] * 255.0 / 16777216.0;
}

vec4 sampleAs3DTexture(sampler2D tex, vec3 texCoord, float size) {
    float sliceSize = 1.0 / size;                  // space of 1 slice
    float slicePixelSize = sliceSize / size;       // space of 1 pixel
    float width = size - 1.0;
    float sliceInnerSize = slicePixelSize * width; // space of size pixels
    float zSlice0 = floor( texCoord.z * width);
    float zSlice1 = min( zSlice0 + 1.0, width);
    float xOffset = slicePixelSize * 0.5 + texCoord.x * sliceInnerSize;
    float yRange = (texCoord.y * width + 0.5) / size;
    float s0 = xOffset + (zSlice0 * sliceSize);
    float s1 = xOffset + (zSlice1 * sliceSize);
    vec4 slice0Color = texture2D(tex, vec2(s0, yRange));
    vec4 slice1Color = texture2D(tex, vec2(s1, yRange));
    float zOffset = mod(texCoord.z * width, 1.0);
    return mix(slice0Color, slice1Color, zOffset);
}

vec2 computeSliceOffset(float slice, vec4 sliceInfo) {
    return sliceInfo.zw * vec2(mod(slice, sliceInfo.y), floor(slice * sliceInfo.z));
}

vec4 sampleAs3DTexture(sampler2D tex, vec3 texCoord, vec4 sliceInfo) {
    float slice = texCoord.z * sliceInfo.x;
    float sliceZ = floor(slice);

    vec2 slice0Offset = computeSliceOffset(sliceZ, sliceInfo);
    vec2 slice1Offset = computeSliceOffset(sliceZ + 1.0, sliceInfo);

    vec2 slicePixelSize = sliceInfo.zw / sliceInfo.x;

    vec2 uv = slicePixelSize * 0.5 + texCoord.xy * (sliceInfo.zw - slicePixelSize);
    vec4 slice0Color = texture2D(tex, slice0Offset + uv);
    vec4 slice1Color = texture2D(tex, slice1Offset + uv);
    return mix(slice0Color, slice1Color, fract(slice));
}

float opSmoothUnion( float d1, float d2, float k ) {
    float h = clamp( 0.5 + 0.5*(d2-d1)/k, 0.0, 1.0 );
    return mix( d2, d1, h ) - k*h*(1.0-h); }

mat2 rotate2d(float angle){
    return mat2(cos(angle),-sin(angle),
                sin(angle),cos(angle));
}

  const float PHI = 1.61803398874989484820459; // Φ = Golden Ratio 

  float gold_noise(in vec2 xy, in float seed)
  {
    return fract(tan(distance(xy*PHI, xy)*seed)*xy.x);
  }

void main() {
    float fovFactor = 3.758;
    vec3 rayDir = normalize(vRayDir);
    
    vec3 pos = vDistInfo.xyz;
    vec3 samplePoint = pos;

    float epsilon = uParams.z;
    float dist = uParams.z;
    float max_dist = 0.6;

    float totalDist = vDistInfo.w;
    float count = 0.0;

    int max_steps = 6;

    float gnoise = gold_noise(gl_FragCoord.xy, fract(time));
    float cubeSize = 16.0;
    float MAX_SCALE = 1.148;
    float t = time * 0.2;
    vec3 offset = vec3(t * 0.6, t * 0.9, t * 0.4);
    float voronoi;
    float perlin;

    for (int i = 0; i < max_steps; i++)
    {

        samplePoint = pos;

        // normalize samplePoint to line up with incoming indirection
        // texture. this one covers a space that is 2x2 units large
        // so we need to halve pos to cover it
        samplePoint.xz *= 0.5;

        // sample indirection texture to get uvs to sample sdf with
        vec4 uv1 = texture2D(tIndirectionA, samplePoint.xz);

        uv1.xyz = vec3(uv1.y, samplePoint.y / (uv1.z * MAX_SCALE), uv1.x);

        vec4 uv2 = texture2D(tIndirectionB, samplePoint.xz);
        uv2.xyz = vec3(uv2.y, samplePoint.y / (uv2.z * MAX_SCALE), uv2.x);

        // clean up interpolation artifacts caused by linear filtering
        uv1 *= step(0.99, uv1.a);
        uv2 *= step(0.99, uv2.a);

        samplePoint.xyz *= vec3(1.0, 0.75, 1.0);

        float SDF1 = texture(tSDF3D, uv1.xyz).r;
        float SDF2 = texture(tSDF3D, uv2.xyz).r;
        samplePoint.y *= 0.8;
        float voronoi1 = texture(tVoronoi3D, samplePoint.xyz * 2.0 + vScrollOffset).r;
        float voronoi2 = texture(tVoronoi3D, samplePoint.xyz * 3.5 + vScrollOffset2).r;

        voronoi = voronoi1 * voronoi2;

        float SDF = min(SDF1, SDF2);
        SDF += voronoi * 2.0;

        SDF += 0.02;
        SDF += gnoise * 0.01;

        dist = SDF;

        // Either we've hit the object or hit nothing at all, either way we should break out of the loop
        if (dist < epsilon || totalDist >= max_dist)
            break;

        totalDist += dist;
        pos += dist * rayDir; // Advance the point forwards in the ray direction by the distance

        count += 1.0;
    }

    if (totalDist >= max_dist) {
        discard;
    }

    vec3 color = vec3(1.0);

    vec3 uvw = vec3(samplePoint.x, (1.0 - samplePoint.z), samplePoint.y * 1.25 + 0.05);
    uvw = clamp(uvw, vec3(0.0), vec3(1.0));

    color = sampleAs3DTexture(tLightmap, uvw, 64.0).rgb;
    color *= 1.1;
    color -= voronoi * 1.25;
    color *= mix(uColor1, vec3(1.0), color.r - voronoi * 12.0);

    gl_FragColor = vec4(mix(uColor1, uColor2, color.r - voronoi * 3.0), 1.0);
    // gl_FragColor.rgb = color;
    gl_FragColor.a = 1.0;

}{@}RaymarchSDFShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tSDF;
uniform vec4 uParams;
uniform vec3 uPositionOffset;
uniform float uFOVFactor;

#!VARYINGS
varying vec2 vUv;
varying vec3 vWorldPos;
varying vec3 vCameraRightWorld;
varying vec3 vCameraUpWorld;
varying vec3 vCameraForwardWorld;

#!SHADER: Vertex
void main() {
    vCameraRightWorld = vec3(viewMatrix[0][0], viewMatrix[1][0], viewMatrix[2][0]);
    vCameraUpWorld = vec3(viewMatrix[0][1], viewMatrix[1][1], viewMatrix[2][1]);
    vCameraForwardWorld = vec3(-viewMatrix[0][2], -viewMatrix[1][2], -viewMatrix[2][2]);
    vWorldPos = vec3(modelMatrix * vec4(position, 1.0));
    vec3 pos = position;
    gl_Position = vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment

vec4 sample3DTexture(sampler2D _tMap, vec3 _dimensions, vec3 _samplePos) {
    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _samplePos.z * subUVWidth;

    vec2 subUV1 = _samplePos.xy;
    subUV1 /= _dimensions.xy;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

// size is size of cube. e.g. 8x8x8 is size 8

vec4 sampleAs3DTexture(sampler2D tex, vec3 texCoord, float size) {
    float sliceSize = 1.0 / size;                         // space of 1 slice
    float slicePixelSize = sliceSize / size;              // space of 1 pixel
    float sliceInnerSize = slicePixelSize * (size - 1.0); // space of size pixels
    float zSlice0 = min(floor(texCoord.z * size), size - 1.0);
    float zSlice1 = min(zSlice0 + 1.0, size - 1.0);
    float xOffset = slicePixelSize * 0.5 + texCoord.x * sliceInnerSize;
    float s0 = xOffset + (zSlice0 * sliceSize);
    float s1 = xOffset + (zSlice1 * sliceSize);
    vec4 slice0Color = texture2D(tex, vec2(s0, texCoord.y));
    vec4 slice1Color = texture2D(tex, vec2(s1, texCoord.y));
    float zOffset = fract(texCoord.z * size);
    return mix(slice0Color, slice1Color, zOffset);
 }

float sceneSDF(vec3 samplePoint, vec4 sliceInfo) {
    vec4 color = sampleAs3DTexture(tSDF, samplePoint, 64.0);
    float sdf = color.g * 2.0 - 1.02;
    return sdf;
} 

void main() {
    vec2 pixelPos = gl_FragCoord.xy - resolution.xy / 2.0;

    vec2 screenPos = -1.0 + 2.0 * gl_FragCoord.xy / resolution.xy; // screenPos can range from -1 to 1
    screenPos.x *= resolution.x / resolution.y; // Correct aspect ratio

    float fovFactor = uFOVFactor;
    vec3 rayDir = normalize(vCameraRightWorld * screenPos.x + vCameraUpWorld * screenPos.y + vCameraForwardWorld * fovFactor);
    float totalDist = 0.0;
    vec3 pos = cameraPosition + (length(cameraPosition)) * rayDir;
    float epsilon = uParams.z;
    float dist = uParams.z;
    float max_dist = uParams.x;
    float count = 0.0;

    vec4 sliceInfo = vec4(64.0, 8.0, 1.0 / 8.0, 0.0);
    sliceInfo.w = 1.0 / floor((sliceInfo.x + sliceInfo.y - 1.0) * sliceInfo.z);

    for (int i = 0; i < 20; i++)
    {
        // Either we've hit the object or hit nothing at all, either way we should break out of the loop
        if (dist < epsilon || totalDist >= max_dist)
            break;

        // dist = sdBox(pos, vec3(0.45)); // Evalulate the distance at the current point
        dist = sceneSDF(pos.xyz * vec3(1.0, -1.0, 1.0) + uPositionOffset, sliceInfo);
        totalDist += dist;
        pos += dist * rayDir; // Advance the point forwards in the ray direction by the distance
        count += 1.0;
    }

    // if (dist > epsilon + 0.01) discard;

    gl_FragColor = vec4(totalDist);

}{@}SDFTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
