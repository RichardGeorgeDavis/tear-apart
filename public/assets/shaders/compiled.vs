    vec4 sdf = texture(tSDF3D, vWorldPos.xyz);

    vec3 color = vec3(sdf.r);
    gl_FragColor = vec4(color, 1.0);
}{@}ScotlCloudShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uPositionOffset;
uniform sampler2D tSdf;
uniform sampler2D tVolumeGradient;
uniform sampler2D tNoise0;
uniform sampler2D tNoise1;
uniform sampler2D tNoise2;
uniform vec3 uLightDir;
uniform vec3 uScale;
uniform vec4 uParams;
uniform vec4 uNoiseParams;
uniform float uFovFactor;

#!VARYINGS
varying vec2 vUv;
varying vec3 vLightDir;
varying vec3 vViewDir;
varying vec3 vCameraRightWorld;
varying vec3 vCameraUpWorld;
varying vec3 vCameraForwardWorld;
varying vec3 vPos;

#!SHADER: Vertex.vs
void main() {
    vCameraRightWorld = vec3(viewMatrix[0][0], viewMatrix[1][0], viewMatrix[2][0]);
    vCameraUpWorld = vec3(viewMatrix[0][1], viewMatrix[1][1], viewMatrix[2][1]);
    vCameraForwardWorld = vec3(-viewMatrix[0][2], -viewMatrix[1][2], -viewMatrix[2][2]);

    vec3 pos = position;
    vUv = uv;
    gl_Position = vec4(pos, 1.0);
    vLightDir = normalize(uLightDir);
    vViewDir = -(modelViewMatrix * vec4(pos, 1.0)).xyz;
    vPos = pos;
}

#!SHADER: Fragment.fs
const int MAX_MARCHING_STEPS = 90;
const float VOLUME_SIZE = 64.0;
const float EPSILON = 0.01;

// vec4 sampleAs3DTexture(sampler2D tex, vec3 texCoord, float size) {
//     texCoord = texCoord.zxy;
//     texCoord += vec3(0.5);
//     float sliceSize = 1.0 / size;                         // space of 1 slice
//     float slicePixelSize = sliceSize / size;              // space of 1 pixel
//     float sliceInnerSize = slicePixelSize * (size - 1.0); // space of size pixels
//     float zSlice0 = min(floor(texCoord.z * size), size - 1.0);
//     float zSlice1 = min(zSlice0 + 1.0, size - 1.0);
//     float xOffset = slicePixelSize * 0.5 + texCoord.x * sliceInnerSize;
//     float s0 = xOffset + (zSlice0 * sliceSize);
//     float s1 = xOffset + (zSlice1 * sliceSize);
//     vec4 slice0Color = texture2D(tex, vec2(s0, texCoord.y));
//     vec4 slice1Color = texture2D(tex, vec2(s1, texCoord.y));
//     float zOffset = mod(texCoord.z * size, 1.0);
//     return mix(slice0Color, slice1Color, zOffset);
//  }

// tex is a texture with each slice of the cube placed in grid in a texture.
// texCoord is a 3d texture coord
// size is the size if the cube in pixels.
// slicesPerRow is how many slices there are across the texture
// numRows is the number of rows of slices
vec2 computeSliceOffset(float slice, float slicesPerRow, vec2 sliceSize) {
  return sliceSize * vec2(mod(slice, slicesPerRow), 
                          floor(slice / slicesPerRow));
}

vec4 sampleAs3DTexture(sampler2D tex, vec3 texCoord, float size, float numRows, float slicesPerRow) {
  float slice   = texCoord.z * size;
  float sliceZ  = floor(slice);                         // slice we need
  float zOffset = fract(slice);                         // dist between slices

  vec2 sliceSize = vec2(1.0 / slicesPerRow,             // u space of 1 slice
                        1.0 / numRows);                 // v space of 1 slice

  vec2 slice0Offset = computeSliceOffset(sliceZ, slicesPerRow, sliceSize);
  vec2 slice1Offset = computeSliceOffset(sliceZ + 1.0, slicesPerRow, sliceSize);

  vec2 slicePixelSize = sliceSize / size;               // space of 1 pixel
  vec2 sliceInnerSize = slicePixelSize * (size - 1.0);  // space of size pixels

  vec2 uv = slicePixelSize * 0.5 + texCoord.xy * sliceInnerSize;
  vec4 slice0Color = texture2D(tex, slice0Offset + uv);
  vec4 slice1Color = texture2D(tex, slice1Offset + uv);
  return mix(slice0Color, slice1Color, zOffset);
  return slice0Color;
}

//  vec4 sampleAs3DTexture(sampler2D tex, vec3 texCoord, float size, int dont_interpolate) {
//     vec4 color = vec4(1.0);
//     vec3 pos = texCoord + vec3(0.5);
//     float sliceSize = 1.0 / size;                         // space of 1 slice
//     float slicePixelSize = sliceSize / size;              // space of 1 pixel
//     float sliceInnerSize = slicePixelSize * (size - 1.0); // space of size pixels
//     float zSlice = min(floor(pos.z * size), size - 1.0);
//     float xOffset = slicePixelSize * 0.5 + pos.x * sliceInnerSize;
//     float s0 = xOffset + (zSlice * sliceSize);
//     vec4 sliceColor = texture2D(tex, vec2(s0, pos.y));
//     float zOffset = mod(pos.z * size, 1.0);
//     color = sliceColor;
//     return color;
//  }

/**
 * Signed distance function for a sphere centered at the origin with radius 1.0;
 */
float sphereSDF(vec3 samplePoint) {
    return (length(samplePoint) - 1.0);
}


float sdBox( vec3 p, vec3 b ) {
  vec3 q = abs(p) - b;
  return length(max(q,0.0)) + min(max(q.x,max(q.y,q.z)),0.0);
}

/**
 * Signed distance function describing the scene.
 * 
 * Absolute value of the return value indicates the distance to the surface.
 * Sign indicates whether the point is inside or outside the surface,
 * negative indicating inside.
 */
float sceneSDF(vec3 samplePoint) {
    float noise0 = texture2D(tNoise0, samplePoint.yz * uNoiseParams.x + time * uNoiseParams.zw).r * uNoiseParams.y;
    // vec4 color = sampleAs3DTexture(tSdf, samplePoint, 64.0);
    vec4 color = sampleAs3DTexture(tSdf, samplePoint, 256.0, 16.0, 16.0);
    // float sdf = color.r - noise0;
    float sdf = color.r;
    return sdf;
} 

void main() {
    vec2 pixelPos = gl_FragCoord.xy - resolution.xy / 2.0;

    vec2 screenPos = -1.0 + 2.0 * gl_FragCoord.xy / resolution.xy; // screenPos can range from -1 to 1
    screenPos.x *= resolution.x / resolution.y; // Correct aspect ratio

    float fovFactor = uFovFactor;
    vec3 rayDir = normalize(vCameraRightWorld * screenPos.x + vCameraUpWorld * screenPos.y + vCameraForwardWorld * fovFactor);
    float totalDist = 0.0;
    vec3 pos = cameraPosition + (length(cameraPosition) - 0.4) * rayDir;
    float epsilon = uParams.z;
    float dist = uParams.z;
    float max_dist = uParams.x;
    float count = 0.0;

    for (int i = 0; i < MAX_MARCHING_STEPS; i++)
    {
        // Either we've hit the object or hit nothing at all, either way we should break out of the loop
        if (dist < epsilon || totalDist >= max_dist)
            break;

        // dist = sdBox(pos, vec3(0.45)); // Evalulate the distance at the current point
        dist = sceneSDF(pos + uPositionOffset);
        totalDist += dist;
        pos += dist * rayDir; // Advance the point forwards in the ray direction by the distance
        count += 1.0;
    }

    if(max(abs(pos.x), max(abs(pos.y), abs(pos.z))) < 0.5) {
        gl_FragColor = vec4(smoothstep(-0.1, 0.6, totalDist));
    } else {
        discard;
    }

    // gl_FragColor = vec4(1.0, 0.0, 0.0, 1.0);

}{@}RadialScrollFXShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    float t = time * 0.5;
    vec2 uv = (vUv - 0.5) * 2.0;
    float x = atan(uv.x, uv.y) * 0.5 / 3.14159 + 0.5;
    float y = length(uv);
    float mask = 1.0 - y;
    vec2 polarCoords = vec2(x, y - t);
    vec2 polarCoords2 = vec2(x + 0.6, y - t * 0.75);

    float alpha = texture2D(tMap, polarCoords).r;
    alpha *= texture2D(tMap, polarCoords2).r;
    alpha *= mask * 4.0;

    gl_FragColor = vec4(vec3(1.0), alpha);
}{@}ShardShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tHighlight;
uniform sampler2D tLayers;
uniform sampler2D tNormal;
uniform sampler2D tNormal2;
uniform sampler2D tMap;
uniform sampler2D tNoise;
uniform float uNormalIntensity;

#!VARYINGS
varying vec2 vUv;
varying vec3 vEye;
varying vec3 vNormal;
varying vec3 vViewDir;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec3 n = normal;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vNormal = normalMatrix * n;
    vEye = vec3(modelViewMatrix * vec4(pos, 1.0));
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    vec3 highlight = texture2D(tHighlight, vUv).rgb;
    highlight = pow(highlight, vec3(2.2));
    vec3 layers = texture2D(tLayers, vUv).rgb;
    float eyeGlow = layers.g;
    float outline = layers.r;
    outline = mix(outline, 1.0, 0.15);
    vec3 normal = unpackNormal(vEye, vNormal, tNormal, uNormalIntensity, 1.0, vUv).xyz;
    vec3 normal2 = unpackNormal(vEye, vNormal, tNormal2, uNormalIntensity, 1.0, vUv).xyz;
    // normal = mix(normal, normal2, 0.05);

    float s = sin(time + vUv.y * 2.0 + vUv.x) * 0.1;
    vec2 muv = matcap(normalize(vEye), normal + s);
    vec3 bg = texture2D(tMap, vUv + normal.xy * 0.25 + s * 0.2).rgb;
    // bg = mix(bg, texture2D(tMap, vUv + normal.xy * 0.5 + s * 0.4).rgb, 0.4);
    bg = mix(bg, texture2D(tMap, vUv + normal.xy * 1.0).rgb, 0.3);
    vec3 matcap = texture2D(tMatcap, muv).rgb;
    // matcap += matcap * bg * 0.07;
    matcap *= clamp(1.6 - outline, 0.0, 1.0);
    vec3 color = bg * mix(vec3(184., 75., 37.) / 255., vec3(1.0), outline);
    color = pow(color, vec3(2.2));
    color += pow(matcap, vec3(2.2));
    eyeGlow = pow(eyeGlow, 2.2);
    color += eyeGlow * 0.5;
    color += highlight * 0.4;
    color = pow(color, vec3(0.45));

    gl_FragColor = vec4(color, 1.0);
}{@}ShardStarShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNoise;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vEye;
varying vec3 vNormal;
varying vec3 vViewDir;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec3 n = normal;

    pos -= vdata;
    pos *= mix(0.2, 1.0, sin(time * 2.0 + uv2.y * 1324.0) * 0.5 + 0.5);
    pos += vdata;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vUv2 = uv2;
    vNormal = normalMatrix * n;
    vEye = vec3(modelViewMatrix * vec4(pos, 1.0));
}

#!SHADER: Fragment

void main() {
    vec2 uv = vUv;
    uv.x /= 8.0;
    uv.x += floor(vUv2.y * 6.0) / 6.0;
    vec3 color = texture2D(tMap, uv).rgb;

    gl_FragColor = vec4(color, 1.0);
}{@}MVShoeShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMotion;
uniform sampler2D tPos;
uniform float uProgress;
uniform float uColumns;
uniform float uRows;
uniform float uDisplacementStrength;
uniform vec2 uClickUv;
uniform float uClickTime;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
#require(range.glsl)

vec2 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

vec2 remap(vec2 _displacement, float displacementStrength) {
    vec2 displacement;
    displacement.r = crange(_displacement.r, 0.0, 1.0, -1.0, 1.0);
    displacement.g = crange(_displacement.g, 0.0, 1.0, -1.0, 1.0);
    return displacement * displacementStrength;
}

void main() {
    
    float MAX_INDEX = uColumns * uRows - 1.0;
    float index = crange(uProgress, 0.0, 1.0, 1.0, MAX_INDEX);

    float blend = fract(index);
    float displacementStrength = uDisplacementStrength * 0.01;

    vec2 dimensions = vec2(uColumns, uRows);

    vec2 subUv = getSubUV(tMap, dimensions, vUv, index);
    vec2 subUvNext = getSubUV(tMap, dimensions, vUv, index + 1.0);

    vec2 displacement = texture2D(tMotion, subUv).rg;
    vec2 displacementNext = texture2D(tMotion, subUvNext).rg;
    vec2 val = mix(displacement, displacementNext, blend);

    displacement = remap(displacement, displacementStrength);
    displacementNext = remap(displacementNext, displacementStrength);

    // visual pos
    vec2 subUvPos = getSubUV(tPos, dimensions, vUv, index);
    vec2 subUvPosNext = getSubUV(tPos, dimensions, vUv, index + 1.0);
    vec3 pos = texture2D(tPos, subUvPos - displacement * blend).rgb;
    vec3 posNext = texture2D(tPos, subUvPosNext + displacementNext * (1.0 - blend)).rgb;
    pos = mix(pos, posNext, blend);

    // click pos
    vec2 clickUv = getSubUV(tPos, dimensions, uClickUv, index);
    vec2 clickUvNext = getSubUV(tPos, dimensions, uClickUv, index + 1.0);
    vec4 clickPos = texture2D(tPos, clickUv - displacement * blend);
    vec4 clickPosNext = texture2D(tPos, clickUvNext + displacement * (1.0 - blend));
    clickPos = mix(clickPos, clickPosNext, blend);
    
    // pulse
    float mask = smoothstep(0.0, 1.0, length(pos));
    float driver = 1.0 - clamp(uClickTime * 0.7, 0.0, 1.0);
    float t = -pow(driver, 5.0) * 5.0;
    float gradient = length(pos - clickPos.xyz) * 0.75;
    float pulse = sin(gradient * 15.0 - t + 3.8) * 0.5 + 0.5;
    pulse = pow(pulse, 15.0 - driver * 15.0);
    pulse += pow(pulse, 55.0 - driver * 25.0);
    // pulse *= mask;
    pulse *= driver;
    pulse *= 1.0 - smoothstep(0.9, 1.0, driver);
    pulse *= 1.0 - clamp(length(gradient) * 3.0, 0.0, 1.0);
    pulse *= 4.0;
    pulse *= clickPos.a;

    // pixellation
    float pixellation = 200.0;
    subUv = mix(subUv, floor(subUv * pixellation) / pixellation, pulse);
    subUvNext = mix(subUvNext, floor(subUvNext * pixellation) / pixellation, pulse);

    vec3 color = texture2D(tMap, subUv - displacement * blend).rgb;
    vec3 colorNext = texture2D(tMap, subUvNext + displacementNext * (1.0 - blend)).rgb;
    color = mix(color, colorNext, blend);

    // add colored pulse
    pulse *= (color.r + color.g + color.b) * 0.5 + 0.15;
    // vec3 pulseColor = mix(pow(vec3(1.0, 0.0, 0.0), vec3(2.2)), pow(vec3(1.0, 0.5, 0.0), vec3(2.2)), driver * 3.0 - 2.0);
    vec3 pulseColor = pow(vec3(1.0, 0.5, 0.0), vec3(2.2));
    pulseColor = pow(pulse, 3.0) * pulseColor;
    color.rgb = pow(color.rgb, vec3(2.2));
    color += pulseColor;
    color.rgb = pow(color.rgb, vec3(0.45));

    // color.rgb = vec3(step(0.8, pos.z));

    gl_FragColor = vec4(color, 1.0);
}{@}ShowroomBillboardLight.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec3 uColor;
uniform float uAlpha;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    vec2 screenuv = gl_FragCoord.xy / resolution;

    vec3 color = vec3(1.0);
    float a = 1.0;
    vec2 uv = vUv;
    uv.x -= 0.5;
    uv.y -= 1.0;
    a = 1.0 - length(uv);
    a = pow(a, 8.0);
    a *= 1.0 - pow(vUv.y, 15.0);
    a *= 1.0 - abs(vUv.x - 0.5);
    // a += a * 0.5;
    a *= uAlpha;
    a *= mix(1.0, 0.9, rand(screenuv + vec2(time, 0.0)));
    color = mix(vec3(0.3, 0.7, 1.0), vec3(1.0), a);
    gl_FragColor = vec4(color, a);
}{@}ShowroomParticleShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tLightmap;
uniform sampler2D tAO;
uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec2 vUv;
varying vec3 vColor;

#!SHADER: Vertex

void main() {
    vec3 pos = texture2D(tPos, position.xy).xyz;
    float scale = 0.8;
    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = scale * 0.1 * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;

    vUv = random.xy;

    float lightmap = texture2D(tLightmap, vUv).r;
    float ao = texture2D(tAO, vUv).r;
    lightmap *= 1.5;
    lightmap = pow(lightmap, 2.2);

    vec3 color = vec3(0.3, 0.6, 1.0) * max(0.2, lightmap);
    color += (1.0 - ao) * lightmap;
    vColor = color;
}

#!SHADER: Fragment

void main() {
    vec3 color = vColor;
    gl_FragColor = vec4(color, 0.4);
}{@}ShowroomSurfaceShader.glsl{@}#!ATTRIBUTES
attribute vec3 barycentric;

#!UNIFORMS
uniform sampler2D tAO;
uniform sampler2D tLightmap;
uniform sampler2D tColorRamp;
uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec2 vUv;
varying vec3 vBc;
varying vec3 vNormal;
varying vec3 vEye;
varying vec3 vPos;



#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vBc = barycentric;
    vNormal = normalMatrix * normal;
    vPos = position;
}

#!SHADER: Fragment

float edgeFactor(float lineWidth) {
  vec3 d = fwidth(vBc);
  vec3 f = smoothstep(-d, d, vBc);
  return min(min(f.x, f.y), f.z);
}

void main() {
    // ao
    float s = 0.0005;
    float ao = texture2D(tAO, vUv).r;

    // lightmap
    float lightmap = texture2D(tLightmap, vUv).r;

    // wireframe
    float lineWidth = 2.0;
    vec3 d = fwidth(vBc) * lineWidth;
    vec3 f = smoothstep(-d, d, vBc);
    float wireframe = 1.0 - min(min(f.x, f.y), f.z);

    // fresnel
    float fresnel = pow(1.0 - max(0.0, dot(vec3(0.0, 0.0, 1.0), normalize(vNormal))), 1.0);

    // emissive
    vec3 color1 = vec3(0.0, 0.4, 0.6);
    vec3 color2 = vec3(0.002, 0.0, 0.03);

    vec3 base = vec3(lightmap * 1.5);
    vec3 emissive = mix(color2, color1, fresnel);
    vec3 color = mix(base, emissive, clamp(ao * 0.6, 0.0, 1.0));
    color += wireframe * 0.15;
    color = pow(color, vec3(2.2));

    gl_FragColor = vec4(color, 1.0);
}{@}ShowroomWallShader.glsl{@}#!ATTRIBUTES
attribute vec3 barycentric;

#!UNIFORMS
uniform sampler2D tAO;
uniform sampler2D tLightmap;
uniform sampler2D tColorRamp;
uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec2 vUv;
varying vec3 vBc;
varying vec3 vNormal;
varying vec3 vEye;
varying vec3 vPos;



#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vBc = barycentric;
    vNormal = normalMatrix * normal;
    vPos = position;
}

#!SHADER: Fragment

float edgeFactor(float lineWidth) {
  vec3 d = fwidth(vBc);
  vec3 f = smoothstep(-d, d, vBc);
  return min(min(f.x, f.y), f.z);
}

void main() {

    // fresnel
    float fresnel = pow(1.0 - max(0.0, dot(vec3(0.0, 0.0, 1.0), normalize(vNormal))), 0.2);

    // emissive
    vec3 color1 = vec3(0.0, 0.475, 0.6);
    vec3 color2 = vec3(0.002, 0.01, 0.03);

    vec3 color = mix(color2, color1, fresnel);
    color = pow(color, vec3(2.2));

    gl_FragColor = vec4(color, fresnel);
