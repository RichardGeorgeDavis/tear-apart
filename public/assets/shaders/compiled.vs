}{@}TokenShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tSymbols;
uniform sampler2D tSymbolsNormal;
uniform sampler2D tMatcap;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying float vIndex;
varying vec3 vNormal;
varying vec3 vEye;

#!SHADER: Vertex

void main() {
    vec3 pos = position;
    vec4 modelViewPos = modelViewMatrix * vec4(pos, 1.0);
    gl_Position = projectionMatrix * modelViewPos;

    vUv = uv;
    vUv2 = uv2;
    vIndex = random.x;
    vEye = normalize(-modelViewPos.xyz);
    vNormal = normalMatrix * normal;
}

#!SHADER: Fragment

vec4 getSubUVTexture(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return texture2D(_tMap, uv);
}

vec2 getSubUV(vec2 _dimensions, vec2 _uv, float _index) {
    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

vec3 unpackNormalPBR( vec3 eye_pos, vec3 surf_norm, sampler2D normal_map, float intensity, float scale, vec2 uv ) {
    surf_norm = normalize(surf_norm);

    vec3 q0 = dFdx( eye_pos.xyz );
    vec3 q1 = dFdy( eye_pos.xyz );
    vec2 st0 = dFdx( uv.st );
    vec2 st1 = dFdy( uv.st );

    vec3 S = normalize( q0 * st1.t - q1 * st0.t );
    vec3 T = normalize( -q0 * st1.s + q1 * st0.s );
    vec3 N = normalize( surf_norm );

    vec3 mapN = texture2D( normal_map, uv * scale ).xyz * 2.0 - 1.0;
    mapN.xy *= intensity;
    mat3 tsn = mat3( S, T, N );
    return normalize( tsn * mapN );
}

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    // index stored on instances
    float index = floor(vIndex + 0.01);
    // float index = floor(vIndex);

    // base texture. use first uv set, named 'UVW' in C4D
    vec4 color = texture2D(tMap, vUv);

    // symbol. use second uv set, named 'UVW2' in C4D
    // vec4 symbol = getSubUVTexture(tSymbols, vec2(4.0), vUv2, index);
    vec2 symbolUv = getSubUV(vec2(4.0), vUv2, index);

    vec4 symbol = texture2D(tSymbols, symbolUv);
    vec3 normal = unpackNormalPBR(vEye, vNormal, tSymbolsNormal, 1.0, 1.0, symbolUv);

    vec2 muv = matcap(vEye, normal);
    vec4 matcap = texture2D(tMatcap, muv);

    // color = mix(matcap.r, vec4(1.0), symbol.r);
    color.rgb = matcap.rgb;

    gl_FragColor = symbol;
