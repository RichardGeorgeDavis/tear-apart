    gl_FragColor = data;
}
{@}guidePositions.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tGuidingStrands;
uniform sampler2D tWeights;
uniform sampler2D tIndex;
uniform float uGuideCount;

uniform sampler2D tSkinData;
uniform float uSkinTextureSize;

uniform float uStrandCount;
uniform float uWeightTextureSize;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment
void main() {


    float index = gl_FragCoord.y;

    vec3 indicies = texture2D(tIndex, vec2(0.5, vUv.y)).xyz;

    vec3 v1 = texture2D(tGuidingStrands, vec2(vUv.x, indicies.x)).xyz;
    vec3 v2 = texture2D(tGuidingStrands, vec2(vUv.x, indicies.y)).xyz;
    vec3 v3 = texture2D(tGuidingStrands, vec2(vUv.x, indicies.z)).xyz;

    vec3 weight = texture2D(tWeights, vec2(0.5, vUv.y)).xyz;

    vec3 pos = (v1 * weight.x) + (v2 * weight.y) + (v3 * weight.z);

    gl_FragColor = vec4(pos, gl_FragCoord.y);
}
{@}HairLightKaijaKay.glsl{@}uniform vec2 uTangentShift;
uniform vec2 uHairSpecPower;
uniform float uDiffuseStrength;
uniform float uSpecularStrengh;

uniform vec3 uDiffuseColor;
uniform vec3 uSpecularColor1;
uniform vec3 uSpecularColor2;

float sinTheta(float theta) {
    float thetaSq = theta * theta;
    return (1.0 - thetaSq) * inversesqrt(1.0 - thetaSq);
}

float kaijyaKayDiffuse(vec3 T, vec3 L) {
    float tDotL = dot(T, L);
    float tDotLSq = tDotL * tDotL;
    return (1.0 - tDotLSq) * inversesqrt(1.0 - tDotLSq);
}

float shiftTangent(in vec3 T, in vec3 N, in float shift) {
    return normalize(T + N * shift);
}

//https://web.engr.oregonstate.edu/~mjb/cs557/Projects/Papers/HairRendering.pdf
float kajiyaKaySpecularity(vec3 H, vec3 T, float exp) {
    float dotTH = dot(T, H);
    float sinTH = sqrt(1.0 - (dotTH * dotTH));
    float dirAtten = smoothstep(-1.0, 0.0, dotTH);
    float spec = dirAtten * pow(sinTH, exp);
    return spec;
}

//float kaijyaKaySpecularity(vec3 T, vec3 E, vec3 L) {
//    float tDotL = dot(T, L);
//    float tDotE = dot(T, E);
//    return pow(tDotL * tDotE + sinTheta(tDotL) * sinTheta(tDotE), 16.0);
//}

vec3 HairLightKaijaKay(in vec3 tangent, in vec3 normal, in vec3 eye, in vec3 lightDir) {

    vec3 diff = uDiffuseColor * kaijyaKayDiffuse(tangent, lightDir);

    float t1 = shiftTangent(tangent, normal, uTangentShift.x);
    float t2 = shiftTangent(tangent, normal, uTangentShift.y);

    vec3 halfVec = normalize(lightDir + eye);

    vec3 spec = uSpecularColor1 * kajiyaKaySpecularity(halfVec, t1, floor(uHairSpecPower.x));
    spec += uSpecularColor1 * kajiyaKaySpecularity(halfVec, t2, floor(uHairSpecPower.y));

    return diff * uDiffuseStrength + spec * uSpecularStrengh;
}
{@}HairLine.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPosition;
uniform sampler2D tIndex;
uniform sampler2D tUvs;
uniform sampler2D tWeights;
uniform sampler2D tMap;
uniform vec2 uTexelSize;

uniform samplerCube tCubeMap;

uniform float uRoughness;
uniform float uShift;

uniform vec3 uColor;
uniform vec3 uColorB;
uniform vec3 uColorC;

uniform float uLightWrap;
uniform float uAOPhaseAmount;
uniform float uColorMode;

#!VARYINGS
varying vec2 vUv;
varying vec3 vCol;
varying vec3 vNormal;
varying vec3 vBinormal;
varying vec3 vPos;
varying vec2 vSt;
varying vec3 vPos;
varying vec3 vEyePos;
varying vec3 vTangent;
varying vec4 vHash;

varying float vNoise;

varying vec3 vt1;
varying vec3 vt2;

#!SHADER: Vertex
#require(volumeShadows.vs)
#require(simplenoise.glsl)

vec3 hash31(float p)
{
    vec3 p3 = fract(vec3(p) * vec3(.1031, .1030, .0973));
    p3 += dot(p3, p3.yzx+33.33);
    return fract((p3.xxy+p3.yzz)*p3.zyx);
}

vec4 hash42(vec2 p)
{
    vec4 p4 = fract(vec4(p.xyxy) * vec4(.1031, .1030, .0973, .1099));
    p4 += dot(p4, p4.wzxy+33.33);
    return fract((p4.xxyz+p4.yzzw)*p4.zywx);

}

void main() {

    vec3 p = texture2D(tPosition, position.xy).xyz;
    vPos = p;
    setupShadows(p);

    vec3 pp = texture2D(tPosition, position.xy + vec2(-uTexelSize.x, 0.0)).xyz;
    vec3 np = texture2D(tPosition, position.xy + vec2(uTexelSize.x, 0.0)).xyz;

    vec3 currentToNext = normalize(np - p);
    vec3 prevToCurrent = normalize(p - pp);
    vec3 binormal = normalize(cross(currentToNext, prevToCurrent));
    vBinormal = binormal;
    vNormal = normalize(cross(binormal, position.x < 1.0 ? currentToNext : prevToCurrent));
    vTangent = normalize(pp - p); //in the case for hairs, the tangent needs to point towards the root

    float scalePhase = position.x * 4.0 * (1.0 - position.x);
    vec3 localPos = p + binormal * 0.0035 * position.z * pow(scalePhase, 2.0);
    vPos = localPos;

    vec3 indicies = texture2D(tIndex, vec2(0.5, position.y)).xyz;

    vec2 v1 = texture2D(tUvs, vec2(0.5, indicies.x)).xy;
    vec2 v2 = texture2D(tUvs, vec2(0.5, indicies.y)).xy;
    vec2 v3 = texture2D(tUvs, vec2(0.5, indicies.z)).xy;

    vec3 weight = texture2D(tWeights, vec2(0.5, position.y)).xyz;
    vSt = (v1 * weight.x) + (v2 * weight.y) + (v3 * weight.z);
    vNoise = clamp(getNoise(vSt.yx * 0.0025, 10.1) * 0.5 + 0.5, 0.9, 1.0);

    vec4 mvPos = modelViewMatrix * vec4(localPos, 1.0);
    vEyePos = mvPos.xyz;
    gl_Position = projectionMatrix * mvPos;

    vUv = position.xy;

    vCol = hash31(position.y * 1300.0);

}

    #!SHADER: Fragment
    #require(volumeShadows.fs)
    #require(hairSinglePBR.glsl)
    #require(getHairNormal.glsl)


vec4 hash42(vec2 p)
{
    vec4 p4 = fract(vec4(p.xyxy) * vec4(.1031, .1030, .0973, .1099));
    p4 += dot(p4, p4.wzxy+33.33);
    return fract((p4.xxyz+p4.yzzw)*p4.zywx);

}

float luma(vec3 color) {
    return dot(color, vec3(0.299, 0.587, 0.114));
}

void main() {

    vec3 eye = normalize(cameraPosition - vPos);
    vec3 lightDir = normalize(vec3(0.0, 1.0, 0.0) - vPos);
    vec3 spec = singleHairPBR(vTangent, lightDir, eye);

    float shadow = getShadows();
    shadow = pow(shadow, 5.0);
    vec3 fakeNormal = getHairNormal(eye, vTangent);
    float light = (dot(fakeNormal, lightDir) * uLightWrap) + (1.0 - uLightWrap);
    //vec3 scattering = sqrt(uColor) * ((dot(fakeNormal, lightDir) + 1.0) / (PI * 4.0)) / (uColor/luma(uColor));

    vec3 lights = vec3(spec + light);

    float fakeAO = mix(0.8, 1.0, smoothstep(0.0, uAOPhaseAmount, (vUv.x * vUv.x)));
    float shadows = shadow;

    vec2 uv = vSt;
    vec3 hairCol = uColor * clamp(vNoise, 0.0, 1.0);
    vec3 col = mix(hairCol, texture2D(tMap, uv).xyz, uColorMode) * shadows * lights;

    gl_FragColor = vec4(col, 1.0);

}
{@}getHairNormal.glsl{@}vec3 getHairNormal(in vec3 eye, in vec3 tangent) {
    return normalize(eye - dot(eye, tangent) * tangent);
}
{@}hairSinglePBR.glsl{@}#define PI 3.14159265359
#define REFRACTION_INDEX 1.55
#define HALF_PI PI * 0.5
#define DEG_TO_RAD 0.01745329251
#define EPS 0.00005

//https://seblagarde.wordpress.com/2014/12/01/inverse-trigonometric-functions-gpu-optimization-for-amd-gcn-architecture/
// input [-1, 1] and output [0, PI]
float fastAcos(in float inX) {
    float x = abs(inX);
    float res = (0.0468878 * x + -0.203471) * x + 1.570796;
    res *= sqrt(1.0f - x);

    return (inX >= 0.0) ? res : PI - res;
}

// input [-1, 1] and output [-PI/2, PI/2]
float fastAsin(in float x) {
    return (PI * 0.5) - fastAcos(x);
}

float gaussian(float thetaI, float thetaR, float alpha, float beta) {
    float pw = exp(-pow(sin(thetaI) + sin(thetaR) - alpha, 2.0) / (2.0 * beta * beta));
    return (1.0 / (beta * sqrt(2.0 * PI))) * pw;
}

float schlickFresnel(float index, float x) {
    float oneMinusIndex = 1.0 - index;
    float onePlusIndex = 1.0 + index;
    float f0 = oneMinusIndex / onePlusIndex;
    f0 = f0 * f0;

    return f0 + (1.0 - f0) * pow(1.0 - x, 5.0);
}

//https://blog.selfshadow.com/publications/s2016-shading-course/karis/s2016_pbs_epic_hair.pdf
//https://developer.nvidia.com/gpugems/gpugems2/part-iii-high-quality-rendering/chapter-23-hair-animation-and-rendering-nalu-demo
vec3 singleHairPBR(in vec3 T, in vec3 L, in vec3 V) {

    //angle along the cylinder/hair's tangent
    float sinThetaI = dot(L, T);
    float sinThetaR = dot(V, T);

    float thetaI = fastAsin(sinThetaI);
    float thetaR = fastAsin(sinThetaR);

    float thetaD = (thetaI - thetaR) * 0.5;
    float thetaH = (thetaR + thetaI) * 0.5;

    float cosThetaD = cos(thetaD);

    //project the light and view vector along the tangent to get a position along the normal plane
    vec3 w = L - sinThetaI * T;
    vec3 v = V - sinThetaR * T;

    //dot(a, b) = ||a|| * ||b|| * cos
    //cos = dot(a, b) / (||a|| * ||b||) || cos = dot(a,b) * (||a||*||b||)^-1
    float cosPhi = dot(w,v) * inversesqrt(dot(w,w) * dot(v,v) + EPS);

    float shift = uShift;
    float roughness = uRoughness;

    float alphaR = -2.0 * shift;
    float alphaTT = shift;
    float alphaTRT = 4.0 * shift;

    float betaR = roughness * roughness;
    float betaTT = betaR * 0.5;
    float betaTRT = 2.0 * betaR;

    float MR = gaussian(sinThetaI, sinThetaR, alphaR, betaR);
    float MTT = gaussian(sinThetaI, sinThetaR, alphaTT, betaTT);
    float MTRT = gaussian(sinThetaI, sinThetaR, alphaTRT, betaTRT);

    //trig identity for cos(phi * 0.5) according to Karis
    float cos_phi_over_2 = sqrt(clamp(0.5 + 0.5 * cosPhi + EPS, 0.0, 1.0));

    //NR
    float NRD =  0.25 * cos_phi_over_2;
    //float NR = schlickFresnel(REFRACTION_INDEX, sqrt(clamp(dot(L, V) * 0.5 + 0.5 + EPS, 0.0, 1.0))) * NRD;
    float NR = schlickFresnel(REFRACTION_INDEX, sqrt(dot(L, V) * 0.5 + 0.5 + EPS)) * NRD;

    //NTT
    float D = exp(-3.65 * cosPhi - 3.98);
    float nPrimeAprox = 1.19 / cosThetaD + 0.36 * cosThetaD;
    float a = 1.0 / nPrimeAprox;
    float hTTAprox = (1.0 + a * (0.6 - 0.8 * cosPhi)) * cos_phi_over_2;
    //float f = schlickFresnel(REFRACTION_INDEX, cosThetaD * sqrt(clamp(1.0 - (hTTAprox * hTTAprox), 0.0, 1.0)));
    float f = schlickFresnel(REFRACTION_INDEX, cosThetaD * sqrt(1.0 - (hTTAprox * hTTAprox)));

    float gammaYIdentity = sqrt(1.0 - (hTTAprox * hTTAprox) * (a * a)); //replaces an asin call
    vec3 t = pow(uColor, vec3(gammaYIdentity / (2.0 * cosThetaD)));

    //    float D = exp(-3.65 * cosPhi - 3.98);
    vec3 A = pow(1.0 - f, 2.0) * t;
    vec3 NTT = A * D;

    //TRT
    float hTRT = 0.8660254038; //sqrt(3)/2
    //float fTRT = schlickFresnel(REFRACTION_INDEX, cosThetaD * sqrt(clamp(1.0 - (hTRT * hTRT), 0.0, 1.0)));
    float fTRT = schlickFresnel(REFRACTION_INDEX, cosThetaD * sqrt(1.0 - (hTRT * hTRT)));
    vec3 TTRT = pow(uColor, vec3(0.8 / cosThetaD));
    float DTRT = exp(17.0 * cosPhi - 16.78);
    vec3 ATRT = pow(1.0 - fTRT, 2.0) * fTRT * TTRT * TTRT;
    vec3 NTRT = ATRT * DTRT;

    return vec3((MR * NR) + (MTT * NTT) + (MTRT * NTRT));

}
{@}predictPosition.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPosition;
uniform sampler2D tVelocity;
uniform sampler2D tOrigin;
uniform sampler2D tOriginNormal;

uniform vec3 uInputPos;
uniform float uApplyInput;
uniform float uTexelSize;
uniform float uDT;
uniform vec2 uHairData;

uniform float uSkinDataSize;

uniform float uWindForce;
uniform float uGravity;
uniform float uFluff;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment
layout(location = 0) out vec4 data1;
layout(location = 1) out vec4 data2;
void main() {
    vec4 pos = texture2D(tPosition, vUv);
    vec3 vel = texture2D(tVelocity, vUv).xyz;

    //store currentPos
    data1 = vec4(pos.xyz, gl_FragCoord.y);

    vec3 origin = texture2D(tOrigin, vec2(0.5, gl_FragCoord.y / uHairData.y)).xyz * 1.0;
    origin.y -= 1.0;
    vec3 normal = texture2D(tOriginNormal, vec2(0.5, gl_FragCoord.y / uHairData.y)).xyz;
    //normal.y -= 0.5

    if(vUv.x < uTexelSize) pos.xyz = origin.xyz;

    //add gravity
    vec3 g = vec3(0.0, -uGravity, 0.0) * uDT;

    //add wind
    vec3 windForce = vec3(0.0, 0.0, -uWindForce) * uDT;

    if(vUv.x > uTexelSize) {
//        float phase = vUv.x * vUv.x * vUv.x;
        float phase = smoothstep(0.0, 1.0, vUv.x);
        vel += g * phase;
        vel += windForce * phase;
        vel += normal * (1.0 - phase) * uFluff * uDT;
    }

    //apply velocity to current position
    pos.xyz += vel * uDT;

    data2 = vec4(pos.xyz, gl_FragCoord.y);

}
