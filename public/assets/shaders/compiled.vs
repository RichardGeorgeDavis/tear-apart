}{@}SignShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec4 uParams;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec4 color = texture2D(tMap, vUv);
    float animate = clamp(sin(vUv.y - color.b * 15.0 + time), 0.0, 1.0);
    animate = max(animate, step(0.6, vUv.y));
    animate = pow(animate, 5.0);
    animate = 1.0;
    vec3 final = mix(uColor1, uColor2, color.g);
    gl_FragColor.rgb = final;
    gl_FragColor.a = color.r * animate * uParams.x;
}{@}CausticsShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tCaustics;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    float radius = 0.1;

    vec2 uv1 = vUv;
    uv1.x += sin(time) * radius;
    uv1.y += cos(time) * radius;

    vec2 uv2 = vUv;
    uv2.x -= sin(time) * radius;
    uv2.y -= cos(time) * radius;

    float caustics1 = texture2D(tCaustics, uv1).x;
    float caustics2 = texture2D(tCaustics, uv2 * 1.25).x;

    caustics1 = min(caustics1, caustics2);
    caustics1 = pow(caustics1, 2.6);

    gl_FragColor = vec4(caustics1);
}{@}ChapelPBRShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
