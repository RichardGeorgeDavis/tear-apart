}{@}SurfaceParticleShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;
uniform sampler3D tVolume3D;
uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec3 vColor;
varying vec3 vVel;
varying vec3 vNormal;
varying vec3 vMvPos;
varying float vRandom;
varying float vSpeed;
varying float vShadow;

#!SHADER: Vertex

void main() {
    vec4 decodedPos = texture2D(tPos, position.xy);
    vec4 decodedPrevPos = texture2D(tPrevPos, position.xy);
    vec3 vel = decodedPos.xyz - decodedPrevPos.xyz;
    vSpeed = length(vel) * 250.0;
    vSpeed = clamp(vSpeed, 0.0, 1.0);
    vSpeed = vSpeed * vSpeed;
    vVel = vel * 150.0;
    
    vec3 pos = decodedPos.xyz;
    vec3 samplePos = pos + 0.5;
    float scale = mix(0.3, 0.5, random.x);

    float layerShadow = 1.0;

    // layers
    if (random.z > 0.6) {
        pos *= 0.97;
        layerShadow = 0.8;

        if (random.x > 0.6) {
            pos *= 0.97;
            layerShadow = 0.6;
        }
    }

    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = scale * 0.1 * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;

    vec4 volume = texture(tVolume3D, samplePos);
    vColor = mix(uColor1, uColor2, volume.y) - vSpeed * 0.1 + random.y * 0.1;
    vColor *= smoothstep(0.3, -0.5, pos.x);
    vColor *= layerShadow;

    vNormal = normalize(normalMatrix * (volume.xyz + vel * 30.0 * random.w));
    vMvPos = mvPosition.xyz;
    vRandom = random.w;
    vShadow = layerShadow;
}

#!SHADER: Fragment

void main() {
    vec2 uv = gl_PointCoord.xy;

    float a = 1.0 - length(uv - 0.5);
    if (a < 0.75) discard;
    a = 1.0 - length(uv - vec2(0.5, 0.35));
    a = a * a * a;

    vec3 lightDir   = normalize(vec3(0.2, 1.0, 0.2));
    vec3 viewDir    = normalize(-vMvPos.xyz);
    vec3 halfwayDir = normalize(lightDir + viewDir);
    float spec = pow(max(dot(vNormal, halfwayDir), 0.0), (42.0 - vRandom * 15.0) * a);

    float diffuseContribution = vColor.r;
    float specContribution = 1.0 - diffuseContribution;

    vec3 color = mix(vec3(1.0), vec3(0.8, 0.05, 0.18) * 2.5, clamp(vSpeed, 0.0, 1.0)) * vec3(diffuseContribution + specContribution * spec) * a * vShadow;
    gl_FragColor = vec4(color, 1.0);
}{@}SurfaceParticleVFX.fs{@}
