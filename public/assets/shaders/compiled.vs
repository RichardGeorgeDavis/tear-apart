{@}CurlBox.glsl{@}#!ATTRIBUTES
attribute vec2 gridPosition;

#!UNIFORMS
uniform vec3 uDimensions;
uniform vec2 uTextureSize;

uniform float uCurlNoiseScale;
uniform float uCurlTimeScale;
uniform float uCurlNoiseSpeed;

uniform float HZ;

#!VARYINGS
varying vec3 vForce;

#!SHADER: Vertex

#require(curl.glsl)
void main() {

    vec3 pos = position * uDimensions;
    vec3 curl = curlNoise(pos * uCurlNoiseScale*0.1 + (time * uCurlTimeScale * 0.1));
    //pos = curl * uCurlNoiseSpeed * 0.01 * HZ;
    pos = curl * uCurlNoiseSpeed * 0.1;

    vForce = pos;

    //place particles in respective buckets
    vec2 gridPos = vec2(0.0);

    float index = float(gl_VertexID);
    gridPos.x = ((mod(index, uDimensions.x) + 0.5) / uDimensions.x) / uDimensions.z;
    gridPos.x += floor(index / (uDimensions.x * uDimensions.y)) * (1.0 / uDimensions.z);
    gridPos.y = (floor(mod(index, (uDimensions.x * uDimensions.y)) / uDimensions.y) + 0.5) / uDimensions.y;

    gl_Position = vec4(2.0 * gridPos - 1.0, 0.0, 1.0);
    gl_PointSize = 1.0;
}

    #!SHADER: Fragment
void main() {
    gl_FragColor = vec4(vForce, 1.0);
}
{@}sampleAs3DTexture.glsl{@}vec4 sampleAs3DTexture(sampler2D tex, vec3 texCoord, float size) {
    float sliceSize = 1.0 / size;                         // space of 1 slice
    float slicePixelSize = sliceSize / size;              // space of 1 pixel
    float sliceInnerSize = slicePixelSize * (size - 1.0); // space of size pixels
    float zSlice0 = min(floor(texCoord.z * size), size - 1.0);
    float zSlice1 = min(zSlice0 + 1.0, size - 1.0);
    float xOffset = slicePixelSize * 0.5 + texCoord.x * sliceInnerSize;
    float s0 = xOffset + (zSlice0 * sliceSize);
    float s1 = xOffset + (zSlice1 * sliceSize);
    vec4 slice0Color = texture2D(tex, vec2(s0, texCoord.y));
    vec4 slice1Color = texture2D(tex, vec2(s1, texCoord.y));
    float zOffset = mod(texCoord.z * size, 1.0);
    return mix(slice0Color, slice1Color, zOffset);
}
{@}hash.glsl{@}float hash12(vec2 p)
{
    vec3 p3  = fract(vec3(p.xyx) * .1031);
    p3 += dot(p3, p3.yzx + 33.33);
    return fract((p3.x + p3.y) * p3.z);
}
{@}initClipPosCapture.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tInitPos;
uniform sampler2D tLogoDepth;
uniform vec2 uFrustumDimensions;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment
#require(depthvalue.fs)
void main() {

    vec3 initPos = texture2D(tInitPos, vUv).xyz;
//    vec3 restorePos = vec3(initPos.x - (uFrustumDimensions.x * 1.5), initPos.y, 0.0);
    vec3 restorePos = vec3(initPos.x - (uFrustumDimensions.x), initPos.y, 0.0);
    float dist = length(initPos - restorePos);

    vec4 initClipPos = projectionMatrix * modelViewMatrix * vec4(initPos, 1.0);
    initClipPos /= initClipPos.w;

    vec3 logoPos = worldPosFromDepth(tLogoDepth, initClipPos.xy);
    float depth = getDepthValue(tLogoDepth, initClipPos.xy*0.5+0.5, 0.1, 100.0);
    if(depth >= 1.0) restorePos = vec3(restorePos.xy, 7.0);
    float logoPosDist = length(vec3(logoPos.xy, 0.0) - restorePos);

    gl_FragColor = vec4(initClipPos.xy * 0.5 + 0.5, dist, logoPosDist);
}
{@}sinNoise.glsl{@}vec3 sinNoise(vec3 seed, float fallOff, int octaves) {

    vec3 noise = vec3(0.0);

    float amp = 1.0;
    float freq = 1.0;

    vec3 s = seed;

    mat3 mat = mat3(0.563152, 0.495996, 0.660945, -0.660945, 0.750435, 0.0, -0.495996, -0.436848, 0.750435);

    for(int i = 0; i < octaves; i++) {
        s = mat * s.yzx;
        noise += sin(s.yzx * freq) * amp;
        amp *= fallOff;
        freq /= fallOff;
        s += noise;

    }

    return noise;
}
{@}unpackrgba.glsl{@}float unpackRGBA (vec4 v) {
    return dot(v, 1.0 / vec4(1.0, 255.0, 65025.0, 16581375.0));
}
{@}wetaParticleIntroComposite.glsl{@}#!ATTRIBUTES

