#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec3 color = texture2D(tMap, vUv).rgb;

    float strobelight2 = 1.0 - fract(time * 2.0);

    float mainintensity = 1.0 - step(sin(time * 0.5), 0.8);
    float strobelight = step(0.5, sin(time * 65.0) * 0.5 + 0.5);

    float lighting = 0.0;
    lighting += strobelight * mainintensity;
    lighting += strobelight2;

    color = vec3(lighting) * color.g * 2.0;
    gl_FragColor = vec4(color, 1.0);
}{@}PepsiOrbShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vec3 pos = position;

    // this shader billboards every quad
    vec3 cameraRightWorld = vec3(viewMatrix[0][0], viewMatrix[1][0], viewMatrix[2][0]);
    vec3 cameraUpWorld = vec3(viewMatrix[0][1], viewMatrix[1][1], viewMatrix[2][1]);

    vec3 particleCenterWorld = vec3(0.0);
    vec2 st = (uv - vec2(0.5)) * 2.0; // remap uvs from 0 -> 1.0 to -1.0 -> 1.0

    // reduce all vertices of the quad to the quad's position (stored in vdata)
    // and then stretch them back out to a square using the stored, unitized UVs
    float billboardSize = 0.2;
    vec3 vertexPositionWorld =
    particleCenterWorld
    + cameraRightWorld * st.x * billboardSize
    + cameraUpWorld * st.y * billboardSize;

    pos = vertexPositionWorld;

    vUv = uv;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    // float a = clamp(1.0 - length(vUv - 0.5) * 2.0, 0.0, 1.0);
    // a = pow(a, 3.0);
    // a *= mix(0.99, 1.01, sin(time * 55.0));
    // vec3 color = vec3(0.1, 0.1, 2.0);
    // color += pow(a, 3.0) * vec3(0.1, 0.1, 2.0);
    // color *= 3.0;
    vec3 color = texture2D(tMap, vUv).rgb;
    color *= mix(0.99, 1.01, sin(time * 55.0));
    gl_FragColor = vec4(color, 1.0);
}{@}TetaviParticleShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPos;
uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec3 vMvPos;
varying vec3 vPos;
varying vec3 vEye;

#!SHADER: Vertex

void main() {
    vec4 decodedPos = texture2D(tPos, position.xy);
    float scale = 0.4;
    vec3 pos = decodedPos.xyz;

    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = scale * 0.1 * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;

    vMvPos = mvPosition.xyz;
    vPos = (modelMatrix * decodedPos).xyz;
}

#!SHADER: Fragment

void main() {
    vec2 uv = gl_PointCoord.xy;

    float a = 1.0 - length(uv - 0.5);
    
    a = pow(a, 7.0);

    a *= clamp(vPos.y * 20.0, 0.0, 1.0);

    float mainintensity = 1.0 - step(sin(time * 0.5), 0.8);
    float strobelight = step(0.5, sin(time * 65.0) * 0.5 + 0.5);
    float falloff = pow(clamp(1.0 - length(vPos) * 0.5, 0.0, 1.0), 2.0);
    
    float lighting = 0.05;
    lighting += strobelight * 35.0 * falloff * mainintensity;

    vec3 color = uColor1 * lighting;
    color += 0.1;


    gl_FragColor = vec4(color, a);
}{@}TetaviTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform int uNormalMode;
uniform int uNormalVisMode;
uniform vec3 uOrbPosition;
uniform vec3 uAreaPosition;

#!VARYINGS
varying vec2 vUv;
varying vec3 vSunPos;
varying vec3 vViewDir;
varying vec3 vMPos;
varying vec3 vWorldPos;
varying vec3 vNormal;
varying vec3 vEye;
varying vec3 vOrbPos;
varying vec3 vAreaPos;

#!SHADER: Vertex
#require(BaseTetaviModelShader.vs)
#require(getNormalFromWorldPosTexture.vs)
#require(lights.vs)

void main() {
    vec3 pos = decodeTetaviData(vUv);

    vec4 mPos = modelMatrix * vec4(pos, 1.0);
    vec4 mvPos = viewMatrix * mPos;
    vMPos = mPos.xyz / mPos.w;
    vViewDir = -mvPos.xyz;
    vWorldPos = mPos.xyz;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vNormal = getNormalFromWorldPosTexture(gl_Position);
    vEye = normalize(cameraPosition - mPos.xyz);
    vOrbPos = normalize(uOrbPosition - mPos.xyz) * vec3(1.0, -1.0, 1.0);
    vAreaPos = normalize(uAreaPosition - mPos.xyz) * vec3(-1.0, 1.0, -1.0);
}

#!SHADER: Fragment
#require(BaseTetaviModelShader.fs)
#require(dnormal.fs)
#require(fresnel.glsl)
#require(range.glsl)
#require(contrast.glsl)

void main() {
    vec3 color = texture2D(tDiffuse, vUv).rgb;
    float skinMask = smoothstep(0.4, 0.5, color.r);
    vec3 normal = vNormal;
    normal.y = -normal.y;

    vec3 keylightDir = normalize(vec3(0.0, 1.0, 0.0));
    vec3 bouncelightDir = normalize(vOrbPos);
    vec3 rimlightDir = normalize(vAreaPos);
    vec3 strobelightDir = normalize(vec3(0.0, -1.0, 0.0));

    vec3 lighting = vec3(0.0);

    float keylight = dot(normal, keylightDir);

    float bouncelight = -dot(normal, bouncelightDir) * 0.5 + 0.1;

    float strobelight = dot(normal, strobelightDir) * 0.5 + 0.1;
    strobelight *= step(0.5, sin(time * 65.0) * 0.5 + 0.5);

    float strobelight2 = dot(normal, strobelightDir) * 0.5 + 0.1;
    strobelight2 *= 1.0 - fract(time * 2.0);

    // strobelight2 *= (sin(time * 4.0) * 0.5 + 0.5);

    // rimlight *= sin(time * 5.0) * 0.5 + 0.5;
    float rimlight = dot(normal, rimlightDir) * 0.5 + 0.15;
    // rimlight *= step(0.5, fract(time * 0.25));
    rimlight *= pow(1.0 - fract(time * 0.5), 2.0);

    float ambient = 0.01;

    float mainintensity = step(sin(time * 0.5), 0.8);
    float falloff = clamp(1.0 - vWorldPos.y * 0.5, 0.0, 1.0);

    // lighting += ambient;
    lighting += max(0.0, keylight * 0.5 + 0.2) * 0.2;

    lighting += max(0.0, bouncelight) * pow(vec3(0.2, 0.3, 1.0), vec3(2.2)) * 30.0 * pow(clamp(1.0 - distance(vWorldPos.xyz, uOrbPosition)* 0.3, 0.0, 1.0), 2.0);
    lighting += max(0.0, rimlight) * pow(vec3(1.0, 0.1, 0.1), vec3(2.2)) * 2.5;

    lighting += max(0.0, strobelight) * pow(vec3(1.1, 1.1, 1.0), vec3(2.2)) * 8.5  * (1.0 - mainintensity) * falloff;
    lighting += max(0.0, strobelight2) * falloff * 10.0;
    
    color = vec3(lighting) * pow(color, vec3(2.2));
    color = pow(color, vec3(0.45));

    float fresnel = dot(vEye, normal) * 0.5 + 0.5;
    color += pow(fresnel, 1.5) * 0.05;

    gl_FragColor = vec4(color, 1.0);
    gl_FragColor.a = 1.0;
}
{@}TetaviTextureProjectShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform int uNormalMode;
uniform int uNormalVisMode;
uniform vec3 uOrbPosition;
uniform vec3 uAreaPosition;
uniform sampler2D tVideo;

#!VARYINGS
varying vec2 vUv;
varying vec3 vSunPos;
varying vec3 vViewDir;
varying vec3 vMPos;
varying vec3 vWorldPos;
varying vec3 vNormal;
varying vec3 vEye;
varying vec3 vOrbPos;
varying vec3 vAreaPos;

#!SHADER: Vertex
#require(BaseTetaviModelShader.vs)
#require(getNormalFromWorldPosTexture.vs)

void main() {
    vec3 pos = decodeTetaviData(vUv);

    vec4 mPos = modelMatrix * vec4(pos, 1.0);
    vec4 mvPos = viewMatrix * mPos;
    vMPos = mPos.xyz / mPos.w;
    vViewDir = -mvPos.xyz;
    vWorldPos = mPos.xyz;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vNormal = getNormalFromWorldPosTexture(gl_Position);
    vEye = normalize(cameraPosition - mPos.xyz);
}

#!SHADER: Fragment
#require(BaseTetaviModelShader.fs)
#require(dnormal.fs)
#require(fresnel.glsl)
#require(range.glsl)
#require(contrast.glsl)

void main() {
    vec3 color = texture2D(tDiffuse, vUv).rgb;
    color = pow(color, vec3(2.2));

    vec3 normal = vNormal;
    normal.y = -normal.y;
    normal = normalize(normal);

    vec2 videoUv = vWorldPos.xy / vec2(4.0, 2.0) + vec2(0.5, 0.0);
    videoUv *= 2.0 / 100.0;

    vec3 video = textureLod(tVideo, videoUv, 16.0).rgb;
    float lighting = dot(normal, normalize(vec3(0.0, 0.0, 1.0))) * 0.5 + 0.1;
    lighting = clamp(lighting, 0.0, 1.0);
    lighting += 0.01;
    float falloff = clamp(-vWorldPos.z * 0.1 + 0.2, 0.0, 1.0);
    falloff = pow(falloff, 2.0) * 5.0;
    color *= video * lighting * 10.0 * falloff;
    color = pow(color, vec3(0.45));

    // color = vec3(falloff);

    gl_FragColor = vec4(color, 1.0);
}
