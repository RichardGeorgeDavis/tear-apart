  return dot(color.rgb, vec3(0.299, 0.587, 0.114));
}{@}GazeSelector.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform float uTime;
uniform vec3 uColor;
uniform float uAlpha;
uniform float uAlpha2;
uniform float uVisible;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment

#define pi 3.1415926538
#require(transformUV.glsl)
#require(range.glsl)
#require(simplenoise.glsl)

float circle(vec2 _st, in float _radius){
    vec2 dist = _st-vec2(0.5);
    return 1.-smoothstep(_radius-(_radius*0.1), _radius+(_radius*0.1), dot(dist,dist)*4.0);
}

float arc(vec2 uv, float outerRadius, float innerRadius, float angle) {
    uv = rotateUV(uv, radians(180.0));
    float cc = circle(uv, outerRadius) - circle(uv, innerRadius);
    vec2 d = vec2(0.5) - uv;

    float angdist = mod(atan(d.x, d.y), 2.0*pi);
    cc *= mix(uAlpha2*0.6, uAlpha, uTime);

    float dotCircle = circle(uv, mix(0.0025, outerRadius, uTime)) - circle(uv, mix(0.0, mix(innerRadius*0.8, innerRadius, uTime), uTime));
    cc += dotCircle * mix(uAlpha2*0.6, uAlpha, uTime) * mix(0.4, 0.8, uTime);

    return cc;
}

void main() {
    float alpha = 1.0;

    float radius = crange(uAlpha, 0.0, 1.0, 0.2, 0.3);
    float offset = crange(uAlpha, 0.0, 1.0, 1.06, 1.1);

    vec2 arcUV = scaleUV(vUv, vec2(0.4));
    alpha *= arc(arcUV, radius*offset, radius, radians(uTime * 360.0));
    alpha *= uVisible;

    vec2 rippleUV = vUv;
    rippleUV += cnoise(rippleUV*3.0+time*0.2)*0.005;
    float ripple = fract(length(rippleUV-0.5)*mix(4.0, 7.0, uTime)-time*0.2);

    float midPoint = mix(0.6, 0.1, uTime);
    ripple *= smoothstep(0.0, midPoint, ripple) * smoothstep(1.0, midPoint, ripple);
    ripple *= smoothstep(0.5, 0.25, length(rippleUV-0.5)) * smoothstep(0.1, 0.15, length(rippleUV-0.5));
    alpha += ripple * mix(0.07, 0.3, uTime) * uVisible;

    gl_FragColor = vec4(uColor, alpha);
}{@}GazeTeleportReticle.fs{@}uniform vec3 uGazeTeleportReticle;
uniform vec3 uGazeTeleportCurrent;
uniform vec3 uGazeTeleportState;

#ifndef HALF_PI
#define HALF_PI 1.5707963267948966
#endif
#ifndef PI2
#define PI2 6.283185307179586
#endif

float getGazeTeleportReticle() {
    #test !Tests.usingVR()
        return 0.0;
    #endtest

    // Animate in/out
    if (uGazeTeleportState.x < 0.01 && uGazeTeleportState.z < 0.01) {
        return 0.0;
    }

    // Ring where currently looking
    float offset = sin(time*3.0) * 0.01;
    float thickness = 0.01;
    float radius = 0.17;
    float r = distance(vWorldPos.xz, uGazeTeleportCurrent.xz);
    float dist = abs(r - offset - (radius - thickness));
    float delta = fwidth(dist);
    float current = (1.0 - smoothstep(-delta, delta, dist - thickness)) * 0.2;
    // Clamp visibility based on 3d distance
    current *= 1.0 - smoothstep(0.3, 0.38, distance(vWorldPos, uGazeTeleportCurrent));
    // Fade in
    current *= uGazeTeleportState.z;

    // Target ring
    float scale = uGazeTeleportState.x < 0.01 ? 0.0 : (1.0 / uGazeTeleportState.x);
    r = distance(vWorldPos.xz, uGazeTeleportReticle.xz);
    dist = abs(r - offset - (radius / scale - thickness));
    delta = fwidth(dist);
    float target = (1.0 - smoothstep(-delta, delta, dist - thickness)) * 0.5;

    // Progress ring
    float progress = 0.0;
    if (uGazeTeleportState.y > 0.01) {
        float thickness2 = 0.005;
        dist = abs(r - offset - ((radius - thickness * 3.0) / scale - thickness2));
        delta = fwidth(dist);
        progress = (1.0 - smoothstep(-delta, delta, dist - thickness2)) * 0.8;

        if (uGazeTeleportState.y < 0.99) {
            vec2 p = vWorldPos.xz - uGazeTeleportReticle.xz;
            float angle = mod(2.0 * atan(p.y, length(p) + p.x) + HALF_PI, PI2) / PI2;
            delta = fwidth(angle);
            progress *= (1. - smoothstep(-delta, delta, angle - uGazeTeleportState.y));
        }
    }

    // Clamp visibility based on 3d distance
    float alpha = target + progress;
    alpha *= 1.0 - smoothstep(0.3, 0.38, distance(vWorldPos, uGazeTeleportReticle));
    // Fade in/out
    alpha *= uGazeTeleportState.x;

    // Mix in the current gaze ring
    alpha += current;

    // Draw only on relatively horizontal surfaces
    alpha *= abs(dot(normalize(vWorldNormal), vec3(0.0, 1.0, 0.0)));
    // Animate texture
    alpha *= 0.7 + sin(time*2.5+vWorldPos.x*10.0+vWorldPos.y*10.0+vWorldPos.z*10.0) * 0.3;

    return alpha;
}
{@}TeleportCylinderShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uColor;
uniform vec3 uMissColor;
uniform float uAlpha;
uniform float uMiss;
uniform float uVis;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment

#require(eases.glsl)
#require(rgb2hsv.fs)

void main() {
    vec3 color = mix(uColor, uMissColor, uMiss);
    float alpha = pow(sineIn(1.0 - vUv.y), 8.0);
    color = rgb2hsv(color);
    color.x += 0.04 * (1.0 - alpha);
    color = hsv2rgb(color);

    gl_FragColor = vec4(color, alpha * uVis * uAlpha);
}{@}TeleportLineShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uLColor;
uniform float uLAlpha;
uniform float uVis;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
}

#!SHADER: Fragment

#require(range.glsl)
#require(rgb2hsv.fs)

void main() {
    float blend = crange(vUv.x, 0.1, 0.3, 0.0, 1.0) * crange(vUv.x, 0.5, 0.7, 1.0, 0.0);
    float t = mix(1.0, 0.6, crange(sin((vUv.x*30.0) - time*10.0), -1.0, 1.0, 0.0, 1.0));

    vec3 ocolor = rgb2hsv(uLColor);
    ocolor.x += 0.04 * vUv.x;
    ocolor = hsv2rgb(ocolor);

    gl_FragColor = vec4(ocolor, alpha * uLAlpha * blend * t * uVis);
}
{@}VAT.glsl{@}/*
    Since iOS often fails reading non-power-of-two textures with 
    linear filtering, it's currently necessary to sample textures 
    twice and then interpolate between frames.
*/

vec4 getInterpolatedTexture(sampler2D tMap, vec2 uv, float frames) {   
    float phase = fract(uv.y) * frames;
    vec2 frameOffsetA = vec2(uv.x, (floor(phase) + 0.5) / frames);
    vec2 frameOffsetB = vec2(uv.x, (ceil(phase) + 0.5) / frames);
    vec4 animationA = texture2D(tMap, frameOffsetA);
    vec4 animationB = texture2D(tMap, frameOffsetB);
    return mix(animationA, animationB, vec4(fract(phase)));
}{@}textureanimations.glsl{@}vec3 getFrame(in float frame, in sampler2D tMap, in vec4 data) {
  vec2 res = data.xy;
  float framesTotal = data.z;
  float framesVertex = data.w;

  frame = mod(frame, framesTotal);

  float pxStart = framesVertex * frame;
  float pxEnd = pxStart + framesVertex;

  float pxCurrent = crange(uv2.x, 0.0, 1.0, pxStart, pxEnd);

  float x = mod(pxCurrent, res.x);
  float y = floor(pxCurrent / res.x);

  vec3 pos = texture2D(tMap, vec2(x, y) / res).xyz;
  
  return pos;
}

vec3 interpolateFrame(in float frame, in sampler2D tMap, in vec4 data) {
  float t = frame;
  vec3 a = getFrame(floor(t), tMap, data);
  vec3 b = getFrame(ceil(t), tMap, data);

  vec3 p = mix(a, b, fract(t));

  return p;
}{@}ARCameraQuad.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    gl_Position = vec4(position, 1.0);
}

#!SHADER: Fragment
void main() {
    #test !!window.Metal
    vUv.y = 1.0 - vUv.y;
    #endtest

    gl_FragColor = texture2D(tMap, vUv);
}{@}VRInputControllerDefault.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec3 vViewDir;
varying vec3 vNormal;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
    vViewDir = -mvPosition.xyz;
    vPos = position;
    vNormal = normalMatrix * normal;
    gl_Position = projectionMatrix * mvPosition;
}

#!SHADER: Fragment

#require(fresnel.glsl)
#require(range.glsl)

void main() {
    float f = getFresnel(vNormal, vViewDir, 0.8);

    f *= crange(vPos.z, 0.04, 0.1, 1.0, 0.0);

    vec3 color = vec3(1.0);
    gl_FragColor = vec4(color, f);
}{@}VRHand.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uColor;
uniform float uStatic;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vNormal;
varying vec3 vViewDir;

#!SHADER: Vertex

#require(skinning.glsl)

void main() {
    vNormal = normalize(normalMatrix * normal);
    vUv = uv;
    vViewDir = -vec3(modelViewMatrix * vec4(position, 1.0));
    vec3 pos = position;

    if (uStatic < 0.5) {
        applySkin(pos, vNormal);
    }

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment

#require(fresnel.glsl)

void main() {
    gl_FragColor = vec4(uColor * (1.0 - getFresnel(vNormal, vViewDir, 5.0)), 1.0);
}