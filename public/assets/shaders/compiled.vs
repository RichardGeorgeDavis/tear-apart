uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)
#require(rgbshift.fs)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}


void main() {
    // vec4 color = texture2D(tDiffuse, vUv);
    vec4 color = getRGB(tDiffuse, vUv, 0.1, 0.0005);

    vec3 bloom = getUnrealBloom(vUv).rgb;

    color.rgb = pow(color.rgb, vec3(1.5));
    color.rgb += pow(bloom, vec3(1.5));
    color.rgb = pow(color.rgb, vec3(1.0/1.5));

  gl_FragColor = color;
  gl_FragColor.a = 1.0;
}{@}MRMShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNormal;
uniform sampler2D tRoughness;
uniform sampler2D tMatcap;
uniform sampler2D tCavity;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vEye;

#!SHADER: Vertex
void main() {
  vec4 modelViewPos = modelViewMatrix * vec4(position, 1.0);

  gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
  vUv = uv;
  vNormal = normalMatrix * normal;
  vEye = normalize(modelViewPos.xyz);
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

float getFresnel(vec3 normal, vec3 viewDir, float power) {
    float d = dot(normalize(normal), normalize(viewDir));
    return 1.0 - pow(abs(d), power);
}

vec2 getSubUV(float _width, vec2 _uv, float _index) {
    float index = _index * (1.0 / _width);
    vec2 uv = _uv;
    uv.x /= _width;
    uv.x += floor(fract(index) * _width) / _width;
    return uv;
}

void main() {
  vec3 normal = unpackNormal(normalize(vEye), vNormal, tNormal, 1.0, 1.0, vUv).xyz;

  vec3 color = texture2D(tMap, vUv).rgb;
  color = pow(color, vec3(2.2));
  float roughness = 1.0 - texture2D(tRoughness, vUv).r;

  // vec3 normal = normalize(vNormal);
  vec3 eye = normalize(vEye);
  float fresnel = getFresnel(normal, eye, 1.0);
  // fresnel = fresnel * fresnel;

  vec2 muv = matcap(eye, normal);

  vec3 matcap = texture2D(tMatcap, muv).rgb;
  // color = matcap;
  matcap = pow(matcap, vec3(2.2));
  color = mix(color, matcap * 2.0, fresnel * roughness * 0.25);
  // color += max(0.0, dot(vNormal, vec3(0.0, -1.0, -0.7))) * vec3(0.0, 0.5, 1.0) * 0.1;
  // color += matcap;
  color = pow(color, vec3(0.45));

  float cavity = texture2D(tCavity, vUv).r;
  cavity -= 0.5;
  // color += cavity * 0.5;

  // color = vec3(fresnel);

  gl_FragColor = vec4(color, 1.0);
}{@}MSDFBlendShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tMap1;
uniform sampler2D tMap2;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vEye;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec3 n = normal;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vNormal = normalMatrix * n;
    vEye = vec3(modelViewMatrix * vec4(pos, 1.0));
}

#!SHADER: Fragment
#require(normalmap.glsl)

float median(float r, float g, float b) {
    return max(min(r, g), min(max(r, g), b));
}

float screenPxRange() {
    vec2 unitRange = vec2(9.0)/vec2(textureSize(tMap1, 0));
    vec2 screenTexSize = vec2(1.0)/fwidth(vUv);
    return max(0.5*dot(unitRange, screenTexSize), 1.0);
}

vec2 rotate(vec2 v, float a) {
	float s = sin(a);
	float c = cos(a);
	mat2 m = mat2(c, -s, s, c);
	return m * v;
}

float roundMerge(float shape1, float shape2, float radius){
    vec2 intersectionSpace = vec2(shape1, shape2);
    intersectionSpace = max(intersectionSpace, 0.0);
    return length(intersectionSpace);
}

float getsd(vec2 uv, vec2 uv2, float blend) {
    vec3 msd1 = texture2D(tMap1, uv).rgb;
    vec3 msd2 = texture2D(tMap2, uv2).rgb;
    float sd1 = median(msd1.r, msd1.g, msd1.b);
    float sd2 = median(msd2.r, msd2.g, msd2.b);

    float sd = mix(sd1, sd2, blend);
    return sd;
}

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    vec2 uv = vUv;
    vec2 uv2 = vUv;

    // uv -= 0.5;
    // uv = rotate(uv, time);
    // uv += 0.5;

    // uv2 -= 0.5;
    // uv2 = rotate(uv2, time);
    // uv2 += 0.5;

    
    // float blend = pow(tan(time * 2.0 - length(vUv - 0.5) * 3.0) * 0.5 + 0.5, 1.0) * 5.0;
    float blend = tan(time * 2.0 + length(vUv - 0.5) * 15.0) * 0.5 + 0.5;
    float eps = 0.005;
    vec2 h = vec2(eps, 0.0);
    float sd = getsd(uv, uv2, blend);
    float sd1 = getsd(uv + h.xy, uv2 + h.xy, blend);
    float sd2 = getsd(uv - h.xy, uv2 - h.xy, blend);
    float sd3 = getsd(uv + h.yx, uv2 + h.yx, blend);
    float sd4 = getsd(uv - h.yx, uv2 - h.yx, blend);


    // float sd = median(msd.r, msd.g, msd.b);

    vec3 n = normalize( vec3(
        (sd1 - sd2) * 0.1,
        (sd3 - sd4) * 0.075, 
        sd * 0.01)
    );

    vec2 muv = matcap(normalize(vEye), n);
    vec3 color = texture2D(tMatcap, muv).rgb;

    // vec3 msd1 = texture2D(tMap1, uv).rgb;
    // vec3 msd2 = texture2D(tMap2, uv2).rgb;
    // float sd1 = median(msd1.r, msd1.g, msd1.b);
    // float sd2 = median(msd2.r, msd2.g, msd2.b);

    // float sd = mix(sd1, sd2, sin(time * 3.0) * 0.5 + 0.5);
    // sd += 0.1;

    // vec3 n = normalize( vec3(
    //     sd1,
    //     sd2,
    //     1.0
    // ));

    float screenPxDistance = screenPxRange()*(sd - 0.5);
    float opacity = clamp(screenPxDistance + 0.5, 0.0, 1.0);

    gl_FragColor = vec4(color, opacity);
}{@}MyTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
vec4 RGBEToLinear(in vec4 value) {
    return vec4(value.rgb * exp2(value.a * 255.0 - 128.0), 1.0);
}

void main() {
    vec4 color = texture2D(tMap, vUv);
    color = RGBEToLinear(color);
    color.rgb = pow(color.rgb, vec3(0.45));
    gl_FragColor = vec4(color.rgb, 1.0);
}{@}RgbmTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

void main() {
    vec4 color = texture2D(tMap, vUv);
    color = RGBMToLinear(color);
    // color.rgb = 1.0 / sqrt(color.rgb);
    color.rgb = pow(color.rgb, vec3(0.45));
    // color.rgb *= 4.0;
    // color.rgb = pow(color.rgb, vec3(0.45));

    // color.rgb = vec3(1.0, 0.0, 0.0);
    
    gl_FragColor = vec4(color.rgb, 1.0);
}{@}PlaneNormalShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNormal;
uniform sampler2D tAlpha;
uniform sampler2D tDiffuse;

uniform vec3 uMousePos;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vPos = (modelMatrix * vec4(position, 1.0)).xyz;
}

#!SHADER: Fragment
void main() {
    vec3 normal = texture2D(tNormal, vUv).rgb * 2.0 - 1.0;
    normal = normalize(normal);
    vec3 color = texture2D(tMap, vUv).rgb;
    
    vec3 lightPos = normalize(uMousePos - vec3(0.0, 0.0, 0.4));
    float dist = length(vPos.xy - lightPos.xy);
    dist = 1.0 - dist;
    dist = clamp(dist, 0.0, 1.0);
    dist = pow(dist, 2.0);

    float dp = max(0.0, dot(lightPos, normal));
    dp += pow(dp, 6.0);
    dp = clamp(dp, 0.0, 1.0);

    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb += dp * pow(texture2D(tDiffuse, vUv).rgb, vec3(2.2)) * dist * 0.7;
    color.rgb = pow(color.rgb, vec3(0.45));

    color.rgb *= texture2D(tAlpha, vUv).r;


    gl_FragColor = vec4(color, 1.0);
}{@}FlatColorShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uColor;

#!VARYINGS
#!SHADER: Vertex
