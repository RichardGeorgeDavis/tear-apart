}{@}ExtensionShader.glsl{@}#!ATTRIBUTES
// vdata and uv2 are used to make windows
// stretch to fit planes exactly, so we don't 
// end up with any half windows.

// vdata.z = floor height
// uv2.y = floor width
// vdata.x = tangent pos offset x
// vdata.y = tangent pos offset z
// uv2.x = seed

attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform samplerCube tCube;

uniform sampler2D tMap;
uniform sampler2D tNormal;
uniform sampler2D tCurtain;
uniform sampler2D tEmissive;
uniform sampler2D tWindow;
uniform sampler2D tWindowARM;

uniform vec3 uColor1;
uniform vec3 uColor2;

uniform float uAtlasHeight;
uniform float uDepth;

#!VARYINGS
varying vec2 vUv;

varying vec3 vTangentPos;
varying vec3 vTangentEye;

varying vec3 vEye;
varying mat3 vTbn;

varying vec3 vPos;
varying vec3 vColor;
varying vec3 vNormal;

varying float vFloorHeight;
varying float vFloorWidth;
varying float vFloorDepth;
varying float vSeed;
varying float vFog;

varying vec3 vTest;



#!SHADER: Vertex
const float c_precision = 64.0;
const float c_precisionp1 = c_precision + 1.0;
/*
 * \param value 3-component encoded float
 * \returns normalized RGB value
 */
vec3 float2color(float value) {
	vec3 color;
	color.r = mod(value, c_precisionp1) / c_precision;
	color.b = mod(floor(value / c_precisionp1), c_precisionp1) / c_precision;
	color.g = floor(value / (c_precisionp1 * c_precisionp1)) / c_precision;
	return color;
}

void main() {
    // x: primpos.x, y: primpos.z, z: random
    vec3 unpackedData = float2color(vdata.x) * vec3(10.0, 10.0, 1.0);

    vec3 pos = position;

    vec3 B = vec3(0.0, 1.0, 0.0);
    vec3 N = normal;
    vec3 T =-normalize(cross(N, B));

    mat3 tbn;
    tbn[0] = vec3(T.x, T.y, T.z); 
    tbn[1] = vec3(B.x, B.y, B.z); 
    tbn[2] = vec3(N.x, N.y, N.z); 

    mat3 invtbn = transpose(tbn);
    vec3 eye = inverse(modelViewMatrix)[3].xyz;

    vTangentPos = invtbn * position;
    vTangentEye = invtbn * inverse(modelViewMatrix)[3].xyz;

    vTangentPos.x -= vdata.y;
    vTangentEye.x -= vdata.y;
    vTangentPos.z -= vdata.z;
    vTangentEye.z -= vdata.z;
    vTangentPos.z = -abs(vTangentPos.z);

    // shift ceiling
    vTangentPos.y += 0.5;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;

    vColor = vec3(invtbn[2]);
    vNormal = normalMatrix * normal;

    vFloorHeight = 4.0;
    vFloorWidth = unpackedData.x;
    vFloorDepth = uDepth;
    vSeed = unpackedData.z;

    vTbn = tbn;
    vEye = (modelMatrix * vec4(position, 1.0)).xyz - cameraPosition;

    vec3 modelViewPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
    vFog = smoothstep(25.0, 500.0, -modelViewPos.z);
    vPos = position;

    vTest = unpackedData;
}

#!SHADER: Fragment

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

float rand(vec2 co, float seed){
    return fract(seed + sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}


void main() {

    // exterior mapping
    vec2 exteriorUv = vUv;
    // exteriorUv.x /= vFloorWidth;
    // exteriorUv.y /= vFloorHeight;

    // vec2 mosaic = vec2(floor(exteriorUv.x), floor(exteriorUv.y));
    float rand1 = vSeed;
    float rand2 = sin(rand1 * 6000.0) * 0.5 + 0.5;
    float rand3 = sin(rand1 * 758.5453) * 0.5 + 0.5;
    // float rand1 = 1.5;
    // float rand2 = 1.5;
    // float rand3 = 1.0;

    // alternate from 4 different textures on the atlas
    // every 4 steps, reverse the sequence
    // id is an integer between 0 and 3

    // controls
    float temperatureMix = clamp(rand1 * 2.0, 0.0, 1.0);


    // interior mapping
    vec3 camToPixel = vTangentPos - vTangentEye;
    
    float isFloor = step(camToPixel.y, 0.0);
    float ceilingHeight = ceil(vTangentPos.y / vFloorHeight - isFloor) * vFloorHeight;
    float ceilingDist = (ceilingHeight - vTangentEye.y) / camToPixel.y;

    float isRear = step(camToPixel.z, 0.0);
    float rearWallDepth = ceil(vTangentPos.z / vFloorDepth - isRear) * vFloorDepth;
    float rearWallDist = (rearWallDepth - vTangentEye.z) / camToPixel.z;

    float innerDepth = ceil(vTangentPos.z / vFloorDepth - isRear);
    float innerDist = (rearWallDepth - vTangentEye.z) / camToPixel.z;

    float isSide = step(camToPixel.x, 0.0);
    float sideWallWidth = ceil((vTangentPos.x) / vFloorWidth - isSide) * vFloorWidth;
    float sideWallDist = (sideWallWidth - vTangentEye.x) / (camToPixel.x);

    vec2 interiorUv;
    float interiorUvOffset;
    float minDist = min(min(ceilingDist, rearWallDist), sideWallDist);

    if (sideWallDist == minDist) {
        interiorUv = vTangentEye.zy + sideWallDist * camToPixel.zy;
        interiorUv.x /= vFloorDepth;
        interiorUv.y /= vFloorHeight;
        interiorUvOffset = isSide == 0.0 ? 1.0 : 0.0;
    } else if (rearWallDist == minDist) {
        interiorUv = vTangentEye.xy + rearWallDist * camToPixel.xy;
        interiorUv.x /= vFloorWidth;
        interiorUv.y /= vFloorHeight;
        interiorUvOffset = 4.0;
    } else if (ceilingDist == minDist) {
        interiorUv = vTangentEye.xz + ceilingDist * camToPixel.xz;
        interiorUv.x /= vFloorWidth;
        interiorUv.y /= vFloorDepth;
        interiorUvOffset = isFloor == 0.0 ? 2.0 : 3.0;
    }

    float column = 1.0 / 5.0;
    interiorUv = fract(interiorUv);
    interiorUv.x *= column;
    interiorUv.x += column * interiorUvOffset;

    // lighting
    vec3 normalMap = texture2D(tNormal, exteriorUv).rgb;
    
    normalMap *= 2.0;
    normalMap -= 1.0;
    normalMap.xy *= 2.0;
    normalMap = normalize(vTbn * normalMap);

    float diffuse = max(0.2, dot(normalMap, normalize(vec3(-0.25, 0.25, 0.8)))) * 0.2;
    float interiorLights = max(0.2, rand3) * 1.5;

    vec3 interior = texture2D(tMap, interiorUv).rgb * interiorLights;
    vec3 temperatureColor = mix(uColor2, uColor1, temperatureMix);
    vec3 curtain = texture2D(tCurtain, exteriorUv).rgb * interiorLights;
    interior *= temperatureColor;
    curtain *= temperatureColor;
    
    float highlight = texture2D(tEmissive, interiorUv).r * interiorLights;
    interior += highlight * interiorLights;
    vec3 window = texture2D(tWindow, exteriorUv).rgb;
    vec3 windowARM = texture2D(tWindowARM, exteriorUv).rgb;
    curtain *= windowARM.r;

    // reflections
    vec3 eye = normalize(vEye);
    float NdV = dot(normalMap, eye);
    float brdf = envBRDFApproxNonmetal(0.0, abs(NdV));
    brdf = max((1.0 - windowARM.b) * 0.5, brdf);

    vec3 R = reflect(eye, normalMap);
    vec3 spec = textureCube(tCube, R).rgb;
    
    // compositing
    // vec3 color = mix(curtain * 0.5, interior, 0.01 + windowARM.z + (1.0 - smoothstep(0.0 + rand2 * 0.3, 0.015 + rand2 * 0.3, abs(exteriorUv.x - 0.5))));
    vec3 color = interior;
    // vec3 color = vec3(1.0);
    
    color = mix(color, window * diffuse, windowARM.z);
    color = mix(color, spec, brdf);

    // color = vec3(verticalStripIdReverse);

    // if (verticalStripId == 0.0) {
