}{@}BoundingBoxAABB.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D data;
uniform float size;
uniform bool evaluateMin;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex

void main() {
    gl_Position = vec4(position, 1.);
    vUv = uv;
}

#!SHADER: Fragment

void main() {

    float k = 0.5 * size;
    vec2 position = floor(vUv / size) * size;

    vec3 a = texture2D(data,  position + vec2(0., 0.)).xyz;
    vec3 b = texture2D(data,  position + vec2(k, 0.)).xyz;
    vec3 c = texture2D(data,  position + vec2(0., k)).xyz;
    vec3 d = texture2D(data,  position + vec2(k, k)).xyz;

    if(evaluateMin) {
        gl_FragColor.x = min(min(a.x, b.x), min(c.x, d.x));
        gl_FragColor.y = min(min(a.y, b.y), min(c.y, d.y));
        gl_FragColor.z = min(min(a.z, b.z), min(c.z, d.z));
    } else {
        gl_FragColor.x = max(max(a.x, b.x), max(c.x, d.x));
        gl_FragColor.y = max(max(a.y, b.y), max(c.y, d.y));
        gl_FragColor.z = max(max(a.z, b.z), max(c.z, d.z));
    }

    gl_FragColor.a = 1.;
}
{@}BoundingBoxDebug.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMin;
uniform sampler2D tMax;
uniform vec3 vMin;
uniform vec3 vMax;
uniform bool redoBBox;

#!VARYINGS

#!SHADER: Vertex

void main() {
    vec3 pos = position;

    vec3 minPosition = vMin;
    vec3 maxPosition = vMax;

    if(redoBBox) {
        minPosition = texture2D(tMin, vec2(0.5)).rgb;
        maxPosition = texture2D(tMax, vec2(0.5)).rgb;
    }

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);
    pos *= s;
    pos += minPosition + vec3(scale * 0.5);


    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment

void main() {
    gl_FragColor = vec4(1., 0., 0., 1.);
}{@}GeneratePyramid.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uPyT;
uniform float uSize;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex

void main() {
    gl_Position = vec4(position, 1.);
    vUv = uv;
}

#!SHADER: Fragment

void main() {

    float k = 0.5 * uSize;
    vec2 position = floor(vUv / uSize) * uSize;

    float a = texture2D(uPyT,  position + vec2(0., 0.)).r;
    float b = texture2D(uPyT,  position + vec2(k, 0.)).r;
    float c = texture2D(uPyT,  position + vec2(0., k)).r;
    float d = texture2D(uPyT,  position + vec2(k, k)).r;

    gl_FragColor.a = a;
    gl_FragColor.b = a + b;
    gl_FragColor.g = a + b + c;
    gl_FragColor.r = a + b + c + d;    
}
{@}MarchCase.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uCornersTexture;
uniform sampler2D uTrianglesIndex;
uniform float uRange;
uniform vec3 u3D;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

//Function used to evaluate the 2D index from a 3D position.
vec2 index2D(vec3 pos) {
    return u3D.x * (pos.xz + u3D.y * vec2(mod(pos.y, u3D.z), floor(pos.y / u3D.z)) + vec2(0.5));
}

void main() {

    vec2 position = floor(vUv / u3D.x);
    vec3 pos3D = vec3(mod(position.y, u3D.y), u3D.z * floor(position.y / u3D.y) + floor(position.x / u3D.y), mod(position.x, u3D.y));

    float c = step(texture(uCornersTexture, index2D(pos3D)).r, uRange)
            + 2. *   step(  texture(uCornersTexture, index2D(pos3D + vec3(1., 0., 0.))).r, uRange)
            + 4. *   step(  texture(uCornersTexture, index2D(pos3D + vec3(1., 1., 0.))).r, uRange)
            + 8. *   step(  texture(uCornersTexture, index2D(pos3D + vec3(0., 1., 0.))).r, uRange)
            + 16. *  step(  texture(uCornersTexture, index2D(pos3D + vec3(0., 0., 1.))).r, uRange)
            + 32. *  step(  texture(uCornersTexture, index2D(pos3D + vec3(1., 0., 1.))).r, uRange)
            + 64. *  step(  texture(uCornersTexture, index2D(pos3D + vec3(1., 1., 1.))).r, uRange)
            + 128. * step(  texture(uCornersTexture, index2D(pos3D + vec3(0., 1., 1.))).r, uRange);
    c *= step(c, 254.);

    float totalTrianglesToGenerate = texture(uTrianglesIndex, vec2(mod(c, 16.), floor(c / 16.)) / 16.).r;

    gl_FragColor = vec4(vec3(totalTrianglesToGenerate * 3.), c);
}{@}NormalsGenerator.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uStream;
uniform sampler2D uPot;
uniform sampler2D uTrianglesIndexes;
uniform sampler2D uTotal;
uniform float uRange;
uniform float uCompactSize;
uniform vec3 u3D;
uniform bool uFastNormals;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

const float EPSILON = 0.00001;

vec2 index2D(vec3 pos) {
    return (pos.xz + u3D.y * vec2(mod(pos.y, u3D.z), floor(pos.y / u3D.z)) + vec2(0.5)) / u3D.x;
}

void main() {

    float vI = dot(floor(uCompactSize * vUv), vec2(1., uCompactSize));

    if(vI >= texture2D(uTotal, vec2(0.5)).r) discard;

    else {

        float p = 1. / u3D.y;
        vec3 p0 = vec3(p, 0., 0.);
        vec3 p1 = vec3(p, p, 0.);
        vec3 p2 = vec3(0., p, 0.);
        vec3 p3 = vec3(0., 0., p);
        vec3 p4 = vec3(p, 0., p);
        vec3 p5 = vec3(p, p, p);
        vec3 p6 = vec3(0., p, p);
    
        vec4 data = texture2D(uStream, vUv);

        float currentVertex = data.b;

        data.xyz = p * vec3(mod(data.y, u3D.y), u3D.z * floor(data.y * p) + floor(data.x * p), mod(data.x, u3D.y));
        
        float mcIndex = 15. * data.a + currentVertex;

        vec4 mcData = texture2D(uTrianglesIndexes, vec2(mod(mcIndex, 64.), floor(mcIndex / 64.)) / 64.);
        mcIndex = mcData.r;

        vec4 m0 = vec4(mcIndex);
        vec4 m1 = vec4(equal(m0, vec4(0., 1., 2., 3.)));
        vec4 m2 = vec4(equal(m0, vec4(4., 5., 6., 7.)));
        vec4 m3 = vec4(equal(m0, vec4(8., 9., 10., 11.)));

        vec3 b0 = data.rgb + m1.y * p0 + m1.z * p1 + m1.w * p2 + m2.x * p3 + m2.y * p4 + m2.z * p5 + m2.w * p6 + m3.y * p0 + m3.z * p1 + m3.w * p2;
        vec3 b1 = data.rgb + m1.x * p0 + m1.y * p1 + m1.z * p2 + m2.x * p4 + m2.y * p5 + m2.z * p6 + m2.w * p3 + m3.x * p3 + m3.y * p4 + m3.z * p5 + m3.w * p6;
        
        vec4 n0 = texture2D(uPot, index2D(u3D.y * b0));
        vec4 n1 = texture2D(uPot, index2D(u3D.y * b1));
        vec2 diff1 = vec2(uRange - n0.r, n1.r - n0.r);
        
        vec3 mult = vec3(lessThan(abs(vec3(diff1.x, uRange - n1.a, -diff1.y)), vec3(0.)));
        vec3 normalA = vec3(0.);
        vec3 normalB = vec3(0.);

        //The regular normals evaluation used forward differences to calculate the gradient.
        if(uFastNormals) {
            vec2 deltaX = index2D(u3D.y * (b0 + vec3(p, 0., 0.)));
            vec2 deltaY = index2D(u3D.y * (b0 + vec3(0., p, 0.)));
            vec2 deltaZ = index2D(u3D.y * (b0 + vec3(0., 0., p)));
            normalA = normalize(-vec3(n0.r - texture(uPot, deltaX).r, n0.r - texture(uPot, deltaY).r, n0.r - texture(uPot, deltaZ).r));

            deltaX = index2D(u3D.y * (b1 + vec3(p, 0., 0.)));
            deltaY = index2D(u3D.y * (b1 + vec3(0., p, 0.)));
            deltaZ = index2D(u3D.y * (b1 + vec3(0., 0., p)));
            normalB = normalize(-vec3(n1.r - texture(uPot, deltaX).r, n1.r - texture(uPot, deltaY).r, n1.r - texture(uPot, deltaZ).r));
        } else {
            //If more smooth gradients are required, a higher order Sobel operator is used to calculate them.
            //this gives a more smoothed surface at the expense of less performance.
            float op = 1.;
            float scaler = 1.;
            vec3 S1A_X = vec3(1., op, 1.);
            vec3 S2A_X = vec3(op, scaler * op, op);
            vec3 S3A_X = vec3(1., op, 1.);
            vec3 S1B_X = vec3(0.);
            vec3 S2B_X = vec3(0.);
            vec3 S3B_X = vec3(0.);
            vec3 S1C_X = vec3(-1., -op, -1.);
            vec3 S2C_X = vec3(-op, -scaler * op, -op);
            vec3 S3C_X = vec3(-1., -op, -1.);
            vec3 S1A_Y = vec3(1., op, 1.);
            vec3 S2A_Y = vec3(0., 0., 0.);
            vec3 S3A_Y = vec3(-1., -op, -1.);
            vec3 S1B_Y = vec3(op, scaler * op, op);
            vec3 S2B_Y = vec3(0., 0., 0.);
            vec3 S3B_Y = vec3(-op, -scaler * op, -op);
            vec3 S1A_Z = vec3(-1., 0., 1.);
            vec3 S2A_Z = vec3(-op, 0., op);
            vec3 S3A_Z = vec3(-1., 0., 1.);
            vec3 S1B_Z = vec3(-op, 0., op);
            vec3 S2B_Z = vec3(-scaler * op, 0., scaler * op);
            vec3 S3B_Z = vec3(-op, 0., op);
            vec3 f1A = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, p, p)))).r,   texture(uPot, index2D(u3D.y * (b0 + vec3(0., p, p)))).r,   texture(uPot, index2D(u3D.y * (b0 + vec3(p, p, p)))).r);
            vec3 f2A = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, 0., p)))).r,  texture(uPot, index2D(u3D.y * (b0 + vec3(0., 0., p)))).r,  texture(uPot, index2D(u3D.y * (b0 + vec3(p, 0., p)))).r);
            vec3 f3A = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, -p, p)))).r,  texture(uPot, index2D(u3D.y * (b0 + vec3(0., -p, p)))).r,  texture(uPot, index2D(u3D.y * (b0 + vec3(p, -p, p)))).r);
            vec3 f1B = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, p, 0.)))).r,  texture(uPot, index2D(u3D.y * (b0 + vec3(0., p, 0.)))).r,  texture(uPot, index2D(u3D.y * (b0 + vec3(p, p, 0.)))).r);
            vec3 f2B = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, 0., 0.)))).r, texture(uPot, index2D(u3D.y * (b0 + vec3(0., 0., 0.)))).r, texture(uPot, index2D(u3D.y * (b0 + vec3(p, 0., 0.)))).r);
            vec3 f3B = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, -p, 0.)))).r, texture(uPot, index2D(u3D.y * (b0 + vec3(0., -p, 0.)))).r, texture(uPot, index2D(u3D.y * (b0 + vec3(p, -p, 0.)))).r);
            vec3 f1C = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, p, -p)))).r,  texture(uPot, index2D(u3D.y * (b0 + vec3(0., p, -p)))).r,  texture(uPot, index2D(u3D.y * (b0 + vec3(p, p, -p)))).r);
            vec3 f2C = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, 0., -p)))).r, texture(uPot, index2D(u3D.y * (b0 + vec3(0., 0., -p)))).r, texture(uPot, index2D(u3D.y * (b0 + vec3(p, 0., -p)))).r);
            vec3 f3C = vec3(texture(uPot, index2D(u3D.y * (b0 + vec3(-p, -p, -p)))).r, texture(uPot, index2D(u3D.y * (b0 + vec3(0., -p, -p)))).r, texture(uPot, index2D(u3D.y * (b0 + vec3(p, -p, -p)))).r);
            float xGradient = dot(f1A, S1A_X) + dot(f2A, S2A_X) + dot(f3A, S3A_X) + dot(f1B, S1B_X) + dot(f2B, S2B_X) + dot(f3B, S3B_X) + dot(f1C, S1C_X) + dot(f2C, S2C_X) + dot(f3C, S3C_X);
            float yGradient = dot(f1A, S1A_Y) + dot(f2A, S2A_Y) + dot(f3A, S3A_Y) + dot(f1B, S1B_Y) + dot(f2B, S2B_Y) + dot(f3B, S3B_Y) + dot(f1C, S1A_Y) + dot(f2C, S2A_Y) + dot(f3C, S3A_Y);
            float zGradient = dot(f1A, S1A_Z) + dot(f2A, S2A_Z) + dot(f3A, S3A_Z) + dot(f1B, S1B_Z) + dot(f2B, S2B_Z) + dot(f3B, S3B_Z) + dot(f1C, S1A_Z) + dot(f2C, S2A_Z) + dot(f3C, S3A_Z);
            normalA = vec3(zGradient, yGradient, xGradient);
            f1A = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, p, p)))).r,   texture(uPot, index2D(u3D.y * (b1 + vec3(0., p, p)))).r,   texture(uPot, index2D(u3D.y * (b1 + vec3(p, p, p)))).r);
            f2A = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, 0., p)))).r,  texture(uPot, index2D(u3D.y * (b1 + vec3(0., 0., p)))).r,  texture(uPot, index2D(u3D.y * (b1 + vec3(p, 0., p)))).r);
            f3A = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, -p, p)))).r,  texture(uPot, index2D(u3D.y * (b1 + vec3(0., -p, p)))).r,  texture(uPot, index2D(u3D.y * (b1 + vec3(p, -p, p)))).r);
            f1B = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, p, 0.)))).r,  texture(uPot, index2D(u3D.y * (b1 + vec3(0., p, 0.)))).r,  texture(uPot, index2D(u3D.y * (b1 + vec3(p, p, 0.)))).r);
            f2B = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, 0., 0.)))).r, texture(uPot, index2D(u3D.y * (b1 + vec3(0., 0., 0.)))).r, texture(uPot, index2D(u3D.y * (b1 + vec3(p, 0., 0.)))).r);
            f3B = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, -p, 0.)))).r, texture(uPot, index2D(u3D.y * (b1 + vec3(0., -p, 0.)))).r, texture(uPot, index2D(u3D.y * (b1 + vec3(p, -p, 0.)))).r);
            f1C = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, p, -p)))).r,  texture(uPot, index2D(u3D.y * (b1 + vec3(0., p, -p)))).r,  texture(uPot, index2D(u3D.y * (b1 + vec3(p, p, -p)))).r);
            f2C = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, 0., -p)))).r, texture(uPot, index2D(u3D.y * (b1 + vec3(0., 0., -p)))).r, texture(uPot, index2D(u3D.y * (b1 + vec3(p, 0., -p)))).r);
            f3C = vec3(texture(uPot, index2D(u3D.y * (b1 + vec3(-p, -p, -p)))).r, texture(uPot, index2D(u3D.y * (b1 + vec3(0., -p, -p)))).r, texture(uPot, index2D(u3D.y * (b1 + vec3(p, -p, -p)))).r);
            xGradient = dot(f1A, S1A_X) + dot(f2A, S2A_X) + dot(f3A, S3A_X) + dot(f1B, S1B_X) + dot(f2B, S2B_X) + dot(f3B, S3B_X) + dot(f1C, S1C_X) + dot(f2C, S2C_X) + dot(f3C, S3C_X);
            yGradient = dot(f1A, S1A_Y) + dot(f2A, S2A_Y) + dot(f3A, S3A_Y) + dot(f1B, S1B_Y) + dot(f2B, S2B_Y) + dot(f3B, S3B_Y) + dot(f1C, S1A_Y) + dot(f2C, S2A_Y) + dot(f3C, S3A_Y);
            zGradient = dot(f1A, S1A_Z) + dot(f2A, S2A_Z) + dot(f3A, S3A_Z) + dot(f1B, S1B_Z) + dot(f2B, S2B_Z) + dot(f3B, S3B_Z) + dot(f1C, S1A_Z) + dot(f2C, S2A_Z) + dot(f3C, S3A_Z);
            normalB = vec3(zGradient, yGradient, xGradient);
        }

        gl_FragColor = vec4(normalize(- (n0.r * normalA + n1.r * normalB) / max(n0.r + n1.r, EPSILON)), mcIndex);

    }
    
}{@}Quad.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    gl_FragColor = texture2D(tMap, vUv);
}{@}StreamCompaction.glsl{@}#!ATTRIBUTES

#!UNIFORMS

uniform sampler2D uPyramid;
uniform sampler2D uBase;
uniform sampler2D uTotal;
uniform float uCompactSize;
uniform int uLevels;
uniform vec3 u3D;


#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

vec2 index2D(vec3 pos) {
    return (pos.xz + u3D.y * vec2(mod(pos.y, u3D.z), floor(pos.y / u3D.z)) + vec2(0.5)) / u3D.x;
}

void main() {

    float vI = dot(floor(uCompactSize * vUv), vec2(1., uCompactSize));

    if(vI >= texture2D(uTotal, vec2(0.5)).r) discard;

    else {

        float offset = u3D.x - 2.;
        float k = 1. / u3D.x;
        vec2 relativePosition = k * vec2(offset, 0.);
        vec4 partialSums = texture2D(uPyramid, relativePosition);
        float start = 0.;
        vec4 starts = vec4(0.);
        vec4 ends = vec4(0.);
        float div0 = 1. / u3D.y;
        float diff = 2.;
        vec4 m = vec4(0.);
        vec2 position = vec2(0.);
        vec4 vI4 = vec4(vI);

        for(int i = 1; i < 20; i++) {
            if(i >= uLevels) break;
            offset -= diff;
            diff *= 2.;
            relativePosition = position + k * vec2(offset, 0.);
            ends = partialSums.wzyx + vec4(start);
            starts = vec4(start, ends.xyz);
            m = vec4(greaterThanEqual(vI4, starts)) * vec4(lessThan(vI4, ends));
            relativePosition += m.y * vec2(k, 0.) + m.z * vec2(0., k) + m.w * vec2(k, k);
            start = dot(m, starts);
            position = 2. * (relativePosition - k * vec2(offset, 0.));
            partialSums = texture2D(uPyramid, relativePosition);
        }

        ends = partialSums.wzyx + vec4(start);
        starts = vec4(start, ends.xyz);
        m = vec4(greaterThanEqual(vI4, starts)) * vec4(lessThan(vI4, ends));
        position += m.y * vec2(k, 0.) + m.z * vec2(0., k) + m.w * vec2(k, k);

        gl_FragColor = vec4(position * u3D.x,  vI - dot(m, starts), texture2D(uBase, position).a);

    }
}{@}TrianglesRenderer.glsl{@}#!ATTRIBUTES
attribute vec3 indices;

#!UNIFORMS
uniform sampler2D tVertices;
uniform sampler2D tNormals;
uniform sampler2D tColors;
uniform bool useVertexColor;

#!VARYINGS
varying vec3 vPos;
varying vec3 vNormal;
varying vec3 vColor;

#!SHADER: Vertex

void main() {

    vec3 pos = texture2D(tVertices, indices.xy).rgb;
    vNormal = texture2D(tNormals, indices.xy).rgb;
    vColor = texture2D(tColors, indices.xy).rgb;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.);

}


#!SHADER: Fragment

void main() {

    float light = pow(max(dot(vNormal, normalize(vec3(0., 1., 1.))), 0.), 1.) * 0.8 + 0.2;

    vec3 color = ( useVertexColor ? vColor : vec3(1.) ) * light;

    gl_FragColor = vec4(color, 1.);
}{@}VerticesGenerator.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uStream;
uniform sampler2D uPot;
uniform sampler2D uTrianglesIndexes;
uniform sampler2D uTotal;
uniform sampler2D tMin;
uniform sampler2D tMax;
uniform vec3 vMin;
uniform vec3 vMax;
uniform bool redoBBox;
uniform float uRange;
uniform float uCompactSize;
uniform vec3 u3D;


#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

vec2 index2D(vec3 pos) {
    return (pos.xz + u3D.y * vec2(mod(pos.y, u3D.z), floor(pos.y / u3D.z)) + vec2(0.5)) / u3D.x;
}

void main() {

    float vI = dot(floor(uCompactSize * vUv), vec2(1., uCompactSize));

    if(vI >= texture2D(uTotal, vec2(0.5)).r) discard;

    else {

        float p = 1. / u3D.y;
        vec3 p0 = vec3(p, 0., 0.);
        vec3 p1 = vec3(p, p, 0.);
        vec3 p2 = vec3(0., p, 0.);
        vec3 p3 = vec3(0., 0., p);
        vec3 p4 = vec3(p, 0., p);
        vec3 p5 = vec3(p, p, p);
        vec3 p6 = vec3(0., p, p);
    
        vec4 data = texture2D(uStream, vUv);

        float currentVertex = data.b;

        data.xyz = p * vec3(mod(data.y, u3D.y), u3D.z * floor(data.y * p) + floor(data.x * p), mod(data.x, u3D.y));
        
        float mcIndex = 15. * data.a + currentVertex;

        vec4 mcData = texture2D(uTrianglesIndexes, vec2(mod(mcIndex, 64.), floor(mcIndex / 64.)) / 64.);
        mcIndex = mcData.r;

        vec4 m0 = vec4(mcIndex);
        vec4 m1 = vec4(equal(m0, vec4(0., 1., 2., 3.)));
        vec4 m2 = vec4(equal(m0, vec4(4., 5., 6., 7.)));
        vec4 m3 = vec4(equal(m0, vec4(8., 9., 10., 11.)));

        vec3 b0 = data.rgb + m1.y * p0 + m1.z * p1 + m1.w * p2 + m2.x * p3 + m2.y * p4 + m2.z * p5 + m2.w * p6 + m3.y * p0 + m3.z * p1 + m3.w * p2;
        vec3 b1 = data.rgb + m1.x * p0 + m1.y * p1 + m1.z * p2 + m2.x * p4 + m2.y * p5 + m2.z * p6 + m2.w * p3 + m3.x * p3 + m3.y * p4 + m3.z * p5 + m3.w * p6;
        
        vec4 n0 = texture2D(uPot, index2D(u3D.y * b0));
        vec4 n1 = texture2D(uPot, index2D(u3D.y * b1));
        vec2 diff1 = vec2(uRange - n0.r, n1.r - n0.r);
        
        vec3 mult = vec3(lessThan(abs(vec3(diff1.x, uRange - n1.a, -diff1.y)), vec3(0.)));

        vec3 padding = vec3(2./ u3D.y);
        vec3 minPosition = vMin;
        vec3 maxPosition = vMax;

        if(redoBBox) {
            minPosition = texture2D(tMin, vec2(0.5)).rgb - padding;
            maxPosition = texture2D(tMax, vec2(0.5)).rgb + padding;
        }
        
        vec3 scale = maxPosition - minPosition;
        vec3 ae = abs(scale);
        float s = max(max(ae.x, ae.y), ae.z);


        gl_FragColor = vec4(mult.x * b0 + mult.y * b1 + mult.z * b0 + (1. - dot(mult, mult)) * mix(b0, b1, (diff1.x) / (diff1.y)), mcData.b);
        gl_FragColor.rgb *= s;
        gl_FragColor.rgb += minPosition;
    
    }
    
}{@}Blur2D.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uDT;
uniform vec2 uAxis;
uniform int uSteps;
uniform vec3 u3D;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

vec4 floatToRGBA(float v) {
    vec4 enc = vec4(1.0, 255.0, 65025.0, 16581375.0) * v;
    enc = fract(enc);
    enc -= enc.yzww * vec4(1.0/255.0, 1.0/255.0, 1.0/255.0,0.0);
    return enc;
}

float rgbaToFloat(float r, float g, float b, float p) {
    return dot( vec4(r, g, b, p), vec4(1.0, 1./255.0, 1./65025.0, 1./16581375.0) );
}

void main() {
    
    vec3 mixColor = vec3(0);
    
    float n = float(uSteps);
    float blend = 0.;
    float sum = 1.;
    float m = 1.;
    float divider = 0.;
    

    vec2 st = vec2(0.);


    for (int i = 0; i <= 50; i += 1) {
                
        if(i >= 2 * uSteps) break;

        st = vUv + (float(i) - 0.5 * float(uSteps))* uAxis;
                
        vec4 data = texture2D(uDT, st);

        blend += m * data.a;
        
        float zeroColor = float(length(vec3(data.rgb)) > 0.0);
        mixColor += zeroColor * data.rgb;
        
        float k = float(i);
        m *= (n - k) / (k + 1.);
        sum += m;
        
        divider += zeroColor;
    } 
    
    blend /= sum;
    
    mixColor /= max(divider, 1.);    

    gl_FragColor = vec4(mixColor, blend);
}{@}BlurDepth.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uDataTexture;
uniform int uSteps;
uniform float uDepth;
uniform vec3 u3D;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

void main() {
    
    vec2 pos = floor(vUv / u3D.x);
    vec3 pos3D = vec3(mod(pos.y, u3D.y), u3D.z * floor(pos.y / u3D.y) + floor(pos.x / u3D.y), mod(pos.x, u3D.y));
    vec3 newPos3D = vec3(0.);
    vec2 st = vec2(0.);

    vec3 mixColor = vec3(0);
    
    float n = float(uSteps);
    float blend =  0.;
    float sum = 1.;
    float m = 1.;
    
    float divider = 0.;

    for (int i = 0; i <= 50; i += 1) {

        if(i >= 2 * uSteps) break;

        newPos3D = pos3D - (float(i) - 0.5 * n) * vec3(0., 1., 0.);
        
        st = (newPos3D.zx + u3D.y * vec2(mod(newPos3D.y, u3D.z), floor(newPos3D.y / u3D.z)) + vec2(0.5)) * u3D.x;
        st.y = fract(st.y);

        vec4 data = texture2D(uDataTexture, st);
        
        blend += m * data.a;
        
        float zeroColor = float(length(vec3(data.rgb)) > 0.0);

        mixColor += zeroColor * data.rgb;
        divider += zeroColor;

        float k = float(i);
        m *= (n - k) / (k + 1.);
        sum += m;

    }

    blend /= sum;
    mixColor /= max(divider, 1.);  

    //Setting the blend first to have the potential in the red channel    
    gl_FragColor = vec4(blend, mixColor);

}{@}GetCorners.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uDataTexture;
uniform vec3 u3D;
uniform float uDepth;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

vec3 data[7];

vec2 index2D(vec3 pos) {
    return u3D.x * (pos.xz + u3D.y * vec2(mod(pos.y, u3D.z), floor(pos.y / u3D.z)) + vec2(0.5));
}

void main() {
    vec2 pos = floor(vUv / u3D.x);
    vec3 pos3D = vec3(mod(pos.y, u3D.y), u3D.z * floor(pos.y / u3D.y) + floor(pos.x / u3D.y), mod(pos.x, u3D.y));

    data[0] = vec3(-1., -1., -1.);
    data[1] = vec3(0., -1., -1.);
    data[2] = vec3(0., 0., -1.);
    data[3] = vec3(-1., 0., -1);
    data[4] = vec3(-1., -1., 0.);
    data[5] = vec3(0., -1., 0.);
    data[6] = vec3(-1., 0., 0.);

    float currentZLevel = floor(pos3D.y);
    vec2 uv  = index2D(pos3D);
    uv.y = fract(uv.y);
    vec4 corner = texture(uDataTexture, uv);

    vec3 newPos3D = vec3(0.);
    float zLevel = 0.;

    for(int i = 0; i < 7; i ++) {

        newPos3D = pos3D + data[i];
        zLevel = floor(newPos3D.y);
        uv = index2D(newPos3D);
        uv.y = fract(uv.y);

        vec4 newBucket = texture2D(uDataTexture, uv);
        corner += newBucket;

    }

    gl_FragColor = vec4(corner * 0.125);
}{@}ParticlesScattering.glsl{@}#!ATTRIBUTES

#!UNIFORMS

uniform vec3 u3D;
uniform sampler2D positionTexture;
uniform sampler2D colorsTexture;
uniform sampler2D tMin;
uniform sampler2D tMax;
uniform vec3 vMin;
uniform vec3 vMax;
uniform bool redoBBox;

uniform float uPhase;
uniform float uSize;

#!VARYINGS
varying vec4 vColor;

#!SHADER: Vertex

void main() {
        
    vec3 pos = texture2D(positionTexture, position.xy).rgb;

    vec3 padding = vec3(2./ u3D.y);

    vec3 minPosition = vMin;
    vec3 maxPosition = vMax;

    if(redoBBox) {
        minPosition = texture2D(tMin, vec2(0.5)).rgb - padding;
        maxPosition = texture2D(tMax, vec2(0.5)).rgb + padding;
    }

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);
    
    pos -= minPosition;
    pos /= s;
    
    
    vec3 gPP = floor(pos * u3D.y);
    gPP.y -= uPhase;

    vec2 gP = u3D.x * (gPP.zx + u3D.y * vec2(mod(gPP.y, u3D.z), floor(gPP.y / u3D.z)) + vec2(0.5));
    gP = 2. * gP - vec2(1.);


    vColor = vec4(texture2D(colorsTexture, position.xy).rgb, 1.);

    gl_PointSize = uSize;   
    gl_Position = vec4(gP, 0., 1.0);
}

#!SHADER: Fragment

void main() {

    gl_FragColor = vColor;

}
{@}SurfaceColorGenerator.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uStream;
uniform sampler2D uPot;
uniform sampler2D uTrianglesIndexes;
uniform sampler2D uTotal;
uniform sampler2D tMin;
uniform sampler2D tMax;
uniform vec3 vMin;
uniform vec3 vMax;
uniform bool redoBBox;
uniform float uRange;
uniform float uCompactSize;
uniform vec3 u3D;


#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

const float EPSILON = 0.00001;

vec2 index2D(vec3 pos) {
    return (pos.xz + u3D.y * vec2(mod(pos.y, u3D.z), floor(pos.y / u3D.z)) + vec2(0.5)) / u3D.x;
}

void main() {

    float vI = dot(floor(uCompactSize * vUv), vec2(1., uCompactSize));

    if(vI >= texture2D(uTotal, vec2(0.5)).r) discard;

    else {

        float p = 1. / u3D.y;
        vec3 p0 = vec3(p, 0., 0.);
        vec3 p1 = vec3(p, p, 0.);
        vec3 p2 = vec3(0., p, 0.);
        vec3 p3 = vec3(0., 0., p);
        vec3 p4 = vec3(p, 0., p);
        vec3 p5 = vec3(p, p, p);
        vec3 p6 = vec3(0., p, p);
    
        vec4 data = texture2D(uStream, vUv);

        float currentVertex = data.b;

        data.xyz = p * vec3(mod(data.y, u3D.y), u3D.z * floor(data.y * p) + floor(data.x * p), mod(data.x, u3D.y));
        
        float mcIndex = 15. * data.a + currentVertex;

        vec4 mcData = texture2D(uTrianglesIndexes, vec2(mod(mcIndex, 64.), floor(mcIndex / 64.)) / 64.);
        mcIndex = mcData.r;

        vec4 m0 = vec4(mcIndex);
        vec4 m1 = vec4(equal(m0, vec4(0., 1., 2., 3.)));
        vec4 m2 = vec4(equal(m0, vec4(4., 5., 6., 7.)));
        vec4 m3 = vec4(equal(m0, vec4(8., 9., 10., 11.)));

        vec3 b0 = data.rgb + m1.y * p0 + m1.z * p1 + m1.w * p2 + m2.x * p3 + m2.y * p4 + m2.z * p5 + m2.w * p6 + m3.y * p0 + m3.z * p1 + m3.w * p2;
        vec3 b1 = data.rgb + m1.x * p0 + m1.y * p1 + m1.z * p2 + m2.x * p4 + m2.y * p5 + m2.z * p6 + m2.w * p3 + m3.x * p3 + m3.y * p4 + m3.z * p5 + m3.w * p6;
        
        vec4 n0 = texture2D(uPot, index2D(u3D.y * b0));
        vec4 n1 = texture2D(uPot, index2D(u3D.y * b1));
        vec2 diff1 = vec2(uRange - n0.r, n1.r - n0.r);
        
        gl_FragColor = vec4((n0.r * n0.gba + n1.r * n1.gba) / max(n0.r + n1.r, EPSILON), 1.);
    
    }
    
}{@}Blur2DCompressed.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uDT;
uniform vec2 uAxis;
uniform int uSteps;
uniform vec3 u3D;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    
    float border = .1;
    
    vec4 blend = vec4(0.);
    float sum = 1.;
    float m = 1.;
    float n = float(uSteps);
    vec2 uv = vUv;

    vec2 pos = floor(uv / u3D.x);
    float zero = float(mod(pos.x, u3D.y) > border && mod(pos.y, u3D.y) > border && mod(pos.x, u3D.y) < u3D.y - 1. - border && mod(pos.y, u3D.y) < u3D.y - 1. - border);

    for (int i = 0; i < 50; i += 1) {

        if(i >= 2 * uSteps) break;

        float k = float(i);
        float j = float(i) - 0.5 * float(uSteps);
        blend +=  zero * m * texture2D(uDT, uv + j * uAxis.xy);
        m *= (n - k) / (k + 1.);
        sum += m;
    } 
    
    blend /= sum;
    blend *= zero;

    gl_FragColor = blend;
}{@}BlurDepthCompressed.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uDataTexture;
uniform int uSteps;
uniform float uDepth;
uniform vec3 u3D;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    
    float sum = 1.;
    float m = 1.;
    float n = float(uSteps);
    float border = .1;

    vec2 pos = floor(vUv / u3D.x);
    vec3 pos3D = vec3(mod(pos.y, u3D.y), u3D.z * floor(pos.y / u3D.y) + floor(pos.x / u3D.y), mod(pos.x, u3D.y));
    vec3 newPos3D = vec3(0.);
    vec2 uv = vec2(0.);
    vec4 blend = vec4(0.);
    float depthLevel = 0.;

    float currentDepthLevel = floor(pos3D.y / uDepth);

    float zero = float(mod(pos.x, u3D.y) > border && mod(pos.y, u3D.y) > border && mod(pos.x, u3D.y) < u3D.y - 1. - border && mod(pos.y, u3D.y) < u3D.y - 1. - border);

    for (int i = 0; i < 50; i += 1) {

        if(i >= 2 * uSteps) break;

        float j = float(i) - 0.5 * float(uSteps);
        float k = float(i);

        newPos3D = pos3D - j * vec3(0., 1., 0.);

        depthLevel = floor(newPos3D.y / uDepth);  

        uv = u3D.x * (newPos3D.xz + u3D.y * vec2(mod(newPos3D.y, u3D.z), floor(newPos3D.y / u3D.z)) + vec2(0.5));
        uv.y = fract(uv.y);

        vec4 newBucket = texture2D(uDataTexture, uv);

        vec3 cases = vec3(bvec3(depthLevel < currentDepthLevel, depthLevel == currentDepthLevel, depthLevel > currentDepthLevel));
        blend += zero * m * (vec4(0., newBucket.rgb) * cases.x + newBucket * cases.y + vec4(newBucket.gba, 0.) * cases.z);
        m *= (n - k) / (k + 1.);
        sum += m;
    }

    blend /= sum;

    blend *= zero;

    gl_FragColor = blend;
}{@}GetCornersCompressed.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uDataTexture;
uniform vec3 u3D;
uniform float uDepth;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment

vec3 data[7];

vec2 index2D(vec3 pos) {
    return u3D.x * (pos.xz + u3D.y * vec2(mod(pos.y, u3D.z), floor(pos.y / u3D.z)) + vec2(0.5));
}

void main() {
    vec2 pos = floor(vUv / u3D.x);
    vec3 pos3D = vec3(mod(pos.y, u3D.y), u3D.z * floor(pos.y / u3D.y) + floor(pos.x / u3D.y), mod(pos.x, u3D.y));

    data[0] = vec3(-1., -1., -1.);
    data[1] = vec3(0., -1., -1.);
    data[2] = vec3(0., 0., -1.);
    data[3] = vec3(-1., 0., -1);
    data[4] = vec3(-1., -1., 0.);
    data[5] = vec3(0., -1., 0.);
    data[6] = vec3(-1., 0., 0.);

    float currentZLevel = floor(pos3D.y / uDepth);
    vec2 uv  = index2D(pos3D);
    uv.y = fract(uv.y);
    vec4 corner = texture(uDataTexture, uv);

    vec3 newPos3D = vec3(0.);
    float zLevel = 0.;

    for(int i = 0; i < 7; i ++) {

        newPos3D = pos3D + data[i];
        zLevel = floor(newPos3D.y / uDepth);
        uv = index2D(newPos3D);
        uv.y = fract(uv.y);

        vec4 newBucket = texture2D(uDataTexture, uv);
        vec3 cases = vec3(bvec3(zLevel < currentZLevel, zLevel == currentZLevel, zLevel > currentZLevel));
        corner += vec4(0., newBucket.rgb) * cases.x + newBucket * cases.y + vec4(newBucket.gba, 0.) * cases.z;

    }

    gl_FragColor = vec4(corner * 0.125);
}{@}ParticlesScatteringCompressed.glsl{@}#!ATTRIBUTES

#!UNIFORMS

uniform vec3 u3D;
uniform sampler2D positionTexture;
uniform sampler2D tMin;
uniform sampler2D tMax;
uniform vec3 vMin;
uniform vec3 vMax;
uniform bool redoBBox;

uniform float uPhase;
uniform float uSize;

#!VARYINGS
varying vec4 vColor;

#!SHADER: Vertex

void main() {
        
    vec3 pos = texture2D(positionTexture, position.xy).rgb;

    vec3 padding = vec3(2./ u3D.y);

    vec3 minPosition = vMin;
    vec3 maxPosition = vMax;

    if(redoBBox) {
        minPosition = texture2D(tMin, vec2(0.5)).rgb - padding;
        maxPosition = texture2D(tMax, vec2(0.5)).rgb + padding;
    }

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);
    
    pos -= minPosition;
    pos /= s;
    
    
    vec3 gPP = floor(pos * u3D.y);
    gPP.y -= uPhase;

    vec2 gP = u3D.x * (gPP.xz + u3D.y * vec2(mod(gPP.y, u3D.z), floor(gPP.y / u3D.z)) + vec2(0.5));
    float depthLevel = floor(gP.y);
    gP.y = fract(gP.y);
    gP = 2. * gP - vec2(1.);


    vColor = vec4(equal(vec4(depthLevel), vec4(0., 1., 2., 3.)));

    gl_PointSize = uSize;   
    gl_Position = vec4(gP, 0., 1.0);
}

#!SHADER: Fragment

void main() {

    vec2 uv = vec2(gl_PointCoord.x, 1.0 - gl_PointCoord.y);
    float alpha = smoothstep(0.5, 0.499, length(uv-0.5));

    if(alpha < .5) discard;    

    gl_FragColor = vColor;

}
{@}SplitChannels.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D uDataTexture;
uniform vec3 u3D_h;
uniform vec3 u3D_l;
uniform float uDepth;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {

    vec2 pos = floor(vUv / u3D_h.x);
    vec3 pos3D = vec3(mod(pos.y, u3D_h.y), u3D_h.z * floor(pos.y / u3D_h.y) + floor(pos.x / u3D_h.y), mod(pos.x, u3D_h.y));

    float zLevel = floor(pos3D.y / uDepth);
    vec2 uv  = u3D_l.x * (pos3D.zx + u3D_l.y * vec2(mod(pos3D.y, u3D_l.z), floor(pos3D.y / u3D_l.z)) + vec2(0.5));
    uv.y = fract(uv.y);

    gl_FragColor = vec4(dot(texture(uDataTexture, uv), vec4(equal(vec4(zLevel), vec4(0., 1., 2., 3.))))); 
       
}{@}Accumulator.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tData;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = position;
    //gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    gl_Position = vec4(position.xy, 0., 1.);
}

#!SHADER: Fragment
void main() {
    gl_FragColor = texture2D(tData, vUv);
    //gl_FragColor = vec4(1. / 100.);
}{@}BoundingBox.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMin;
uniform sampler2D tMax;
uniform vec4 lightOrientation;

#!VARYINGS
varying vec4 vColor;

#!SHADER: Vertex

vec3 rotateVector( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}

void main() {
    vec3 pos = position;

    vec3 minPosition = texture2D(tMin, vec2(0.5)).rgb;
    vec3 maxPosition = texture2D(tMax, vec2(0.5)).rgb;

    vec4 or = lightOrientation;
    or.xyz *= -1.;
    minPosition = rotateVector(or, minPosition);
    maxPosition = rotateVector(or, maxPosition);

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);
    pos *= s;

    pos += minPosition + vec3(scale * 0.5);

    vColor = mix(vec4(1., 0., 0., 1.), vec4(1., 1., 1., 1.), vec4(position.y + 0.5));

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment

void main() {
    gl_FragColor = vColor;
}{@}ParticlesVolume.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform float uScattering;
uniform float shadowSize;
uniform vec4 lightOrientation;
uniform vec3 voxelData;
uniform sampler2D positionTexture;
uniform sampler2D tMin;
uniform sampler2D tMax;

uniform float autoBB;
uniform vec3 bbMin;
uniform vec3 bbMax;

#!VARYINGS

#!SHADER: Vertex

vec3 rotateVector( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}

void main() {
        
    vec3 pos = texture(positionTexture, position.xy).rgb;

    pos = rotateVector(lightOrientation, pos);

    vec3 minPosition = bbMin;
    vec3 maxPosition = bbMax;

    if(autoBB > 0.5) {
        minPosition = texture2D(tMin, vec2(0.5)).rgb;
        maxPosition = texture2D(tMax, vec2(0.5)).rgb;
    }

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);

    pos -= minPosition;
    pos /= s;


    vec3 gridPosition = floor(voxelData.y * pos);

    vec2 voxelPosition =  2. * (gridPosition.xz + voxelData.y * vec2(mod(gridPosition.y, voxelData.x), floor(gridPosition.y / voxelData.x)) + vec2(0.5)) / voxelData.z - vec2(1.);

    gl_PointSize = shadowSize;
    
    gl_Position = vec4(voxelPosition, 0., 1.0);
}

#!SHADER: Fragment

void main() {

    gl_FragColor = vec4(vec3(1./ max(1., uScattering * voxelData.y)), 1.);

}
