#!SHADER: Vertex
#require(rotation.glsl)
void main() {
    vec3 pos = position;
    // pos = vec3( rotationMatrix(vec3(1.0, 0.0, 0.0), sin(pos.x * 0.04 + time - pos.y * 0.03) * 0.2) * vec4(pos, 1.0));

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;
    vN = normal;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;;
    vV = worldPos.xyz - cameraPosition;
    vUv = uv * uTiling;
    vUv2 = uv2;
    vFog = smoothstep(25.0, 150.0, -modelViewPos.z);
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N) {
    float roughness = clamp(MRO.y + uERON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uERON.z);
    vec3 diffuse = pow(textureCube(tCubeDiffuse, N, 12.0).rgb, vec3(2.2)) * 2.0;
    // vec3 diffuse = pow(textureCube(tCube, N, 12.0).rgb, vec3(2.2)) * 2.0;
    float brdf = envBRDFApproxNonmetal(roughness, NdV);
    vec3 lightmap = vec3(1.0);

    if (uUseLightmap > 0.0) {
        lightmap = texture2D(tLightmap, vUv2).rgb;
        lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
        lightmap.rgb *= uLightmapIntensity;
    }

    diffuse *= baseColor.rgb;
    diffuse *= pow(uTint, vec3(2.2));

    float lod = roughness * 8.0;
    vec3 specular = pow(textureCube(tCube, R, lod).rgb, vec3(2.2));
    vec4 result = vec4(mix(diffuse * uEnv.x, specular, brdf) * ao, 1.0);
    result.rgb *= lightmap.rgb;
    return result;
}

void main() {
    vec2 uv = vUv;
    vec3 N = normalize(vWorldNormal);
    vec3 V = normalize(vV);
    vec3 unpackedNormal = unpackNormal(V, N, tNormal, uERON.w, 1.0, uv).xyz;
    vec3 R = reflect(V, unpackedNormal);
    float NdV = abs(dot(unpackedNormal, V));
    vec4 MRO = texture2D(tMRO, uv);
    vec4 baseColor = texture2D(tBaseColor, uv);
    baseColor.rgb = pow(baseColor.rgb, vec3(2.2));
    vec4 color = getIBLContribution(NdV, baseColor, MRO, R, V, unpackedNormal);
    vec3 emissive = baseColor.rgb * MRO.r * uERON.r;
    color.rgb += emissive;
    color.rgb = unreal(color.rgb);

    // fog
    // vec3 fogColor = textureCube(tCubeDiffuse, V, 12.0).rgb * 0.2;
    // color.rgb = mix(color.rgb, fogColor, vFog);
    // color.rgb += emissive * 0.5;

    gl_FragColor = color;
}{@}MobileWaterShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tNormal;
uniform samplerCube tCube;
uniform samplerCube tCubeDiffuse;
uniform sampler2D tLightmap;
uniform float uUseLightmap;
uniform float uLightmapIntensity;
uniform vec3 uTint;
uniform vec4 uERON;
uniform vec2 uEnv;
uniform vec2 uTiling;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vN;
varying vec3 vV;
varying vec3 vWorldNormal;
varying float vFog;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;
    vN = normal;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;;
    vV = worldPos.xyz - cameraPosition;
    vUv = uv * uTiling;
    vUv2 = uv2;
    vFog = smoothstep(25.0, 200.0, -modelViewPos.z);
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N) {
    float roughness = clamp(MRO.y + uERON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uERON.z);
    vec3 diffuse = vec3(1.0);
    float brdf = envBRDFApproxNonmetal(roughness, NdV);
    vec3 lightmap = vec3(1.0);

    if (uUseLightmap > 0.0) {
        lightmap = texture2D(tLightmap, vUv2).rgb;
        lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
        lightmap.rgb *= uLightmapIntensity;
    }

    diffuse *= baseColor.rgb;
    // diffuse *= 0.5;
    diffuse *= pow(uTint, vec3(2.2));

    float lod = roughness * 8.0;
    vec3 specular = pow(textureCube(tCube, R, lod).rgb, vec3(2.2));
    vec4 result = vec4(mix(diffuse * uEnv.x, specular * uEnv.y, brdf) * ao, 1.0);
    result.rgb *= lightmap.rgb;
    return result;
}

void main() {
    vec2 uv = vUv;
    vec3 N = normalize(vWorldNormal);
    vec3 V = normalize(vV);
    float t = time * 0.1;
    vec3 unpackedNormal = unpackNormal(V, N, tNormal, uERON.w, 1.0, uv + vec2(t, t * 0.4)).xyz;
    unpackedNormal += unpackNormal(V, N, tNormal, uERON.w, 1.0, (uv ) * 2.0 + vec2(t, t * 0.3)).xyz;
    unpackedNormal += unpackNormal(V, N, tNormal, uERON.w, 2.0, (uv ) * 0.1 + vec2(t, t * 0.1) * 0.2).xyz;
    unpackedNormal *= 0.333;
    vec3 R = reflect(V, unpackedNormal);
    float NdV = abs(dot(unpackedNormal, V));
    vec4 MRO = vec4(0.0, 0.0, 1.0, 1.0);
    vec4 baseColor = vec4(1.0);
    vec4 color = getIBLContribution(NdV, baseColor, MRO, R, V, unpackedNormal);
    // vec3 emissive = baseColor.rgb * MRO.r * uERON.r;
    // color.rgb += emissive;
    color.rgb = unreal(color.rgb);

    // fog
    // vec3 fogColor = mix(textureCube(tCubeDiffuse, V, 12.0).rgb * 0.5, vec3(1.0, 0.0, 0.0), 0.5);
    // color.rgb = mix(color.rgb, fogColor, vFog);
    // color.rgb += emissive * 0.5;

    gl_FragColor = color;
    gl_FragColor.a = 1.0;
}{@}SkyTextureShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform samplerCube tCubeDiffuse;
uniform sampler2D tMap;
uniform vec2 uTiling;
uniform float uBrightness;
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec2 uRange;

#!VARYINGS
varying vec2 vUv;
varying vec3 vEye;
varying vec3 vN;
varying vec3 vColor1;
varying vec3 vColor2;
varying vec3 vPos;
varying float vFog;

#!SHADER: Vertex
void main() {
    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    vec4 modelViewPos = modelViewMatrix * vec4(position, 1.0);
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vEye = normalize(worldPos.xyz - cameraPosition);
    vN = normalize(worldPos.xyz);
    vColor1 = pow(uColor1, vec3(2.2));
    vColor2 = pow(uColor2, vec3(2.2));
    vPos = position;
    // vFog = smoothstep(25.0, 200.0, -modelViewPos.z) * clamp(1.0 - worldPos.y, 0.0, 1.0);
}

#!SHADER: Fragment
float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    vec4 color = textureCube(tCubeDiffuse, vN, 11.0 + rand(vUv + fract(time))) * uBrightness;
    float gradient = pow(smoothstep(uRange.x, uRange.y, vPos.y), 2.2);
    gradient *= pow(smoothstep(-0.2, 0.2, vPos.y), 2.0);
    color.rgb += pow(mix(vColor1, vColor2, gradient), vec3(0.45));
    // color.rgb = mix(color.rgb, mix(color.rgb, vec3(1.0, 0.0, 0.0) * 0.3, 0.5), vFog);
    gl_FragColor = color;
}{@}SplineParticleShader.glsl{@}#!ATTRIBUTES
attribute vec3 lookup;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;
uniform sampler2D tDisplacementAnimation;
uniform float uScale;
uniform float uVelScale;

#!VARYINGS
varying vec3 vNormal;

#!SHADER: Vertex
#require(VAT.glsl)

vec3 transformTowardsVector(vec3 from, vec3 to) {
    vec3 pos = from;
    vec3 dir = normalize(to);

    // rotate up/down
    float a = dir.y;
    float s = sin(a);
	float c = cos(a);
	mat2 m = mat2(c, -s, s, c);
    pos.yz = m * pos.yz;

    // rotate around y axis
    float a2 = atan(dir.x, dir.z);
    float s2 = sin(a2);
	float c2 = cos(a2);
	mat2 m2 = mat2(c2, -s2, s2, c2);
    pos.xz = m2 * pos.xz;

    return pos;
}

void main() {
    vec3 localpos = position;

    // Get particle velocity
    vec3 offset = texture2D(tPos, lookup.xy).xyz;
    vec3 prevOffset = texture2D(tPrevPos, lookup.xy).xyz;
    vec3 vel = offset - prevOffset;

    // Get animated displacement
    float displacementStrength = clamp(length(vel) * uVelScale, 0.0, 1.0);
    vec3 displacement = getInterpolatedTexture(tDisplacementAnimation, vec2(uv2.x, lookup.x + time * 1.2), 29.0).rgb;
    vec3 displacedPos = localpos + displacement * displacementStrength;

    // Transform normals and vertices
    // localpos = transformTowardsVector(displacedPos, vel);
    localpos = transformTowardsVector(localpos, vel);
    vNormal = transformTowardsVector(normal, vel);
    
    vec3 off = offset;
    off.y = 0.0;
    vec3 pos = localpos * uScale + offset;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    // A dot product calculation, normalized to the 0 -> 1 range, with a pow()
    // added for more realistic falloff.
    float lighting = pow(dot(vNormal, vec3(0.5, 0.5, 0.0)) * 0.5 + 0.5, 2.0);
    float ambient = 0.1;
    lighting += ambient;

    gl_FragColor = vec4(lighting);
}{@}VerticalMarqueeShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uSpeed;
uniform vec2 uTiling;
uniform vec2 uScrollDir;
uniform vec3 uColor;
uniform float uBrightness;
uniform float uFade;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUvOriginal;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv * uTiling;
    vUv += time * uSpeed * uScrollDir;
    vUvOriginal = uv;
}

#!SHADER: Fragment
void main() {
    float mask = texture2D(tMap, vUv).r * pow(vUvOriginal.y, uFade);
    gl_FragColor = vec4(uColor * uBrightness, mask);
}{@}LayeredMotionVectorShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tFrontAlpha;
uniform sampler2D tMap;
uniform sampler2D tMotion;
uniform sampler2D tMapBack;
uniform sampler2D tMotionBack;
uniform float uProgress;
uniform float uBlend;
uniform float uGridSize;
uniform float uDisplacementStrength;
uniform float uDisplacementStrengthBack;

uniform sampler2D glass_tMap;
uniform float glass_uGridSize;
uniform float glass_uDisplacementStrength;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
#require(range.glsl)

vec2 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

vec2 remap(vec2 _displacement, float _strength) {
    vec2 displacement;
    displacement.r = crange(_displacement.r, 0.0, 1.0, -1.0, 1.0);
    displacement.g = crange(_displacement.g, 0.0, 1.0, -1.0, 1.0);
    return displacement * _strength;
}

void main() {
    // watch front
    float MAX_INDEX = uGridSize * uGridSize - 1.0;
    float index = crange(uProgress, 0.0, 1.0, 1.0, MAX_INDEX);

    float blend = fract(index);

    vec2 subUv = getSubUV(tMap, vec2(uGridSize), vUv, index);
    vec2 subUvNext = getSubUV(tMap, vec2(uGridSize), vUv, index + 1.0);

    // blend from one frame to the next
    vec2 displacement = texture2D(tMotion, subUv).rg;
    displacement = remap(displacement, uDisplacementStrength);

    vec2 displacementNext = texture2D(tMotion, subUvNext).rg;
    displacementNext = remap(displacementNext, uDisplacementStrength);

    vec3 color = texture2D(tMap, subUv - displacement * blend).rgb;
    vec3 colorNext = texture2D(tMap, subUvNext + displacementNext * (1.0 - blend)).rgb;
    color = mix(color, colorNext, blend);

    vec3 rawColor = texture2D(tMap, subUv).rgb;
    color = mix(color, rawColor, uBlend);

    vec3 alpha = texture2D(tFrontAlpha, subUv - displacement * blend).rgb;
    vec3 alphaNext = texture2D(tFrontAlpha, subUvNext + displacementNext * (1.0 - blend)).rgb;
    alpha = mix(alpha, alphaNext, blend);

    // watch back
    subUv = getSubUV(tMap, vec2(uGridSize), vUv, index);
    subUvNext = getSubUV(tMap, vec2(uGridSize), vUv, index + 1.0);

    // blend from one frame to the next
    displacement = texture2D(tMotionBack, subUv).rg;
    displacement = remap(displacement, uDisplacementStrengthBack);

    displacementNext = texture2D(tMotionBack, subUvNext).rg;
    displacementNext = remap(displacementNext, uDisplacementStrengthBack);

    vec3 backColor = texture2D(tMapBack, subUv - displacement * blend).rgb;
    vec3 backColorNext = texture2D(tMapBack, subUvNext + displacementNext * (1.0 - blend)).rgb;
    backColor = mix(backColor, backColorNext, blend);

    // compositing
    color += backColor * (1.0 - alpha);

    // glass layer
    float GLASS_MAX_INDEX = glass_uGridSize * glass_uGridSize - 1.0;
    float glass_index = crange(uProgress + 0.05, 0.0, 1.0, 1.0, GLASS_MAX_INDEX);

    float glass_blend = fract(glass_index);

    vec2 glass_subUv = getSubUV(tMap, vec2(glass_uGridSize), vUv, glass_index);
    vec2 glass_subUvNext = getSubUV(tMap, vec2(glass_uGridSize), vUv, glass_index + 1.0);

    // blend from one frame to the next
    vec3 glass_color = texture2D(glass_tMap, glass_subUv).rgb;
    vec3 glass_colorNext = texture2D(glass_tMap, glass_subUvNext).rgb;
    glass_color = mix(glass_color, glass_colorNext, glass_blend);

    color = pow(color, vec3(2.2));
    glass_color = pow(glass_color, vec3(2.2));
    color += glass_color;
    color = pow(color, vec3(0.45));

    // color = glass_color;

    gl_FragColor = vec4(color, 1.0);
}{@}MotionVecShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMotion;
uniform float uProgress;
uniform float uBlend;
uniform float uGridSize;
uniform float uDisplacementStrength;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
#require(range.glsl)

vec2 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

vec2 remap(vec2 _displacement) {
    vec2 displacement;
    displacement.r = crange(_displacement.r, 0.0, 1.0, -1.0, 1.0);
    displacement.g = crange(_displacement.g, 0.0, 1.0, -1.0, 1.0);
    return displacement * uDisplacementStrength;
}

void main() {
    float MAX_INDEX = uGridSize * uGridSize - 1.0;
    float index = crange(uProgress, 0.0, 1.0, 1.0, MAX_INDEX);

    float blend = fract(index);

    vec2 subUv = getSubUV(tMap, vec2(uGridSize), vUv, index);
    vec2 subUvNext = getSubUV(tMap, vec2(uGridSize), vUv, index + 1.0);

    // blend from one frame to the next
    vec2 displacement = texture2D(tMotion, subUv).rg;
    displacement = remap(displacement);

    vec2 displacementNext = texture2D(tMotion, subUvNext).rg;
    displacementNext = remap(displacementNext);

    vec3 color = texture2D(tMap, subUv - displacement * blend).rgb;
    vec3 colorNext = texture2D(tMap, subUvNext + displacementNext * (1.0 - blend)).rgb;
    color = mix(color, colorNext, blend);

    vec3 rawColor = texture2D(tMap, subUv).rgb;
    color = mix(color, rawColor, uBlend);

    gl_FragColor = vec4(color, 1.0);
}{@}MotionVectorShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMotion;
uniform float uProgress;
uniform float uBlend;
uniform vec2 uMouse;
uniform float uSlideMulti;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vPos = pos;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
#require(range.glsl)
#require(blendmodes.glsl)
#require(rgb2hsv.fs)

vec2 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

// float crange(float oldValue, float oldMin, float oldMax, float newMin, float newMax) {
//     return clamp(range(oldValue, oldMin, oldMax, newMin, newMax), min(newMin, newMax), max(newMin, newMax));
// }

vec4 sharpen(in sampler2D tex, in vec2 coords, in vec2 renderSize) {
  float dx = 1.0 / renderSize.x;
  float dy = 1.0 / renderSize.y;
  vec4 sum = vec4(0.0);
  sum += -1. * texture2D(tex, coords + vec2( -1.0 * dx , 0.0 * dy));
  sum += -1. * texture2D(tex, coords + vec2( 0.0 * dx , -1.0 * dy));
  sum += 5. * texture2D(tex, coords + vec2( 0.0 * dx , 0.0 * dy));
  sum += -1. * texture2D(tex, coords + vec2( 0.0 * dx , 1.0 * dy));
  sum += -1. * texture2D(tex, coords + vec2( 1.0 * dx , 0.0 * dy));
  return sum;
}

vec2 remap(vec2 _displacement, float _multiply) {
    vec2 displacement;
    displacement.r = crange(_displacement.r, 0.0, 1.0, -1.0, 1.0);
    displacement.g = crange(_displacement.g, 0.0, 1.0, -1.0, 1.0);
    // return displacement * 0.008;
    return displacement * 0.002 * _multiply * uSlideMulti;
}

void main() {
    float index = crange(uProgress, 0.0, 1.0, 1.0, 15.0);
    // index = clamp(index, 1.0, 15.0);

    float blend = fract(index);

    vec2 subUv = getSubUV(tMap, vec2(4.0), vUv, index);
    vec2 subUvNext = getSubUV(tMap, vec2(4.0), vUv, index + 1.0);

    // blend from one frame to the next
    vec2 displacement = sharpen(tMotion, subUv, resolution).rg;
    displacement = remap(displacement, 1.0);

    vec2 displacementNext = sharpen(tMotion, subUvNext, resolution).rg;
    displacementNext = remap(displacementNext, 1.0);

    vec3 color = texture2D(tMap, subUv - displacement * blend).rgb;
    vec3 colorNext = texture2D(tMap, subUvNext + displacementNext * (1.0 - blend)).rgb;
    color = mix(color, colorNext, blend);

    vec3 rawColor = texture2D(tMap, subUv).rgb;
    color = mix(color, rawColor, uBlend);

    //color = color + pow(color, vec3(3.0));

    float blendMouse = smoothstep(0.6, 0.0, length(uMouse-vPos.xy));
    blendMouse *= 0.8 + sin(time*10.0 + time*4.0) * 0.01;
    blendMouse *= 0.8;

    //color = blendOverlay(color, vec3(1.0, 0.0, 0.0), blendMouse);

    if (rgb2hsv(color).z < 0.05) discard;

    float alpha = 1.0;//smoothstep(0.001, 0.05, rgb2hsv(color).z);

    gl_FragColor = vec4(color, alpha);
}{@}RTFKTMotionVectorShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMotion;
uniform sampler2D tDepth;
uniform float uProgress;
uniform float uBlend;
uniform vec2 uMouse;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vPos = pos;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
#require(range.glsl)
#require(blendmodes.glsl)
#require(rgb2hsv.fs)
#require(simplenoise.glsl)

vec2 getSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

// float crange(float oldValue, float oldMin, float oldMax, float newMin, float newMax) {
//     return clamp(range(oldValue, oldMin, oldMax, newMin, newMax), min(newMin, newMax), max(newMin, newMax));
// }

vec4 sharpen(in sampler2D tex, in vec2 coords, in vec2 renderSize) {
  float dx = 1.0 / renderSize.x;
  float dy = 1.0 / renderSize.y;
  vec4 sum = vec4(0.0);
  sum += -1. * texture2D(tex, coords + vec2( -1.0 * dx , 0.0 * dy));
  sum += -1. * texture2D(tex, coords + vec2( 0.0 * dx , -1.0 * dy));
  sum += 5. * texture2D(tex, coords + vec2( 0.0 * dx , 0.0 * dy));
  sum += -1. * texture2D(tex, coords + vec2( 0.0 * dx , 1.0 * dy));
  sum += -1. * texture2D(tex, coords + vec2( 1.0 * dx , 0.0 * dy));
  return sum;

  return texture2D(tex, coords + vec2( -1.0 * dx , 0.0 * dy));

}

vec2 remap(vec2 _displacement) {
    vec2 displacement;
    displacement.r = crange(_displacement.r, 0.0, 1.0, -1.0, 1.0);
    displacement.g = crange(_displacement.g, 0.0, 1.0, -1.0, 1.0);
    // return displacement * 0.008;
    return displacement * 0.02;
}

void main() {
    float index = crange(uProgress, 0.0, 1.0, 1.0, 15.0);
    // index = clamp(index, 1.0, 15.0);

    float blend = fract(index);

    vec2 subUv = getSubUV(tMap, vec2(4.0), vUv, index);
    vec2 subUvNext = getSubUV(tMap, vec2(4.0), vUv, index + 1.0);

    // blend from one frame to the next
    vec2 displacement = texture2D(tMotion, subUv).rg;
    displacement = remap(displacement);

    vec2 displacementNext = texture2D(tMotion, subUvNext).rg;
    displacementNext = remap(displacementNext);

    vec3 color = texture2D(tMap, subUv - displacement * blend).rgb;
    vec3 colorNext = texture2D(tMap, subUvNext + displacementNext * (1.0 - blend)).rgb;
    color = mix(color, colorNext, blend);

    vec3 rawColor = texture2D(tMap, subUv).rgb;
    vec3 rawColorNext = texture2D(tMap, subUvNext).rgb;
    rawColor = mix(rawColor, rawColorNext, blend);

    color = mix(color, rawColor, uBlend);

    float depth = texture2D(tDepth, subUv - displacement * blend).r;
    float depthNext = texture2D(tDepth, subUvNext + displacementNext * (1.0 - blend)).r;
    depth = mix(depth, depthNext, blend);
    //depth += cnoise(vec3(depth * 100.0) + time * 0.2) * 0.01;
    //depth = smoothstep(0.1, 0.8, depth);
    float mouseDepth = 0.65 + uMouse.x * 0.1;
    float padding = 0.1;
    //color += smoothstep(mouseDepth, mouseDepth + padding, depth);
    float wave = mouseDepth;
    float depthWave = smoothstep(wave-0.002, wave, depth) * smoothstep(wave + 0.002, wave, depth);
    depthWave *= smoothstep(0.0, 0.3, abs(depth) - 0.5);
    depthWave *= 0.5 + sin(time + uMouse.y + vPos.y * 20.0) * 0.5;
    //color += depthWave;
    //color = blendOverlay(color, vec3(1.0, 0.0, 0.0), depthWave);


    //color = color + pow(color, vec3(3.0));
    //color = blendOverlay(color, vec3(1.0, 0.0, 0.0), blendMouse);

    if (rgb2hsv(color).z < 0.05) discard;

    gl_FragColor = vec4(color, 1.0);
