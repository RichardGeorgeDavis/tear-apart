{@}YoomVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)
#require(rgbshift.fs)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 hueShift(vec3 color, float hue) {
    const vec3 k = vec3(0.57735, 0.57735, 0.57735);
    float cosAngle = cos(hue);
    return vec3(color * cosAngle + cross(k, color) * sin(hue) + k * dot(k, color) * (1.0 - cosAngle));
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}


void main() {
    vec4 color = texture2D(tDiffuse, vUv);
    // vec4 color = getRGB(tDiffuse, vUv, 0.1, 0.0008);

    vec3 bloom = getUnrealBloom(vUv).rgb;

    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb += pow(bloom, vec3(3.0));

    color.rgb = pow(color.rgb, vec3(0.45));

    // color.rgb -= 0.5;
    // color.rgb *= 1.05;
    // color.rgb += 0.5;


    color.rgb += rand(vUv + fract(time)) * 0.075;

  gl_FragColor = color;
  gl_FragColor.a = 1.0;
}{@}Noise3DTest.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec4 indices;
uniform float uScaler;

#!VARYINGS

#!SHADER: Vertex

void main() {
    gl_Position = vec4(position, 1.0);
}

#!SHADER: Fragment

#require(perlin3d.glsl)

layout(location=0) out vec4 data0;
layout(location=1) out vec4 data1;
layout(location=2) out vec4 data2;
layout(location=3) out vec4 data3;

vec3 sdSphere(vec3 pos) {
    return vec3( length(pos - vec3(uScaler * 0.5)) / uScaler - 0.3);
}

void main() {


    vec2 xy = gl_FragCoord.xy;

    data0 = vec4( sdSphere( vec3(xy, indices.x) ), 1.);
    data1 = vec4( sdSphere( vec3(xy, indices.y) ), 1.);
    data2 = vec4( sdSphere( vec3(xy, indices.z) ), 1.);
    data3 = vec4( sdSphere( vec3(xy, indices.w) ), 1.);

    float scaler = uScaler * 0.1;
    xy /= scaler;

   // xy.xy += time;

    float amp = 0.;
    data0 += amp * vec4( vec3( cnoise( vec3(xy, indices.x / scaler) ) * 0.5 + 0.5 ), 1.);
    data1 += amp * vec4( vec3( cnoise( vec3(xy, indices.y / scaler) ) * 0.5 + 0.5 ), 1.);
    data2 += amp * vec4( vec3( cnoise( vec3(xy, indices.z / scaler) ) * 0.5 + 0.5 ), 1.);
    data3 += amp * vec4( vec3( cnoise( vec3(xy, indices.w / scaler) ) * 0.5 + 0.5 ), 1.);


}
{@}RayMarchingShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler3D tData;
uniform vec4 orientation;


#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex.vs

void main() {
    vUv = uv;
    gl_Position = vec4(position, 1.);

}


#!SHADER: Fragment.fs

const int MAX_MARCHING_STEPS = 100;
const float MIN_DIST = 0.0;
const float MAX_DIST = 2.;
const float EPSILON = 0.01;

//Orientation function used to rotate the view relative to the camera.
vec3 orientate( vec4 quat, vec3 vec) {
    return  vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}


//Ray box intersection function
 float boxRay(vec3 ro, vec3 rd, vec3 boxmin, vec3 boxmax) {
    vec3 invR = 1. / rd;
    vec3 tbot = invR * (boxmin - ro);
    vec3 ttop = invR * (boxmax - ro);
    vec3 tmin = min(ttop, tbot);
    vec3 tmax = max(ttop, tbot);
    vec2 t0 = max(tmin.xx, tmin.yz);
    float tnear = max(t0.x, t0.y);
    t0 = min(tmax.xx, tmax.yz);
    float tfar = min(t0.x, t0.y);
    if( tnear > tfar || tfar < 0.0) return -1.;
    return tnear;
  }


float sceneSDF(vec3 samplePoint) {

    return textureLod(tData, samplePoint + vec3(0.5), (4. * (sin(time) * 0.5 + 0.5 ))  ).r;

}


//Mapping function used for raymarching
float map(vec3 eye, vec3 marchingDirection, float start, float end) {
    
    float depth = start;

    for (int i = 0; i < MAX_MARCHING_STEPS; i++) {
       
        float dist = sceneSDF(eye + depth * marchingDirection);

        if ((dist) < EPSILON) {
			return depth;
        }

        depth += dist;

        if (depth >= end) {
            return end;
        }
        
    }
    return end;
}



vec3 calcNormal(vec3 p) {
    float eps = 0.02;
    return normalize(vec3(
        sceneSDF(vec3(p.x + eps, p.y, p.z)) - sceneSDF(vec3(p.x - eps, p.y, p.z)),
        sceneSDF(vec3(p.x, p.y + eps, p.z)) - sceneSDF(vec3(p.x, p.y - eps, p.z)),
        sceneSDF(vec3(p.x, p.y, p.z + eps)) - sceneSDF(vec3(p.x, p.y, p.z - eps))
    ));
}


void main() {

    gl_FragColor = vec4(0.);


    //Generate a ray with the caamera orientation.
    vec2 xy = (2.0 * gl_FragCoord.xy - resolution.xy)/resolution.y;
    vec4 conj = orientation;

    float z = resolution.y / tan(radians(35.) / 2.0);
    vec3 dir =  normalize(vec3(xy, z / resolution.y));
    dir = normalize(dir);

    vec3 eye = vec3(0.0, 0.0, -length(cameraPosition));

    eye = orientate(orientation, eye);
    dir = orientate(orientation, dir);

    //Find the collision point between the ray and the bounding box of the texture
    //this discard fragments that won't contribute (rendered in white)
    float t = boxRay(eye, dir, vec3(-0.5), vec3(0.5));

    if(t == -1.) {

        //Case where there's no intersection with the bounding box
        gl_FragColor = vec4(.0);
		return;
    } 


    //If there's an intersection the new starting point is used
    //as the initial point of the distance field.
    vec3 position3D = eye + t * dir;;
    float dist = map(position3D, dir, MIN_DIST, MAX_DIST);

    if(dist >= MAX_DIST - EPSILON) {
        gl_FragColor = vec4(0.);
        return;
    }

    //Renders the position found.
    position3D += dir * dist ;

    vec3 normal = calcNormal(position3D);

    vec3 lightVector = vec3(0., 1., 0.);
    //lightVector = orientate(orientation, lightVector);

    vec3 color = vec3( dot(normal, lightVector)) * 0.8 + 0.1;
    gl_FragColor = vec4(color * 0.5 + 0.5, 1.);




}{@}RaymarchFunctions.glsl{@}
//================================================
//Helper functions
//================================================


vec3 orientate( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}



float Fresnel(in vec3 incom, in vec3 normal, in float index_internal, in float index_external) {
 	float eta = index_internal / index_external;
 	float cos_theta1 = dot(incom, normal);
 	float cos_theta2 = 1.0 - (eta * eta) * (1.0 - cos_theta1 * cos_theta1);

 	if (cos_theta2 < 0.0)
 	{
 		return 1.0;
 	}
 	else
 	{
 		cos_theta2 = sqrt(cos_theta2);
 		float fresnel_rs = (index_internal * cos_theta1 - index_external * cos_theta2) / (index_internal * cos_theta1 + index_external * cos_theta2);
 		float fresnel_rp = (index_internal * cos_theta2 - index_external * cos_theta1) / (index_internal * cos_theta2 + index_external * cos_theta1);
 		return (fresnel_rs * fresnel_rs + fresnel_rp * fresnel_rp) * 0.5;
 	}
}


 float boxRay(vec3 ro, vec3 rd, vec3 boxmin, vec3 boxmax) {
    vec3 invR = 1. / rd;
    vec3 tbot = invR * (boxmin - ro);
    vec3 ttop = invR * (boxmax - ro);
    vec3 tmin = min(ttop, tbot);
    vec3 tmax = max(ttop, tbot);
    vec2 t0 = max(tmin.xx, tmin.yz);
    float tnear = max(t0.x, t0.y);
    t0 = min(tmax.xx, tmax.yz);
    float tfar = min(t0.x, t0.y);
    if( tnear > tfar || tfar < 0.0) return -1.;
    return tnear;
}



bool planeIntersect(vec3 rayOrigin, vec3 rayDirection, vec3 planeNormal, float d, out float param) {
    param = -1.;
    float ang = dot(rayDirection, planeNormal);
    if(ang > EPSILON || ang == 0.) return false;
    param = -(dot(rayOrigin, planeNormal) - d) / ang;
    return param >= 0.;
}


vec2 sampleFlatMap(vec3 v) {
    float s = atan(v.z, v.x) / PI;
    float t = 2. * asin(v.y) / PI;
    return vec2(s, t) * 0.5 + 0.5;
}


//================================================
//Functions for texture distance field evaluation
//================================================


float sdfTexture(vec3 samplePoint, sampler3D textureData) {
    float pot = 1.;
    vec3 p = samplePoint + offset;
    pot = texture(textureData, p, 0.).x;
    pot = 2. * pot - 1.;
    pot *= 0.5;
    return pot;
}

vec2 map(vec3 eye, vec3 marchingDirection, float start, float end, sampler3D textureData) {
    
    float depth = start;
    
    for (int i = 0; i < MAX_MARCHING_STEPS; i++) {

        float dist = sdfTexture(eye + depth * marchingDirection, textureData);
        float d = abs(dist);
        if (abs(dist) < EPSILON) {
			return vec2(depth, float(i));
        }

        depth += d > 0.02 ? 1.1 * d : d;

        if (depth >= end) {
            return vec2(end, float(i));
        }

    }

    return vec2(end, float(MAX_MARCHING_STEPS));
}


vec3 calcNormalSDF(vec3 p, sampler3D textureData) {
    float eps = normalPrecision;
    return normalize(vec3(
        sdfTexture(vec3(p.x + eps, p.y, p.z), textureData) - sdfTexture(vec3(p.x - eps, p.y, p.z), textureData),
        sdfTexture(vec3(p.x, p.y + eps, p.z), textureData) - sdfTexture(vec3(p.x, p.y - eps, p.z), textureData),
        sdfTexture(vec3(p.x, p.y, p.z + eps), textureData) - sdfTexture(vec3(p.x, p.y, p.z - eps), textureData)
    ));
}
