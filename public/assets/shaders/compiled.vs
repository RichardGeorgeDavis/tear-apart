#!SHADER: Vertex
void main() {
    vec3 pos = position;
    // vec3 pos = vec3(uv.x, uv.y, 0.0) * 10.0;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vUv2 = uv2;
}

#!SHADER: Fragment
void main() {
    vec3 color = texture2D(tMap, vUv2).rgb;
    gl_FragColor = vec4(color, 1.0);
}{@}DecalShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tBaseColor;
uniform sampler2D tNormal;
uniform float uSurfaceOffset;

#!VARYINGS
varying vec2 vUv;
varying vec3 vEye;
varying vec3 vNormal;
varying vec3 vViewDir;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    pos += normal * uSurfaceOffset;
    vec3 n = normal;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vNormal = normalMatrix * n;
    vEye = vec3(modelViewMatrix * vec4(pos, 1.0));
}

#!SHADER: Fragment
#require(normalmap.glsl)

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    vec4 baseColor = texture2D(tBaseColor, vUv);
    if (baseColor.a < 0.5) discard;

    vec3 normal = unpackNormal(vEye, vNormal, tNormal, 1.5, 1.0, vUv).xyz;
    // normal = normalize(vNormal);

    vec2 muv = matcap(normalize(vEye), normal);
    vec3 color = texture2D(tMatcap, muv).rgb;
    color *= baseColor.rgb;

    gl_FragColor = vec4(color, 1.0);
}{@}DemoShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying float vAo;

#!SHADER: Vertex
void main() {
    // vec3 pos = position;
    vec3 pos = position;
    pos = position;
    pos *= 0.025;
    pos.y *= 2.0 + random.y * 45.0;
    pos.xz *= 2.0 + random.y * 20.0;
    // pos.y += 0.5;
    // pos.y *= 4.0;
    // pos.xz *= 0.45;
    // pos.z += 0.1;
    // pos.z *= 5.0;
    // pos.x *= 1.0;
    // pos.z *= 1.0;
    pos = transformPosition(pos, offset, vec3(1.0), orientation);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vNormal = transformNormal(normal, orientation);
    vAo = step(0.5, random.x);
}

#!SHADER: Fragment
void main() {
    vec3 color = texture2D(tMap, vUv).rgb;
    if (color.r < 0.5) discard;

    float dp = dot(vNormal, vec3(0.0, 1.0, 0.5)) * 0.5 + 0.5;
    dp = vUv.y * 0.25 + 0.75;
    // dp = 1.0;
    color *= vec3(dp);
    color *= max(0.3, vAo);

    gl_FragColor = vec4(color, 1.0);
}{@}DepthPointShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tPos;

#!VARYINGS
varying vec3 vRandom;

#!SHADER: Vertex

void main() {
    float depth = random.x;

    vec4 decodedPos = texture2D(tPos, position.xy);
    float scale = 0.4;
    vec3 pos = decodedPos.xyz;

    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = scale * 0.1 * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;

    vRandom = random;
}

#!SHADER: Fragment

void main() {
    vec4 color = vec4(vRandom);

    gl_FragColor = color;
