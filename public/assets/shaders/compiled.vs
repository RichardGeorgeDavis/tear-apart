#require(rotation.glsl)
void main() {


    vec3 pos = position;
    vec3 n = normal;
    // pos -= center;

    vec3 axis = vec3(0.0, 1.0, 0.0);
    float angle = sin(time * 1.5 - pos.z * 2.0) * 0.2;

    // float angle = sin(time + center.y + center.z) * 3.14 + 3.14;

    pos = vec3( rotationMatrix(axis, angle) * vec4(pos, 1.0));
    // n = vec3( rotationMatrix(axis, angle) * vec4(normal, 1.0));
    // pos -= normalize(center) * sin(angle * 2.0) * 0.03;
    // pos += center;


    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vTransformedNormal = n;
    vPos = pos;
}

#!SHADER: Fragment
void main() {
    // float value = dot(normalize(vTransformedNormal), vec3(0.0, 0.0, -1.0)) * 0.5 + 0.5;
    float value = vPos.y * 5.0;
    // float ao = pow(clamp(length(vPos) * 0.88, 0.0, 1.0), 34.0);
    // value *= ao;
    value = pow(value, 0.45);
    gl_FragColor = vec4(value);
    // gl_FragColor = vec4(vTransformedNormal, 1.0);
}{@}ShatterShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform vec3 uObjectPos;

#!VARYINGS
varying vec3 vColor;
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vNormal;
varying vec3 vTransformedNormal;
varying vec3 vPos;
varying float vGrad;

#!SHADER: Vertex
#require(rotation.glsl)
void main() {

    float t = time * 0.35;
    vec3 center = vdata - uObjectPos * vec3(1.0, 0.0, 1.0);

    float grad = length(center);
    float inverseGrad = clamp(1.0 - grad * 0.7, 0.0, 1.0);

    vec3 pos = position;
    vec3 n = normal;
    pos -= vdata;

    vec3 axis = cross(normalize(center), vec3(0.0, 1.0, 0.0));

    float angle = pow(inverseGrad, 2.0) + pow(inverseGrad, 3.0) * 2.0;
    float strength = angle;
    angle += uv2.y * angle * 0.25;
    pos *= clamp(1.0 - pow(angle, 6.0), 0.0, 1.0);
    angle *= 4.0;

    pos = vec3( rotationMatrix(axis, angle) * vec4(pos, 1.0));
    n = vec3( rotationMatrix(axis, angle) * vec4(normal, 1.0));

    pos.y += strength + pow(inverseGrad, 3.0) * 2.0;
    pos += vdata;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vUv2 = uv2;
    vNormal = normalize(center);
    vTransformedNormal = n;
    vPos = pos;
    vGrad = grad;
}

#!SHADER: Fragment
#require(shadows.fs)
void main() {
    float value = dot(normalize(vTransformedNormal), vec3(-1.0, 1.0, 0.0)) * 0.5 + 0.5;
    float ao = vGrad + dot(normalize(vNormal), normalize(vTransformedNormal));
    ao = clamp(ao, 0.4, 1.0);
    value *= ao;
    value = pow(value, 0.45);
    gl_FragColor = vec4(value);
}{@}TransparentShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uAlpha;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec3 color = texture2D(tMap, vUv).rgb;
    gl_FragColor = vec4(color, uAlpha);
}{@}TubeShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tWind;

#!VARYINGS
varying vec3 vColor;
varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vTransformedNormal;
varying vec3 vPos;
varying float vAngle;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;
    pos -= offset;

    vec2 wind = texture2D(tWind, offset.xz * 0.15 + vec2(time * 0.085, time * 0.1) - position.y * 0.04).xy;
    vec2 wind2 = texture2D(tWind, offset.xz * 0.15 + vec2(time * 0.085, time * 0.1) + 0.02 - position.y * 0.04).xy;
    wind = mix(wind, wind2, 0.5);
    wind = wind * 2.0 - 1.0;
    float angle = length(wind) * 0.8;
    vec3 axis = cross(vec3(0.0, 1.0, 0.0), normalize(vec3(wind.x, 0.0, wind.y)));
    pos.y *= angle * 1.0 + 0.7;
    pos = vec3( rotationMatrix(axis, angle) * vec4(pos, 1.0));
    n = vec3( rotationMatrix(axis, angle * 3.0) * vec4(normal, 0.0));
    pos += offset;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vTransformedNormal = n;
    vPos = pos;
    vAngle = angle * 0.5 + 0.5;
}

#!SHADER: Fragment
void main() {
    float value = dot(normalize(vTransformedNormal), normalize(vec3(-1.5, 1.0, -0.1))) * 0.5 + 0.5;
    float ao = pow(vPos.y * 0.5, 3.0);
    value *= ao;
    value += pow(vAngle * 1.55, 15.0) * 0.015;
    value *= mix(1.0, ao, 0.9);
    value *= 7.0;
    value *= smoothstep(0.2, 1.0, vPos.y);
    value = pow(value, 0.45);
    gl_FragColor = vec4(value);
}{@}WhaleRotationShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec3 vNormal;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;
    // pos.z -= 1.7;
    pos.y -= 0.5;
    float angle = sin(time + pos.z * 1.25) * 0.1;
    mat4 rotMatrix = rotationMatrix(vec3(0.0, 0.0, 1.0), time + pos.z);
    pos = vec3(rotMatrix * vec4(pos, 1.0));
    n = vec3(rotMatrix * vec4(n, 1.0));
    pos.y += 0.5;

    // pos.z += 1.7;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vNormal = n;
}

#!SHADER: Fragment
void main() {
    float value = dot(vNormal, vec3(0.0, 1.0, 0.0)) * 0.5 + 0.5;
    gl_FragColor = vec4(value);
}{@}HexagonGridShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec3 vColor;
varying vec3 vNormal;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;

    vColor = offset;
    vNormal = normal;



    vec3 axis = cross(normalize(offset), vec3(0.0, 0.0, 1.0));
    // axis = mix(vec3(0.0, 1.0, 0.0), vec3(1.0, 0.0, 0.0), sin(offset.x * 0.6) * 0.5 + 0.5);
    // vec3 axis = vec3(1.0, 0.0, 0.0);
    float angle = sin(length(offset * 0.5) - time);
    mat4 m = rotationMatrix(axis, angle);



    pos -= offset;
    pos = (m * vec4(pos.xyz, 1.0)).xyz;
    pos += offset;

    // vNormal -= offset;
    vNormal = (m * vec4(vNormal.xyz, 0.0)).xyz;
    // vNormal += offset;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    gl_FragColor = vec4(vNormal * 0.5 + 0.5, 1.0);
}{@}HexagonVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

void main() {
    vec4 color = texture2D(tDiffuse, vUv);

    // vec3 bloom = pow(getUnrealBloom(vUv).rgb, vec3(2.2));
    // bloom = mix(bloom, uncharted2(bloom), 0.5);
    // vec3 bloom = getHydraBloom(vUv);
    // color.rgb += bloom;

    // color.rgb = pow(color.rgb, vec3(2.2));
    // color.rgb = uncharted2(color.rgb);
    // color.rgb += bloom;
    // color.rgb = pow(color.rgb, vec3(0.45454545));
    // color.rgb = unreal(color.rgb);



    color.rgb += (getNoise(vUv, time) - 0.5) * 0.1;

    // color.rgb = mix(texture2D(tDiffuse, vUv).rgb + getUnrealBloom(vUv).rgb, color.rgb, 0.0);

    // color.rgb = uncharted2(bloom);
    // color.rgb = bloom;

  gl_FragColor = color;
}{@}PhysicalShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;
attribute vec3 vdata;
attribute float side;

#!UNIFORMS
uniform sampler2D tVideo;

uniform sampler2D tBaseColor;
uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform sampler2D tLUT;
uniform sampler2D tFluid;
uniform sampler2D tFluidMask;

uniform sampler2D tEnvDiffuse;
uniform sampler2D tEnvSpecular;

uniform sampler2D tLightmap;
uniform float uUseLightmap;
uniform float uLightmapIntensity;

uniform vec4 uParams;
uniform vec3 uFogColor;

uniform vec3 uTint;
uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;
uniform vec2 uEnv;

uniform float uHDR;
uniform float uLightmapAsDiffuse;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vN;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec3 vColor;
varying float vFog;
varying float vAngle;
varying float vSide;
varying float vAO;

#!SHADER: Vertex
#require(rotation.glsl)

const float LOG2 = 1.442695;

void main() {
    // vec3 ndc = offset.xyz / gl_Position.w; //perspective divide/normalize
    // vec2 viewportCoord = ndc.xy * 0.5 + 0.5; //ndc is -1 to 1 in GL. scale for 0 to 1
    // vec2 viewportPixelCoord = viewportCoord * resolution;

    // vec2 fluidUv = offset.xy * 0.1 + vec2(0.4, 0.5);
    // vec2 fluidUv = offset.xy * 0.1 + vec2(0.4, 0.5);
    // vec2 fluidUv = viewportPixelCoord;
    vUv = position.xy * 0.01 + offset.xy * 0.1 + vec2(0.4, 0.5);

    vec4 screenUv = projectionMatrix * modelViewMatrix * vec4(offset, 1.0);
    screenUv /= screenUv.w;

    // vec3 fluidVel = texture2D(tFluid, fluidUv).rgb;
    // float fluidMag = length(fluidVel);
    vec2 fluidUv = offset.xy * 0.1 + vec2(0.4, 0.5);
    vec3 fluidVel = texture2D(tFluid, screenUv.xy * 0.5 + 0.5).rgb;
    float fluidMask = texture2D(tFluidMask, screenUv.xy * 0.5 + 0.5).r;
    fluidMask = 1.0 - pow(1.0 - fluidMask, 6.2);
    vColor = vec3(fluidMask);


    vec4 color = texture2D(tVideo, offset.xy * 0.1 + vec2(0.4, 0.5));

    vec3 pos = position;

    float layFlat = 1.0;
    // layFlat = clamp(sin(pow(length(offset), 1.0) * -0.15 + time * 0.2 - 5.0) * 3.0, 0.0, 1.0);
    layFlat = 0.0;
    
    float strength = length(offset) * 0.1 + 0.5;

    vec3 axis = cross(normalize(offset), vec3(0.0, 0.0, 1.0));
    float angle = (sin(length(offset * 1.4) - time * 1.0) * 0.5 + 0.5) * 3.14159 + 3.14159;
    angle *= 2.0;

    // angle += pow(fluidMag, 2.2) * 3.14159 * 2.0;
    angle = mix(angle, 0.0, layFlat);
    angle += fluidMask * 3.14 * 0.6;

    // axis += fluidVel;

    mat4 m = rotationMatrix(axis, angle);


    float mask = 0.0;

    // flatten edges
    // if (side == 1.0) {
    //     mask = step(position.y, 0.0);
    //     pos.y *= mix(1.0, 0.0, mask);
    // } else if (side == 2.0) {
    //     mask = 1.0 - step(position.x, 0.0);
    //     pos.x *= mix(1.0, 0.0, mask);
    // } else if (side == 3.0) {
    //     mask = 1.0 - step(position.y, 0.0);
    //     pos.y *= mix(1.0, 0.0, mask);
    // } else if (side == 4.0 ) {
    //     mask = step(position.x, 0.0);
    //     pos.x *= mix(1.0, 0.0, mask);
    // }

    vec3 off = offset;

    pos -= offset;
    pos *= mix(0.95, 1.0, layFlat);
    pos = (m * vec4(pos.xyz, 1.0)).xyz;
    // pos.z += (angle * 0.2) * strength - 1.0 * (1.0 - layFlat);
    off.z += (angle * 0.2) * strength - 1.0 * (1.0 - layFlat);
    off.z *= 3.0 * (1.0 - clamp(length(offset * 0.2), 0.0, 1.0));
    // off.z += fluidMask * 0.25;
    // off -= fluidVel * pow(fluidMask, 2.0) * 0.0005;
    pos += off;

    // pos.y *= 0.25;
    // pos.z *= 3.0 * (1.0 - clamp(length(offset * 0.2), 0.0, 1.0));

    // vAO = smoothstep(0.5, 1.0, pos.z);

    vec3 n = (m * vec4(mix(normal.xyz, normalize(position), 0.1), 0.0)).xyz;
    n = mix(normal, n, strength);

    n = mix(n, vec3(0.0, 0.0, 1.0), layFlat - fluidMask);

    vAO = 1.0 - (dot(normalize(vec3(0.2, 0.0, -1.0)), n) * 0.5 + 0.5);
    vAO = abs(vAO);
    vAO = pow(vAO, 5.0);
    vAO = 1.0 - clamp(vAO, 0.0, 1.0);
    vAO = mix(1.0, vAO, smoothstep(0.0, 0.2, pos.z));
    // vAO = sin(length(offset * 2.8) - time * 2.0);

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = viewMatrix * worldPos;
    gl_Position = projectionMatrix * modelViewPos;

    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;

    vN = n;
    vWorldNormal = worldNormal;
    vV = worldPos.xyz - cameraPosition;
    
    // vUv *= 1.2;
    // vUv = uv;
    vUv2 = uv2;

    vAngle = angle;

    
    float fogDistance = -modelViewPos.z;
    float fogFactor = 0.0021;
    float fogAmount = 1. - exp2(-fogFactor * fogFactor * fogDistance * fogDistance * LOG2);
    fogAmount = clamp(fogAmount, 0., 1.);
    vFog = fogAmount;

    vSide = side;
}

#!SHADER: Fragment
#require(normalmap.glsl)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * cosTheta - 6.98316) * cosTheta);
}

vec2 sampleSphericalMap(vec3 v)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;

    // match default C4D baked HDRI
    uv.x = fract(uv.x + 0.25 + uParams.y + 0.8 - 0.1);

    return uv;
}

vec4 SRGBtoLinear(vec4 srgb) {
    vec3 linOut = pow(srgb.xyz, vec3(2.2));
    return vec4(linOut, srgb.w);
}

vec3 linearToSRGB(vec3 color) {
    return pow(color, vec3(0.4545454545454545));
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec4 autoToLinear(vec4 texel, float uHDR) {
    vec4 color = RGBMToLinear(texel);
    if (uHDR == 0.0) { color = SRGBtoLinear(texel); }
    return color;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N, sampler2D tLUT, sampler2D tEnvDiffuse, sampler2D tEnvSpecular) {
    float metallic = clamp(MRO.x + uMRON.x - 1.0, 0.0, 1.0);
    float roughness = clamp(MRO.y + uMRON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uMRON.z);

    vec2 lutUV = vec2(NdV, roughness);
    vec2 diffuseUV = sampleSphericalMap(N);

    vec3 brdf = SRGBtoLinear(texture2D(tLUT, lutUV)).rgb;
    vec3 diffuse = autoToLinear( texture2D(tEnvDiffuse, diffuseUV ), uHDR).rgb;

    vec3 lightmap = vec3(1.0);

    if (uUseLightmap > 0.0) {
        lightmap = texture2D(tLightmap, vUv2).rgb;
        lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
        diffuse.rgb *= lightmap.rgb;
    }

    diffuse *= baseColor.rgb;

    float level = floor(roughness * ENV_LODS);
    vec2 specUV = sampleSphericalMap(R);

    specUV.y /= 2.0;
    specUV /= pow(2.0, level);
    specUV.y += 1.0 - exp(-LN2 * level);

    vec3 specular = autoToLinear(texture2D(tEnvSpecular, specUV), uHDR).rgb;

    // fake stronger specular highlight
    specular += pow(specular, vec3(2.2)) * uEnv.y;

    if (uUseLightmap > 0.0) {
        specular *= lightmap;
    }

    vec3 F0 = vec3(0.01);
    F0 = mix(F0, baseColor.rgb, metallic);

    vec3 F = fresnelSphericalGaussianRoughness(NdV, F0, roughness);

    vec3 diffuseContrib = 1.0 - F;
    specular = specular.rgb * (F);

    diffuseContrib *= 1.0 - metallic;

    float alpha = baseColor.a;

    return vec4((diffuseContrib * diffuse + specular) * ao * uEnv.x, alpha);
}

void main() {
    vec2 uv = vUv;
    vec3 N = vWorldNormal;
    vec3 V = normalize(vV);
    vec3 worldNormal = unpackNormal(V, N, tNormal, uMRON.w, 1.0, uv).xyz;
    vec3 R = reflect(V, worldNormal);
    float NdV = abs(dot(worldNormal, V));

    vec4 MRO = texture2D(tMRO, uv);
    MRO.r = 0.5;
    vec4 baseColor = texture2D(tBaseColor, uv);
    baseColor.rgb = texture2D(tVideo, uv).rgb * 0.6;
    baseColor = SRGBtoLinear(baseColor);
    
    vec4 color = getIBLContribution(NdV, baseColor, MRO, R, V, worldNormal, tLUT, tEnvDiffuse, tEnvSpecular);

    color.rgb = pow(color.rgb, vec3(0.45454545));
    // color.rgb = mix(color.rgb, uFogColor, vFog);
    
    // gl_FragColor = color * vAO;
    gl_FragColor = color * 1.2;
    gl_FragColor.rgb += vColor * color.rgb * 0.2;
    // gl_FragColor.rgb = vec3(vColor) * 0.1;
    // gl_FragColor.rgb = vColor;
    // gl_FragColor = vec4(vAO);
    gl_FragColor.a = 1.0;
}{@}IbizaBuildingShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tBaseColor;
uniform sampler2D tNormal;
uniform float uBrightness;
uniform vec2 uFogRange;
uniform vec3 uFogColor;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vN;
varying vec3 vV;
varying float vFog;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vUv2 = uv2;

    vec3 worldPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;

    vN = worldNormal;
    vV = worldPos.xyz - cameraPosition;

    vec4 modelViewPos = viewMatrix * vec4(worldPos, 1.0);
    vFog = smoothstep(uFogRange.x, uFogRange.y, -modelViewPos.z);
}

#!SHADER: Fragment
#require(normalmap.glsl)
void main() {
    vec3 lightmap = texture2D(tMap, vUv2).rgb;
    vec3 baseColor = texture2D(tBaseColor, vUv).rgb;
    vec3 color = vec3(0.0);
    color += pow(lightmap, vec3(2.2)) * pow(baseColor, vec3(2.2)) * 1.5 * uBrightness;

    color = pow(color, vec3(0.45));

    color = mix(color, uFogColor, vFog);

    gl_FragColor = vec4(color, 1.0);
}{@}IbizaFloorShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tBaseColor;
uniform sampler2D tBaseColor2;
uniform sampler2D tHeight;
uniform sampler2D tNormal;
uniform float uBrightness;
uniform vec2 uFogRange;
uniform vec3 uFogColor;
uniform vec3 uLightPos;
uniform vec3 uLightColor;
uniform float uShininess;
uniform float uKs;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vPos;
varying vec3 vMvPos;
varying vec3 vLightDir;
varying float vFog;
varying vec3 vN;
varying vec3 vL;
varying vec3 vV;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vUv2 = uv2;

    vec3 worldPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;

    vN = worldNormal;
    vV = worldPos.xyz - cameraPosition;

    vec4 modelViewPos = viewMatrix * vec4(worldPos, 1.0);
    vFog = smoothstep(uFogRange.x, uFogRange.y, -modelViewPos.z);
    vPos = position;

    vMvPos = vec3(modelViewMatrix * vec4(position, 1.0));
    vUv = uv * 1.0;
    vLightDir = vec3(modelViewMatrix * vec4(uLightPos, 1.0)) - vMvPos;

    vec3 P = vec3(modelViewMatrix * vec4(position, 1.0));
    vec3 N = normalMatrix * normal;
    vec3 L = vec3(modelViewMatrix * vec4(uLightPos, 1.0)) - P;
    vec3 V = -P;

    vN = N;
    vL = L;
    vV = V;
}

#!SHADER: Fragment
#require(normalmap.glsl)
void main() {
    vec3 lightmap = texture2D(tMap, vUv2).rgb;
    vec3 baseColor = texture2D(tBaseColor, vUv).rgb;
    vec3 baseColor2 = texture2D(tBaseColor2, vUv).rgb;
    float height = texture2D(tHeight, vUv).r;

    float ramp = 1.0 - abs(vPos.x);
    ramp += height * 8.0;
    ramp = smoothstep(0.5, 1.0, ramp);
    baseColor = mix(baseColor2, baseColor, ramp);

    vec3 color = vec3(0.0);
    color += pow(lightmap, vec3(2.2)) * pow(baseColor, vec3(2.2)) * 1.5 * uBrightness;
    color = pow(color, vec3(0.45));
    color = mix(color, uFogColor, vFog);

    float roughness = 1.0 - baseColor2.r;
    roughness = roughness * roughness;
    float ao = height;

    vec3 normal = unpackNormal(vV, vN, tNormal, 0.8, 1.0, vUv).xyz;

    // vec3 N = normalize(vN);
    vec3 N = normal;
    vec3 L = normalize(vL);
    vec3 V = normalize(vV);

    float lambert = pow(max(dot(N, L), 0.0), 2.0);

    vec3 H = normalize(L + V);
    float spec = max(dot(N, H), 0.0);
    float shininess = (1.0 - roughness) * uShininess;
    spec = pow(spec, shininess);

    float ks = uKs;
    float kd = 1.0 - ks;

    vec3 light = color * (1.0 - spec) + spec * ks * uLightColor * ao;
    // light *= ao;

    gl_FragColor = vec4(light, 1.0);
    gl_FragColor.a = 1.0;
}{@}IbizaParticleShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;
uniform sampler3D tVolume3D;
uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec3 vMvPos;
varying vec3 vPos;

#!SHADER: Vertex

void main() {
    vec4 decodedPos = texture2D(tPos, position.xy);
    float scale = 2.0;
    vec3 pos = decodedPos.xyz;

    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = scale * 0.1 * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;

    vMvPos = mvPosition.xyz;
    vPos = (modelMatrix * decodedPos).xyz;
}

#!SHADER: Fragment

void main() {
    vec2 uv = gl_PointCoord.xy;

    float a = 1.0 - length(uv - 0.5);
    
    a = pow(a, 7.0);

    a *= smoothstep(-vMvPos.z, 0.0, 5.0);
    a *= vPos.z * 0.007 + 0.45;
    a *= 4.0;
    // a *= smoothstep(-vMvPos.z, 0.0, 5.0);
    // a *= smoothstep(-vMvPos.z, 0.0, 5.0);
    a *= clamp(vPos.y * 0.4, 0.0, 1.0);
    a *= 1.5;
    // if (a < 0.75) discard;
    // a = 1.0 - length(uv - vec2(0.5, 0.35));
    // a = a * a * a;

    // vec3 lightDir   = normalize(vec3(0.2, 1.0, 0.2));
    // vec3 viewDir    = normalize(-vMvPos.xyz);
    // vec3 halfwayDir = normalize(lightDir + viewDir);
    // float spec = pow(max(dot(vNormal, halfwayDir), 0.0), 42.0 * a);

    // float diffuseContribution = 0.5;
    // float specContribution = 1.0 - diffuseContribution;

    // vec3 color = vec3(diffuseContribution + specContribution * spec) * a;
    vec3 color = uColor1;
    // color = vec3(a);
    gl_FragColor = vec4(color, a);
}{@}IbizaSkyShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform vec2 uRange;
uniform vec2 uTiling;
uniform vec2 uOffset;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv * uTiling + uOffset;
}

#!SHADER: Fragment
void main() {
    float value = texture2D(tMap, vUv).r;
    float displacement = sin(value * 5.0 + time * 0.3 + vUv.y * 17.0) * 0.0035;

    vec3 color = texture2D(tMap, vUv + displacement).rgb;
    gl_FragColor = vec4(color, 1.0);
}{@}IbizaTreeShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tBaseColor;
uniform sampler2D tOpacity;
uniform sampler2D tTranslucency;
uniform float uDiscard;
uniform vec3 uLightPos;
uniform vec3 uLightColor;
uniform vec3 uAmbientColor;
uniform float uWindStrength;

#!VARYINGS
varying vec2 vUv;
varying vec3 vWorldNormal;
varying vec3 vLightDir;
varying vec3 vAmbientColor;
varying vec3 vLightColor;
varying vec3 vColor;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;

    // leaf rustle
    pos -= vdata;
    pos = (rotationMatrix(vec3(1.0, 0.0, 0.5), uWindStrength * (cos(time * 2.7 + pos.x * 16.0) * 0.1 + sin(time * 5.0 + pos.z * 5.0) * 0.01 * position.y)) * vec4(pos, 1.0)).xyz;
    pos += vdata;

    // tree sway
    pos = (rotationMatrix(vec3(0.0, 0.0, 1.0), uWindStrength * sin(time - position.y * 0.05) * 0.001 * position.y) * vec4(pos, 1.0)).xyz;


    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;

    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;
    vWorldNormal = worldNormal;
    vLightDir = normalize(uLightPos);
    vAmbientColor = pow(uAmbientColor, vec3(2.2));
    vLightColor = pow(uLightColor, vec3(2.2));
    vColor = vdata;
}

#!SHADER: Fragment
void main() {
    float alpha = texture2D(tOpacity, vUv).r;
    if (alpha < uDiscard) discard;

    vec4 color = texture2D(tBaseColor, vUv);
    color.rgb = pow(color.rgb, vec3(2.2));
    color.rgb *= vAmbientColor;

    float lightStrength = dot(vLightDir, vWorldNormal) * 0.5 + 0.5;
    color.rgb += lightStrength * vLightColor;

    gl_FragColor = color;
}{@}ImpactDebrisInstanceShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec2 vUv;
varying vec3 vTransformedNormal;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
  vec3 pos = position;
  pos.y += scale.y;
  gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
  vUv = uv;
  vTransformedNormal = transformNormal(normal, orientation);
  vPos = (modelMatrix * vec4(pos, 1.0)).xyz;
}

#!SHADER: Fragment
void main() {
    float value = dot(normalize(vTransformedNormal), vec3(-1.0, 1.0, 0.0)) * 0.5 + 0.5;
    value = max(0.5, value);
    // float ao = vGrad + dot(normalize(vNormal), normalize(vTransformedNormal));
    // ao = clamp(ao, 0.2, 1.0);
    // value *= ao;
    // value = pow(value, 0.45);

    // wide gradient
    value += pow(clamp(1.0 - length(vPos.xz) * 0.2, 0.0, 1.0), 2.0);

    vec3 lightBlue = vec3(0.0, 122.0, 191.0) / 255.0;
    vec3 darkBlue = vec3(0.0, 50.0, 102.0) / 255.0;

    vec3 color = mix(darkBlue, lightBlue, value);

  // vec3 color = vec3(value);
  gl_FragColor = vec4(color, 1.0);
}
{@}ImpactDebrisShader.glsl{@}#!ATTRIBUTES
attribute float scale;

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
  vec3 pos = position;
  float size = mix(1.0, 7.0, scale);
  pos.y += size * 0.5 * 0.01;
  gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
  gl_PointSize = size;
  vUv = uv;
}

#!SHADER: Fragment
void main() {
  vec3 color = vec3(1.0);
