#!UNIFORMS
uniform sampler2D tData;
uniform sampler2D tData2;
uniform sampler2D tData3;
uniform sampler2D tData4;
uniform sampler2D tData5;
uniform sampler2D tData6;
uniform sampler2D tData7;

uniform vec2 voxelData;
uniform vec4 indices;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex

void main() {
    vUv = uv;
    gl_Position = vec4(position, 1.0);
}

#!SHADER: Fragment


layout(location=0) out vec4 data0;
layout(location=1) out vec4 data1;
layout(location=2) out vec4 data2;
layout(location=3) out vec4 data3;


vec2 index2D(vec2 uv, float index) {
    return uv / voxelData.x + vec2(mod(index, voxelData.x), floor(index / voxelData.x)) / voxelData.x;

}

void main() {

    vec2 uv = vUv;
    float multiplier = 1. / 7.;

    vec2 i1 = index2D(uv,indices.x);
    vec2 i2 = index2D(uv,indices.y);
    vec2 i3 = index2D(uv,indices.z);
    vec2 i4 = index2D(uv,indices.w);

    data0 = texture(tData, i1);
    data1 = texture(tData, i2);
    data2 = texture(tData, i3);
    data3 = texture(tData, i4);
    

    data0 += texture(tData2, i1);
    data1 += texture(tData2, i2);
    data2 += texture(tData2, i3);
    data3 += texture(tData2, i4);

    data0 += texture(tData3, i1);
    data1 += texture(tData3, i2);
    data2 += texture(tData3, i3);
    data3 += texture(tData3, i4);

    data0 += texture(tData4, i1);
    data1 += texture(tData4, i2);
    data2 += texture(tData4, i3);
    data3 += texture(tData4, i4);

    data0 += texture(tData5, i1);
    data1 += texture(tData5, i2);
    data2 += texture(tData5, i3);
    data3 += texture(tData5, i4);

    data0 += texture(tData6, i1);
    data1 += texture(tData6, i2);
    data2 += texture(tData6, i3);
    data3 += texture(tData6, i4);

    data0 += texture(tData7, i1);
    data1 += texture(tData7, i2);
    data2 += texture(tData7, i3);
    data3 += texture(tData7, i4);

    data0 *= multiplier;
    data1 *= multiplier;
    data2 *= multiplier;
    data3 *= multiplier;

}{@}RayFixedPassShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler3D tData;
uniform vec4 orientation;


#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex.vs

void main() {
    vUv = uv;
    gl_Position = vec4(position, 1.);

}


#!SHADER: Fragment.fs

const int MAX_MARCHING_STEPS = 100;
const float MIN_DIST = 0.0;
const float MAX_DIST = 2.;
const float EPSILON = 0.01;

//Orientation function used to rotate the view relative to the camera.
vec3 orientate( vec4 quat, vec3 vec) {
    return  vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}


//Ray box intersection function
 float boxRay(vec3 ro, vec3 rd, vec3 boxmin, vec3 boxmax) {
    vec3 invR = 1. / rd;
    vec3 tbot = invR * (boxmin - ro);
    vec3 ttop = invR * (boxmax - ro);
    vec3 tmin = min(ttop, tbot);
    vec3 tmax = max(ttop, tbot);
    vec2 t0 = max(tmin.xx, tmin.yz);
    float tnear = max(t0.x, t0.y);
    t0 = min(tmax.xx, tmax.yz);
    float tfar = min(t0.x, t0.y);
    if( tnear > tfar || tfar < 0.0) return -1.;
    return tnear;
  }


float sceneSDF(vec3 samplePoint) {

    return textureLod(tData, samplePoint + vec3(0.5), (3. * (sin(time * 2.) * 0.5 + 0.5 ))  ).r;

}


//Mapping function used for raymarching
float map(vec3 eye, vec3 marchingDirection, float start, float end) {
    
    float depth = start;

    for (int i = 0; i < MAX_MARCHING_STEPS; i++) {
       
        float dist = sceneSDF(eye + depth * marchingDirection);

        if ((dist) > 0.1) {
			return depth;
        }

        depth += 0.01;

        if (depth >= end) {
            return end;
        }
        
    }
    return end;
}



vec3 calcNormal(vec3 p) {
    float eps = 0.02;
    return normalize(vec3(
        sceneSDF(vec3(p.x + eps, p.y, p.z)) - sceneSDF(vec3(p.x - eps, p.y, p.z)),
        sceneSDF(vec3(p.x, p.y + eps, p.z)) - sceneSDF(vec3(p.x, p.y - eps, p.z)),
        sceneSDF(vec3(p.x, p.y, p.z + eps)) - sceneSDF(vec3(p.x, p.y, p.z - eps))
    ));
}


void main() {

    gl_FragColor = vec4(0.);


    //Generate a ray with the caamera orientation.
    vec2 xy = (2.0 * gl_FragCoord.xy - resolution.xy)/resolution.y;
    vec4 conj = orientation;

    float z = resolution.y / tan(radians(35.) / 2.0);
    vec3 dir =  normalize(vec3(xy, z / resolution.y));
    dir = normalize(dir);

    vec3 eye = vec3(0.0, 0.0, -length(cameraPosition));

    eye = orientate(orientation, eye);
    dir = orientate(orientation, dir);

    //Find the collision point between the ray and the bounding box of the texture
    //this discard fragments that won't contribute (rendered in white)
    float t = boxRay(eye, dir, vec3(-0.5), vec3(0.5));

    if(t == -1.) {

        //Case where there's no intersection with the bounding box
        gl_FragColor = vec4(.0);
		return;
    } 


    //If there's an intersection the new starting point is used
    //as the initial point of the distance field.
    vec3 position3D = eye + t * dir;;
    float dist = map(position3D, dir, MIN_DIST, MAX_DIST);

    if(dist >= MAX_DIST - EPSILON) {
        gl_FragColor = vec4(0.);
        return;
    }

    //Renders the position found.
    position3D += dir * dist ;

    vec3 normal = calcNormal(position3D);

    vec3 lightVector = vec3(0., 1., 0.);
    //lightVector = orientate(orientation, lightVector);

    vec3 color = vec3( dot(normal, lightVector)) * 0.8 + 0.1;
    gl_FragColor = vec4(normal * 0.5 + 0.5, 1.);




}{@}VoxelShader.glsl{@}#!ATTRIBUTES
attribute vec3 lookup;

attribute vec4 random;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler3D tData;
uniform sampler2D tColor;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vNormal;
varying vec3 vColor;

varying vec3 dir1;
varying vec3 dir2;
varying vec3 dir3;
varying vec3 dir4;
varying vec3 dir5;

#require(instance.vs)
#require(range.glsl)

#!SHADER: Vertex
void main() {
  vUv = uv;

  float ang = radians(30.);
  float s = sin(ang);
  float c = cos(ang);

  dir1 = vec3(0., 0., 1.);
  dir2 = vec3( c, 0., s);
  dir3 = vec3(-c, 0., s);
  dir4 = vec3(0., c, s);
  dir5 = vec3(0.,-c, s);

  vec3 zAxis = normalize(normal);
  vec3 xAxis = vec3(1., 0., 0.);
  vec3 yAxis = vec3(0., 1., 0.);
  vec3 UP = vec3(0., 1., 0.);
  mat3 rot = mat3(0.);

  if(abs(dot(UP, normal)) < 0.99) {
    xAxis = normalize(cross(UP, zAxis));
    yAxis = normalize(cross(zAxis, xAxis));  
    rot = mat3(xAxis, yAxis, zAxis);
 
  } else {
    zAxis = vec3(0., 0., 1.);
    rot = mat3(xAxis, zAxis, yAxis);
  }
  

  dir1 = rot * dir1;
  dir2 = rot * dir2;
  dir3 = rot * dir3;
  dir4 = rot * dir4;
  dir5 = rot * dir5;
	

  vec3 offset = texture2D(tPos, lookup.xy).xyz;
  vColor = texture2D(tColor, lookup.xy).xyz;

  bool white = vColor.r > 0.99 && vColor.g > 0.99 && vColor.b > 0.99;
  float scale = white ? 0.08 : 0.4;

  vec3 pos = transformPosition(position, offset, scale);

  gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
  
  vNormal = normal;
  vPos = pos;

}

#!SHADER: Fragment

const float MAX_DISTANCE = 64.0;
const float MAX_ALPHA = 0.95;

vec4 SampleVoxels(vec3 pos, float lod)
{
    vec3 minPosition = vec3(-15.);
    vec3 maxPosition = vec3(15.);

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);
    
    vec3 uvw = pos;
    uvw -= minPosition;
    uvw /= s;
	
	return textureLod(tData, uvw, lod);
}


vec4 voxelTracing(vec3 startPos, vec3 direction, float tanHalfAngle) {
	float lod = 0.0;
	vec3 color = vec3(0.0);
	float alpha = 0.0;
	float occlusion = 0.0;

	//Voxel Cube Size
	float voxelWorldSize = 0.5;
	float dist = voxelWorldSize;

	while(dist < MAX_DISTANCE && alpha < MAX_ALPHA) {
		float diameter = max(voxelWorldSize, 2.0 * tanHalfAngle * dist);
		float lodLevel = log2(diameter / voxelWorldSize);
		vec4 voxelColor = SampleVoxels(startPos + dist * direction, lodLevel);
    float sub = 1. - alpha;
    float aa = pow(voxelColor.a, 1.);
    alpha += sub * aa;
		occlusion += sub * aa / (1.0 + 0.03 * diameter);
    color += sub * voxelColor.rgb;
		dist += diameter;
	}

	return vec4(color, clamp(1. - occlusion, 0., 1.) );
}

void main() {

    vec3 startPos = vPos + vNormal * 0.5;
    vec4 cone1 = voxelTracing(startPos, vNormal, .9);    
    
    vec4 cone = cone1;

    vec3 diffuse = 0.1 * vec3( dot(vNormal, vec3(0., 1., 0.)));
    diffuse += cone.a * cone.rgb;


    gl_FragColor = vec4(diffuse + 0.1 * cone.a * vColor.rgb, 1.);

    bool white = vColor.r > 0.99 && vColor.g > 0.99 && vColor.b > 0.99;
    if(!white) gl_FragColor.rgb = vColor;
    //else gl_FragColor.a = 0.4;
    
    //gl_FragColor = vec4( cone.rgb, 1.);
