    vec3 F0 = vec3(0.01);
    F0 = mix(F0, baseColor.rgb, metallic);

    vec3 F = fresnelSphericalGaussianRoughness(NdV, F0, roughness);

    vec3 diffuseContrib = 1.0 - F;
    specular = specular.rgb * (F);

    diffuseContrib *= 1.0 - metallic;

    float alpha = baseColor.a;
    return vec4((diffuseContrib * diffuse + specular) * ao * uEnv.x, alpha);
}

vec2 matcap(vec3 eye, vec3 normal) {
    vec3 reflected = reflect(eye, normal);
    float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
    return reflected.xy / m + 0.5;
}

void main() {
    vec2 uv = vUv;
    vec3 N = vN;
    vec3 normal = unpackNormal(normalize(vV), normalize(N), tNormal, 1.0, 1.0, vUv).xyz;
    vec3 color = normal;
    vec2 muv = matcap(normalize(vV), normal);
    vec3 matcap = texture2D(tMRO, muv).rgb;
    vec3 lightmap = texture2D(tLightmap, vUv).rgb;

    color = matcap;
    color += lightmap;

    

    gl_FragColor = vec4(color, 1.0);
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
}{@}SimpleGradientShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uColor1;
uniform vec3 uColor2;
uniform vec2 uRange;

#!VARYINGS
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    // worldPos += cameraPosition;
    gl_Position = projectionMatrix * viewMatrix * worldPos;
    vPos = position;
}

#!SHADER: Fragment
void main() {
    float blend = smoothstep(uRange.x, uRange.y, vPos.y);
    vec3 color = mix(uColor1, uColor2, blend);
    gl_FragColor = vec4(color, 1.0);
}{@}StaticToonNPCShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tOriginal;
uniform float uOriginalMix;

uniform sampler2D tCrossHatch;
uniform sampler2D tBaseColor;
uniform sampler2D tNormal;

uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;

uniform float uBrushIntensity;
uniform float uAmbient;
uniform vec3 uAmbientColor;
uniform float uHighlightLevel;
uniform float uHighlightSoftness;
uniform vec3 uHighlightColor;
uniform float uShadowLevel;
uniform float uShadowSoftness;
uniform vec3 uShadowColor;
uniform vec3 uLightPos;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec4 vColor;
varying vec3 vLightPos;


#!SHADER: Vertex

void main() {
    vec3 pos = position;
    vec3 n = normal;

    vUv = uv;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vLightPos = normalize(uLightPos);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}


#!SHADER: Fragment
#require(normalmap.glsl)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

void main() {
    vec2 uv = vUv;
    vec3 N = vWorldNormal;
    vec3 V = normalize(vV);
    vec3 normal = unpackNormal(V, N, tNormal, uMRON.w, 1.0, uv).xyz;
    vec2 offset = vec2(floor(time * 4.0) / 4.0);
    offset = vec2(0.0);
    vec3 color = vec3(0.0);
    vec3 baseColor = texture2D(tBaseColor, uv).rgb * uAmbient;
    baseColor = pow(baseColor, vec3(2.2));
    color += baseColor;

    float lighting = dot(normalize(normal), vLightPos);
    float brushStrokes = texture2D(tCrossHatch, vUv * uTiling + offset).r;

    float highlight = smoothstep(uHighlightLevel - uHighlightSoftness, uHighlightLevel + uHighlightSoftness, lighting * mix(1.0, brushStrokes, uBrushIntensity));
    float shadow = smoothstep(uShadowLevel - uShadowSoftness, uShadowLevel + uShadowSoftness, lighting + mix(1.0, brushStrokes, uBrushIntensity) - 0.5);
    
    vec3 shadowColor = pow(uShadowColor, vec3(2.2));
    vec3 highlightColor = pow(uHighlightColor, vec3(2.2));
    vec3 lightColor = vec3(0.0);

    color *= mix(shadowColor, vec3(1.0), shadow);
    color += mix(vec3(0.0), highlightColor, highlight);
    color = pow(color, vec3(0.45));

    float unstylizedLighting = max(0.25, dot(normalize(normal), vec3(0.0, 1.0, 0.4))) * 1.5;
    gl_FragColor.rgb = mix(color.rgb, texture2D(tOriginal, vUv).rgb * unstylizedLighting, uOriginalMix);
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
}{@}StaticToonNPCShaderOutline.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uTint;
uniform vec4 uMRON;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec4 vColor;


#!SHADER: Vertex

void main() {
    vec3 pos = position;
    vec3 n = normal;

    vec2 offset = vec2(floor(time * 6.0) / 6.0);
    pos += n * 0.0055 * uMRON.z;

    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    vWorldNormal = n;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}


#!SHADER: Fragment



void main() {
    gl_FragColor = vec4(uTint, 1.0);
    gl_FragColor.a = 1.0;
}{@}StylizedCharacterShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tMRO;

uniform sampler2D tCrossHatch;
uniform sampler2D tBaseColor;
uniform sampler2D tNormal;

uniform vec2 uTiling;
uniform vec2 uCrosshatchTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;
uniform float uIOR;

uniform float uBrushIntensity;
uniform float uAmbient;
uniform vec3 uAmbientColor;
uniform float uHighlightLevel;
uniform float uHighlightSoftness;
uniform vec3 uHighlightColor;
uniform float uShadowLevel;
uniform float uShadowSoftness;
uniform vec3 uShadowColor;
uniform vec3 uLightPos;

#!VARYINGS
varying vec2 vUv;
varying vec2 vCrosshatchUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec4 vColor;
varying vec3 vLightPos;
varying vec3 vEye;
varying vec3 vNormal;


#!SHADER: Vertex

void main() {
    vec3 pos = position;
    vec3 n = normal;

    vUv = uv * uTiling;
    vCrosshatchUv = uv * uCrosshatchTiling;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = modelViewMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vLightPos = normalize(uLightPos);
    vEye = normalize(modelViewPos.xyz);
    vNormal = normalMatrix * normal;
    vPos = position;

    gl_Position = projectionMatrix * modelViewPos;
}


#!SHADER: Fragment
#require(normalmap.glsl)
#require(shadows.fs)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

vec2 getSubUV(float _width, vec2 _uv, float _index) {
    float index = _index * (1.0 / _width);
    vec2 uv = _uv;
    uv.x /= _width;
    uv.x += floor(fract(index) * _width) / _width;
    return uv;
}

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

float getFresnel(vec3 normal, vec3 viewDir, float power) {
    float d = dot(normalize(normal), normalize(viewDir));
    return 1.0 - pow(abs(d), power);
}

void main() {
    vec3 mro = texture2D(tMRO, vUv).rgb;
    float metallic = clamp((uMRON.x - 1.0) * 10.0, 0.0, 1.0);

    vec2 uv = vUv;
    vec3 N = vWorldNormal;
    vec3 V = normalize(vV);

    vec3 worldNormal = unpackNormal(V, N, tNormal, uMRON.w, 1.0, uv).xyz;
    vec3 normal = unpackNormal(normalize(vEye), vNormal, tNormal, uMRON.w, 1.0, uv).xyz;
    
    vec3 color = vec3(0.0);
    vec3 baseColor = texture2D(tBaseColor, uv).rgb * uAmbient;
    baseColor = pow(baseColor, vec3(2.2));
    color += baseColor;

    float lighting = dot(worldNormal, vLightPos);
    float brushStrokes = texture2D(tCrossHatch, vCrosshatchUv).r;

    float highlight = smoothstep(uHighlightLevel - uHighlightSoftness, uHighlightLevel + uHighlightSoftness, lighting * mix(1.0, brushStrokes, uBrushIntensity));
    float shadow = smoothstep(uShadowLevel - uShadowSoftness, uShadowLevel + uShadowSoftness, lighting + mix(1.0, brushStrokes, uBrushIntensity) - 0.5);
    
    vec3 shadowColor = pow(uShadowColor, vec3(2.2));
    vec3 highlightColor = pow(uHighlightColor, vec3(2.2));
    vec3 lightColor = vec3(0.0);

    color *= mix(shadowColor, vec3(1.0), shadow);
    color += mix(vec3(0.0), highlightColor, highlight);

    float ior = uIOR;
    float roughness = mro.g * mro.g;
    roughness = clamp(roughness + uMRON.y - 1.0, 0.0, 1.0);
    ior *= 1.0 - roughness;
    float fresnel = getFresnel(worldNormal, -V, ior);

    vec2 muv = matcap(vEye, normal);
    roughness += uMRON.y - 1.0;
    roughness = clamp(roughness, 0.0, 1.0);
    roughness = floor(roughness * 7.0);
    muv = getSubUV(8.0, muv, roughness);
    vec3 matcap = texture2D(tMatcap, muv).rgb;
    matcap = pow(matcap, vec3(2.2)) * 3.0;
    matcap *= mix(vec3(1.0), baseColor.rgb * 1.0, metallic);
    color = mix(color, matcap, fresnel);
    color = pow(color, vec3(0.45));

    gl_FragColor.rgb = color.rgb * clamp(mro.b + uMRON.z, 0.0, 1.0);
    gl_FragColor.a = 1.0;
}{@}StylizedNPCShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tBaseColor;
uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform sampler2D tLUT;

uniform sampler2D tEnvDiffuse;
uniform sampler2D tEnvSpecular;

uniform sampler2D tLightmap;
uniform float uUseLightmap;
uniform float uLightmapIntensity;

uniform vec4 uParams;
uniform vec3 uFogColor;

uniform vec3 uTint;
uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;
uniform vec3 uEnv;

uniform float uHDR;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec4 vColor;


#!SHADER: Vertex
#require(skinning.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;

    applySkin(pos, n);
    pos -= n * 0.005;
    // pos = mix((pos - vec3(0.0, 4.0, 0.0)) * 2.0, position, 0.2);

    vUv = uv * uTiling + uOffset;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    // vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vWorldNormal = n;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}


#!SHADER: Fragment
#require(normalmap.glsl)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * cosTheta - 6.98316) * cosTheta);
}

vec2 sampleSphericalMap(vec3 v)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;
    // match default C4D baked HDRI
    uv.x = uv.x + 0.25 + uEnv.z; 

    return uv;
}

vec4 SRGBtoLinear(vec4 srgb) {
    vec3 linOut = pow(srgb.xyz, vec3(2.2));
    return vec4(linOut, srgb.w);
}

vec3 linearToSRGB(vec3 color) {
    return pow(color, vec3(0.4545454545454545));
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec4 autoToLinear(vec4 texel, float uHDR) {
    vec4 color = RGBMToLinear(texel);
    // if (uHDR == 0.0) { color = SRGBtoLinear(texel); }
    return color;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N, sampler2D tLUT, sampler2D tEnvDiffuse, sampler2D tEnvSpecular) {
    float metallic = clamp(MRO.x + uMRON.x - 1.0, 0.0, 1.0);
    float roughness = clamp(MRO.y + uMRON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uMRON.z);

    vec2 lutUV = vec2(NdV, roughness);
    vec2 diffuseUV = sampleSphericalMap(N);

    vec3 brdf = SRGBtoLinear(texture2D(tLUT, lutUV)).rgb;
    vec3 diffuse = autoToLinear( texture2D(tEnvDiffuse, diffuseUV ), uHDR).rgb;

    vec3 lightmap = vec3(1.0);

    // if (uUseLightmap > 0.0) {
    //     lightmap = texture2D(tLightmap, vUv2).rgb;
    //     lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
    //     diffuse.rgb *= lightmap.rgb;
    // }

    diffuse *= baseColor.rgb;

    float level = floor(roughness * ENV_LODS);
    vec2 specUV = sampleSphericalMap(R);

    specUV.y /= 2.0;
    specUV /= pow(2.0, level);
    specUV.y += 1.0 - exp(-LN2 * level);

    vec3 specular = autoToLinear(texture2D(tEnvSpecular, specUV), uHDR).rgb;

    // fake stronger specular highlight
    specular += pow(specular, vec3(2.2)) * uEnv.y;

    // if (uUseLightmap > 0.0) {
    //     specular *= lightmap;
    // }

    vec3 F0 = vec3(0.01);
    F0 = mix(F0, baseColor.rgb, metallic);

    vec3 F = fresnelSphericalGaussianRoughness(NdV, F0, roughness);

    vec3 diffuseContrib = 1.0 - F;
    specular = specular.rgb * (F);

    diffuseContrib *= 1.0 - metallic;

    float alpha = baseColor.a;
    return vec4((diffuseContrib * diffuse + specular) * ao * uEnv.x, alpha);
}

void main() {
    vec2 uv = vUv;
    vec3 N = vWorldNormal;

    vec2 offset = vec2(floor(time * 6.0) / 6.0);
    vec3 brushstrokes = texture2D(tLightmap, vUv * 2.0 + offset).rgb;
    vec4 baseColor = texture2D(tBaseColor, uv + brushstrokes.rg * 0.01);
    baseColor.rgb *= mix(1.0, brushstrokes.r, 0.5);
    baseColor.rgb = mix(baseColor.rgb, uTint, 0.5);

    vec3 light = uEnv;
    float lighting = dot(normalize(N + (brushstrokes.rgb * 2.0 - 1.0) * 0.1), normalize(light));
    float toon = 0.6 * smoothstep(0.66, 0.67, lighting) + 0.4;
    baseColor *= toon;
    
    vec4 color = vec4(baseColor * 1.15);
    gl_FragColor = color;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
}{@}StylizedTerrainShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tMRO;

uniform sampler2D tBaseColor;
uniform sampler2D tNormal;

uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;
uniform float uIOR;
uniform vec3 uGrassTint;

uniform float uAmbient;
uniform vec3 uAmbientColor;
uniform vec3 uShadowColor;
uniform vec3 uLightPos;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec3 vColor;
varying vec3 vLightPos;
varying vec3 vEye;
varying vec3 vNormal;
varying vec3 vGrassTint;


#!SHADER: Vertex

void main() {
    vec3 pos = position;
    vec3 n = normal;

    vUv = uv;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = modelViewMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vLightPos = normalize(uLightPos);
    vEye = normalize(modelViewPos.xyz);
    vNormal = normalMatrix * normal;
    vPos = position;
    vColor = vdata;
    vGrassTint = pow(uGrassTint, vec3(2.2));

    gl_Position = projectionMatrix * modelViewPos;
}


#!SHADER: Fragment
#require(normalmap.glsl)
#require(shadows.fs)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

vec2 getSubUV(float _width, vec2 _uv, float _index) {
    float index = _index * (1.0 / _width);
    vec2 uv = _uv;
    uv.x /= _width;
    uv.x += floor(fract(index) * _width) / _width;
    return uv;
}

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

vec2 getSubUV(vec2 _dimensions, vec2 _uv, float _index) {

    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

void main() {
    float blend = smoothstep(0.0, 0.6, vColor.r);

    vec2 uv1 = vUv;
    uv1 = fract(uv1 * uTiling);
    vec2 uv2 = uv1;

    uv1 = getSubUV(vec2(2.0), uv1, 2.0);
    uv2 = getSubUV(vec2(2.0), uv2, 3.0);


    vec3 mro1 = texture2D(tMRO, uv1).rgb;
    vec3 mro2 = texture2D(tMRO, uv2).rgb;
    vec3 mro = mix(mro1, mro2, blend);

    vec3 N = vWorldNormal;
    vec3 V = normalize(vV);

    vec3 normal1 = unpackNormal(normalize(vEye), vNormal, tNormal, uMRON.w, 1.0, uv1).xyz;
    vec3 normal2 = unpackNormal(normalize(vEye), vNormal, tNormal, uMRON.w, 1.0, uv2).xyz;
    vec3 normal = mix(normal1, normal2, blend);
    
    vec3 color = vec3(0.0);
    vec3 baseColor1 = texture2D(tBaseColor, uv1).rgb;
    // vec3 baseColor2 = texture2D(tBaseColor, uv2).rgb;
    vec3 baseColor = mix(baseColor1, uGrassTint, blend);

    baseColor = pow(baseColor, vec3(2.2));
    color += baseColor;

    vec3 shadowColor = pow(uShadowColor, vec3(2.2));

    float ior = uIOR;
    float roughness = mro.g * mro.g;
    ior *= 1.0 - roughness;
    float fresnel = 1.0 - pow(max(0.0, dot(-vEye, vNormal) * 0.5 + 0.5), max(0.0, uIOR) * 2.0);

    vec2 muv = matcap(vEye, normal);
    roughness += uMRON.y - 1.0;
    roughness = clamp(roughness, 0.0, 1.0);
    roughness = floor(roughness * 7.0);
    muv = getSubUV(8.0, muv, roughness);
    vec3 matcap = texture2D(tMatcap, muv).rgb;
    matcap = pow(matcap, vec3(2.2)) * 2.0;
    color = mix(color, matcap, fresnel);
    color = pow(color, vec3(0.45));

    float floorShadow = getShadow(vPos, 1.0/32000.0);
    color.rgb *= mix(uShadowColor, vec3(1.0), floorShadow);

    gl_FragColor.rgb = color.rgb * clamp(mro.b + uMRON.z, 0.0, 1.0) * mix(1.0 - vColor.r, 1.0, 0.35);
    // gl_FragColor.rgb  =vec3(vColor.r);
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
}{@}StylizedTerrainShaderAlt.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tWind;
uniform sampler2D tMatcap;
uniform sampler2D tMRO;

uniform sampler2D tBaseColor;
uniform sampler2D tNormal;

uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;
uniform float uIOR;

uniform float uAmbient;
uniform vec3 uAmbientColor;
uniform vec3 uShadowColor;
uniform vec3 uLightPos;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec3 vColor;
varying vec3 vLightPos;
varying vec3 vEye;
varying vec3 vNormal;
varying vec3 vGrassTint;


#!SHADER: Vertex

void main() {
    vec3 pos = position;
    vec3 n = normal;

    vUv = uv;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vec4 modelViewPos = modelViewMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vLightPos = normalize(uLightPos);
    vEye = normalize(modelViewPos.xyz);
    vNormal = normalMatrix * normal;
    vPos = position;
    vColor = vdata;

    gl_Position = projectionMatrix * modelViewPos;
}


#!SHADER: Fragment
#require(normalmap.glsl)
#require(shadows.fs)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

vec2 getSubUV(float _width, vec2 _uv, float _index) {
    float index = _index * (1.0 / _width);
    vec2 uv = _uv;
    uv.x /= _width;
    uv.x += floor(fract(index) * _width) / _width;
    return uv;
}

float envBRDFApproxNonmetal( float roughness, float NdV )
{
	const vec2 c0 = vec2(-1.0, -0.0275 );
	const vec2 c1 = vec2( 1.0, 0.0425 );
	vec2 r = roughness * c0 + c1;
	return min( r.x * r.x, exp2( -9.28 * NdV ) ) * r.x + r.y;
}

vec2 getSubUV(vec2 _dimensions, vec2 _uv, float _index) {

    float index = _index * (1.0 / _dimensions.x);
    vec2 uv = _uv;
    uv /= _dimensions;
    uv.y += (1.0 / _dimensions.y) * (_dimensions.y - 1.0);
    uv.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    uv.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    return uv;
}

void main() {
    // float t = time * 0.4;
    // float wind = texture2D(tWind, vUv * 4.0 + vec2(0.0, -t)).r;
    // wind *= texture2D(tWind, vUv * 2.0 + vec2(t * 0.2, -t)).r;
    // wind = pow(wind, 2.0);

    float blend = smoothstep(0.0, 0.6, vColor.r);

    vec2 uv1 = vUv;
    uv1 = fract(uv1 * uTiling);
    vec2 uv2 = uv1;

    uv1 = getSubUV(vec2(2.0), uv1, 2.0);
    uv2 = getSubUV(vec2(2.0), uv2, 3.0);

    vec3 mro = texture2D(tMRO, uv1).rgb;

    vec3 N = vWorldNormal;
    vec3 V = normalize(vV);

    vec3 normal = unpackNormal(normalize(vEye), vNormal, tNormal, uMRON.w, 1.0, uv1).xyz;
    
    vec3 color = vec3(0.0);
    vec3 baseColor = texture2D(tBaseColor, uv1).rgb;

    baseColor = pow(baseColor, vec3(2.2));
    color += baseColor;

    vec3 shadowColor = pow(uShadowColor, vec3(2.2));

    float ior = uIOR;
    float roughness = mro.g * mro.g;
    ior *= 1.0 - roughness;
    float fresnel = 1.0 - pow(max(0.0, dot(-vEye, vNormal) * 0.5 + 0.5), max(0.0, uIOR) * 2.0);

    vec2 muv = matcap(vEye, normal);
    roughness += uMRON.y - 1.0;
    roughness = clamp(roughness, 0.0, 1.0);
    roughness = floor(roughness * 7.0);
    muv = getSubUV(8.0, muv, roughness);
    vec3 matcap = texture2D(tMatcap, muv).rgb;
    matcap = pow(matcap, vec3(2.2)) * 2.0;
    color = mix(color, matcap, fresnel);
    color = pow(color, vec3(0.45));

    float floorShadow = getShadow(vPos, 1.0/32000.0);
    color.rgb *= mix(uShadowColor, vec3(1.0), floorShadow);

    gl_FragColor.rgb = color.rgb * clamp(mro.b + uMRON.z, 0.0, 1.0);
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
}{@}TestNPCShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tBaseColor;
uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform sampler2D tLUT;

uniform sampler2D tEnvDiffuse;
uniform sampler2D tEnvSpecular;

uniform sampler2D tLightmap;
uniform float uUseLightmap;
uniform float uLightmapIntensity;

uniform vec4 uParams;
uniform vec3 uFogColor;

uniform vec3 uTint;
uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;
uniform vec3 uEnv;

uniform float uHDR;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec4 vColor;


#!SHADER: Vertex
#require(skinning.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;

    applySkin(pos, n);
    // pos = mix((pos - vec3(0.0, 4.0, 0.0)) * 2.0, position, 0.2);

    vUv = uv * uTiling + uOffset;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    // vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vWorldNormal = n;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}


#!SHADER: Fragment
#require(normalmap.glsl)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * cosTheta - 6.98316) * cosTheta);
}

vec2 sampleSphericalMap(vec3 v)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;
    // match default C4D baked HDRI
    uv.x = uv.x + 0.25 + uEnv.z; 

    return uv;
}

vec4 SRGBtoLinear(vec4 srgb) {
    vec3 linOut = pow(srgb.xyz, vec3(2.2));
    return vec4(linOut, srgb.w);
}

vec3 linearToSRGB(vec3 color) {
    return pow(color, vec3(0.4545454545454545));
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec4 autoToLinear(vec4 texel, float uHDR) {
    vec4 color = RGBMToLinear(texel);
    // if (uHDR == 0.0) { color = SRGBtoLinear(texel); }
    return color;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N, sampler2D tLUT, sampler2D tEnvDiffuse, sampler2D tEnvSpecular) {
    float metallic = clamp(MRO.x + uMRON.x - 1.0, 0.0, 1.0);
    float roughness = clamp(MRO.y + uMRON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uMRON.z);

    vec2 lutUV = vec2(NdV, roughness);
    vec2 diffuseUV = sampleSphericalMap(N);

    vec3 brdf = SRGBtoLinear(texture2D(tLUT, lutUV)).rgb;
    vec3 diffuse = autoToLinear( texture2D(tEnvDiffuse, diffuseUV ), uHDR).rgb;

    vec3 lightmap = vec3(1.0);

    // if (uUseLightmap > 0.0) {
    //     lightmap = texture2D(tLightmap, vUv2).rgb;
    //     lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
    //     diffuse.rgb *= lightmap.rgb;
    // }

    diffuse *= baseColor.rgb;

    float level = floor(roughness * ENV_LODS);
    vec2 specUV = sampleSphericalMap(R);

    specUV.y /= 2.0;
    specUV /= pow(2.0, level);
    specUV.y += 1.0 - exp(-LN2 * level);

    vec3 specular = autoToLinear(texture2D(tEnvSpecular, specUV), uHDR).rgb;

    // fake stronger specular highlight
    specular += pow(specular, vec3(2.2)) * uEnv.y;

    // if (uUseLightmap > 0.0) {
    //     specular *= lightmap;
    // }

    vec3 F0 = vec3(0.01);
    F0 = mix(F0, baseColor.rgb, metallic);

    vec3 F = fresnelSphericalGaussianRoughness(NdV, F0, roughness);

    vec3 diffuseContrib = 1.0 - F;
    specular = specular.rgb * (F);

    diffuseContrib *= 1.0 - metallic;

    float alpha = baseColor.a;
    return vec4((diffuseContrib * diffuse + specular) * ao * uEnv.x, alpha);
}

void main() {
    // vec2 uv = vUv;
    vec3 N = vWorldNormal;
    // vec3 V = normalize(vV);
    // vec3 worldNormal = unpackNormal(V, N, tNormal, uMRON.w, 1.0, uv).xyz;
    // vec3 R = reflect(V, worldNormal);
    // float NdV = abs(dot(worldNormal, V));

    // vec4 MRO = texture2D(tMRO, uv);
    // vec4 baseColor = texture2D(tBaseColor, uv);
    // baseColor = SRGBtoLinear(baseColor);
    
    // vec4 color = getIBLContribution(NdV, baseColor, MRO, R, V, worldNormal, tLUT, tEnvDiffuse, tEnvSpecular);
    // color.rgb = pow(color.rgb, vec3(0.45454545));
    // color.rgb = vec3(1.0, 0.0, 0.0);
    vec4 color = vec4(dot(normalize(N), vec3(0.0, 1.0, 0.0))) * 0.5 + 0.5;
    gl_FragColor = color;
    gl_FragColor.a = 1.0;
}{@}ToonNPCShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tOriginal;
uniform float uOriginalMix;

uniform sampler2D tCrossHatch;
uniform sampler2D tBaseColor;
uniform sampler2D tNormal;

uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;

uniform float uBrushIntensity;
uniform float uAmbient;
uniform vec3 uAmbientColor;
uniform float uHighlightLevel;
uniform float uHighlightSoftness;
uniform vec3 uHighlightColor;
uniform float uShadowLevel;
uniform float uShadowSoftness;
uniform vec3 uShadowColor;
uniform vec3 uLightPos;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec4 vColor;
varying vec3 vLightPos;


#!SHADER: Vertex
#require(skinning.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;

    applySkin(pos, n);
    // pos -= n * 0.005;
    // pos = mix((pos - vec3(0.0, 4.0, 0.0)) * 2.0, position, 0.2);

    vUv = uv;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    // vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vWorldNormal = n;
    vLightPos = normalize(uLightPos);

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}


#!SHADER: Fragment
#require(normalmap.glsl)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

void main() {
    vec2 uv = vUv;
    vec3 N = vWorldNormal;
    vec3 V = normalize(vV);
    vec3 normal = unpackNormal(V, N, tNormal, uMRON.w, 1.0, uv).xyz;
    vec2 offset = vec2(floor(time * 6.0) / 6.0);
    offset = vec2(0.0);
    vec3 color = vec3(0.0);
    vec3 baseColor = texture2D(tBaseColor, uv).rgb * uAmbient;
    baseColor = pow(baseColor, vec3(2.2));
    color += baseColor;

    float lighting = dot(normalize(normal), vLightPos);
    float brushStrokes = texture2D(tCrossHatch, vUv * uTiling + offset).r;

    float highlight = smoothstep(uHighlightLevel - uHighlightSoftness, uHighlightLevel + uHighlightSoftness, lighting * mix(1.0, brushStrokes, uBrushIntensity));
    float shadow = smoothstep(uShadowLevel - uShadowSoftness, uShadowLevel + uShadowSoftness, lighting + mix(1.0, brushStrokes, uBrushIntensity) - 0.5);
    
    vec3 shadowColor = pow(uShadowColor, vec3(2.2));
    vec3 highlightColor = pow(uHighlightColor, vec3(2.2));
    vec3 lightColor = vec3(0.0);

    color *= mix(shadowColor, vec3(1.0), shadow);
    color += mix(vec3(0.0), highlightColor, highlight);
    color = pow(color, vec3(0.45));

    // float crossHatch = texture2D(tCrossHatch, vUv * uTiling + offset).r;
    // float lighting = dot(normalize(normal), normalize(uEnv));
    // float toon = 0.6 * smoothstep(0.66, 0.67, lighting) + 0.4;
    // float darkHatch = clamp(crossHatch + max(0.0, lighting - 0.1), 0.0, 1.0);
    // float lightHatch = smoothstep(uOffset.x, uOffset.x + 0.05, mix(lighting, crossHatch, 0.2));
    // vec3 innerLines = texture2D(tMRO, vUv).rgb;
    // float innerLine = mix(innerLines.r, 1.0, max(0.0, lighting));
    // float pupils = innerLines.g;
    // float eyeWhites = innerLines.b;

    // baseColor.rgb *= min(1.0, max(0.5, lighting * 0.5 + 0.6));
    // baseColor.rgb *= mix(uInnerLineColor, vec3(1.0), innerLine);
    // baseColor.rgb += mix(vec3(0.0), uLightHatchColor, lightHatch);

    // baseColor.rgb *= mix(uDarkHatchColor, vec3(1.0), darkHatch);
    // baseColor.rgb = mix(uEyeWhitesColor, baseColor.rgb, clamp(eyeWhites + 0.2, 0.0, 1.0));
    // baseColor.rgb *= pupils;
    // vec4 color = vec4(baseColor * 1.2);
    float unstylizedLighting = max(0.25, dot(normalize(normal), vec3(0.0, 1.0, 0.4))) * 1.5;
    gl_FragColor.rgb = mix(color.rgb, texture2D(tOriginal, vUv).rgb * unstylizedLighting, uOriginalMix);
    gl_FragColor.a = 1.0;
}{@}ToonNPCShaderOutline.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tBaseColor;
uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform sampler2D tLUT;

uniform sampler2D tEnvDiffuse;
uniform sampler2D tEnvSpecular;

uniform sampler2D tLightmap;
uniform float uUseLightmap;
uniform float uLightmapIntensity;

uniform vec4 uParams;
uniform vec3 uFogColor;

uniform vec3 uTint;
uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;
uniform vec3 uEnv;

uniform float uHDR;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec4 vColor;


#!SHADER: Vertex
#require(skinning.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;

    applySkin(pos, n);

    vec2 offset = vec2(floor(time * 6.0) / 6.0);
    vec3 brushstrokes = texture2D(tLightmap, uv * 2.0 + offset).rgb;
    // pos += n * 0.0075 * brushstrokes.r;
    pos += n * 0.0055 * uMRON.z;
    // pos = mix((pos - vec3(0.0, 4.0, 0.0)) * 2.0, position, 0.2);

    vUv = uv * uTiling + uOffset;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    // vWorldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * n;
    vWorldNormal = n;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}


#!SHADER: Fragment
#require(normalmap.glsl)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

vec3 fresnelSphericalGaussianRoughness(float cosTheta, vec3 F0, float roughness) {
	return F0 + (max(vec3(1.0 - roughness), F0) - F0) * pow(2.0, (-5.55473 * cosTheta - 6.98316) * cosTheta);
}

vec2 sampleSphericalMap(vec3 v)
{
    vec2 uv = vec2(atan(v.z, v.x), asin(v.y));
    uv *= INV_ATAN;
    uv += 0.5;
    // match default C4D baked HDRI
    uv.x = uv.x + 0.25 + uEnv.z; 

    return uv;
}

vec4 SRGBtoLinear(vec4 srgb) {
    vec3 linOut = pow(srgb.xyz, vec3(2.2));
    return vec4(linOut, srgb.w);
}

vec3 linearToSRGB(vec3 color) {
    return pow(color, vec3(0.4545454545454545));
}

vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec4 autoToLinear(vec4 texel, float uHDR) {
    vec4 color = RGBMToLinear(texel);
    // if (uHDR == 0.0) { color = SRGBtoLinear(texel); }
    return color;
}

vec4 getIBLContribution(float NdV, vec4 baseColor, vec4 MRO, vec3 R, vec3 V, vec3 N, sampler2D tLUT, sampler2D tEnvDiffuse, sampler2D tEnvSpecular) {
    float metallic = clamp(MRO.x + uMRON.x - 1.0, 0.0, 1.0);
    float roughness = clamp(MRO.y + uMRON.y - 1.0, 0.0, 1.0);
    float ao = mix(1.0, MRO.z, uMRON.z);

    vec2 lutUV = vec2(NdV, roughness);
    vec2 diffuseUV = sampleSphericalMap(N);

    vec3 brdf = SRGBtoLinear(texture2D(tLUT, lutUV)).rgb;
    vec3 diffuse = autoToLinear( texture2D(tEnvDiffuse, diffuseUV ), uHDR).rgb;

    vec3 lightmap = vec3(1.0);

    // if (uUseLightmap > 0.0) {
    //     lightmap = texture2D(tLightmap, vUv2).rgb;
    //     lightmap.rgb = pow(lightmap.rgb, vec3(2.2));
    //     diffuse.rgb *= lightmap.rgb;
    // }

    diffuse *= baseColor.rgb;

    float level = floor(roughness * ENV_LODS);
    vec2 specUV = sampleSphericalMap(R);

    specUV.y /= 2.0;
    specUV /= pow(2.0, level);
    specUV.y += 1.0 - exp(-LN2 * level);

    vec3 specular = autoToLinear(texture2D(tEnvSpecular, specUV), uHDR).rgb;

    // fake stronger specular highlight
    specular += pow(specular, vec3(2.2)) * uEnv.y;

    // if (uUseLightmap > 0.0) {
    //     specular *= lightmap;
    // }

    vec3 F0 = vec3(0.01);
    F0 = mix(F0, baseColor.rgb, metallic);

    vec3 F = fresnelSphericalGaussianRoughness(NdV, F0, roughness);

    vec3 diffuseContrib = 1.0 - F;
    specular = specular.rgb * (F);

    diffuseContrib *= 1.0 - metallic;

    float alpha = baseColor.a;
    return vec4((diffuseContrib * diffuse + specular) * ao * uEnv.x, alpha);
}

void main() {
    vec2 uv = vUv;
    vec3 N = vWorldNormal;
    // vec3 V = normalize(vV);
    // vec3 worldNormal = unpackNormal(V, N, tNormal, uMRON.w, 1.0, uv).xyz;
    // vec3 R = reflect(V, worldNormal);
    // float NdV = abs(dot(worldNormal, V));

    // vec4 MRO = texture2D(tMRO, uv);
    vec3 brushstrokes = texture2D(tLightmap, vUv * 20.0).rgb;
    vec4 baseColor = texture2D(tBaseColor, uv + brushstrokes.rg * 0.01);
    baseColor.rgb = mix(baseColor.rgb, uTint, 0.5);

    // baseColor = SRGBtoLinear(baseColor);
    
    // vec4 color = getIBLContribution(NdV, baseColor, MRO, R, V, worldNormal, tLUT, tEnvDiffuse, tEnvSpecular);
    // color.rgb = pow(color.rgb, vec3(0.45454545));
    // color.rgb = vec3(1.0, 0.0, 0.0);
    vec3 light = uEnv;
    float lighting = dot(normalize(N + (brushstrokes.rgb * 2.0 - 1.0) * 0.1), normalize(light));
    float toon = 0.6 * smoothstep(0.66, 0.67, lighting) + 0.4;
    baseColor *= toon;
    // baseColor += max(0.0, 1.0 - lighting) * 0.2;
    vec4 color = vec4(baseColor);
    gl_FragColor = vec4(uTint, 1.0);
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
}{@}ToonRockShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tOriginal;
uniform float uOriginalMix;

uniform sampler2D tCrossHatch;
uniform sampler2D tBaseColor;
uniform sampler2D tMRO;
uniform sampler2D tNormal;
uniform sampler2D tLUT;

uniform sampler2D tLightmap;
uniform float uUseLightmap;
uniform float uLightmapIntensity;

uniform vec4 uParams;
uniform vec3 uFogColor;
uniform vec3 uDarkHatchTint;
uniform vec3 uInnerLineTint;
uniform vec3 uEyeWhitesTint;
uniform vec3 uShadowColor;

uniform vec3 uTint;
uniform vec2 uTiling;
uniform vec2 uOffset;
uniform vec4 uMRON;
uniform vec3 uEnv;

uniform float uHDR;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying vec3 vV;
varying vec3 vWorldNormal;
varying vec4 vColor;


#!SHADER: Vertex
#require(skinning.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;

    vUv = uv;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    vV = worldPos.xyz - cameraPosition;
    vWorldNormal = n;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vPos = position;
}


#!SHADER: Fragment
#require(normalmap.glsl)
#require(shadows.fs)

const vec2 INV_ATAN = vec2(0.1591, 0.3183);
const float LN2 = 0.6931472;
const float ENV_LODS = 7.0;

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

void main() {
    vec2 uv = vUv;
    vec3 N = vWorldNormal;
    vec3 V = normalize(vV);
    vec3 normal = unpackNormal(V, N, tNormal, 1.0, 1.0, uv).xyz;
    // vec3 R = reflect(V, worldNormal);
    // float NdV = abs(dot(worldNormal, V));

    // vec4 MRO = texture2D(tMRO, uv);
    vec2 offset = vec2(floor(time * 6.0) / 6.0);
    offset = vec2(0.0);
    vec4 baseColor = texture2D(tBaseColor, uv);
    baseColor.rgb = mix(baseColor.rgb, uEyeWhitesTint, 0.8);
    // baseColor.rgb *= mix(1.0, brushstrokes.r, 0.5);
    // baseColor.rgb = mix(baseColor.rgb, uTint, 0.0);

    float crossHatch = texture2D(tCrossHatch, vUv * uTiling + offset).r;
    // baseColor = SRGBtoLinear(baseColor);
    
    // vec4 color = getIBLContribution(NdV, baseColor, MRO, R, V, worldNormal, tLUT, tEnvDiffuse, tEnvSpecular);
    // color.rgb = pow(color.rgb, vec3(0.45454545));
    // color.rgb = vec3(1.0, 0.0, 0.0);
    // float lighting = dot(normalize(normal + (brushstrokes.rgb * 2.0 - 1.0) * 0.1), normalize(uEnv));
    // float lighting = dot(normalize(normal), normalize(uEnv));
    float lighting = dot(normalize(normal), normalize(uEnv));
    float darkHatch = clamp(crossHatch + max(0.0, lighting - 0.1), 0.0, 1.0);
    float lightHatch = smoothstep(uOffset.x, uOffset.x + uOffset.y, mix(lighting, crossHatch, 0.2));
    vec3 innerLines = texture2D(tMRO, vUv).rgb;
    // float innerLine = mix(innerLines.r, 1.0, max(0.0, lighting));
    float innerLine = innerLines.r;
    // float pupils = innerLines.g;
    // float eyeWhites = innerLines.b;
    // baseColor *= toon;

    // baseColor.rgb = uTint;
    baseColor.rgb *= min(1.0, max(0.5, lighting * 0.5 + 0.6));
    baseColor.rgb *= mix(uInnerLineTint, vec3(1.0), innerLine);
    baseColor.rgb += mix(vec3(0.0), uTint, lightHatch);

    baseColor.rgb *= mix(uDarkHatchTint, vec3(1.0), darkHatch);
    // baseColor.rgb = mix(uEyeWhitesTint, baseColor.rgb, clamp(eyeWhites + 0.2, 0.0, 1.0));
    // baseColor.rgb *= pupils;
    // baseColor.rgb += lightHatch;
    // baseColor += max(0.0, 1.0 - lighting) * 0.2;
    vec4 color = vec4(baseColor);
    float shadow = getShadow(vPos, 1.0/32000.0);
    color.rgb *= mix(uShadowColor, vec3(1.0), shadow);
    gl_FragColor = color;

    float unstylizedShadow = max(0.25, shadow);
    gl_FragColor.rgb = mix(color.rgb, texture2D(tOriginal, vUv).rgb * unstylizedShadow, uOriginalMix);
    // gl_FragColor = vec4(shadow);
    gl_FragColor.a = 1.0;
    gl_FragColor.a = 1.0;
}{@}PaperBagShader.glsl{@}#!ATTRIBUTES
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMatcap;
uniform sampler2D tNormal;
uniform float uNormalTiling;
uniform float uNormalIntensity;

#!VARYINGS
varying vec2 vUv;
varying vec3 vEye;
varying vec3 vNormal;
varying vec3 vN;
varying vec3 vV;


#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec3 worldPos = vec3(modelMatrix * vec4(pos, 1.0));
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vNormal = normalMatrix * normal;
    vN = normalMatrix * normal;
    vEye = vec3(modelViewMatrix * vec4(pos, 1.0));
    vV = worldPos.xyz - cameraPosition;
}

#!SHADER: Fragment
#require(normalmap.glsl)
vec2 matcap(vec3 eye, vec3 normal) {
  vec3 reflected = reflect(eye, normal);
  float m = 2.8284271247461903 * sqrt( reflected.z+1.0 );
  return reflected.xy / m + 0.5;
}

void main() {
    vec3 normal = unpackNormal(vV, vNormal, tNormal, uNormalIntensity, uNormalTiling, vUv).xyz;

    vec2 muv = matcap(normalize(vEye), normalize(normal));

    // float lighting = dot(normalize(vN), normalize(vec3(1.0, 1.0, 0.0))) * 0.5 + 0.5;

    vec3 color = texture2D(tMatcap, muv).rgb;
    // color *= lighting;

    gl_FragColor = vec4(color, 1.0);
}{@}ParticlePerfTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;
uniform sampler3D tVolume3D;
uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
