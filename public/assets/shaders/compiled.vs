    vec3 color = vec3(0.0);

    gl_FragColor = vec4(color, alpha);
}{@}ParticleShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;
uniform sampler3D tVolume3D;
uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec3 vMvPos;
varying vec3 vPos;
varying vec3 vColor;

#!SHADER: Vertex

void main() {
    vec4 decodedPos = texture2D(tPos, position.xy);
    float scale = 2.0;
    vec3 pos = decodedPos.xyz;
    
    // animated noise
    vec3 n = random.xyz;
    // pos += n * sin(length(pos.xyz) + time * 0.25) * 0.5;

    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = scale * mix(0.01, 0.04, random.x * 0.5 + 0.5) * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;

    vMvPos = mvPosition.xyz;
    vPos = (modelMatrix * decodedPos).xyz;

    // fade from epicenter
    float falloff = 1.0 - min(1.0, length(pos) * 0.2);

    // radial pulse
    falloff += (sin(falloff * 12.0 + time * 1.0)) * falloff;
    
    vColor = mix(uColor1, uColor2, random.w) * falloff;
}

#!SHADER: Fragment

void main() {
    vec2 uv = gl_PointCoord.xy;

    float circle = 1.0 - smoothstep(0.0, 0.5, length(uv - 0.5));
    float alpha = circle * 0.3;
    vec3 color = vColor;
    gl_FragColor = vec4(color, alpha * 0.5);
}{@}CelImageShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tMap2;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}

#!SHADER: Fragment
void main() {
    vec4 color = texture2D(tMap, vUv);
    vec4 color2 = texture2D(tMap2, vUv + vec2(0.0, -time * 0.2));
    float value = step(0.9, color.r + color2.g * 0.4);
    gl_FragColor = vec4(value);
}{@}MainPortalShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap1;
uniform sampler2D tMap2;
uniform sampler2D tMap3;
uniform sampler2D tMap4;

#!VARYINGS
varying vec2 vUv;
varying vec2 vPolarUv;
varying vec2 vPolarUv2;
varying vec3 vColor;
varying float vDist;

#!SHADER: Vertex
const float TWO_PI = 3.14159 * 2.0;
const float PI = 3.14159;

void main() {
    vec3 pos = position;
    float t = time * 0.5;
    vUv = uv;

    vec2 tc = uv;
    tc -= 0.5;
    float x = atan(tc.x, tc.y);
    float y = length(tc);
    vDist = y;

    vPolarUv = vec2(x / TWO_PI, y);

    vColor = texture2D(tMap1, vPolarUv).rgb;


    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment
const float TWO_PI = 3.14159 * 2.0;
const float PI = 3.14159;

void main() {
    float t = time * 0.5;
    vec2 uv = vUv;

    vec2 tc = uv;
    tc -= 0.5;
    float x = atan(tc.x, tc.y);
    float y = length(tc);
    float dist = y;

    y -= t * 0.1;
    vec2 polarUv = vec2(x / TWO_PI, y);

    // y -= t * 0.02;
    // x += t * 0.1;
    // vec2 polarUv2 = vec2(x / TWO_PI, y);

    vec3 color1 = texture2D(tMap1, polarUv + vColor.rg * 0.01).rgb;
    vec3 color2 = texture2D(tMap1, polarUv + vColor.rg * 0.01 - vec2(time * 0.0073, time * 0.01 + 0.5)).rgb;

    vec3 color = max(color1, color2);
    color *= 1.0 - dist * 2.0;

    vec3 noise = texture2D(tMap2, vUv).rgb;
    vec3 animatedNoise = texture2D(tMap2, polarUv).rgb;
    // float rim = smoothstep(0.0, 0.1, noise.b) * (1.0 - smoothstep(-1.0, 1.0, noise.b));
    
    float grad = length(vUv - 0.5) * 2.0;
    grad *= noise.b;
    grad += animatedNoise.g * 0.2;
    grad -= animatedNoise.r * 0.2;

    float hardMask = step(0.5, grad);

    float grad1 = abs(grad - 0.5);
    float rim = 1.0 - smoothstep(0.0, 0.05, grad1);

    float mainGlow = (1.0 - grad) * hardMask + rim;
    mainGlow = color.b * 4.0 * hardMask + rim;

    gl_FragColor = vec4(mainGlow);
}{@}SimpleUvShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    gl_FragColor = vec4(vUv, 0.0, 1.0);
}{@}TorusPortalShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform sampler2D tMap1;
uniform sampler2D tMap2;
uniform sampler2D tMap3;
uniform sampler2D tMap4;

#!VARYINGS
varying vec2 vUv;
varying vec2 vPolarUv;
varying vec2 vPolarUv2;
varying vec3 vColor;
varying float vDist;
varying vec3 vColor;

#!SHADER: Vertex
const float TWO_PI = 3.14159 * 2.0;
const float PI = 3.14159;

void main() {
    vUv = uv;
    vec3 pos = position;

    vec3 color = vdata;
    vColor = color;

    vec3 noise = color * 25.0 + time;
    noise.r = sin(noise.r);
    noise.g = sin(noise.g);
    noise.b = sin(noise.b);
    // vColor = noise;

    pos += noise * 0.02;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}

#!SHADER: Fragment
const float TWO_PI = 3.14159 * 2.0;
const float PI = 3.14159;

void main() {
    float t = time * 0.25;
    vec2 uv = vUv;

    vec3 n1 = texture2D(tMap2, vUv * vec2(2.0, 1.0) + vColor.rg * 0.1 + vec2(t * 0.01, t * 0.13)).rgb;
    vec3 n2 = texture2D(tMap3, vUv + vColor.rg * 0.05 + vec2(t * 0.003, t * 0.17)).rgb;

    float verticalGradient = uv.y;
    float alpha = step(0.055, verticalGradient);
    if (alpha < 0.5) discard;

    float rim = pow(verticalGradient, 50.0);
    float softGradient = pow((verticalGradient - 0.4) * 2.5, 2.0);

    alpha = n1.r * n2.r * softGradient;
    alpha *= 3.0;
    alpha = smoothstep(0.2, 1.0, alpha);
    alpha += rim;

    // vec3 color1 = texture2D(tMap1, vUv + vec2(t * 0.01, t * 0.1)).rgb;
    // vec3 color2 = texture2D(tMap1, vUv + vec2(t * 0.0173 + 0.5, t * 0.113)).rgb;

    // color1 = max(color1, color2);

    vec3 color1 = texture2D(tMap1, vUv).rgb;
    gl_FragColor = vec4(alpha);
}{@}WindowPortalShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tWindow;
uniform sampler2D tNormal;
uniform vec4 uUvTransform;

#!VARYINGS
varying vec3 vEye;
varying vec3 vPos;
varying vec3 vN;
varying vec3 vV;
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vec4 worldPos = modelMatrix * vec4(position, 1.0);
    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vV = worldPos.xyz - cameraPosition.xyz;
    vN = normalMatrix * normal;
    vUv = uv;
    vPos = position;
}

#!SHADER: Fragment
#require(normalmap.glsl)

const float PI = 3.14159;

void main() {
    vec2 newUv = vec2(0.0);
    vec3 V = normalize(vV);
    vec3 N = normalize(vN);
    newUv.x = 0.5 + atan(V.z,V.x)/(PI*2.0);
    newUv.y = 0.5 - asin(V.y)/PI;
    newUv.y = -newUv.y;

    float t = time * 0.05;
    vec3 normal1 = unpackNormal(V, N, tNormal, 1.0, 3.0, vUv + vec2(t, -t)).xyz;
    vec3 normal2 = unpackNormal(V, N, tNormal, 1.0, 3.0, vUv * 0.5 + vec2(-t * 0.5, t * 0.5)).xyz;
    vec3 normal = min(normal1, normal2);

    float dist = length(vPos.xyz - vec3(0.0, 1.0, 0.0));

    // to remove seams
    // vec2 dx = dFdx(newUV);
    // vec2 dy = dFdy(newUV);
    // vec2 du = vec2(dx.x, dy.x);
    // du.x -= (abs(du.x) > 0.5) * sign(du.x);
    // du.y -= (abs(du.y) > 0.5) * sign(du.y);
    // dx.x = du.x;
    // dy.x = du.y;

    vec4 windowTexture = texture2D(tWindow, newUv * uUvTransform.xy + uUvTransform.zw);
    gl_FragColor = windowTexture;
}{@}RainShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying float vDist;
varying vec3 vRayDir;
varying vec3 vRayOrigin;
varying vec3 vSamplePos;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);

    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;

    vec3 rayDir = worldPos.xyz - cameraPosition;
    
    vRayDir = rayDir;
    vec3 rayOrigin = worldPos.xyz - rayDir;
    vec3 samplePos = rayOrigin;
    vRayOrigin = rayOrigin;
    vSamplePos = rayOrigin - rayDir * 300.0;
    vPos = pos;
}

#!SHADER: Fragment


float getPlane(vec3 samplePos, vec3 rayDir, vec3 plane, vec3 target) {
    float res = length(samplePos - target);
    res = res / dot(rayDir, plane);
    return res;
}

void main() {
    vec3 rayDir1 = normalize(vRayDir);
    vec3 rayDir2 = rayDir1;
    rayDir1.z = abs(rayDir1.z);
    rayDir2.x = abs(rayDir2.x);
    
    float t = -time * 1.5;
    vec2 textureScale = vec2(0.02);
    float dist1 = 0.0;
    float dist2 = 0.0;
    vec3 samplePos1 = vSamplePos;
    vec3 samplePos2 = vSamplePos;

    dist1 = getPlane(vSamplePos, rayDir1, vec3(0.0, 0.0, 1.0), vec3(vSamplePos.x, vSamplePos.y, 10.0));
    samplePos1 = vSamplePos + dist1 * rayDir1;
    float val1 = texture2D(tMap, samplePos1.xy * textureScale + vec2(0.0, t * sign(vSamplePos.z))).r;
    dist1 = getPlane(vSamplePos, rayDir1, vec3(0.0, 0.0, 1.0), vec3(vSamplePos.x, vSamplePos.y, 30.0));
    samplePos1 = vSamplePos + dist1 * rayDir1;
    val1 += texture2D(tMap, samplePos1.xy * textureScale + vec2(0.0, t * sign(vSamplePos.z))).r;

    dist2 = getPlane(vSamplePos, rayDir2, vec3(1.0, 0.0, 0.0), vec3(10.0, vSamplePos.y, vSamplePos.z));
    samplePos2 = vSamplePos + dist2 * rayDir2;
    float val2 = texture2D(tMap, samplePos2.zy * textureScale + vec2(0.0, t * sign(vSamplePos.x))).r;
    dist2 = getPlane(vSamplePos, rayDir2, vec3(1.0, 0.0, 0.0), vec3(30.0, vSamplePos.y, vSamplePos.z));
    samplePos2 = vSamplePos + dist2 * rayDir2;
    val2 += texture2D(tMap, samplePos2.zy * textureScale + vec2(0.0, t * sign(vSamplePos.x))).r;

    float val = val1 + val2;

    val = pow(val, 2.0);
    val *= 5.0;

    vec3 color = vec3(val);

    gl_FragColor = vec4(color, 1.0);
}{@}RaindropShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vPos = (modelMatrix * vec4(position, 1.0)).xyz;
}

#!SHADER: Fragment
#require(rotation.glsl)

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 getRain(vec2 uv, float t, float seed) {
    // we need three grids. 
    float gridSize = 30.0;
    
    // a grid of uvs, 
    vec2 uvGrid = fract(uv * gridSize);

    // a grid of static random black-to-white values, 
    vec2 maskGrid = floor(uv * gridSize) / gridSize;
    vec2 largeMaskGrid = floor(uv * gridSize * 0.25) / gridSize * 0.25;
    float randGrid = rand(maskGrid * 12.0 + seed);
    float randGridLarge = rand(largeMaskGrid * 72.1 + seed * 23.0);

    // randGridLarge = 1.0;

    // and a grid of animating black-to-white values
    float animatedGrid = fract(randGrid + randGridLarge + t);

    float driver = animatedGrid;

    // ripple
    float dist = length(uvGrid - 0.5);
    float width = 0.035;
    float z = smoothstep(driver - width, driver, dist);
    z += smoothstep(driver - width, driver - width * 2.0, dist);
    z = 1.0 - z;
    float mask = clamp(z, 0.0, 1.0);
    float edgeMask = clamp((1.0 - dist * 1.66), 0.0, 1.0);
    edgeMask = pow(edgeMask, 4.0);

    float circles = dist;
    circles = smoothstep(driver, driver - width, circles);
    circles *= smoothstep(driver - width * 2.0, driver - width, dist);
    circles *= sin(circles * 4.0);

    // generate normals by using x/y from the uvs, and the concentric circles for depth
    vec3 normal = vec3(uvGrid.x - 0.5, uvGrid.y - 0.5, circles);
    normal = normalize(normal) * 4.0;
    normal = mix(normal, vec3(0.0, 0.0, 1.0), (1.0 - circles * 2.0));
    normal = mix(normal, vec3(0.0, 0.0, 1.0), 1.0 - edgeMask);

    // normal =  vec3(animatedGrid);

    return normal;
}

void main() {
    float t = time * 0.45;
    vec2 uv = vPos.xz * 0.02;
    vec2 rotatedUv1 = rotationMatrix(0.3) * uv;
    vec2 rotatedUv2 = rotationMatrix(0.5) * uv;

    // layer some rains
    vec3 normal = getRain(uv + vec2(0.1), t, 216.0);
    normal += getRain(rotatedUv1 * 1.1 + vec2(3.52, 0.05), t * 1.05 + 0.55, 662.0);
    normal += getRain(rotatedUv2 * 0.86 + vec2(0.31, 2.75), t * 0.97 + 0.4, 134.0);
    normal += getRain(rotatedUv1 * 0.92 + vec2(0.44, 1.16), t * 1.03 + 2.67, 564.0);
    normal += getRain(uv * 1.1 + vec2(1.52, 0.2), t * 1.07 + 0.82, 82.0);
    normal *= 2.0;

    vec3 color = vec3(normal * 0.5 + 0.5);
    // vec3 color = normal;

    gl_FragColor = vec4(color, 1.0);
}{@}NormalBlendShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS

#!VARYINGS
varying vec3 vNormal;
varying vec3 vColor;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    float normalBlend = vdata.x;
    vec3 upVector = vec3(0.0, 1.0, 0.0);
    vec3 n = mix(normal, upVector, normalBlend);
    vNormal = normalMatrix * n;
    vColor = vdata;
}

#!SHADER: Fragment
void main() {

    gl_FragColor = vec4(vNormal, 1.0);
}{@}RoundedCornersShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vViewNormal;
varying vec3 vView;
varying vec3 vPos;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
    vNormal = normal;
    vViewNormal = normalMatrix * normal;
    vView = normalize(cameraPosition - position.xyz);
    vPos = position.xyz;
}

#!SHADER: Fragment


float edge_detection(vec3 p) {
  vec3 ddx = dFdx(p);
  vec3 ddy = dFdy(p);
  float edge = max(dot(ddx,ddx), dot(ddy,ddy));
  return sqrt(edge);
}

// void main() {
//   vec3 normal = normalize(v_normal);
//   vec3 view = normalize(camera_position - v_position.xyz);
//   vec3 edge = edge_detection(v_position.xyz);
//   float t = smoothstep(1.0 - BEVEL_WIDTH, 1.0, edge);
//   vec3 bevel = mix(normal, view_normal(normal, view), t);
//   vec3 light = normalize(light_position - v_position.xyz);
//   float diffuse = max(dot(bevel, light), 0.0);
//   vec3 final_color = diffuse * diffuse_color.rgb;
//   gl_FragColor = vec4(final_color, 1.0);
// }

void main() {
    float BEVEL_WIDTH = 0.1;
    vec3 normal = normalize(vNormal);
    vec3 viewNormal = normalize(vView + normal);
    float edge = edge_detection(vNormal.xyz);
    float t = smoothstep(1.0 - BEVEL_WIDTH, 1.0, edge);

    float ddx = dFdx(vNormal.x);
    vec3 ddy = dFdy(vNormal.xyz);

    vec3 color = vec3(abs(ddx) * 1000.0);
    gl_FragColor = vec4(color, 1.0);
}{@}CloudFluffyRE.glsl{@}{@}CloudVFX.fs{@}
uniform float uRGBStrength;
uniform float uExposure;

#require(UnrealBloom.fs)
#require(simplenoise.glsl)
#require(HydraBloom.glsl)

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

vec3 unreal(vec3 x) {
  return x / (x + 0.155) * 1.019;
}

void main() {
    vec4 color = texture2D(tDiffuse, vUv);

    vec3 bloom = pow(getUnrealBloom(vUv).rgb, vec3(2.2));
    // bloom = mix(bloom, uncharted2(bloom), 0.5);
    // vec3 bloom = getHydraBloom(vUv);
    // color.rgb += bloom;

    color.rgb = pow(color.rgb, vec3(2.2));
    // color.rgb = uncharted2(color.rgb);
    color.rgb += bloom;
    // color.rgb = pow(color.rgb, vec3(0.45454545));
    color.rgb = pow(color.rgb, vec3(0.45));
    // color.rgb = unreal(color.rgb);



    color.rgb += (getNoise(vUv, time) - 0.5) * 0.1;

    // color.rgb = mix(texture2D(tDiffuse, vUv).rgb + getUnrealBloom(vUv).rgb, color.rgb, 0.0);

    // color.rgb = uncharted2(bloom);
    // color.rgb = bloom;

  gl_FragColor = color;
}{@}DerivativeTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);

    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec3 color = texture2D(tMap, vUv).rgb;
    float mask = (dFdx(color.g) + dFdx(color.r) + dFdy(color.g) + dFdy(color.r)) * 10.0;
    mask = clamp(mask, 0.0, 1.0);
    gl_FragColor = vec4(vec3(mask), 1.0);
}{@}FullScreenShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec4 color = texture2D(tMap, vUv);
    gl_FragColor = color;
}{@}NormalTestShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

