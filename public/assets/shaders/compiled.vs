varying vec3 vPos;

#!SHADER: Vertex

void main() {
    vec4 decodedPos = texture2D(tPos, position.xy);
    float scale = 2.0;
    vec3 pos = decodedPos.xyz;

    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = scale * 0.05 * (1000.0 / length(mvPosition.xyz));
    gl_Position = projectionMatrix * mvPosition;

    vMvPos = mvPosition.xyz;
    vPos = (modelMatrix * decodedPos).xyz;
}

#!SHADER: Fragment

void main() {
    vec2 uv = gl_PointCoord.xy;

    float a = 1.0 - length(uv - 0.5);
    // float circle = a * a * a *
    // float alpha = circle * 0.005;
