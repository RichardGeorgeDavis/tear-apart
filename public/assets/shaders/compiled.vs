{@}VelocityLife.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tVelocityLife;
//uniform sampler2D tCurlBox;
uniform sampler2D tScreenOrigin;
uniform sampler2D tInitClipPos;
uniform sampler2D tPos;
uniform sampler2D tDisplay;
uniform sampler2D tNoise;

uniform float uDissolve;
uniform float uScrollDirection;
uniform float uApplyInitPos;

uniform vec3 uWindForce;
uniform float uApplyWind;

uniform vec3 uLifeParams;
uniform vec2 uFrustumDimensions;
uniform vec3 uCurlBoxDimensions;

uniform float uCurlNoiseScale;
uniform float uCurlTimeScale;
uniform float uCurlNoiseSpeed;
uniform float uSpatialNoiseScale;
uniform float HZ;
uniform float uInertia;
uniform float uFlowCount;

uniform float uLogoTransition;
uniform float uIntroTransition;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = vec4(position, 1.0);
    vUv = uv;
}

    #!SHADER: Fragment
    #require(curl.glsl)
    #require(sampleAs3DTexture.glsl)
    #require(luma.fs)
    #require(sinNoise.glsl)

float sdBox(vec3 p, vec3 len) {
    vec3 q = (abs(p) - len);
    return length(max(q, vec3(0.0)));
}

float hash12(vec2 p)
{
    vec3 p3  = fract(vec3(p.xyx) * .1031);
    p3 += dot(p3, p3.yzx + 33.33);
    return fract((p3.x + p3.y) * p3.z);
}

vec3 hash33(vec3 p3)
{
    p3 = fract(p3 * vec3(.1031, .1030, .0973));
    p3 += dot(p3, p3.yxz+33.33);
    return fract((p3.xxy + p3.yxx)*p3.zyx);

}vec4 hash42(vec2 p)
{
    vec4 p4 = fract(vec4(p.xyxy) * vec4(.1031, .1030, .0973, .1099));
    p4 += dot(p4, p4.wzxy+33.33);
    return fract((p4.xxyz+p4.yzzw)*p4.zywx);

}


void main() {

    vec4 hash = hash42(gl_FragCoord.xy);
    vec4 velocityLife = texture2D(tVelocityLife, vUv);
    vec3 vel = velocityLife.xyz;
    float life = velocityLife.w;
    vec3 force = vec3(0.0);

    vec4 pos = texture2D(tPos, vUv);
    float goToOrigin = pos.w; //used for initial intro

    vec3 clipPos = texture2D(tInitClipPos, vUv).xyz;
    vec3 screenOrigin = vec3(texture2D(tScreenOrigin, vUv).xy, 0.0);

    float dissolvePhase = uDissolve * 4.0 * (1.0-uDissolve);

    vec3 signedHash = vec3(2.0 * hash.xyz - 1.0);
    vec3 spatialOffset = sinNoise(signedHash * 0.45 + pos.xyz * 2.0 + vec3((2.0 * vUv - 1.0) * 3.0, time * 1.13), .737, 2) * uSpatialNoiseScale * (goToOrigin >= uFlowCount ? 0.0 : 1.0);
    float temporalOffset = (spatialOffset.x + spatialOffset.y + spatialOffset.z) * 0.3333 * 0.01 * (goToOrigin >= uFlowCount ? 0.0 : 1.0);
    vec3 curl = curlNoise(spatialOffset + ((pos.xyz * uCurlNoiseScale * 0.1)) + (((time * uCurlTimeScale * 0.1) * (1.0-uApplyInitPos))));
    curl *= uCurlNoiseSpeed * 0.01 * HZ;

    vec3 windForce = vec3(0.0);
    windForce += curl;
    windForce += uWindForce * 0.01 * HZ;
    force += windForce;

//    float forceApplyThreshold = 1.0-luma(texture2D(tDisplay,clipPos.xy).xyz);
//    vec3 dissolveForce = (vec3(0.0, 0.0, 1.0) * 0.001 + curl * 2.0) * smoothstep(0.0, clamp(forceApplyThreshold, 0.0001, 1.0), dissolvePhase) * HZ;
//    dissolveForce = windForce;
//    force += dissolveForce;

    vel += force * (1.0 / mix(1.0, 1.1, hash.w));
    vel *= uInertia;

    vec2 boxBoundsZ = vec2(-0.5, -0.5);
    float restoreForceStrength = 0.001;
    if(pos.z > boxBoundsZ.x) vel.z += (boxBoundsZ.x - pos.z) * restoreForceStrength * HZ;
    if(pos.z < boxBoundsZ.y) vel.z += (boxBoundsZ.y - pos.z) * restoreForceStrength * HZ;
    //
    vec2 boxBoundsY = vec2(uFrustumDimensions.y * 0.5, uFrustumDimensions.y * -0.5);
    if(pos.y > boxBoundsY.x) vel.y += (boxBoundsY.x - pos.y) * restoreForceStrength * HZ;
    if(pos.y < boxBoundsY.y) vel.y += (boxBoundsY.y - pos.y) * restoreForceStrength * HZ;

    if(life <= 0.0) life = 1.0;
    life -= mix(uLifeParams.x, uLifeParams.y, hash12(gl_FragCoord.xy)) * 0.01;

    gl_FragColor = vec4(vel, life);
}
{@}WetaLandingParticlesShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tScreenOrigin;
uniform sampler2D tInitClip;
uniform sampler2D tVelocityLife;
uniform sampler2D tDisplay;
uniform sampler2D tDepthImage;

uniform float uDPR;
uniform vec3 uColor;
uniform vec3 uGlintColor;
uniform float uTransition;
uniform float uLogoColorTransition;

uniform float uFlowCount;
uniform vec3 uLightPos;
uniform vec4 uLightParams;

#!VARYINGS
varying vec2 vInitClipPos;
varying float vIndex;
varying vec3 vGlintNormal;
varying vec3 vPos;
varying vec3 vEyePos;
varying vec3 vRestoreParams;

#!SHADER: Vertex

vec4 hash41(float p)
{
    vec4 p4 = fract(vec4(p) * vec4(.1031, .1030, .0973, .1099));
    p4 += dot(p4, p4.wzxy+33.33);
    return fract((p4.xxyz+p4.yzzw)*p4.zywx);

}

void main() {

    vIndex = float(gl_VertexID);
    vec4 hash = hash41(vIndex*0.1);

    vec4 pos = texture2D(tPos, position.xy);
    vPos = pos.xyz;

    vec3 initClip = texture2D(tInitClip, position.xy).xyz;
    vec3 initPos = texture2D(tScreenOrigin, position.xy).xyz;
    vec4 mvPosition = modelViewMatrix * vec4(pos.xyz, 1.0);

    vEyePos = mvPosition.xyz;
    float eyeDist = length(vEyePos);
    //float scaleDither = (1000.0/eyeDist) * mix(0.002, 0.004, hash.w * (eyeDist));
    gl_PointSize = uDPR*1.5;
    //gl_PointSize = uDPR*1.0;

    float restoreDistPhase = length(initPos - pos.xyz)/initClip.z;
    float distPhase = smoothstep(0.0, 0.1, restoreDistPhase);
    float distPhaseColorIntensity = smoothstep(0.0, 0.05, restoreDistPhase);

    //incredibly ugly, but this is only for demo purposes...
    float applyColorAnimation = pos.w >= uFlowCount ? 1.0 : (uLogoColorTransition >= 1.0 ? 1.0 : 0.0);
    vRestoreParams = vec3(distPhase, applyColorAnimation, distPhaseColorIntensity);

    gl_Position = projectionMatrix * mvPosition;
    vInitClipPos = initClip.xy;

    vGlintNormal = normalize(vec3(2.0 * hash.xy - 1.0, mix(0.1, 1.0, hash.z))) * step(mix(0.995, 0.85, uLightParams.w), hash.w);

}


#!SHADER: Fragment
#require(luma.fs)
#require(aspectuv.glsl)

vec4 packRGBA (float v) {
    vec4 pack = fract(vec4(1.0, 255.0, 65025.0, 16581375.0) * v);
    pack -= pack.yzww * vec2(1.0 / 255.0, 0.0).xxxy;
    return pack;
}

void main() {
    //TODO: aspect correct
    vec2 clipUv = vInitClipPos;
    clipUv -= 0.5;
    clipUv *= getAspectCoverScale(vec2(1280.0, 545.0), resolution.xy);
    clipUv += 0.5;
    vec3 col = texture2D(tDisplay, clipUv).xyz;
    vec3 particleStateColor = uColor;

    vec2 localPoint = gl_PointCoord.xy;
    localPoint.y = 1.0 - localPoint.y;

    vec3 eyeDir = normalize(-vEyePos);
    float eyeDist = length(vEyePos);
    float glint = max(0.0, dot(vGlintNormal, eyeDir));
    glint += pow(glint, 4.0);

    //trashy normals for the time being
    vec3 impostorNormal = normalMatrix * normalize(vec3(2.0 * localPoint - 1.0, 1.0));
    vec3 localSurface = vPos + vec3(impostorNormal.xy, eyeDir.z);
    float halfLambert = dot(normalize(uLightPos - localSurface), normalize(impostorNormal)) * 0.5 + 0.5;
    halfLambert = mix(halfLambert * halfLambert, halfLambert, uLightParams.x);
    vec3 glintLight = uGlintColor * glint * halfLambert;

    halfLambert *= mix(1.0 / (1.0 + pow(dot((uLightPos - localSurface), (uLightPos-localSurface)), 1.0)), 1.0, uLightParams.y);
    halfLambert *= mix(0.7, 0.75, uLightParams.z);
    float ambient = impostorNormal.y * 0.5 + 0.5;

    float colorTransition = pow(smoothstep(luma(col), 1.0, uTransition), 3.0);

    float fog = texture2D(tDepthImage, clipUv).x;
    fog = pow(fog, 2.0);
    fog = mix(fog, 1.0, uLightParams.w);

    vec3 swirlParticleColor = (mix(particleStateColor*0.5, particleStateColor, fog) + glintLight + halfLambert - ambient * 0.5) + mix(0.1, 0.2, fog); //adding the fog looks nicer than multiplying with this setup
    vec3 logoParticleColor = particleStateColor + glintLight + halfLambert + ambient * 0.8;
    vec3 finalCol = mix(mix(col * mix(1.0, 0.3, vRestoreParams.z), swirlParticleColor, vRestoreParams.x), swirlParticleColor, pow(1.0-vRestoreParams.y, 50.0));

    #drawbuffer Color gl_FragColor = vec4(finalCol, 1.0);
    #drawbuffer GlintBuffer gl_FragColor = vec4(glintLight * (vRestoreParams.x * vRestoreParams.y) * mix(0.1, 1.0, fog), 1.0);
}
