}{@}FakeFurShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vEye;

#!SHADER: Vertex
void main() {
  vEye = -(modelViewMatrix * vec4(position, 1.0)).xyz;
  vec3 pos = position;
  gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
  vUv = uv;
  vNormal = normalMatrix * normal;
}

#!SHADER: Fragment

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
  vec3 normal = normalize(vNormal);
  float fresnel = dot(normal, normalize(vEye));

  float alpha = texture2D(tMap, vUv).r;
  alpha += rand(vUv) * 0.3;
  alpha -= (1.0 - vUv.y) * fresnel * 0.5;

  fresnel = max(0.0, fresnel);
  if (alpha < 0.5) discard;

  float light = dot(normal, vec3(0.0, 1.0, 0.0)) * 0.5 + 0.5;
  vec3 color = vec3(light);

  gl_FragColor = vec4(color, 1.0);
}{@}FurBaseShader.glsl{@}#!ATTRIBUTES

