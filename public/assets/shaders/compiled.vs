}{@}FallingObjectShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uBlur;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
  vec3 pos = position;

  float scale = 1.0;
  pos.y += 0.5;
  pos *= scale;
  pos.y -= 0.5;
  gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
  vUv = uv;
}

#!SHADER: Fragment
void main() {
  vec4 color = vec4(0.0);
  int iterations = 30;
  if (uBlur > 0.5) {
    for (int i = 0; i < iterations; i++) {
      color += texture2D(tMap, vUv + vec2(0.0, -float(i) * 0.005));
    }
    color /= float(iterations);
    color.rgb /= mix(1.0, color.a, 0.8);
  } else {
    color = vec4(texture2D(tMap, vUv));
  }

  gl_FragColor = color;
}{@}GroundShatterShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;
attribute float shatter;

#!UNIFORMS
uniform vec3 uObjectPos;
uniform float uStrength;
uniform float uObjectShadowScale;

#!VARYINGS
varying vec3 vColor;
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vNormal;
varying vec3 vTransformedNormal;
varying vec3 vPos;
varying float vGrad;

#!SHADER: Vertex
#require(rotation.glsl)
void main() {

    float t = time * 0.35;
    vec3 center = vdata - uObjectPos * vec3(1.0, 2.0, 1.0);

    float grad = length(center);
    grad *= uStrength;
    float inverseGrad = clamp(1.0 - grad * 0.7, 0.0, 1.0);
    vec3 pos = position;
    vec3 n = normal;

    if (shatter > 0.5) {
      pos -= vdata;

      vec3 axis = cross(normalize(center), vec3(0.0, 1.0, 0.0));

      float angle = pow(inverseGrad, 2.0) + pow(inverseGrad, 3.0) * 2.0;
      float strength = angle;
      angle += uv2.y * angle * 0.25;
      angle *= 4.0;

      pos = vec3( rotationMatrix(axis, angle * 0.4) * vec4(pos, 1.0));
      n = vec3( rotationMatrix(axis, angle) * vec4(normal, 1.0));

      pos.y += strength + pow(inverseGrad, 5.0) * 0.5;
      pos.y -= strength * pow(inverseGrad, 2.0) * 4.0;
      pos += vdata;
    }

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vUv2 = uv2;
    vNormal = mix(normal, normalize(center), shatter);
    vTransformedNormal = n;
    vPos = (modelMatrix * vec4(pos, 1.0)).xyz;
    vGrad = grad;
}

#!SHADER: Fragment

void main() {
    if (vPos.y < -0.01) discard;

    float grad = length(vPos.xz);

    // lighting
    float value = dot(normalize(vTransformedNormal), vec3(-1.0, 1.0, 0.0)) * 0.5 + 0.5;
    value += smoothstep(0.5, 1.0, value) * smoothstep(3.0, 0.0, grad) * 0.8;
    // float ao = clamp(grad * 0.9, 0.0, 1.0);
    // ao = clamp(ao, 0.2, 1.0);
    // value *= ao;
    // value = pow(value, 0.45);

    // wide gradient
    // value *= pow(clamp(1.0 - length(vPos.xz) * 0.15, 0.0, 1.0), 2.0);

    // falling shadow
    // float scale = uObjectShadowScale;
    // float invScale = 1.0 / scale;
    // float circle = min(1.0, length(vPos.xz) * invScale);
    // circle = smoothstep(0.45, 0.55 + scale * 0.1, circle);
    // circle = mix(circle, 1.0, clamp(scale * 0.2, 0.25, 1.0));
    // value *= circle;

    float alpha = smoothstep(3.0, 2.0, grad);
    // alpha *= clamp(vPos.z * 1.0 + 2.5, 0.0, 1.0);

    vec3 lightBlue = vec3(0.0, 122.0, 191.0) / 255.0 * 0.9;
    vec3 darkBlue = vec3(0.0, 50.0, 102.0) / 255.0 * 0.75;

    vec3 color = mix(darkBlue, lightBlue, value);


    gl_FragColor = vec4(color, alpha);
}{@}MBgShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
  gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
  vUv = uv;
}

#!SHADER: Fragment
float rand(vec2 n) { 
	return fract(sin(dot(n, vec2(12.9898, 4.1414))) * 43758.5453);
}

void main() {
  vec3 color = texture2D(tMap, vUv).rgb;
  color += texture2D(tMap, vUv + vec2(0.0, 0.1)).rgb;
  color /= 2.0;
  color.r += rand(vUv + fract(time)) * 0.05;
  color.g += rand(vUv + fract(time + 0.25)) * 0.05;
  color.b += rand(vUv + fract(time + 0.5)) * 0.05;
  gl_FragColor = vec4(color, 1.0);
}{@}ShockwaveShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform float uProgress;
uniform float uOpacity;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
  gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
  vUv = uv;
}

#!SHADER: Fragment
void main() {
  float progress = uProgress * 0.420;
  vec3 lightBlue = vec3(0.0, 122.0, 191.0) / 255.0 + 0.75;
  vec3 color = lightBlue;
  float dist = length(vUv - 0.5);
  float alpha = smoothstep(-0.1 + progress, 0.1 + progress * 2.0, dist);
  alpha *= smoothstep(0.05 + progress, 0.0 + progress, dist);
  alpha *= uOpacity;

  if (alpha < 0.001) discard;

  gl_FragColor = vec4(color, alpha);
}{@}SpritesheetShader.glsl{@}#!ATTRIBUTES
attribute vec4 random;

#!UNIFORMS
uniform sampler2D tFlipbook;
uniform vec2 uFlipbookDimensions;
uniform float uAlpha;
uniform float uProgress;

#!VARYINGS
varying vec2 vUv;
varying float vIndex;
varying vec4 vRandom;
varying float vFade;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    vec4 worldPos = modelMatrix * vec4(pos, 1.0);
    gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;
    vIndex = random.x;

    vec3 cameraDir = normalize(worldPos.xyz - cameraPosition);
    vec3 worldNormal = mat3(modelMatrix[0].xyz, modelMatrix[1].xyz, modelMatrix[2].xyz) * normal;
    float dp = dot(cameraDir, normalize(worldNormal));
    vFade = pow(dp, 2.0);
}

#!SHADER: Fragment
vec4 getInterpolatedSubUV(sampler2D _tMap, vec2 _dimensions, vec2 _uv, float _index) {
    float subUVWidth = 1.0 / _dimensions.x;
    float subUVHeight = 1.0 / _dimensions.y;

    float index = _index * subUVWidth;

    vec2 subUV1 = _uv;
    subUV1 /= _dimensions;

    vec2 subUV2 = subUV1;

    float offset = subUVHeight * (_dimensions.y - 1.0);
    subUV1.y += offset;
    subUV2.y += offset;

    subUV1.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV1.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex1 = texture2D(_tMap, subUV1);
    index += subUVWidth;
    subUV2.x += floor(fract(index) * _dimensions.x) / _dimensions.x;
    subUV2.y -= floor(fract(index / _dimensions.y) * _dimensions.y) / _dimensions.y;
    vec4 tex2 = texture2D(_tMap, subUV2);

    tex1 = mix(tex1, tex2, fract(index * _dimensions.x));

    return tex1;
}

void main() {
    float t = uProgress * (uFlipbookDimensions.x * uFlipbookDimensions.y);
    vec4 color = getInterpolatedSubUV(tFlipbook, uFlipbookDimensions, vUv, t);
    vec3 lightBlue = vec3(0.0, 122.0, 191.0) / 255.0;
    vec3 darkBlue = vec3(0.0, 50.0, 102.0) / 255.0 * 0.75;
    color.rgb = mix(vec3(1.0), lightBlue, 0.75) + 0.5;
    color.a *= smoothstep(1.0, 0.9, vUv.y);
    color.a *= smoothstep(0.0, 0.2, vUv.y);
    gl_FragColor = vec4(color.rgb, color.a * uAlpha * vFade);
}{@}FoldShader.glsl{@}#!ATTRIBUTES
attribute vec3 random;
attribute vec2 uv2;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tLightmap;
uniform float uLightmapIntensity;
uniform float uAtlasTiles;
uniform float uRandomizeTiles;
uniform float uCornerPadding;
uniform float uRandomDarken;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying float vTileIndex;
varying float vAtlasTiles;
varying float vDarken;
varying float vFog;
varying float vCheck;

#!SHADER: Vertex
#require(rotation.glsl)

float rand(vec2 co, float seed){
    return fract(seed + sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    vec4 worldPos = modelMatrix * vec4(position, 1.0);

    float radius = 5.0;
    float distToTangent = -1.0;

    float gradient = clamp((worldPos.z - distToTangent) / radius, 0.0, 1.0);
    float angle = gradient * 3.14 * 0.5 - 3.14 * 0.5;

    vec2 circlePos = vec2(radius * clamp(cos(angle), 0.0, 3.14 * 0.5), radius * clamp(sin(angle), -3.14 * 0.5, 3.14 * 0.5));
    vec3 cylinderPos = vec3(worldPos.x, -circlePos.x, circlePos.y);
    vec2 dir = normalize(cylinderPos.yz) * worldPos.y;
    cylinderPos.yz -= dir.xy;
    cylinderPos.y += radius;
    cylinderPos.z += radius;

    worldPos.z -= distToTangent;

    float temp = worldPos.z;

    if (temp > 0.0 && temp < radius) {
        worldPos.xyz = cylinderPos;
    }

    if (temp <= 0.0) {
        worldPos.z = worldPos.y;
        worldPos.y = -temp + radius;
    }

    worldPos.z += distToTangent;

    gl_Position = projectionMatrix * viewMatrix * worldPos;
    vUv = uv;
    vUv2 = uv2;

}

#!SHADER: Fragment

void main() {
    vec3 color = texture2D(tMap, vUv).rgb;
    // color *= step(5.9, vCheck);

    gl_FragColor = vec4(color, 1.0);
}{@}InceptionInteriorMappingShader.glsl{@}#!ATTRIBUTES
attribute vec3 random;
attribute vec2 uv2;

// interior mapping attributes
attribute vec3 primpos;
attribute vec3 tangent;
attribute vec3 walldata;

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tInterior;
uniform sampler2D tInteriorEmissive;
uniform float uInteriorBrightness;
uniform sampler2D tWindowMask;
uniform sampler2D tLightmap;
uniform float uLightmapIntensity;
uniform float uAtlasTiles;
uniform float uRandomizeTiles;
uniform float uCornerPadding;
uniform float uHeightOffset;

uniform vec3 uColor1;
uniform vec3 uColor2;

#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying float vTileIndex;
varying float vAtlasTiles;

// interior mapping varyings
varying vec3 vTangentPos;
varying vec3 vTangentEye;
varying vec3 vEye;
varying mat3 vTbn;
varying float vFloorHeight;
varying float vFloorWidth;
varying float vFloorDepth;
varying float vSeed;
varying float vFog;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
            vec4 worldPos = modelMatrix * vec4(position, 1.0);

    float radius = 500.0;
    float distToTangent = -900.0 + cameraPosition.z;

    float gradient = clamp((worldPos.z - distToTangent) / radius, 0.0, 1.0);
    float angle = gradient * 3.14159 * 0.5 - 3.14159 * 0.5;

    vec2 circlePos = vec2(radius * clamp(cos(angle), 0.0, 3.14159 * 0.5), radius * clamp(sin(angle), -3.14 * 0.5, 3.14 * 0.5));
    vec3 cylinderPos = vec3(worldPos.x, -circlePos.x, circlePos.y);
    vec2 dir = normalize(cylinderPos.yz) * worldPos.y;
    cylinderPos.yz -= dir.xy;
    cylinderPos.y += radius;
    cylinderPos.z += radius;

    worldPos.z -= distToTangent;

    float temp = worldPos.z;

    if (temp > 0.0 && temp < radius) {
        worldPos.xyz = cylinderPos;
    }

    if (temp <= 0.0) {
        worldPos.z = worldPos.y;
        worldPos.y = -temp * (3.14159 * 0.5) + radius;
    }

    worldPos.z += distToTangent;

    gl_Position = projectionMatrix * viewMatrix * worldPos;

    // vec4 worldPos = modelMatrix * vec4(position, 1.0);

    // float radius = 900.0;
    // float distToTangent = 450.0 + cameraPosition.z;

    // float gradient = clamp((worldPos.z - distToTangent) / radius, 0.0, 1.0);
    // float angle = gradient * 3.14 * 0.5;

    // worldPos.z -= distToTangent;
    // worldPos.y -= radius;

    // float temp = worldPos.z;

    // if (temp > 0.0 && temp < radius) {
    //     worldPos.z = 0.0;
    // }

    // if (temp >= radius) {
    //     worldPos.z -= radius;
    // }

    // mat4 rotMatrix = rotationMatrix(vec3(1.0, 0.0, 0.0), angle);
    // worldPos = rotMatrix * worldPos;
    // worldPos.y += radius;

    // if (temp > 0.0 && temp < radius) {
    //     worldPos.yz *= 2.0 / 3.14;
    // }


    // if (temp >= radius) {
    //     worldPos.z *= 2.0 / 3.14;
    //     worldPos.y -= (radius - radius * (2.0 / 3.14));
    // }

    // // slight hack to scale buildings up to correct size
    // if (temp > 0.0 && temp < radius) {
    //     float scaleMix = (1.0 - smoothstep(0.0, radius, temp));
    //     scaleMix = pow(scaleMix, 2.0);
    //     // scaleMix = smoothstep(0.0, 1.0, scaleMix);
    //     float maxScale = (1.0 / (2.0 / 3.14));
    //     worldPos.y *= mix(1.0, maxScale, scaleMix);
    // }

    // worldPos.z += distToTangent;

    // gl_Position = projectionMatrix * viewMatrix * worldPos;

    vUv = uv;
    vUv2 = uv2;

    // interior mapping
    vec3 B = vec3(0.0, 1.0, 0.0);
    vec3 N = normal;
    vec3 T = tangent;

    mat3 tbn;
    tbn[0] = vec3(T.x, T.y, T.z); 
    tbn[1] = vec3(B.x, B.y, B.z); 
    tbn[2] = vec3(N.x, N.y, N.z); 

    mat3 invtbn = transpose(tbn);
    vec3 eye = inverse(modelViewMatrix)[3].xyz;

    vTbn = tbn;
    vEye = (modelMatrix * vec4(position, 1.0)).xyz - cameraPosition;

    vTangentPos = invtbn * position;
    vTangentEye = invtbn * inverse(modelViewMatrix)[3].xyz;

    vTangentPos.x -= primpos.x;
    vTangentEye.x -= primpos.x;
    vTangentPos.z -= primpos.z;
    vTangentEye.z -= primpos.z;
    vTangentPos.y -= primpos.y;
    vTangentEye.y -= primpos.y;
    vTangentPos.z = -abs(vTangentPos.z);

    vTangentPos.y += uHeightOffset;
    vTangentEye.y += uHeightOffset;

    // vTangentPos = (rotMatrix * vec4(vTangentPos.xyz, 1.0)).xyz;
    // vTangentEye = (rotMatrix * vec4(vTangentEye.xyz, 1.0)).xyz;

    vFloorHeight = walldata.z;
    vFloorWidth = walldata.y;
    vFloorDepth = 5.0;
    vSeed = walldata.x;

    // corner padding
    if (vUv.x < 0.1) {
        vUv.x -= 0.063 * uCornerPadding;
    } else {
        vUv.x += 0.063 * uCornerPadding;
    }

    vTileIndex = floor(fract(random.g + uRandomizeTiles) * uAtlasTiles);
    vAtlasTiles = floor(uAtlasTiles);
    vFog = clamp(-angle * 0.2, 0.0, 1.0);
}

#!SHADER: Fragment
float rand(vec2 co, float seed){
    return fract(seed + sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

vec3 czm_saturation(vec3 rgb, float adjustment)
{
    // Algorithm from Chapter 16 of OpenGL Shading Language
    const vec3 W = vec3(0.2125, 0.7154, 0.0721);
    vec3 intensity = vec3(dot(rgb, W));
    return mix(intensity, rgb, adjustment);
}

void main() {
    vec2 mosaic = vec2(floor(vUv.x), floor(vUv.y));
    float rand1 = rand(mosaic, vSeed + 20.5);
    float rand2 = sin(rand1 * 600.1) * 0.5 + 0.5;
    float rand3 = sin(rand1 * 758.5) * 0.5 + 0.5;

    // interior mapping
    vec3 camToPixel = vTangentPos - vTangentEye;
    
    float isFloor = step(camToPixel.y, 0.0);
    float ceilingHeight = ceil(vTangentPos.y / vFloorHeight - isFloor) * vFloorHeight;
    float ceilingDist = (ceilingHeight - vTangentEye.y) / camToPixel.y;

    float isRear = step(camToPixel.z, 0.0);
    float rearWallDepth = ceil(vTangentPos.z / vFloorDepth - isRear) * vFloorDepth;
    float rearWallDist = (rearWallDepth - vTangentEye.z) / camToPixel.z;

    float innerDepth = ceil(vTangentPos.z / vFloorDepth - isRear) * 0.2;
    float innerDist = (rearWallDepth - vTangentEye.z) / camToPixel.z;

    float isSide = step(camToPixel.x, 0.0);
    float sideWallWidth = ceil((vTangentPos.x) / vFloorWidth - isSide) * vFloorWidth;
    float sideWallDist = (sideWallWidth - vTangentEye.x) / (camToPixel.x);

    vec2 interiorUv = vec2(0.0);
    float interiorUvOffset;
    float minDist = min(min(ceilingDist, rearWallDist), sideWallDist);
    if (sideWallDist == minDist) {
        interiorUv = vTangentEye.zy + sideWallDist * camToPixel.zy;
        interiorUv.x /= vFloorDepth;
        interiorUv.y /= vFloorHeight;
        interiorUvOffset = isSide == 0.0 ? 1.0 : 0.0;
    } else if (rearWallDist == minDist) {
        interiorUv = vTangentEye.xy + rearWallDist * camToPixel.xy;
        interiorUv.x /= vFloorWidth;
        interiorUv.y /= vFloorHeight;
        interiorUvOffset = 4.0;
    } else if (ceilingDist == minDist) {
        interiorUv = vTangentEye.xz + ceilingDist * camToPixel.xz;
        interiorUv.x /= vFloorWidth;
        interiorUv.y /= vFloorDepth;
        interiorUvOffset = isFloor == 0.0 ? 2.0 : 3.0;
    }

    float column = 1.0 / 5.0;
    interiorUv = fract(interiorUv);
    interiorUv.x *= column;
    interiorUv.x += column * interiorUvOffset;

    // exterior color
    vec2 uv = vUv;
    float offset = vTileIndex;

    uv = uv / vec2(1.0, vAtlasTiles);

    vec2 dx = dFdx(uv);
    vec2 dy = dFdy(uv);

    uv.y = mod(uv.y, 1.0 / vAtlasTiles) + offset / vAtlasTiles;
    uv.x = fract(uv.x);

    vec3 color = texture2DGrad(tMap, uv, dx, dy).rgb;
    color *= texture2D(tLightmap, vUv2).rgb * uLightmapIntensity;

    // interior color
    vec3 interior = texture2DGrad(tInterior, interiorUv, dx, dy).rgb;
    vec3 interiorEmissive = texture2DGrad(tInteriorEmissive, interiorUv, dx, dy).rgb;
    float randomBrightness = max(0.1, rand3 * rand3);
    // randomBrightness -= sin(rand1 * 10.0 + time * 2.0 + mosaic.y * 2.0);
    interior = mix(uColor1, uColor2, rand2) * interior;
    interior = pow(interior, vec3(2.2));
    interior += pow(interiorEmissive.r, 2.2) * 2.0;
    interior = pow(interior, vec3(0.45));
    interior *= uInteriorBrightness * randomBrightness;

    // compositing
    float interiorMask = texture2DGrad(tWindowMask, uv, dx, dy).r;
    color = mix(color, interior, interiorMask);
    color = mix(color, vec3(100.0, 66.0, 61.0) / 255.0, vFog);
    color += interior * interiorMask * vFog * 0.5;

    color = czm_saturation(color, 1.5);
    // discard;

    gl_FragColor = vec4(color, 1.0);
}{@}InceptionShader.glsl{@}#!ATTRIBUTES
