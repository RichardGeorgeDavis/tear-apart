}{@}ReducerShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D data;
uniform float size;
uniform bool evaluateMin;
uniform vec4 lightOrientation;
uniform bool applyOrientation;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex

void main() {
    gl_Position = vec4(position, 1.);
    vUv = uv;
}

#!SHADER: Fragment

vec3 rotateVector( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}

void main() {

    float k = 0.5 * size;
    vec2 position = floor(vUv / size) * size;

    vec3 a = texture2D(data,  position + vec2(0., 0.)).xyz;
    vec3 b = texture2D(data,  position + vec2(k, 0.)).xyz;
    vec3 c = texture2D(data,  position + vec2(0., k)).xyz;
    vec3 d = texture2D(data,  position + vec2(k, k)).xyz;

    if(applyOrientation) {
        a = rotateVector(lightOrientation, a);
        b = rotateVector(lightOrientation, b);
        c = rotateVector(lightOrientation, c);
        d = rotateVector(lightOrientation, d);
    }

    if(evaluateMin) {
        gl_FragColor.x = min(min(a.x, b.x), min(c.x, d.x));
        gl_FragColor.y = min(min(a.y, b.y), min(c.y, d.y));
        gl_FragColor.z = min(min(a.z, b.z), min(c.z, d.z));
    } else {
        gl_FragColor.x = max(max(a.x, b.x), max(c.x, d.x));
        gl_FragColor.y = max(max(a.y, b.y), max(c.y, d.y));
        gl_FragColor.z = max(max(a.z, b.z), max(c.z, d.z));
    }

    gl_FragColor.a = 1.;
}
