#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNoise;
uniform vec3 uColor;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
void main() {
    vec3 color = texture2D(tMap, vUv).rgb;

    vec2 st = vUv - 0.55;
    float y = length(st);
    float x = atan(st.x, st.y);
    vec2 uv = vec2(x, y);
    float r = texture2D(tNoise, uv + vec2(y * 5.0, -time * 0.1)).r;

    // float strobelight = sin(time * 5.0) * 0.5 + 0.5;
    float strobelight = 1.0 - fract(time * 0.5);
    // strobelight *= step(0.5, fract(time * 0.25));
    strobelight = pow(strobelight, 2.0);

    color = vec3(strobelight) * uColor * color.g * 1.2;
    gl_FragColor = vec4(color, 1.0);
