    vec3 pos = 2. * position;
    gl_Position = vec4(pos, 1.0);
}

#!SHADER: Fragment
void main() {
    gl_FragColor = texture2D(tMap, vUv);
}{@}ReducerShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D data;
uniform float size;
uniform bool evaluateMin;
uniform vec4 lightOrientation;
uniform bool applyOrientation;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex

void main() {
    gl_Position = vec4(position, 1.);
    vUv = uv;
}

#!SHADER: Fragment

vec3 rotateVector( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}

void main() {

    float k = 0.5 * size;
    vec2 position = floor(vUv / size) * size;

    vec3 a = texture2D(data,  position + vec2(0., 0.)).xyz;
    vec3 b = texture2D(data,  position + vec2(k, 0.)).xyz;
    vec3 c = texture2D(data,  position + vec2(0., k)).xyz;
    vec3 d = texture2D(data,  position + vec2(k, k)).xyz;

    if(applyOrientation) {
        a = rotateVector(lightOrientation, a);
        b = rotateVector(lightOrientation, b);
        c = rotateVector(lightOrientation, c);
        d = rotateVector(lightOrientation, d);
    }

    if(evaluateMin) {
        gl_FragColor.x = min(min(a.x, b.x), min(c.x, d.x));
        gl_FragColor.y = min(min(a.y, b.y), min(c.y, d.y));
        gl_FragColor.z = min(min(a.z, b.z), min(c.z, d.z));
    } else {
        gl_FragColor.x = max(max(a.x, b.x), max(c.x, d.x));
        gl_FragColor.y = max(max(a.y, b.y), max(c.y, d.y));
        gl_FragColor.z = max(max(a.z, b.z), max(c.z, d.z));
    }

    gl_FragColor.a = 1.;
}
{@}ShadowsBlur.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tData;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    vUv = uv;
    vec3 pos = 2. * position;
    gl_Position = vec4(pos.xy, 0., 1.);
}

#!SHADER: Fragment

#require(radialblur.fs)

void main() {

    gl_FragColor.rgb = radialBlur(tData, vUv,  10., resolution, 10.);
    gl_FragColor.a = 1.;
    //gl_FragColor = texture2D(tData, vUv);
}{@}VolumeShadowsParticlesShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tColor;


uniform sampler2D tMin;
uniform sampler2D tMax;
uniform sampler2D tShadows;
uniform vec4 lightOrientation;
uniform vec3 voxelData;


uniform vec3 uColor;
uniform float uAmbientLight;
uniform float uSize;
uniform float uAlpha;
uniform sampler2D tLife;
uniform float uTransition;
varying vec3 vColor;


#!VARYINGS
varying vec2 vUv;
varying vec2 vUv2;
varying float mixer;
varying vec3 vPos;
varying float vLife;

#!SHADER: Vertex

vec3 rotateVector( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}

void main() {
    
    vec3 pos = texture2D(tPos, position.xy).xyz;
    vLife = texture2D(tLife, position.xy).r;
    vColor = texture2D(tColor, position.xy).xyz;

    vec3 lightPos = rotateVector(lightOrientation, pos);

    vec3 minPosition = texture2D(tMin, vec2(0.5)).rgb;
    vec3 maxPosition = texture2D(tMax, vec2(0.5)).rgb;
    vec3 scale = maxPosition - minPosition;
    float s = max(max(scale.x, scale.y), scale.z);
    
    lightPos -= minPosition;
    lightPos /= s;

    vPos = lightPos;
 
    vec3 gridPosition = floor(voxelData.y * lightPos);
    vUv = (gridPosition.xz + voxelData.y * vec2(mod(gridPosition.y, voxelData.x), floor(gridPosition.y / voxelData.x)) + vec2(0.5)) / voxelData.z;
    
    gridPosition = ceil(voxelData.y * lightPos);
    vUv2 = (gridPosition.xz + voxelData.y * vec2(mod(gridPosition.y, voxelData.x), floor(gridPosition.y / voxelData.x)) + vec2(0.5)) / voxelData.z;
    
    mixer = fract(lightPos.y * voxelData.y);

    //gl_PointSize = 3.;
    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = max(0.02 * uSize * (1000.0 / length(mvPosition.xyz)), 2.);

    gl_Position = projectionMatrix * mvPosition;

}

#!SHADER: Fragment

void main() {

    vec2 uv = vec2(gl_PointCoord.x, 1.0 - gl_PointCoord.y);
    float alpha = smoothstep(0.5, 0.499, length(uv-0.5));

    vec2 st = 2. * uv - 1.;

    //for the shadows
    float shadow = 1. - texture2D(tShadows, vUv).r;
    float shadow2 = 1. - texture2D(tShadows, vUv2).r;
    //shadow = mix(shadow, shadow2, mixer);

    vec3 color = vColor * mix(shadow, 1., uAmbientLight);
    //color = pow(color, vec3(3.));

    gl_FragColor = vec4(color, alpha * uAlpha * vLife * clamp(uTransition, 0., 1.));

    if(alpha < 0.01) discard;

}
{@}volumeShadows.fs{@}varying float vShadow;

float getShadows() {
    return vShadow;
}
{@}volumeShadows.vs{@}uniform sampler2D tMin;
uniform sampler2D tMax;
uniform sampler2D tShadows;
uniform vec4 lightOrientation;
uniform vec3 voxelData;

uniform float autoBB;
uniform vec3 bbMin;
uniform vec3 bbMax;

varying float vShadow;

vec3 rotateVector( vec4 quat, vec3 vec) {
    return vec + 2.0 * cross( cross( vec, quat.xyz ) + quat.w * vec, quat.xyz );
}

void setupShadows(vec3 pos) {

    vec3 lightPos = rotateVector(lightOrientation, pos);

    vec3 minPosition = bbMin;
    vec3 maxPosition = bbMax;

    if(autoBB > 0.5) {
        minPosition = texture2D(tMin, vec2(0.5)).rgb;
        maxPosition = texture2D(tMax, vec2(0.5)).rgb;
    }

    vec3 scale = maxPosition - minPosition;
    vec3 ae = abs(scale);
    float s = max(max(ae.x, ae.y), ae.z);
    
    lightPos -= minPosition;
    lightPos /= s;
 
    vec3 gridPosition = floor(voxelData.y * lightPos);
    vec2 bucket1 = (gridPosition.xz + voxelData.y * vec2(mod(gridPosition.y, voxelData.x), floor(gridPosition.y / voxelData.x)) + vec2(0.5)) / voxelData.z;
    
    gridPosition = ceil(voxelData.y * lightPos);
    vec2 bucket2 = (gridPosition.xz + voxelData.y * vec2(mod(gridPosition.y, voxelData.x), floor(gridPosition.y / voxelData.x)) + vec2(0.5)) / voxelData.z;
    
    float shadowMixer = fract(lightPos.y * voxelData.y);

    float shadow = 1. - texture2D(tShadows, bucket1).r;
    float shadow2 = 1. - texture2D(tShadows, bucket2).r;

    vShadow =  mix(shadow, shadow2, shadowMixer);

}
{@}HDRLightmapShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
vec4 RGBMToLinear(vec4 value) {
    float maxRange = 6.0;
    return vec4(value.xyz * value.w * maxRange, 1.0);
}

vec3 uncharted2Tonemap(vec3 x) {
  float A = 0.15;
  float B = 0.50;
  float C = 0.10;
  float D = 0.20;
  float E = 0.02;
  float F = 0.30;
  return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

vec3 uncharted2(vec3 color) {
  const float W = 11.2;
  float exposureBias = 10.0;
  vec3 curr = uncharted2Tonemap(exposureBias * color);
  vec3 whiteScale = 1.0 / uncharted2Tonemap(vec3(W));
  return curr * whiteScale;
}

void main() {
    vec4 color = texture2D(tMap, vUv);
    color = RGBMToLinear(color);
    float brightness = (sin(time * 5.0 + vUv.x * 0.5) * 0.5 + 0.5);
    brightness = pow(brightness, 2.0) * 5.0 + 0.1;
    color.rgb *= brightness;
    color.rgb = uncharted2(color.rgb);
    color.rgb = pow(color.rgb, vec3(0.4545));


    gl_FragColor = color;
}{@}HeightfieldShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tNoise;

#!VARYINGS
varying vec2 vUv;
varying vec3 vNormal;
varying float vHeight;

#!SHADER: Vertex
void main() {
    float heightFactor = max(0.0, sin(length(position) * 1.0 - time) * 0.5 + 0.5);
    heightFactor = 1.0;
    vec3 data = texture2D(tMap, uv).rgb;
    float height = data.r;
    vec3 pos = position;
    pos.y += height * 1.5 * heightFactor;



    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vNormal = normal;
    vHeight = heightFactor;
}

#!SHADER: Fragment

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    float n = rand(vUv) * 1000.0;
    n *= 0.000001;
    float eps = 0.0015 + (1.0 - vHeight) * 0.02 + n;
    float x = texture2D(tMap, vUv - vec2(eps, 0.0)).r - texture2D(tMap, vUv + vec2(eps, 0.0)).r;
    float y = texture2D(tMap, vUv - vec2(0.0, eps)).r - texture2D(tMap, vUv + vec2(0.0, eps)).r;
    vec3 data = texture2D(tMap, vUv).rgb;
    float z = data.r + (1.0 - vHeight) * 4.0;
    vec3 normal = vec3(x, z * 0.1, y);

    // eps = 0.002;
    // x = texture2D(tMap, vUv).r - texture2D(tMap, vUv + vec2(eps, 0.0)).r;
    // y = texture2D(tMap, vUv).r - texture2D(tMap, vUv + vec2(0.0, eps)).r;
    // z = data.r + (1.0 -vHeight);
    // normal += vec3(x, y, z * 0.01);

    normal.y -= data.g * 1.0 * vHeight * 0.15;
    normal = normalize(normal);
    float l = dot(normalize(normal), normalize(vec3(5.5, 1.0, 5.5)));
    vec3 color = normalize(normal) * 0.5 + 0.5;
    color = vec3(max(0.0, l * 0.7 + 0.3));
    gl_FragColor = vec4(color, 1.0);
}{@}DotShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
varying vec3 vNormal;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vNormal = normal;
}

#!SHADER: Fragment
void main() {
    float value = dot(normalize(vNormal), vec3(0.0, 1.0, 0.0)) * 0.5 + 0.5;
    value = pow(value, 0.6);
    gl_FragColor = vec4(value);
}{@}EyeballShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform vec3 uObjectPos;

#!VARYINGS
varying vec3 vNormal;
varying vec3 vPos;
varying float vCheck;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
    vec3 pos = position;
    pos = position;

    vec3 n = normal;

    vec3 target = uObjectPos;
    vec3 dir = normalize(offset - target);
    float angleUpDown = dot(dir, vec3(0.0, 1.0, 0.0)) * (3.14 / 2.0);
    float angleLeftRight = atan(dir.x, dir.z);

    pos = vec3(rotationMatrix(vec3(0.0, 1.0, 0.0), 3.14 / 2.0) * vec4(pos, 1.0));
    n = vec3(rotationMatrix(vec3(0.0, 1.0, 0.0), 3.14 / 2.0) * vec4(n, 1.0));

    pos.yz = rotationMatrix(angleUpDown) * pos.yz;
    pos.xz = rotationMatrix(angleLeftRight) * pos.xz;

    n.yz = rotationMatrix(angleUpDown) * n.yz;
    n.xz = rotationMatrix(angleLeftRight) * n.xz;

    pos += offset;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vNormal = n;
    vPos = pos;
    // vCheck = blinkGrad;
}

#!SHADER: Fragment
void main() {
    float value = dot(vNormal, vec3(0.0, 1.0, 0.0)) * 0.5 + 0.5;
    value = pow(value, 0.8);
    gl_FragColor = vec4(value);
    gl_FragColor.a = 1.0;
}{@}HexagonSphereShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;
attribute vec2 uv2;

#!UNIFORMS
uniform float uMix1;

#!VARYINGS
varying vec3 vColor;
varying vec2 vUv;
varying vec2 vUv2;
varying vec3 vNormal;
varying vec3 vTransformedNormal;
varying vec3 vPos;

#!SHADER: Vertex
#require(rotation.glsl)
void main() {


    vec3 center = vdata;

    vec3 pos = position;
    vec3 n = normal;
    pos -= center;

    vec3 axis = cross(normalize(center), vec3(0.0, -1.0, -1.0));

    float angle = sin(time + center.y + center.z) * 3.14 + 3.14;

    pos = vec3( rotationMatrix(axis, angle) * vec4(pos, 1.0));
    n = vec3( rotationMatrix(axis, angle) * vec4(normal, 1.0));
    pos -= normalize(center) * sin(angle * 2.0) * 0.03;
    pos += center;


    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vUv = uv;
    vUv2 = uv2;
    vNormal = normalize(center);
    vTransformedNormal = n;
    vPos = pos;
}

#!SHADER: Fragment
void main() {
    float value = dot(normalize(vTransformedNormal), vec3(0.0, 1.0, 0.0)) * 0.5 + 0.5;
    // value *= dot(normalize(vNormal), vec3(0.0, 1.0, 0.0)) * 0.5 + 0.5;
    float ao = pow(clamp(length(vPos) * 0.95, 0.0, 1.0), 34.0);
    value *= ao;
    value = pow(value, 0.45);
    gl_FragColor = vec4(value);
}{@}InstancedCone.glsl{@}#!ATTRIBUTES
attribute vec3 lookup;

#!UNIFORMS
uniform sampler2D tPos;
uniform sampler2D tPrevPos;

#!VARYINGS
varying vec3 vPos;
varying vec3 vNormal;
varying vec3 vVel;

#!SHADER: Vertex
#require(rotation.glsl)

void main() {
	
  vec3 offset = texture2D(tPos, lookup.xy).xyz;
  vec3 vel = offset - texture2D(tPrevPos, lookup.xy).xyz;
  vec3 dir = -normalize(vel);

//   float angleUpDown = dot(dir, vec3(0.0, 1.0, 0.0)) * (3.14 / 2.0);
  float angleUpDown = dot(dir, vec3(0.0, 1.0, 0.0));
  float angleLeftRight = atan(dir.x, dir.z);

  vec3 pos = position;
  vec3 n = normal;
  pos *= 0.05;
  pos.z *= 3.0;
  pos.yz = rotationMatrix(angleUpDown) * pos.yz;
  pos.xz = rotationMatrix(angleLeftRight) * pos.xz;

  pos += offset;

  gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

  vPos = pos;
  vNormal = normalize(n);
  vVel = vel;
}


#!SHADER: Fragment

void main() {   
    float value = dot(vNormal, vec3(0.0, 1.0, -1.0)) * 0.5 + 0.5;
    value *= length(vVel) * 30.0;
    value = max(0.05, value);
    value = pow(value, 0.45);
  gl_FragColor = vec4(value);
    
}
{@}ScalesShader.glsl{@}#!ATTRIBUTES
// attribute vec3 vdata;
// attribute vec2 uv2;

#!UNIFORMS

#!VARYINGS
