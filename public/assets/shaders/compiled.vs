#!UNIFORMS
uniform vec3 uColor;
uniform vec3 uBorderColor;
uniform float uAlpha;

#!VARYINGS
varying vec2 vUv;

#!SHADER: VRInputControllerPoint.vs
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: VRInputControllerPoint.fs

const float borderWidth = 0.08;

void main() {
    vec2 uv = vUv * (2. + borderWidth * 4.) - (1. + borderWidth * 2.); // -1.0 ... 1.0
    float r = length(uv);

    // border
    float dist = abs(r-(1. - borderWidth));
    float delta = fwidth(dist);
    float alpha = 1.0 - smoothstep(-delta, delta, dist - borderWidth);
    vec4 border = vec4(uBorderColor, alpha);

    // fill
    dist = r-(1. - borderWidth);
    delta = fwidth(dist);
    float limit = borderWidth * 0.5;
    alpha = 1.0 - smoothstep(-delta, delta, dist - limit);
    vec4 fill = vec4(uColor, alpha);

    alpha = border.a + fill.a * (1. - border.a);

    gl_FragColor = vec4((border.rgb * border.a + fill.rgb * fill.a * (1. - border.a)) / alpha, uAlpha * alpha);
}{@}TorsoShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tDiffuse;
uniform sampler2D tWorldNormal;
uniform sampler2D tAlpha;

uniform vec2 uTopTeethAO;
uniform vec2 uBottomTeethAO;
uniform vec2 uBottomTeethLight;

uniform vec3 uMousePos;
uniform vec3 uPrevMousePos;
uniform float uMouseBright;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying float vDist;
varying float vMouseSpeed;

#!SHADER: Vertex
#require(rotation.glsl)
#require(skinning.glsl)

void main() {
    vec3 pos = position;
    vec3 n = normal;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vDist = length(pos - position);
    vPos = (modelMatrix * vec4(pos, 1.0)).xyz;
    vMouseSpeed = clamp(length(uMousePos - uPrevMousePos) * 10.0, 0.0, 1.0);
}

#!SHADER: Fragment
void main() {
    float mask = vUv.y - abs(vUv.x - 0.5) * 0.7;
    if (mask > 0.8) discard;

    float d = texture2D(tDiffuse, vUv).r;

    vec3 color = texture2D(tMap, vUv).rgb;

    // mouse point light
    vec3 normal = texture2D(tWorldNormal, vUv).rgb;

    normal = normal * 2.0 - 1.0;

    float dist = length(uMousePos.xy - vPos.xy);
    float clampedDist = 1.0 - clamp(dist * 2.0, 0.0, 1.0);
    clampedDist = pow(clampedDist, 2.0);
    clampedDist = clamp(clampedDist * 1.0, 0.0, 1.0);

    vec3 lightDir = -normalize(vPos * vec3(1.0, 1.0, 1.0) - (uMousePos * vec3(1.0, 1.0, 1.0) + vec3(0.0, 0.0, 0.5)));
    float lighting = max(0.0, dot(lightDir, normal));
    lighting *= clampedDist;

    color.rgb = pow(color.rgb, vec3(2.2));
    // color.rgb += lighting * pow(texture2D(tDiffuse, vUv).rgb, vec3(2.2)) * 5.0 * uMouseBright;
    color.rgb = pow(color.rgb, vec3(0.45));

    color.rgb = vec3(lighting * d);


    gl_FragColor = vec4(color, 1.0);
}{@}TwoShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
uniform sampler2D tMap;
uniform sampler2D tDepth;
uniform sampler2D tNormal;
uniform sampler2D tHairMask;
uniform sampler2D tFaceMask;
uniform sampler2D tHairFlowmap;

uniform vec3 uMousePos;

uniform float uDepthStrength;
uniform float uDepthPower;

#!VARYINGS
varying vec2 vUv;
varying vec3 vPos;
varying float vDepth;

#!SHADER: Vertex
void main() {
    vec3 pos = position;
    float depth = texture2D(tDepth, uv).r;
    vDepth = depth;
    depth = 1.0 - pow(1.0 - depth, uDepthPower);
    depth += uv.y * 0.17;
    pos.z += depth * uDepthStrength;

    vec3 flow = texture2D(tHairFlowmap, uv).rgb;
    float hairMask = texture2D(tHairMask, uv).r;

    // pos += sin(length(flow) * 6.0 + length(pos * 10.0) + time * 6.0) * hairMask * flow * 0.0002;
    // pos += sin(length(flow) * 16.0 + length(pos * 27.0) + time * 8.0) * hairMask * flow * 0.0005;

    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    vUv = uv;
    vPos = pos;
}

#!SHADER: Fragment
void main() {
    float facemask = texture2D(tFaceMask, vUv).r;
    // if (facemask < 0.01) discard;
    vec3 color = texture2D(tMap, vUv).rgb;

    vec3 normal = texture2D(tNormal, vUv).rgb;

    normal = normal * 2.0 - 1.0;

    float dist = length(uMousePos * vec3(1.0, 1.0, 0.01) - vPos * vec3(1.0, 1.0, 0.01));
    float clampedDist = 1.0 - clamp(dist * 2.0, 0.0, 1.0);
    clampedDist = pow(clampedDist, 2.0);
    clampedDist = clamp(clampedDist * 1.0, 0.0, 1.0);

    vec3 lightDir = -normalize(vPos - uMousePos);
    float lighting = dot(lightDir, normal);

    color = pow(color, vec3(2.2));
    color += max(0.0, lighting) * clampedDist * color * 3.0;
    color = pow(color, vec3(0.45));

    // color = vec3(lighting);

    gl_FragColor = vec4(color, facemask);
}{@}FloatingSphereShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS

#!VARYINGS
