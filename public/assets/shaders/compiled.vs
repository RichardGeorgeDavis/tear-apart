#!UNIFORMS
uniform sampler2D tMap;
uniform vec3 uColor;
uniform sampler2D tDepth;

#!VARYINGS
varying vec2 vUv;

#!SHADER: Vertex
void main() {
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    vUv = uv;
}

#!SHADER: Fragment
float getDepthValue(sampler2D tDepth, vec2 uv, float n, float f) {
    vec4 depth = texture2D(tDepth, uv);
    return (2.0 * n) / (f + n - depth.x * (f - n));
}

vec3 worldPosFromDepth(sampler2D tDepth) {
    float depth = texture2D(tDepth, vUv).r;
    float z = depth * 2.0 - 1.0;

    vec4 clipSpacePosition = vec4(vUv * 2.0 - 1.0, z, 1.0);
    vec4 viewSpacePosition = inverse(projectionMatrix) * clipSpacePosition;

    // Perspective division
    viewSpacePosition /= viewSpacePosition.w;

    vec4 worldSpacePosition = inverse(viewMatrix) * viewSpacePosition;

    return worldSpacePosition.xyz;
}

float rand(vec2 co){
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    vec2 screenuv = gl_FragCoord.xy / resolution;
    float d = 1.0 - clamp(length(vUv - 0.5) * 2.0, 0.0, 1.0);
    d = pow(d, 11.0);
    vec3 color = vec3(0.1, 0.6, 1.0);

    float alpha = d;

    float delta = 0.0005;
    float depth = texture2D(tDepth, screenuv).r;
    alpha *= clamp(depth, 0.0, 1.0);

    float n = rand(screenuv + fract(time + 1.0));
    float n2 = rand(screenuv + fract(time + 5.0));
    alpha -= n * 0.15;

    color += pow(alpha, 5.0) * 0.3;

    // color += n2 * 0.5;

    // float depth = getDepthValue(tDepth, screenuv, uNear, uFar);
    // color = vec3(depth);
    gl_FragColor = vec4(color, alpha);
}{@}GlowFrameShader.glsl{@}#!ATTRIBUTES
attribute vec3 vdata;

#!UNIFORMS
uniform vec3 uColor;
uniform vec4 uParams;
uniform vec2 uGlowDist;

#!VARYINGS
varying vec3 vNormal;
varying vec3 vPos;
varying float vAngle;
varying vec2 vUv;
varying vec3 vColor;
varying vec3 vVel;
varying float vBraking;
varying float vZdist;

#!SHADER: Vertex
#require(range.glsl)
#require(instance.vs)

vec2 rotate(vec2 v, float a) {
    float s = sin(a);
    float c = cos(a);
    mat2 m = mat2(c, -s, s, c);
    return m * v;
}

void main() {
    vec3 pos = position;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

    vPos = pos;
    vColor = vdata;
    vZdist = crange(mvpos.z, uGlowDist.x, uGlowDist.y, 0.0, 1.0);
}

#!SHADER: Fragment
#require(range.glsl)
#require(simplenoise.glsl)
void main() {
    float alpha = pow(vColor.r - uParams.y, uParams.x);

    // thicker car lines when camera is far away
    alpha += clamp(vZdist, 0.0, 1.0);

    vec3 color = uColor;
    color += pow(alpha, 2.0) * 0.5;
    alpha *= clamp(vPos.y * 6.0 - 0.1, 0.0, 1.0);

    gl_FragColor = vec4(color, alpha);
}{@}GlowPlaneShader.glsl{@}#!ATTRIBUTES

#!UNIFORMS
